---
import Wordmark from './Wordmark.astro';
import Button from '../ui/Button.astro';
import MobileMenu from './MobileMenu.astro';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/realisations', label: 'Réalisations' },
  { href: '/tarifs', label: 'Tarifs' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<header
  id="site-header"
  data-scrolled="false"
  transition:persist
  transition:name="site-header"
  class="sticky top-0 z-50 transition-[background-color,backdrop-filter,box-shadow,border-color] duration-300 ease-out border-b border-transparent"
>
  <div class="max-w-content mx-auto px-6 h-24 md:h-28 flex items-center justify-between gap-6">
    <Wordmark href="/" size="md" />

    <nav class="hidden md:flex items-center gap-1" aria-label="Navigation principale">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-nav-link
          data-href={link.href}
          data-active={isActive(link.href) ? 'true' : 'false'}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class="group/nav relative px-4 py-2 rounded-full text-sm font-medium transition-colors duration-200 ease-out text-bleu-nuit/70 hover:text-bleu-nuit data-[active=true]:text-bleu-nuit"
        >
          {link.label}
          <span
            class="absolute left-1/2 -translate-x-1/2 -bottom-0.5 w-1.5 h-1.5 rounded-full bg-bleu opacity-0 transition-opacity duration-200 group-data-[active=true]/nav:opacity-100"
            aria-hidden="true"
          ></span>
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <Button variant="primary" size="sm" href="/contact">Demander mon site</Button>
    </div>

    <button
      id="menu-toggle"
      type="button"
      data-open="false"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Ouvrir le menu"
      class="group md:hidden relative w-11 h-11 -mr-2 flex items-center justify-center rounded-full hover:bg-bleu-nuit/5 transition-colors"
    >
      <span class="sr-only">Menu</span>
      <span class="relative flex flex-col items-center justify-center gap-1.5 w-6 h-6">
        <span class="block w-6 h-0.5 bg-bleu-nuit rounded-full transition-transform duration-300 ease-out origin-center group-data-[open=true]:rotate-45 group-data-[open=true]:translate-y-2"></span>
        <span class="block w-6 h-0.5 bg-bleu-nuit rounded-full transition-opacity duration-200 ease-out group-data-[open=true]:opacity-0"></span>
        <span class="block w-6 h-0.5 bg-bleu-nuit rounded-full transition-transform duration-300 ease-out origin-center group-data-[open=true]:-rotate-45 group-data-[open=true]:-translate-y-2"></span>
      </span>
    </button>
  </div>
</header>

<MobileMenu navLinks={navLinks} />

<style>
  /* Effet glassmorphism subtil au scroll — règle brief §4.5 */
  #site-header[data-scrolled='true'] {
    background-color: rgb(254 254 250 / 0.82);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    box-shadow: 0 1px 3px rgb(11 20 55 / 0.06);
    border-bottom-color: rgb(11 20 55 / 0.06);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const SCROLL_THRESHOLD = 8;
    let scrolled = false;

    const update = () => {
      const next = window.scrollY > SCROLL_THRESHOLD;
      if (next !== scrolled) {
        scrolled = next;
        header.dataset.scrolled = String(next);
      }
    };

    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  // Mise à jour de l'état actif de la nav après chaque View Transition
  // (le header est `transition:persist` donc le SSR initial reste figé sur la 1ère page)
  const updateActiveNav = () => {
    const path = location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll<HTMLElement>('[data-nav-link]').forEach((el) => {
      const href = el.dataset.href;
      let active = false;
      if (href === '/') active = path === '/';
      else if (href) active = path === href || path.startsWith(href + '/');
      el.dataset.active = String(active);
      if (active) el.setAttribute('aria-current', 'page');
      else el.removeAttribute('aria-current');
    });
  };

  document.addEventListener('astro:page-load', updateActiveNav);
</script>
