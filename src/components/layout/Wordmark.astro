---
/**
 * Wordmark — logo SVG 9site4 + texte "9site4" (Sora 700, "9site" bleu-nuit, "4" orange).
 */
interface Props {
  href?: string;
  size?: 'sm' | 'md' | 'lg';
  tone?: 'dark' | 'light';
  class?: string;
}

const {
  href,
  size = 'md',
  tone = 'dark',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'text-xl gap-1.5',
  md: 'text-2xl gap-2',
  lg: 'text-3xl gap-2.5',
};

const toneClasses = {
  dark: 'text-bleu-nuit',
  light: 'text-blanc-casse',
};

const Element = href ? 'a' : 'span';
---

<Element
  {...(href ? { href } : {})}
  class:list={[
    'inline-flex items-center font-sora font-bold leading-none tracking-tight transition-opacity duration-200 ease-out hover:opacity-80',
    sizeClasses[size],
    toneClasses[tone],
    className,
  ]}
>
  <svg
    class="h-[1.15em] w-auto shrink-0"
    viewBox="0 0 418 597"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <polygon points="36 0 243 265 334 268 251 385 0 597 149 356 111 330 36 0" fill="#91A6FF"/>
    <polygon points="363 268 418 300 362 331 363 268" fill="#FF8F00"/>
  </svg>
  <span>9site<span class="text-orange">4</span></span>
</Element>
