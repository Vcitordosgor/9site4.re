---
/**
 * Wordmark — logo SVG 9site4 + texte "9site4" (Sora 700, "9site" bleu-nuit, "4" orange).
 */
interface Props {
  href?: string;
  size?: 'sm' | 'md' | 'lg';
  tone?: 'dark' | 'light';
  class?: string;
}

const {
  href,
  size = 'md',
  tone = 'dark',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'text-xl gap-2',
  md: 'text-2xl gap-2.5',
  lg: 'text-3xl gap-3',
};

const letters = ['9', 's', 'i', 't', 'e', '4'];

const toneClasses = {
  dark: 'text-bleu-nuit',
  light: 'text-blanc-casse',
};

const Element = href ? 'a' : 'span';
---

<Element
  {...(href ? { href } : {})}
  class:list={[
    'inline-flex items-center font-sora font-bold leading-none tracking-tight transition-opacity duration-200 ease-out hover:opacity-80',
    sizeClasses[size],
    toneClasses[tone],
    className,
  ]}
>
  <svg
    class="h-[3em] w-auto shrink-0"
    viewBox="0 0 418 597"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <polygon points="36 0 243 265 334 268 251 385 0 597 149 356 111 330 36 0" fill="#91A6FF"/>
    <polygon class="wordmark-pulse" points="363 268 418 300 362 331 363 268" fill="#FF8F00"/>
  </svg>
  <span class="wordmark-text inline-flex">
    {letters.map((letter) => <span class="wordmark-letter">{letter}</span>)}
  </span>
</Element>

<style>
  /* Pulse continu sur le triangle orange du logo */
  @keyframes wordmark-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  .wordmark-pulse {
    animation: wordmark-pulse 2.5s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* Vague orange qui traverse les 6 lettres de "9site4" en boucle (3s) */
  @keyframes wordmark-letter-flash {
    0%, 16.67% { color: #FF8F00; }
    16.68%, 100% { color: inherit; }
  }
  .wordmark-letter {
    animation: wordmark-letter-flash 3s linear infinite;
  }
  .wordmark-letter:nth-child(1) { animation-delay: 0s; }
  .wordmark-letter:nth-child(2) { animation-delay: 0.5s; }
  .wordmark-letter:nth-child(3) { animation-delay: 1s; }
  .wordmark-letter:nth-child(4) { animation-delay: 1.5s; }
  .wordmark-letter:nth-child(5) { animation-delay: 2s; }
  .wordmark-letter:nth-child(6) { animation-delay: 2.5s; }

  @media (prefers-reduced-motion: reduce) {
    .wordmark-pulse,
    .wordmark-letter { animation: none; }
    .wordmark-letter:last-child { color: #FF8F00; }
  }
</style>
