---
/**
 * Wordmark temporaire — "9site4" en Sora 700, "9site" bleu-nuit, "4" orange.
 * Sera remplacé par le logo définitif (fourni par le client).
 */
interface Props {
  href?: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'text-xl',
  md: 'text-2xl',
  lg: 'text-3xl',
};

const Element = href ? 'a' : 'span';
---

<Element
  {...(href ? { href } : {})}
  class:list={[
    'inline-flex items-baseline font-sora font-bold leading-none tracking-tight text-bleu-nuit transition-opacity duration-200 ease-out hover:opacity-80',
    sizeClasses[size],
    className,
  ]}
  aria-label="9site4"
>
  <span aria-hidden="true">9site</span><span aria-hidden="true" class="text-orange">4</span>
</Element>
