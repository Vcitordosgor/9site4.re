---
/**
 * Wordmark temporaire — "9site4" en Sora 700, "9site" bleu-nuit, "4" orange.
 * Sera remplacé par le logo définitif (fourni par le client).
 */
interface Props {
  href?: string;
  size?: 'sm' | 'md' | 'lg';
  tone?: 'dark' | 'light';
  class?: string;
}

const {
  href,
  size = 'md',
  tone = 'dark',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'text-xl',
  md: 'text-2xl',
  lg: 'text-3xl',
};

const toneClasses = {
  dark: 'text-bleu-nuit',
  light: 'text-blanc-casse',
};

const Element = href ? 'a' : 'span';
---

<Element
  {...(href ? { href } : {})}
  class:list={[
    'inline-flex items-baseline font-sora font-bold leading-none tracking-tight transition-opacity duration-200 ease-out hover:opacity-80',
    sizeClasses[size],
    toneClasses[tone],
    className,
  ]}
>
  9site<span class="text-orange">4</span>
</Element>
