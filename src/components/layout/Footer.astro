---
import Wordmark from './Wordmark.astro';
import siteConfig from '../../data/siteConfig.json';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/realisations', label: 'Réalisations' },
  { href: '/tarifs', label: 'Tarifs' },
  { href: '/contact', label: 'Contact' },
];

const currentYear = new Date().getFullYear();

const whatsappUrl = `https://wa.me/${siteConfig.contact.whatsapp}?text=${encodeURIComponent(
  siteConfig.contact.whatsappMessage
)}`;
---

<footer class="relative bg-bleu-nuit text-blanc-casse">
  <div class="max-w-content mx-auto px-6 pt-16 pb-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Bloc 1 — Identité -->
      <div>
        <Wordmark size="md" tone="light" />
        <p class="mt-4 text-sm text-blanc-casse/70 leading-relaxed max-w-xs">
          {siteConfig.baseline}
        </p>
        <p class="mt-6 text-sm text-blanc-casse/60">Fait à La Réunion 🌴</p>
      </div>

      <!-- Bloc 2 — Navigation -->
      <div>
        <h2 class="text-xs uppercase tracking-wider font-semibold text-blanc-casse/50">
          Navigation
        </h2>
        <ul class="mt-4 space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="inline-block text-sm text-blanc-casse/80 hover:text-orange transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Bloc 3 — Offre -->
      <div>
        <h2 class="text-xs uppercase tracking-wider font-semibold text-blanc-casse/50">
          Offre
        </h2>
        <p class="mt-4 text-sm text-blanc-casse/80 leading-relaxed">
          {siteConfig.pricing.highlight}
        </p>
        <a
          href="/tarifs"
          class="mt-3 inline-flex items-center gap-1 text-sm text-bleu hover:text-orange transition-colors duration-200"
        >
          Voir les tarifs
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Bloc 4 — Contact -->
      <div>
        <h2 class="text-xs uppercase tracking-wider font-semibold text-blanc-casse/50">
          Contact
        </h2>
        <ul class="mt-4 space-y-2">
          <li>
            <a
              href={`mailto:${siteConfig.contact.email}`}
              class="inline-block text-sm text-blanc-casse/80 hover:text-orange transition-colors duration-200 break-all"
            >
              {siteConfig.contact.email}
            </a>
          </li>
          <li>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block text-sm text-blanc-casse/80 hover:text-orange transition-colors duration-200"
            >
              WhatsApp · {siteConfig.contact.whatsappDisplay}
            </a>
          </li>
          <li class="text-sm text-blanc-casse/60">
            Réunion {siteConfig.location.areaCode}
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-blanc-casse/10 flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3">
      <p class="text-xs text-blanc-casse/50">
        © {currentYear} {siteConfig.siteName}. Tous droits réservés.
      </p>
      <a
        href="/mentions-legales"
        class="text-xs text-blanc-casse/60 hover:text-blanc-casse transition-colors underline-offset-4 hover:underline"
      >
        Mentions légales
      </a>
    </div>
  </div>
</footer>
