---
/**
 * Select natif — meilleur pour l'accessibilité mobile (clavier système).
 * Chevron custom via background SVG.
 */
interface Option {
  value: string;
  label: string;
}

interface Props {
  id: string;
  name: string;
  label: string;
  options: Option[];
  required?: boolean;
  placeholder?: string;
  helper?: string;
  error?: string;
  defaultValue?: string;
  class?: string;
}

const {
  id,
  name,
  label,
  options,
  required = false,
  placeholder,
  helper,
  error,
  defaultValue = '',
  class: className = '',
} = Astro.props;

const helperId = helper ? `${id}-helper` : undefined;
const errorId = error ? `${id}-error` : undefined;
const describedBy = [helperId, errorId].filter(Boolean).join(' ') || undefined;

const baseSelect =
  'w-full h-12 pl-4 pr-10 rounded-xl bg-blanc-casse text-bleu-nuit appearance-none bg-no-repeat transition-colors duration-200 ease-out';
const stateClasses = error
  ? 'ring-1 ring-red-500 focus:ring-2 focus:ring-red-500'
  : 'ring-1 ring-bleu-nuit/15 focus:ring-2 focus:ring-bleu focus:ring-offset-0';

// Chevron SVG inline (Lucide chevron-down) en data URI
const chevron =
  "url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='%230B1437' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>\")";
---

<div class:list={['flex flex-col gap-1.5', className]}>
  <label for={id} class="text-sm font-medium text-bleu-nuit">
    {label}
    {required && <span class="text-orange ml-0.5" aria-hidden="true">*</span>}
  </label>
  <select
    id={id}
    name={name}
    required={required}
    aria-invalid={error ? 'true' : undefined}
    aria-describedby={describedBy}
    class:list={[baseSelect, stateClasses, 'outline-none']}
    style={`background-image: ${chevron}; background-position: right 12px center;`}
  >
    {placeholder && (
      <option value="" disabled selected={defaultValue === ''}>
        {placeholder}
      </option>
    )}
    {options.map((opt) => (
      <option value={opt.value} selected={opt.value === defaultValue}>
        {opt.label}
      </option>
    ))}
  </select>
  {helper && !error && (
    <p id={helperId} class="text-xs text-bleu-nuit/60">{helper}</p>
  )}
  {error && (
    <p id={errorId} role="alert" class="text-xs font-medium text-red-600">{error}</p>
  )}
</div>
