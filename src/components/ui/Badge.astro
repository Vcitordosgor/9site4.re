---
/**
 * Badge — petit label discret pour catégorie, statut, modules.
 * rounded-full, fond teinté, texte semibold.
 */
interface Props {
  variant?: 'neutral' | 'primary' | 'secondary' | 'accent' | 'outline';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  variant = 'neutral',
  size = 'sm',
  class: className = '',
} = Astro.props;

const sizes = {
  sm: 'h-6 px-2.5 text-xs',
  md: 'h-7 px-3 text-sm',
};

const variants = {
  neutral: 'bg-bleu-nuit/5 text-bleu-nuit/80 ring-1 ring-bleu-nuit/10',
  primary: 'bg-orange/10 text-orange ring-1 ring-orange/20',
  secondary: 'bg-bleu/15 text-bleu-nuit ring-1 ring-bleu/30',
  accent: 'bg-bleu-nuit text-blanc-casse',
  outline: 'bg-transparent text-bleu-nuit ring-1 ring-bleu-nuit/30',
};
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 font-inter font-medium rounded-full whitespace-nowrap',
    sizes[size],
    variants[variant],
    className,
  ]}
>
  <slot />
</span>
