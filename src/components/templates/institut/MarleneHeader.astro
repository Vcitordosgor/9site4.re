---
import data from '../../../data/templates/marlene.json';
---

<header
  id="marlene-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-500 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-marlene-nacre/95 data-[scrolled=true]:backdrop-blur-sm"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <!-- Wordmark : Marcellus très espacé style enseigne dorée -->
    <a href="#top" class="flex items-baseline gap-2 group" aria-label="Maison Marléne — accueil">
      <span class="font-marcellus text-marlene-noir text-base md:text-lg uppercase tracking-[0.32em] leading-none">
        {data.info.wordmark1}
      </span>
      <span class="font-marcellus text-marlene-bordeaux text-base md:text-lg uppercase tracking-[0.32em] leading-none">
        {data.info.wordmark2}
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-8 font-mulish text-[11px] uppercase tracking-[0.22em] text-marlene-noir/70 font-medium" aria-label="Navigation">
      <a href="#rituel" class="hover:text-marlene-bordeaux transition-colors duration-500">Rituel</a>
      <a href="#carte" class="hover:text-marlene-bordeaux transition-colors duration-500">Carte des soins</a>
      <a href="#cartes" class="hover:text-marlene-bordeaux transition-colors duration-500">Cartes cadeaux</a>
      <a href="#institut" class="hover:text-marlene-bordeaux transition-colors duration-500">L'institut</a>
    </nav>

    <!-- CTA discret bordeaux -->
    <a
      href="#reservation"
      class="hidden md:inline-flex items-center h-10 px-5 bg-marlene-bordeaux text-marlene-nacre font-marcellus text-sm tracking-wider hover:bg-marlene-noir transition-colors duration-500"
    >
      Réserver
    </a>

    <!-- Mobile lien souligné -->
    <a
      href="#reservation"
      class="md:hidden font-eb-garamond italic text-marlene-bordeaux text-base underline underline-offset-4 decoration-marlene-champagne"
    >
      Réserver
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('marlene-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
