---
/**
 * RituelSignature — soin emblématique en scénario théâtral.
 * Photo verticale grande à gauche + 5 actes en didascalies italiques à droite.
 * Format programme de théâtre.
 */
import data from '../../../data/templates/marlene.json';
---

<section id="rituel" class="bg-marlene-sable py-24 md:py-36 px-6 md:px-10 overflow-hidden">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-16 md:mb-20 max-w-2xl mx-auto">
      <p class="font-mulish text-[10px] uppercase tracking-[0.4em] text-marlene-bordeaux mb-5">
        ✦ Soin signature ✦
      </p>
      <h2 class="font-marcellus text-marlene-noir uppercase tracking-[0.05em] leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 64px);">
        {data.rituel.nom}
      </h2>
      <p class="mt-5 font-eb-garamond italic text-marlene-moka text-xl md:text-2xl">
        {data.rituel.soustitre} · {data.rituel.duree} · {data.rituel.prix}
      </p>
    </header>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- Photo verticale grande à gauche -->
      <div class="lg:col-span-5">
        <div class="relative aspect-[3/4] bg-marlene-noir overflow-hidden">
          <img
            src={data.info.photoRituel}
            alt={data.rituel.nom}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
          <!-- Cadre champagne intérieur -->
          <div class="absolute inset-3 border border-marlene-nacre/30" aria-hidden="true"></div>
        </div>

        <!-- Caption -->
        <p class="mt-5 font-eb-garamond italic text-marlene-moka text-base leading-relaxed">
          {data.rituel.description}
        </p>
      </div>

      <!-- Actes du scénario à droite -->
      <ol class="lg:col-span-7 lg:pl-6 space-y-10 md:space-y-12">
        {data.rituel.actes.map((a, i) => (
          <li class="grid grid-cols-12 gap-4 md:gap-6 items-start">

            <!-- Numéro d'acte -->
            <div class="col-span-3 md:col-span-2 text-right">
              <p class="font-marcellus text-marlene-bordeaux text-base md:text-lg tracking-wide">
                {a.num}
              </p>
              <p class="mt-1 font-mulish text-[10px] uppercase tracking-[0.25em] text-marlene-moka tabular-nums">
                {a.duree}
              </p>
            </div>

            <!-- Filet vertical champagne -->
            <span class="hidden md:block col-span-1 justify-self-center w-px bg-marlene-champagne/40 h-full self-stretch" aria-hidden="true"></span>

            <!-- Titre + didascalie -->
            <div class="col-span-9 md:col-span-9">
              <h3 class="font-marcellus text-marlene-noir text-2xl md:text-3xl uppercase tracking-wide leading-tight mb-3">
                {a.titre}
              </h3>
              <p class="font-eb-garamond italic text-marlene-moka text-base md:text-lg leading-[1.85]">
                « {a.didascalie} »
              </p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- CTA fin de scénario -->
    <div class="mt-16 md:mt-20 text-center">
      <a
        href="#reservation"
        class="inline-flex items-center justify-center h-14 px-10 bg-marlene-noir text-marlene-nacre font-marcellus tracking-wider text-sm uppercase hover:bg-marlene-bordeaux transition-colors duration-500"
      >
        Réserver le rituel
      </a>
    </div>
  </div>
</section>
