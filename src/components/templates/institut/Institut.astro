---
/**
 * Institut — adresse + photo intérieur + horaires.
 * Layout split : photo carrée + infos à droite.
 */
import data from '../../../data/templates/marlene.json';
---

<section id="institut" class="bg-marlene-nacre py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      <!-- Photo carrée intérieur -->
      <div class="lg:col-span-6">
        <div class="relative aspect-square overflow-hidden bg-marlene-sable">
          <img
            src={data.info.photoInstitut}
            alt="L'intérieur de la Maison Marléne"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
          <!-- Cadre champagne intérieur -->
          <div class="absolute inset-3 border border-marlene-nacre/40" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Infos -->
      <div class="lg:col-span-6">

        <p class="font-mulish text-[10px] uppercase tracking-[0.4em] text-marlene-bordeaux mb-5">
          ✦ L'institut ✦
        </p>

        <h2 class="font-marcellus text-marlene-noir uppercase tracking-[0.05em] leading-[1.05]" style="font-size: clamp(34px, 5vw, 56px);">
          Au cœur de<br/>Saint-Gilles.
        </h2>

        <p class="mt-7 font-eb-garamond italic text-marlene-moka text-lg md:text-xl leading-[1.7] max-w-md">
          {data.pitch.essence}
        </p>

        <!-- Adresse -->
        <div class="mt-10 pb-7 border-b border-marlene-noir/15">
          <p class="font-mulish text-[10px] uppercase tracking-[0.32em] text-marlene-champagne mb-3">Adresse</p>
          <p class="font-marcellus text-marlene-noir text-xl md:text-2xl uppercase tracking-wide leading-snug">
            {data.info.adresseLigne1}
          </p>
          <p class="font-eb-garamond italic text-marlene-moka text-lg">
            {data.info.adresseLigne2}
          </p>
        </div>

        <!-- Horaires -->
        <div class="mt-7">
          <p class="font-mulish text-[10px] uppercase tracking-[0.32em] text-marlene-champagne mb-3">Horaires d'ouverture</p>
          <ul class="grid grid-cols-2 gap-x-8 gap-y-1.5">
            {data.horaires.map((h) => (
              <li class="flex items-baseline justify-between gap-3 font-eb-garamond text-base">
                <span class:list={['italic', h.ouvert ? 'text-marlene-noir' : 'text-marlene-moka/55']}>{h.jour}</span>
                <span class:list={['tabular-nums text-right', h.ouvert ? 'text-marlene-bordeaux' : 'italic text-marlene-moka/45']}>
                  {h.label}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact rapide -->
        <div class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-3">
          <a href={`tel:${data.info.telephoneHref}`} class="font-marcellus text-marlene-bordeaux text-lg tabular-nums underline underline-offset-4 decoration-marlene-champagne hover:decoration-marlene-bordeaux transition-colors">
            {data.info.telephone}
          </a>
          <a href={`mailto:${data.info.email}`} class="font-eb-garamond italic text-marlene-moka text-base hover:text-marlene-bordeaux transition-colors break-all">
            {data.info.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
