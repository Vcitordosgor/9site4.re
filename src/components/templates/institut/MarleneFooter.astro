---
import data from '../../../data/templates/marlene.json';
const year = new Date().getFullYear();
---

<footer class="bg-marlene-noir text-marlene-nacre/75 py-12 px-6 md:px-10 border-t border-marlene-champagne/30">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-marcellus uppercase tracking-[0.2em] text-marlene-nacre text-base leading-none">{data.info.wordmark1}</span>
          <span class="font-marcellus uppercase tracking-[0.2em] text-marlene-rose text-base leading-none">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-eb-garamond italic text-marlene-nacre/55 text-sm">
          {data.info.soustitre} · {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-mulish text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-marlene-rose transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-marlene-champagne" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-marlene-rose transition-colors break-all">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-marlene-champagne" aria-hidden="true"></li>
        <li class="font-eb-garamond italic text-marlene-rose">{data.info.instagram}</li>
      </ul>
    </div>

    <!-- Filet champagne dégradé -->
    <div class="h-px mb-6" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgba(201,165,108,0.5) 30%, rgba(201,165,108,0.5) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-mulish text-[10px] uppercase tracking-[0.28em] text-marlene-nacre/45">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-marlene-nacre/70 hover:text-marlene-rose transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
