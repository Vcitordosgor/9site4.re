---
/**
 * HeroEditorial — composition 3 niveaux verticaux : enseigne typographique
 * + photo détail au centre + 2 colonnes texte serif italique + 3 mini-cards
 * services-phares en bas. Style page d'éditorial mode.
 */
import data from '../../../data/templates/marlene.json';
---

<section id="top" class="relative bg-marlene-nacre overflow-hidden">

  <!-- Filets champagne décoratifs verticaux -->
  <div class="absolute top-0 bottom-0 left-6 md:left-10 w-px bg-gradient-to-b from-transparent via-marlene-champagne/30 to-transparent pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-0 bottom-0 right-6 md:right-10 w-px bg-gradient-to-b from-transparent via-marlene-champagne/30 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-content mx-auto px-6 md:px-10 pt-32 pb-16 md:pt-44 md:pb-24">

    <!-- NIVEAU 1 : Enseigne typographique très espacée -->
    <header class="text-center mb-16 md:mb-24">
      <p class="font-mulish text-[10px] uppercase tracking-[0.4em] text-marlene-champagne mb-5">
        — Institut · depuis {data.info.annee} —
      </p>
      <h1 class="font-marcellus text-marlene-noir leading-[0.95] tracking-[0.15em] uppercase">
        <span class="block" style="font-size: clamp(36px, 7vw, 88px);">
          {data.info.wordmark1}
        </span>
        <span class="block text-marlene-bordeaux mt-2 italic font-eb-garamond" style="font-size: clamp(48px, 9vw, 120px); letter-spacing: 0.05em;">
          {data.info.wordmark2}
        </span>
      </h1>
      <p class="mt-7 font-eb-garamond italic text-marlene-moka text-xl md:text-2xl">
        {data.info.soustitre}
      </p>
    </header>

    <!-- NIVEAU 2 : Photo carrée centre + 2 colonnes texte -->
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center mb-20 md:mb-28">

      <!-- Colonne gauche : présentation -->
      <div class="lg:col-span-4 lg:text-right">
        <p class="font-mulish text-[10px] uppercase tracking-[0.32em] text-marlene-champagne mb-4">
          La maison
        </p>
        <p class="font-eb-garamond italic text-marlene-noir text-lg md:text-xl leading-[1.7]">
          {data.pitch.intro}
        </p>
      </div>

      <!-- Photo carrée au centre -->
      <div class="lg:col-span-4">
        <div class="relative aspect-square max-w-xs mx-auto bg-marlene-sable overflow-hidden">
          <img
            src={data.info.photoHero} srcset={`${(data.info.photoHero).replace(/\.webp$/, "-640.webp")} 640w, ${(data.info.photoHero).replace(/\.webp$/, "-1024.webp")} 1024w, ${data.info.photoHero} 1600w`} sizes="100vw"
            alt="Détail de l'institut Maison Marléne"
            class="w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async">
          <!-- Cadre champagne intérieur -->
          <div class="absolute inset-3 border border-marlene-champagne/40" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Colonne droite : coordonnées -->
      <div class="lg:col-span-4">
        <p class="font-mulish text-[10px] uppercase tracking-[0.32em] text-marlene-champagne mb-4">
          Nous trouver
        </p>
        <p class="font-marcellus text-marlene-noir text-lg leading-snug mb-2">
          {data.info.adresseLigne1}<br/>
          {data.info.adresseLigne2}
        </p>
        <p class="font-eb-garamond italic text-marlene-moka text-base mb-5">
          {data.info.ville}, {data.info.adresseLigne2.slice(0, 5)}
        </p>
        <a href={`tel:${data.info.telephoneHref}`} class="font-marcellus text-marlene-bordeaux text-lg tabular-nums underline underline-offset-4 decoration-marlene-champagne hover:decoration-marlene-bordeaux transition-colors">
          {data.info.telephone}
        </a>
      </div>
    </div>

    <!-- Filet champagne séparateur ornemental -->
    <div class="flex items-center justify-center gap-4 mb-14" aria-hidden="true">
      <span class="block h-px w-24 md:w-40 bg-gradient-to-r from-transparent to-marlene-champagne"></span>
      <span class="font-eb-garamond italic text-marlene-champagne text-2xl">&amp;</span>
      <span class="block h-px w-24 md:w-40 bg-gradient-to-l from-transparent to-marlene-champagne"></span>
    </div>

    <!-- NIVEAU 3 : 3 mini-cards services-phares -->
    <ul class="grid sm:grid-cols-3 gap-4 md:gap-6 max-w-4xl mx-auto">
      {[
        { titre: 'Soin signature', detail: '90 min · 130 €', href: '#rituel' },
        { titre: 'Massage', detail: '60 min · 75 €', href: '#carte' },
        { titre: 'Manucure spa', detail: '45 min · 45 €', href: '#carte' },
      ].map((s) => (
        <li>
          <a href={s.href} class="block bg-marlene-nacre border border-marlene-champagne/30 hover:border-marlene-bordeaux p-5 text-center group transition-colors duration-500">
            <p class="font-mulish text-[10px] uppercase tracking-[0.28em] text-marlene-champagne mb-2 group-hover:text-marlene-bordeaux">
              ★
            </p>
            <p class="font-marcellus text-marlene-noir text-base md:text-lg uppercase tracking-wide">
              {s.titre}
            </p>
            <p class="mt-1 font-eb-garamond italic text-marlene-moka text-sm tabular-nums">
              {s.detail}
            </p>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-12 text-center">
      <a
        href="#reservation"
        class="inline-flex items-center justify-center h-13 px-9 bg-marlene-bordeaux text-marlene-nacre font-marcellus tracking-wider text-sm uppercase hover:bg-marlene-noir transition-colors duration-500"
        style="height: 52px;"
      >
        Réserver mon soin
      </a>
    </div>
  </div>
</section>
