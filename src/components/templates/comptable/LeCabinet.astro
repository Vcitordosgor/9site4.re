---
/**
 * LeCabinet — adresse + photo extérieure du bâtiment + horaires.
 */
import data from '../../../data/templates/auberval.json';
---

<section class="bg-auberval-feutre py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      <!-- Photo extérieure -->
      <div class="lg:col-span-6">
        <div class="relative aspect-[4/3] overflow-hidden bg-auberval-gris">
          <img
            src={data.info.photoCabinet}
            alt="Le Cabinet Auberval & Associés à Saint-Denis"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover grayscale"
          />
          <!-- Voile marine léger -->
          <div class="absolute inset-0 bg-auberval-marine/10"></div>
        </div>
        <p class="mt-3 font-plex-sans italic text-auberval-encre/65 text-sm">
          Fig. — Le cabinet, 24 rue de l'Église, Saint-Denis (974).
        </p>
      </div>

      <!-- Infos -->
      <div class="lg:col-span-6">

        <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-5">
          ✦ Le cabinet
        </p>

        <h2 class="font-source-serif text-auberval-marine leading-[1.05]" style="font-size: clamp(34px, 5vw, 56px);">
          24 rue de l'Église,<br/>
          <span class="italic text-auberval-or">centre de Saint-Denis.</span>
        </h2>

        <p class="mt-7 font-plex-sans text-auberval-encre/85 text-base md:text-lg leading-[1.75] max-w-md">
          Bâtiment des années 1970, deuxième étage. Ascenseur. Salle d'attente discrète. Accueil sur rendez-vous uniquement, du lundi au vendredi.
        </p>

        <!-- Adresse + horaires -->
        <div class="mt-10 grid sm:grid-cols-2 gap-8">
          <div>
            <p class="font-dm-mono text-[10px] uppercase tracking-[0.28em] text-auberval-or mb-3">Adresse</p>
            <p class="font-source-serif text-auberval-marine text-xl leading-snug">
              {data.info.adresseLigne1}<br/>
              <span class="italic text-auberval-encre/75">{data.info.adresseLigne2}</span>
            </p>
          </div>
          <div>
            <p class="font-dm-mono text-[10px] uppercase tracking-[0.28em] text-auberval-or mb-3">Horaires</p>
            <ul class="space-y-1.5">
              {data.horaires.map((h) => (
                <li class="flex items-baseline justify-between gap-3 font-plex-sans text-sm">
                  <span class:list={[h.ouvert ? 'text-auberval-marine' : 'text-auberval-encre/45']}>{h.jour}</span>
                  <span class:list={['tabular-nums', h.ouvert ? 'text-auberval-encre/85' : 'italic text-auberval-encre/45']}>
                    {h.label}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Contact rapide -->
        <div class="mt-10 pt-8 border-t border-auberval-marine/15 flex flex-wrap items-center gap-x-7 gap-y-3">
          <a href={`tel:${data.info.telephoneHref}`} class="font-source-serif text-auberval-marine text-lg tabular-nums underline underline-offset-4 decoration-auberval-or hover:decoration-auberval-marine">
            {data.info.telephone}
          </a>
          <a href={`mailto:${data.info.email}`} class="font-plex-sans italic text-auberval-encre/85 text-base hover:text-auberval-marine transition-colors break-all">
            {data.info.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
