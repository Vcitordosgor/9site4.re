---
import data from '../../../data/templates/auberval.json';
const year = new Date().getFullYear();
---

<footer class="bg-auberval-feutre text-auberval-encre/75 py-12 px-6 md:px-10 border-t border-auberval-or/30">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-source-serif text-auberval-marine text-xl leading-none">{data.info.wordmark}</span>
          <span class="font-source-serif italic text-auberval-or text-base leading-none">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-source-serif italic text-auberval-encre/60 text-sm">
          {data.info.soustitre} · {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-plex-sans text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-auberval-marine transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-auberval-or" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-auberval-marine transition-colors break-all">{data.info.email}</a></li>
      </ul>
    </div>

    <!-- Filet doré -->
    <div class="h-px mb-6 bg-gradient-to-r from-transparent via-auberval-or/50 to-transparent" aria-hidden="true"></div>

    <!-- Mentions OEC obligatoires -->
    <div class="mb-6 font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/60 leading-relaxed space-y-1">
      <p>✦ Cabinet inscrit à l'Ordre des Experts-Comptables sous le n° {data.info.agrement}</p>
      <p>✦ Soumis aux normes professionnelles de l'OEC et au Code de déontologie</p>
      <p>✦ Marina Hoarau-Lebon inscrite à la Compagnie Nationale des Commissaires aux Comptes</p>
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-dm-mono text-[10px] uppercase tracking-[0.25em] text-auberval-encre/55">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-auberval-marine hover:text-auberval-or transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
