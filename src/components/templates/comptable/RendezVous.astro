---
/**
 * RendezVous — Wizard cabinet comptable best-in-class.
 * 4 étapes : structure → CA → besoin → coordonnées
 * - Cards visuelles forme juridique
 * - Slider CA avec auto-suggest forfait + honoraires
 * - Sidebar récap sticky
 * - Multi-step avec progress bar
 */
import data from '../../../data/templates/auberval.json';
const waBase = `https://wa.me/${data.info.whatsapp}`;

const structures = [
  { id: 'micro',     label: 'Micro / EI',   detail: 'Auto-entrepreneur, EI'            },
  { id: 'eurl-sasu', label: 'EURL / SASU',  detail: 'Société sans salarié'             },
  { id: 'sarl-sas',  label: 'SARL / SAS',   detail: 'Société avec salariés'            },
  { id: 'asso',      label: 'Association',  detail: 'Loi 1901, fondation'              },
  { id: 'creation',  label: 'En création',  detail: 'Pas encore de statut'             },
  { id: 'autre',     label: 'Autre',        detail: 'SCI, SCM, profession libérale…'   },
];

const besoins = [
  { id: 'creation',     label: 'Création d\'entreprise',           detail: 'Statuts + immatriculation' },
  { id: 'changement',   label: 'Changement de cabinet',           detail: 'Reprise dossier en cours' },
  { id: 'audit',        label: 'Mission d\'audit',                 detail: 'CAC, audit contractuel' },
  { id: 'fiscal',       label: 'Conseil fiscal & patrimoine',     detail: 'Optimisation, transmission' },
  { id: 'paie',         label: 'Paie & social',                   detail: 'DSN, contrats, ruptures' },
  { id: 'autre',        label: 'Autre / À discuter',              detail: 'Question spécifique' },
];
---

<section id="rendez-vous" class="bg-auberval-blanc py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-12 md:mb-16 max-w-3xl">
      <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-5">
        ✦ Demande de rendez-vous
      </p>
      <h2 class="font-source-serif text-auberval-marine leading-[1.05]" style="font-size: clamp(36px, 5vw, 56px);">
        Premier contact,<br/>
        <span class="italic text-auberval-or">en 4 questions claires.</span>
      </h2>
      <p class="mt-5 font-source-serif italic text-auberval-encre/70 text-base md:text-lg leading-relaxed max-w-xl">
        Le premier rendez-vous est offert et dure environ 45 minutes. Honoraires estimés en temps réel selon votre profil.
      </p>
    </header>

    <div class="grid lg:grid-cols-12 gap-8 items-start">

      <!-- LEFT : Wizard -->
      <div class="lg:col-span-8">
        <form id="auberval-form" class="bg-auberval-feutre border border-auberval-marine/15 p-6 md:p-9" novalidate>

          <!-- Progress bar -->
          <div class="mb-7">
            <div class="flex items-center justify-between mb-2">
              <p class="font-plex-sans text-[10px] uppercase tracking-[0.28em] text-auberval-encre/65 font-medium">
                Étape <span id="a-step-current" class="text-auberval-or tabular-nums">1</span>/4
              </p>
              <p id="a-step-label" class="font-plex-sans text-[10px] uppercase tracking-[0.28em] text-auberval-or font-semibold">
                Votre structure
              </p>
            </div>
            <div class="h-[2px] bg-auberval-marine/10 overflow-hidden">
              <div id="a-progress" class="h-full bg-auberval-or transition-all duration-500 ease-out" style="width: 25%;"></div>
            </div>
          </div>

          <!-- ÉTAPE 1 : Structure -->
          <fieldset class="a-step" data-step="1">
            <legend class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold pb-3 border-b border-auberval-marine/15 w-full mb-5">
              I. Forme juridique
            </legend>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
              {structures.map((s) => (
                <label class="cursor-pointer">
                  <input type="radio" name="structure" value={s.id} data-label={s.label} class="peer sr-only" required />
                  <span class="block px-4 py-3.5 bg-auberval-blanc border border-auberval-marine/20 peer-checked:border-auberval-marine peer-checked:bg-auberval-marine peer-checked:text-auberval-feutre transition-all hover:border-auberval-marine/40">
                    <p class="font-source-serif font-medium text-base leading-tight">{s.label}</p>
                    <p class="mt-1 font-plex-sans italic text-[12px] text-auberval-encre/65 peer-checked:text-auberval-feutre/65 leading-snug">{s.detail}</p>
                  </span>
                </label>
              ))}
            </div>
          </fieldset>

          <!-- ÉTAPE 2 : CA / Volume -->
          <fieldset class="a-step hidden" data-step="2">
            <legend class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold pb-3 border-b border-auberval-marine/15 w-full mb-5">
              II. Volume d'activité
            </legend>

            <div class="bg-auberval-blanc border border-auberval-marine/15 p-5 mb-5">
              <div class="flex items-baseline justify-between mb-3">
                <p class="font-plex-sans text-[10px] uppercase tracking-[0.22em] text-auberval-encre/65 font-medium">
                  Chiffre d'affaires annuel HT
                </p>
                <p>
                  <span id="a-ca-display" class="font-source-serif font-medium text-auberval-marine tabular-nums" style="font-size: clamp(20px, 2.5vw, 32px);">100 K€</span>
                </p>
              </div>
              <input
                type="range"
                name="ca"
                id="a-ca-slider"
                min="0"
                max="9"
                value="2"
                step="1"
                class="w-full accent-auberval-marine cursor-pointer"
              />
              <div class="grid grid-cols-5 gap-0 mt-2 font-dm-mono text-[9px] uppercase tracking-wider text-auberval-encre/65">
                <span class="text-left">&lt; 50K</span>
                <span class="text-center">100K</span>
                <span class="text-center">300K</span>
                <span class="text-center">700K</span>
                <span class="text-right">2M+</span>
              </div>
            </div>

            <!-- Salariés -->
            <div class="mb-5">
              <p class="font-plex-sans text-[10px] uppercase tracking-[0.22em] text-auberval-encre/65 font-medium mb-2">Nombre de salariés</p>
              <div class="flex flex-wrap gap-2">
                {['0', '1-5', '6-20', '21-50', '50+'].map((n, i) => (
                  <label class="cursor-pointer">
                    <input type="radio" name="salaries" value={n} class="peer sr-only" checked={i === 0} />
                    <span class="inline-flex items-center justify-center min-w-[3rem] h-9 px-3 bg-auberval-blanc border border-auberval-marine/20 peer-checked:border-auberval-marine peer-checked:bg-auberval-marine peer-checked:text-auberval-feutre font-source-serif text-sm transition-colors tabular-nums">
                      {n}
                    </span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Honoraires estimés (live) -->
            <div class="p-5 bg-auberval-marine text-auberval-feutre">
              <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-2">
                ✦ Honoraires estimés
              </p>
              <p class="font-source-serif text-auberval-feutre leading-none mb-1" style="font-size: clamp(28px, 3vw, 40px);">
                <span id="a-honoraires-display">95 € / mois</span>
              </p>
              <p id="a-honoraires-detail" class="font-source-serif italic text-auberval-feutre/85 text-sm leading-relaxed">
                Forfait TPE — tenue, bilan, liasse fiscale, déclarations TVA inclus.
              </p>
            </div>
          </fieldset>

          <!-- ÉTAPE 3 : Besoin -->
          <fieldset class="a-step hidden" data-step="3">
            <legend class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold pb-3 border-b border-auberval-marine/15 w-full mb-5">
              III. Nature de votre demande
            </legend>
            <div class="grid sm:grid-cols-2 gap-2">
              {besoins.map((b) => (
                <label class="cursor-pointer">
                  <input type="radio" name="besoin" value={b.id} data-label={b.label} class="peer sr-only" />
                  <span class="block px-4 py-3.5 bg-auberval-blanc border border-auberval-marine/20 peer-checked:border-auberval-or peer-checked:bg-auberval-or/10 transition-all hover:border-auberval-marine/40">
                    <p class="font-source-serif text-base leading-tight">{b.label}</p>
                    <p class="mt-1 font-plex-sans italic text-[12px] text-auberval-encre/65 leading-snug">{b.detail}</p>
                  </span>
                </label>
              ))}
            </div>
          </fieldset>

          <!-- ÉTAPE 4 : Coordonnées -->
          <fieldset class="a-step hidden" data-step="4">
            <legend class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold pb-3 border-b border-auberval-marine/15 w-full mb-5">
              IV. Vos coordonnées
            </legend>

            <div class="grid sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label for="a-nom" class="block font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/75 mb-1.5">Nom & prénom</label>
                <input id="a-nom" name="nom" type="text" required autocomplete="name"
                  class="w-full h-11 px-3 bg-auberval-blanc border border-auberval-marine/25 focus:border-auberval-marine font-source-serif text-auberval-marine text-base outline-none transition-colors" />
              </div>
              <div>
                <label for="a-tel" class="block font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/75 mb-1.5">Téléphone</label>
                <input id="a-tel" name="telephone" type="tel" inputmode="tel" required autocomplete="tel"
                  class="w-full h-11 px-3 bg-auberval-blanc border border-auberval-marine/25 focus:border-auberval-marine font-source-serif text-auberval-marine text-base outline-none transition-colors tabular-nums" />
              </div>
            </div>
            <div class="mb-4">
              <label for="a-email" class="block font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/75 mb-1.5">Email</label>
              <input id="a-email" name="email" type="email" inputmode="email" autocomplete="email"
                class="w-full h-11 px-3 bg-auberval-blanc border border-auberval-marine/25 focus:border-auberval-marine font-source-serif text-auberval-marine text-base outline-none transition-colors" />
            </div>
            <div>
              <label for="a-message" class="block font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/75 mb-1.5">
                Précisions <span class="font-source-serif normal-case italic tracking-normal">(facultatif)</span>
              </label>
              <textarea id="a-message" name="message" rows="3" placeholder="Activité, secteur, échéances, contexte particulier…"
                class="w-full px-3 py-2 bg-auberval-blanc border border-auberval-marine/25 focus:border-auberval-marine font-source-serif text-auberval-marine text-base placeholder:text-auberval-encre/45 outline-none transition-colors resize-none"></textarea>
            </div>
          </fieldset>

          <!-- Navigation -->
          <div class="mt-7 pt-6 border-t border-auberval-marine/15 flex flex-wrap items-center justify-between gap-3">
            <button type="button" id="a-btn-prev"
              class="hidden inline-flex items-center gap-1.5 h-10 px-4 border border-auberval-marine/30 text-auberval-marine font-plex-sans text-[11px] uppercase tracking-[0.18em] hover:border-auberval-or hover:text-auberval-or transition-colors cursor-pointer">
              ← Retour
            </button>
            <button type="button" id="a-btn-next"
              class="ml-auto inline-flex items-center justify-center h-12 px-7 bg-auberval-marine text-auberval-feutre font-plex-sans font-medium text-sm hover:bg-auberval-encre transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer"
              disabled>
              Continuer →
            </button>
            <button type="submit" id="a-btn-submit"
              class="hidden ml-auto inline-flex items-center justify-center h-13 px-9 bg-auberval-or text-auberval-marine font-plex-sans font-semibold text-sm hover:bg-auberval-marine hover:text-auberval-feutre transition-colors cursor-pointer"
              style="height: 52px;">
              Envoyer la demande →
            </button>
          </div>

          <p class="mt-4 font-source-serif italic text-auberval-encre/65 text-sm">
            Réponse de notre secrétariat sous 24 heures ouvrées.
          </p>
        </form>
      </div>

      <!-- RIGHT : Sidebar récap -->
      <aside class="lg:col-span-4 lg:sticky lg:top-24 space-y-4">
        <div class="bg-auberval-feutre border border-auberval-or/40 p-6">
          <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-4">
            ✦ Votre profil
          </p>
          <ul class="space-y-3 text-sm">
            <li class="flex items-baseline justify-between gap-3 pb-2 border-b border-auberval-marine/15">
              <span class="font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/65">Structure</span>
              <span id="a-recap-structure" class="font-source-serif text-auberval-marine text-right">—</span>
            </li>
            <li class="flex items-baseline justify-between gap-3 pb-2 border-b border-auberval-marine/15">
              <span class="font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/65">CA annuel</span>
              <span id="a-recap-ca" class="font-source-serif text-auberval-marine tabular-nums">—</span>
            </li>
            <li class="flex items-baseline justify-between gap-3 pb-2 border-b border-auberval-marine/15">
              <span class="font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-encre/65">Besoin</span>
              <span id="a-recap-besoin" class="font-source-serif text-auberval-marine text-right">—</span>
            </li>
            <li class="flex items-baseline justify-between gap-3">
              <span class="font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-or font-semibold">Forfait estimé</span>
              <span id="a-recap-honoraires" class="font-source-serif text-auberval-or font-medium tabular-nums">—</span>
            </li>
          </ul>
        </div>

        <div class="p-5 bg-auberval-blanc border border-auberval-marine/15">
          <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-3">
            ✦ Engagements
          </p>
          <ul class="space-y-2 font-source-serif text-auberval-encre/85 text-sm leading-relaxed">
            <li>✓ 1ᵉʳ RDV offert (45 min)</li>
            <li>✓ Devis personnalisé sous 48 h</li>
            <li>✓ Convention écrite avant tout engagement</li>
            <li>✓ Inscription OEC · ROF</li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>

<script define:vars={{ waBase }}>
  const form = document.getElementById('auberval-form');
  if (form) {
    const steps = form.querySelectorAll('.a-step');
    const stepLabels = ['Votre structure', 'Volume d\'activité', 'Votre besoin', 'Coordonnées'];
    const totalSteps = steps.length;
    const stepCurrentEl = document.getElementById('a-step-current');
    const stepLabelEl = document.getElementById('a-step-label');
    const progressBar = document.getElementById('a-progress');
    const btnPrev = document.getElementById('a-btn-prev');
    const btnNext = document.getElementById('a-btn-next');
    const btnSubmit = document.getElementById('a-btn-submit');
    let currentStep = 1;

    /* CA → forfait estimation */
    const caSteps = [
      { display: '< 50 K€',        value: 50,   forfait: '95 € / mois',     detail: 'Forfait micro/EI minimal — tenue + bilan annuel.' },
      { display: '50–100 K€',      value: 100,  forfait: '120 € / mois',    detail: 'Forfait TPE — tenue, bilan, liasse fiscale, TVA.' },
      { display: '100 K€',         value: 100,  forfait: '150 € / mois',    detail: 'Forfait TPE — tenue, bilan, liasse, déclarations.' },
      { display: '200 K€',         value: 200,  forfait: '220 € / mois',    detail: 'Forfait PME — tout inclus + RDV trimestriel.' },
      { display: '300 K€',         value: 300,  forfait: '290 € / mois',    detail: 'Forfait PME — tout inclus + suivi mensuel.' },
      { display: '500 K€',         value: 500,  forfait: '450 € / mois',    detail: 'Au temps passé — suivi rapproché.' },
      { display: '700 K€',         value: 700,  forfait: '620 € / mois',    detail: 'Au temps passé — équipe dédiée.' },
      { display: '1 M€',           value: 1000, forfait: '850 € / mois',    detail: 'Au temps passé — pilotage stratégique inclus.' },
      { display: '1.5 M€',         value: 1500, forfait: 'Sur devis',       detail: 'Convention sur mesure.' },
      { display: '2 M€+',          value: 2000, forfait: 'Sur devis',       detail: 'Convention sur mesure + audit annuel.' },
    ];

    function updateRecap() {
      const structure = form.querySelector('input[name="structure"]:checked');
      const caIdx = parseInt(document.getElementById('a-ca-slider')?.value || '2', 10);
      const besoin = form.querySelector('input[name="besoin"]:checked');
      const ca = caSteps[caIdx];

      const recapS = document.getElementById('a-recap-structure');
      const recapCA = document.getElementById('a-recap-ca');
      const recapB = document.getElementById('a-recap-besoin');
      const recapH = document.getElementById('a-recap-honoraires');

      if (recapS) recapS.textContent = structure?.dataset.label || '—';
      if (recapCA) recapCA.textContent = ca?.display || '—';
      if (recapB) recapB.textContent = besoin?.dataset.label || '—';
      if (recapH) recapH.textContent = (structure && ca) ? ca.forfait : '—';

      const display = document.getElementById('a-ca-display');
      if (display && ca) display.textContent = ca.display;
      const honoraires = document.getElementById('a-honoraires-display');
      if (honoraires && ca) honoraires.textContent = ca.forfait;
      const honorairesDetail = document.getElementById('a-honoraires-detail');
      if (honorairesDetail && ca) honorairesDetail.textContent = ca.detail;
    }

    function showStep(n) {
      steps.forEach((s) => s.classList.add('hidden'));
      form.querySelector(`.a-step[data-step="${n}"]`)?.classList.remove('hidden');
      currentStep = n;
      if (stepCurrentEl) stepCurrentEl.textContent = String(n);
      if (stepLabelEl) stepLabelEl.textContent = stepLabels[n - 1];
      if (progressBar) progressBar.style.width = `${(n / totalSteps) * 100}%`;
      btnPrev?.classList.toggle('hidden', n === 1);
      btnNext?.classList.toggle('hidden', n === totalSteps);
      btnSubmit?.classList.toggle('hidden', n !== totalSteps);
      validateCurrent();
    }

    function validateCurrent() {
      let valid = false;
      if (currentStep === 1) valid = !!form.querySelector('input[name="structure"]:checked');
      else if (currentStep === 2) valid = true;
      else if (currentStep === 3) valid = !!form.querySelector('input[name="besoin"]:checked');
      else if (currentStep === 4) {
        const nom = form.querySelector('#a-nom')?.value.trim();
        const tel = form.querySelector('#a-tel')?.value.trim();
        valid = !!nom && !!tel;
      }
      if (btnNext) btnNext.disabled = !valid;
    }

    form.querySelectorAll('input, textarea').forEach((input) => {
      input.addEventListener('change', () => { validateCurrent(); updateRecap(); });
      input.addEventListener('input', () => { validateCurrent(); updateRecap(); });
    });

    btnNext?.addEventListener('click', () => { if (currentStep < totalSteps) showStep(currentStep + 1); });
    btnPrev?.addEventListener('click', () => { if (currentStep > 1) showStep(currentStep - 1); });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const structure = form.querySelector('input[name="structure"]:checked');
      const besoin = form.querySelector('input[name="besoin"]:checked');
      const caIdx = parseInt(document.getElementById('a-ca-slider')?.value || '2', 10);
      const ca = caSteps[caIdx];
      const salaries = form.querySelector('input[name="salaries"]:checked');

      const text = [
        'Bonjour, je souhaite un rendez-vous avec le Cabinet Auberval & Associés.',
        '',
        '— PROFIL —',
        structure ? `Structure : ${structure.dataset.label}` : '',
        ca ? `CA annuel : ${ca.display}` : '',
        salaries ? `Salariés : ${salaries.value}` : '',
        '',
        '— DEMANDE —',
        besoin ? `Sujet : ${besoin.dataset.label}` : '',
        ca ? `Forfait estimé : ${ca.forfait}` : '',
        '',
        '— CONTACT —',
        fd.get('nom') ? `Nom : ${fd.get('nom')}` : '',
        fd.get('telephone') ? `Tél : ${fd.get('telephone')}` : '',
        fd.get('email') ? `Email : ${fd.get('email')}` : '',
        fd.get('message') ? `\nPrécisions : ${fd.get('message')}` : '',
      ].filter(Boolean).join('\n');

      window.open(`${waBase}?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
    });

    /* Init */
    validateCurrent();
    updateRecap();
  }
</script>
