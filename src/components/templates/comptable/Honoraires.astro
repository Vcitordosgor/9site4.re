---
/**
 * Honoraires — tableau tarifaire institutionnel avec ranges.
 */
import data from '../../../data/templates/auberval.json';
---

<section id="honoraires" class="bg-auberval-feutre py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-3xl mx-auto">

    <header class="mb-14 md:mb-16">
      <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-5">
        ✦ Honoraires
      </p>
      <h2 class="font-source-serif text-auberval-marine leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Honoraires &<br/>
        <span class="italic text-auberval-or">conditions générales.</span>
      </h2>
    </header>

    <!-- Tableau honoraires -->
    <div class="border-t-2 border-auberval-marine">
      {data.honoraires.map((h) => (
        <div class="grid grid-cols-12 gap-3 py-5 items-baseline border-b border-auberval-marine/15">
          <div class="col-span-7 sm:col-span-7">
            <p class="font-source-serif text-auberval-marine text-lg md:text-xl">
              {h.label}
            </p>
            <p class="mt-1 font-plex-sans italic text-auberval-encre/65 text-sm">
              {h.detail}
            </p>
          </div>
          <div class="col-span-5 sm:col-span-5 text-right">
            <p class="font-source-serif text-auberval-marine text-xl md:text-2xl tabular-nums leading-none">
              {h.prix}
            </p>
            <p class="mt-1 font-dm-mono text-[10px] uppercase tracking-[0.18em] text-auberval-or">
              {h.unite}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Note honoraires -->
    <div class="mt-10 p-6 md:p-8 bg-auberval-blanc border-l-2 border-auberval-or">
      <p class="font-dm-mono text-[10px] uppercase tracking-[0.28em] text-auberval-or mb-3">
        Inclus dans tous les forfaits
      </p>
      <p class="font-source-serif text-auberval-marine text-base md:text-lg leading-[1.8]">
        {data.noteHonoraires}
      </p>
    </div>

    <p class="mt-8 font-plex-sans italic text-auberval-encre/65 text-sm leading-relaxed">
      Devis personnalisé envoyé sous 48h après le premier rendez-vous. Conventions d'honoraires écrites avant tout engagement.
    </p>
  </div>
</section>
