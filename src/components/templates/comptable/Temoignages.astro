---
/**
 * Temoignages — 4 témoignages format lettres de référence anonymisées.
 * Initiales, fonction, ancienneté client.
 */
import data from '../../../data/templates/auberval.json';
---

<section id="temoignages" class="bg-auberval-blanc py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-16 max-w-3xl">
      <p class="font-plex-sans text-[10px] uppercase tracking-[0.32em] text-auberval-or font-semibold mb-5">
        ✦ Lettres de référence
      </p>
      <h2 class="font-source-serif text-auberval-marine leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Quelques retours,<br/>
        <span class="italic text-auberval-or">en toute confidentialité.</span>
      </h2>
      <p class="mt-5 font-source-serif italic text-auberval-encre/70 text-base leading-relaxed">
        Pour respecter le secret professionnel, nos clients sont identifiés par leurs initiales et leur secteur. Témoignages complets disponibles sur demande.
      </p>
    </header>

    <ul class="grid md:grid-cols-2 gap-6">
      {data.temoignages.map((t) => (
        <li class="bg-auberval-feutre border-l-2 border-auberval-or p-7 md:p-9">

          <!-- Initiales en gros + fonction -->
          <div class="flex items-baseline justify-between gap-4 mb-5 pb-5 border-b border-auberval-marine/15">
            <div>
              <p class="font-source-serif text-auberval-marine text-3xl tracking-wide leading-none">
                {t.initiales}
              </p>
              <p class="mt-2 font-plex-sans text-auberval-encre/85 text-sm font-medium">
                {t.fonction}
              </p>
            </div>
            <span class="font-dm-mono text-[10px] uppercase tracking-[0.22em] text-auberval-or text-right">
              ✓ {t.anciennete}
            </span>
          </div>

          <!-- Texte -->
          <blockquote class="font-source-serif italic text-auberval-marine/85 text-base md:text-lg leading-[1.85]">
            « {t.texte} »
          </blockquote>
        </li>
      ))}
    </ul>
  </div>
</section>
