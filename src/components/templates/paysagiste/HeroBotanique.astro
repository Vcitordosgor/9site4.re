---
/**
 * HeroBotanique — composition florale.
 * Mobile : tagline + petite photo + CTA.
 * Desktop : grille 7/5 — texte à gauche avec ornements floraux SVG
 * flottants, photo principale CIRCULAIRE à droite (≠ rectangles
 * des autres templates) avec petite photo secondaire fleurs en
 * collage.
 */
import data from '../../../data/templates/agapanthes.json';
---

<section class="relative isolate overflow-hidden bg-agap-lin pt-28 md:pt-32 pb-20 md:pb-32 px-6 md:px-10">

  <!-- Ornements SVG floraux décoratifs (desktop) -->
  <svg class="hidden lg:block absolute top-32 left-6 w-24 h-24 text-agap-sauge/35" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 10 Q 60 30, 80 30 Q 60 35, 60 50 Q 50 35, 40 50 Q 40 35, 20 30 Q 40 30, 50 10z" />
  </svg>
  <svg class="hidden lg:block absolute bottom-20 right-12 w-32 h-32 text-agap-rose/45 rotate-45" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <circle cx="50" cy="30" r="14" opacity="0.85"/>
    <circle cx="32" cy="55" r="14" opacity="0.85"/>
    <circle cx="68" cy="55" r="14" opacity="0.85"/>
    <circle cx="42" cy="75" r="11" opacity="0.85"/>
    <circle cx="58" cy="75" r="11" opacity="0.85"/>
  </svg>

  <div class="relative max-w-content mx-auto grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

    <!-- Colonne texte gauche (7) -->
    <div class="lg:col-span-7 relative">
      <p class="hero-eyebrow flex items-center gap-3 text-xs font-outfit font-medium uppercase tracking-[0.32em] text-agap-violet">
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
        <span>Atelier paysagiste · Saint-Leu</span>
      </p>

      <!-- Tagline en deux lignes Cormorant — italique sur la 2e -->
      <h1 class="hero-title mt-6 sm:mt-8 font-cormorant text-agap-feuille leading-[0.98]" style="font-size: clamp(48px, 8vw, 108px);">
        <span class="block font-medium">{data.info.tagline}</span>
        <span class="block italic font-medium text-agap-violet">{data.info.taglineItalic}</span>
      </h1>

      <p class="hero-intro mt-8 max-w-xl font-outfit text-agap-feuille/75 leading-[1.75]" style="font-size: clamp(15.5px, 1.6vw, 17.5px);">
        {data.info.intro}
      </p>

      <!-- 2 CTA -->
      <div class="hero-cta mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a
          href="#devis"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-outfit font-semibold uppercase tracking-[0.2em] rounded-full bg-agap-violet text-agap-lin hover:bg-agap-violet-fonce transition-colors"
          style="box-shadow: 0 12px 32px rgb(107 91 149 / 0.30);"
        >
          Demander un devis
        </a>
        <a
          href="#realisations"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-outfit font-semibold uppercase tracking-[0.2em] rounded-full bg-transparent text-agap-feuille ring-1 ring-agap-feuille/30 hover:ring-agap-violet hover:text-agap-violet transition-colors"
        >
          Voir nos jardins
        </a>
      </div>
    </div>

    <!-- Colonne photo droite (5) — composition circulaire -->
    <div class="hero-photo lg:col-span-5 relative">
      <!-- Photo principale CIRCULAIRE -->
      <figure class="relative mx-auto max-w-[420px] lg:max-w-none">
        <!-- Cercle décoratif sauge derrière, décalé -->
        <div class="hidden lg:block absolute -top-4 -left-4 w-full h-full rounded-full ring-1 ring-agap-violet/40 pointer-events-none" aria-hidden="true"></div>

        <div class="relative overflow-hidden rounded-full border border-agap-violet/15" style="aspect-ratio: 1/1;">
          <img
            src={data.info.photoHero}
            alt={data.info.photoHeroAlt}
            width="900"
            height="900"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>

        <!-- Petite photo fleur en collage, en bas à droite (cercle) -->
        <figure class="absolute -bottom-4 -right-2 sm:-right-4 w-28 sm:w-36 lg:w-44 aspect-square rounded-full overflow-hidden border-4 border-agap-lin shadow-lg">
          <img
            src={data.info.photoFleur}
            alt={data.info.photoFleurAlt}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
          />
        </figure>

        <!-- Petite étiquette manuscrite au-dessus -->
        <span class="absolute -top-3 left-4 sm:-left-3 inline-flex items-center px-3 h-8 bg-agap-lin border border-agap-violet/30 font-cormorant italic text-agap-violet text-sm" aria-hidden="true">
          ✦ Saint-Leu · 2011
        </span>
      </figure>
    </div>
  </div>
</section>

<style>
  @keyframes agap-rise {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes agap-fade {
    from { opacity: 0; transform: scale(0.94) rotate(-2deg); }
    to   { opacity: 1; transform: scale(1) rotate(0); }
  }

  .hero-eyebrow { animation: agap-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) backwards;  animation-delay: 200ms; }
  .hero-title   { animation: agap-rise 1000ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 350ms; }
  .hero-intro   { animation: agap-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) backwards;  animation-delay: 600ms; }
  .hero-cta     { animation: agap-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards;  animation-delay: 800ms; }
  .hero-photo   { animation: agap-fade 1200ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 450ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-title, .hero-intro, .hero-cta, .hero-photo {
      animation: none !important; opacity: 1; transform: none !important;
    }
  }
</style>
