---
/**
 * Devis — wrapper de la section "Demande de devis".
 * Charge le formulaire en Astro Island Preact.
 * Le formulaire ouvre WhatsApp pré-rempli.
 */
import data from '../../../data/templates/agapanthes.json';
import RdvForm from './RdvForm.tsx';
---

<section id="devis" class="relative bg-agap-pierre/40 py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-outfit font-medium uppercase tracking-[0.32em] text-agap-violet">
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
        <span>Demander un devis</span>
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-cormorant text-agap-feuille leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 60px);">
        Parlons de
        <span class="italic font-medium text-agap-violet">votre jardin.</span>
      </h2>
      <p class="scroll-reveal mt-6 font-outfit text-agap-feuille/70 leading-[1.7]">
        Réponse sous 48h ouvrées. Premier rendez-vous de diagnostic
        toujours sur place et toujours gratuit.
      </p>
    </header>

    <div class="scroll-reveal">
      <RdvForm
        client:load
        typesIntervention={data.typesIntervention}
        surfaces={data.surfaces}
        frequences={data.frequences}
        whatsapp={data.info.whatsapp}
        atelierNom={data.info.nom}
      />
    </div>
  </div>
</section>
