---
import data from '../../../data/templates/agapanthes.json';
const year = new Date().getFullYear();
---

<footer class="bg-agap-feuille text-agap-lin/85 py-12 px-6 md:px-10 border-t border-agap-violet/30">
  <div class="max-w-content mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="flex items-baseline gap-2 leading-none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-agap-violet -mb-0.5" aria-hidden="true">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
          </svg>
          <span class="font-cormorant italic text-agap-lin text-2xl">{data.info.wordmark1}</span>
          <span class="font-cormorant italic font-semibold text-agap-rose text-2xl">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-cormorant italic text-agap-lin/65 text-sm">
          Saint-Leu · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 text-sm font-outfit">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-agap-rose transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-flex w-1 h-1 rounded-full bg-agap-violet/45" aria-hidden="true"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-agap-rose transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <!-- Filet violet séparateur -->
    <div class="mt-10 mb-6 h-px" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgb(107 91 149 / 0.4) 30%, rgb(107 91 149 / 0.4) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 text-xs uppercase tracking-[0.25em] text-agap-lin/70 font-outfit">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="font-semibold text-agap-lin hover:text-agap-rose transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
