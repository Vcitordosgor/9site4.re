---
/**
 * PaysagisteHeader — header transparent au top, lin/blur au scroll.
 * Wordmark "Les agapanthes" en Cormorant italique violet.
 * Petite illustration SVG feuille en début de wordmark.
 */
import data from '../../../data/templates/agapanthes.json';

const navLinks = [
  { href: '#approche',     label: 'Approche' },
  { href: '#services',     label: 'Services' },
  { href: '#realisations', label: 'Réalisations' },
  { href: '#equipe',       label: 'Équipe' },
];
---

<header
  id="agap-header"
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500 ease-out"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">
    <a href="#top" class="flex items-baseline gap-2 leading-none transition-colors group">
      <!-- Petite feuille SVG en début, comme un cachet -->
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-agap-violet group-hover:text-agap-sauge-fonce transition-colors -mb-0.5" aria-hidden="true">
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z" stroke="currentColor" stroke-width="0" />
      </svg>
      <span class="font-cormorant italic text-agap-feuille" style="font-size: 24px;">{data.info.wordmark1}</span>
      <span class="font-cormorant italic font-semibold text-agap-violet" style="font-size: 24px;">{data.info.wordmark2}</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 lg:gap-9" aria-label="Navigation">
      {navLinks.map((l) => (
        <a
          href={l.href}
          class="text-xs uppercase tracking-[0.22em] font-outfit font-medium text-agap-feuille/70 hover:text-agap-violet transition-colors"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href="#devis"
      class="hidden md:inline-flex items-center justify-center h-10 px-5 text-xs font-outfit font-semibold uppercase tracking-[0.18em] rounded-full bg-agap-violet text-agap-lin hover:bg-agap-violet-fonce transition-colors"
    >
      Devis gratuit
    </a>

    <button
      id="agap-menu-toggle"
      type="button"
      data-open="false"
      aria-expanded="false"
      aria-controls="agap-mobile-menu"
      aria-label="Ouvrir le menu"
      class="group md:hidden relative w-10 h-10 -mr-2 flex items-center justify-center"
    >
      <span class="sr-only">Menu</span>
      <span class="relative flex flex-col items-center justify-center gap-1.5 w-6 h-6">
        <span class="block w-6 h-0.5 bg-agap-feuille rounded-full transition-transform duration-300 origin-center group-data-[open=true]:rotate-45 group-data-[open=true]:translate-y-2"></span>
        <span class="block w-6 h-0.5 bg-agap-feuille rounded-full transition-opacity duration-200 group-data-[open=true]:opacity-0"></span>
        <span class="block w-6 h-0.5 bg-agap-feuille rounded-full transition-transform duration-300 origin-center group-data-[open=true]:-rotate-45 group-data-[open=true]:-translate-y-2"></span>
      </span>
    </button>
  </div>
</header>

<!-- Menu mobile plein écran -->
<div
  id="agap-mobile-menu"
  data-open="false"
  aria-hidden="true"
  inert
  class="md:hidden fixed inset-0 top-16 z-40 bg-agap-lin transition-opacity duration-300 ease-out data-[open=false]:opacity-0 data-[open=false]:pointer-events-none data-[open=true]:opacity-100"
>
  <nav class="h-full flex flex-col px-6 pt-10 pb-10" aria-label="Navigation mobile">
    <ul class="flex-1 flex flex-col gap-1">
      {navLinks.map((l) => (
        <li>
          <a href={l.href} data-agap-link class="block py-4 font-cormorant italic text-agap-feuille hover:text-agap-violet transition-colors border-b border-agap-feuille/10" style="font-size: 32px;">
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="pt-6">
      <a
        href="#devis"
        data-agap-link
        class="inline-flex items-center justify-center w-full h-14 text-sm font-outfit font-semibold uppercase tracking-[0.2em] rounded-full bg-agap-violet text-agap-lin hover:bg-agap-violet-fonce transition-colors"
      >
        Demander un devis
      </a>
    </div>
  </nav>
</div>

<style>
  /* Header lin opaque/blur au scroll */
  #agap-header[data-scrolled='true'] {
    background-color: rgb(244 242 236 / 0.92);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    backdrop-filter: saturate(160%) blur(12px);
    box-shadow: 0 1px 0 rgb(107 91 149 / 0.10);
  }
</style>

<script>
  const header = document.getElementById('agap-header');
  if (header) {
    const update = () => {
      header.dataset.scrolled = String(window.scrollY > 60);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  const toggle = document.getElementById('agap-menu-toggle');
  const menu = document.getElementById('agap-mobile-menu');
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.dataset.open = String(open);
      toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
      menu.dataset.open = String(open);
      menu.setAttribute('aria-hidden', String(!open));
      if (open) menu.removeAttribute('inert');
      else menu.setAttribute('inert', '');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });
    menu.querySelectorAll<HTMLElement>('[data-agap-link]').forEach((el) => {
      el.addEventListener('click', () => setOpen(false));
    });
  }
</script>
