---
/**
 * Services — 6 services en grille avec icônes botaniques.
 * Style éditorial doux, sans bordures épaisses (≠ plombier).
 * Chaque service = card lin avec icône cerclée violet, titre
 * Cormorant italique, description, badge délai.
 */
import data from '../../../data/templates/agapanthes.json';

const icons: Record<string, string> = {
  // sketch (compas / plan)
  sketch:  '<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>',
  // scissor
  scissor: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>',
  // tree
  tree:    '<path d="M12 2v20"/><path d="M5 8a7 7 0 0 1 14 0"/><path d="M3 14a9 9 0 0 1 18 0"/><path d="M5 8h14"/><path d="M3 14h18"/>',
  // deck (planches)
  deck:    '<rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18"/><path d="M3 15h18"/>',
  // drop
  drop:    '<path d="M12 2.69 5.6 9.8a8.5 8.5 0 1 0 12.8 0L12 2.69z"/>',
  // book
  book:    '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
};
---

<section id="services" class="relative bg-agap-lin py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center max-w-3xl mx-auto mb-14 md:mb-20">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-outfit font-medium uppercase tracking-[0.32em] text-agap-violet">
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
        <span>Nos services</span>
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-cormorant text-agap-feuille leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 60px);">
        Du dessin
        <span class="italic font-medium text-agap-violet">à la dernière taille.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {data.services.map((s, i) => (
        <li class="scroll-reveal group flex flex-col bg-agap-pierre/30 hover:bg-agap-violet hover:text-agap-lin border border-agap-feuille/8 hover:border-agap-violet transition-colors duration-300 p-7 md:p-8" style={`transition-delay: ${i * 60}ms`}>
          <!-- Icône cerclée -->
          <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-agap-violet/10 text-agap-violet group-hover:bg-agap-lin/20 group-hover:text-agap-lin transition-colors">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[s.icon] || icons.scissor} />
          </span>

          <h3 class="mt-6 font-cormorant italic font-semibold text-agap-feuille group-hover:text-agap-lin leading-tight transition-colors" style="font-size: 26px;">
            {s.titre}
          </h3>

          <p class="mt-3 font-outfit text-sm text-agap-feuille/75 group-hover:text-agap-lin/85 leading-[1.7] flex-1 transition-colors">
            {s.description}
          </p>

          <!-- Délai en bas -->
          <div class="mt-6 pt-5 border-t border-agap-feuille/10 group-hover:border-agap-lin/20 flex items-center gap-2 text-xs font-outfit font-medium uppercase tracking-[0.22em] text-agap-violet group-hover:text-agap-lin transition-colors">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>{s.delai}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
