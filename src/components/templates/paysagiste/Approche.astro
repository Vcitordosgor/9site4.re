---
/**
 * Approche — manifesto + 3 valeurs.
 * Layout : citation centrée en grand Cormorant + 3 valeurs en grille
 * avec icônes botaniques cerclées sauge.
 */
import data from '../../../data/templates/agapanthes.json';

const icons: Record<string, string> = {
  // leaf
  leaf:    '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  // drop
  drop:    '<path d="M12 2.69 5.6 9.8a8.5 8.5 0 1 0 12.8 0L12 2.69z"/>',
  // scissor (sécateur stylisé)
  scissor: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>',
};
---

<section id="approche" class="relative bg-agap-lin py-20 md:py-32 px-6 md:px-10">

  <!-- Ornement feuille flottante en arrière-plan -->
  <svg class="absolute top-12 right-6 w-32 h-32 text-agap-sauge/15 hidden md:block" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
  </svg>

  <div class="relative max-w-content mx-auto">

    <!-- Citation manifeste centrée en grand Cormorant -->
    <header class="text-center max-w-3xl mx-auto mb-20 md:mb-24">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-outfit font-medium uppercase tracking-[0.32em] text-agap-violet mb-8">
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
        <span>Notre approche</span>
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
      </p>

      <blockquote class="scroll-reveal">
        <!-- Grand guillemet violet décoratif -->
        <span class="block font-cormorant italic text-agap-violet/30 leading-none -mb-6" style="font-size: 96px;" aria-hidden="true">«</span>
        <p class="font-cormorant italic text-agap-feuille leading-[1.3]" style="font-size: clamp(28px, 4vw, 44px);">
          {data.manifesto}
        </p>
      </blockquote>
    </header>

    <!-- 3 valeurs avec icônes cerclées sauge -->
    <ul class="grid sm:grid-cols-3 gap-10 md:gap-14 max-w-5xl mx-auto">
      {data.valeurs.map((v, i) => (
        <li class="scroll-reveal text-center" style={`transition-delay: ${i * 80}ms`}>
          <!-- Icône cerclée sauge avec ring violet en décalé -->
          <span class="relative inline-flex items-center justify-center w-16 h-16 rounded-full bg-agap-sauge/20 text-agap-sauge-fonce">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[v.icon] || icons.leaf} />
            <span class="absolute -top-1 -right-1 w-full h-full rounded-full ring-1 ring-agap-violet/40" aria-hidden="true"></span>
          </span>

          <h3 class="mt-6 font-cormorant italic font-semibold text-agap-feuille" style="font-size: 26px;">
            {v.titre}
          </h3>
          <p class="mt-3 font-outfit text-sm text-agap-feuille/70 leading-[1.7]">
            {v.description}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
