---
/**
 * Equipe — 3 paysagistes en portraits CIRCULAIRES.
 * Vraiment différent du resto (1 chef en portrait carré) :
 * ici 3 personnes en cercles avec rôles + bio + tag expérience.
 */
import data from '../../../data/templates/agapanthes.json';
---

<section id="equipe" class="relative bg-agap-pierre/40 py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center max-w-3xl mx-auto mb-14 md:mb-20">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-outfit font-medium uppercase tracking-[0.32em] text-agap-violet">
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
        <span>L'équipe</span>
        <span class="block w-8 h-px bg-agap-violet" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-cormorant text-agap-feuille leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 60px);">
        Trois paires de mains,
        <span class="block italic font-medium text-agap-violet">une seule signature.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12 max-w-5xl mx-auto">
      {data.equipe.map((m, i) => (
        <li class="scroll-reveal text-center" style={`transition-delay: ${i * 80}ms`}>
          <!-- Portrait CIRCULAIRE avec ring violet décalé -->
          <figure class="relative w-44 sm:w-52 mx-auto">
            <span class="absolute -top-2 -right-2 w-full h-full rounded-full ring-1 ring-agap-violet/45" aria-hidden="true"></span>
            <div class="relative overflow-hidden rounded-full bg-agap-violet-fonce" style="aspect-ratio: 1/1;">
              <img
                src={m.photo}
                alt={m.photoAlt}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover"
              />
            </div>
            <!-- Tag expérience en pastille -->
            <span class="absolute -bottom-3 left-1/2 -translate-x-1/2 inline-flex items-center px-3 h-7 bg-agap-lin border border-agap-violet/30 rounded-full font-cormorant italic text-agap-violet text-xs whitespace-nowrap">
              ✦ {m.experience}
            </span>
          </figure>

          <h3 class="mt-8 font-cormorant italic font-semibold text-agap-feuille leading-tight" style="font-size: 26px;">
            {m.nom}
          </h3>
          <p class="mt-1 text-xs font-outfit font-medium uppercase tracking-[0.22em] text-agap-violet">
            {m.role}
          </p>

          <p class="mt-4 font-outfit text-sm text-agap-feuille/70 leading-[1.7] max-w-xs mx-auto">
            {m.bio}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
