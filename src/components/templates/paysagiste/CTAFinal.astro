---
/**
 * CTAFinal — bandeau violet profond + photo feuille + citation finale.
 * Style poétique avec ornement floral SVG décoratif.
 */
import data from '../../../data/templates/agapanthes.json';
---

<section class="relative bg-agap-violet-fonce text-agap-lin py-20 md:py-32 px-6 md:px-10 text-center overflow-hidden">

  <!-- Halo violet doux + halo sauge -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[44rem] h-[44rem] rounded-full"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(157 171 142 / 0.20) 0%, transparent 70%);">
    </div>
  </div>

  <!-- Ornement floral SVG -->
  <svg class="relative mx-auto w-16 h-16 text-agap-rose mb-8" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <circle cx="50" cy="30" r="14" opacity="0.85"/>
    <circle cx="32" cy="55" r="14" opacity="0.85"/>
    <circle cx="68" cy="55" r="14" opacity="0.85"/>
    <circle cx="42" cy="75" r="11" opacity="0.85"/>
    <circle cx="58" cy="75" r="11" opacity="0.85"/>
  </svg>

  <div class="relative max-w-2xl mx-auto">
    <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-outfit font-medium uppercase tracking-[0.32em] text-agap-rose">
      <span class="block w-8 h-px bg-agap-rose/55" aria-hidden="true"></span>
      <span>{data.info.wordmark1} {data.info.wordmark2}</span>
      <span class="block w-8 h-px bg-agap-rose/55" aria-hidden="true"></span>
    </p>

    <h2 class="scroll-reveal mt-6 font-cormorant text-agap-lin leading-[1.1]" style="font-size: clamp(40px, 5.5vw, 64px);">
      Un jardin,
      <span class="italic font-medium text-agap-rose">ça se rêve à deux.</span>
    </h2>

    <p class="scroll-reveal mt-6 font-outfit text-agap-lin/75 leading-[1.8] max-w-md mx-auto">
      On vient sur place pour comprendre votre terrain, vos envies,
      votre vie. Le devis arrive ensuite, sous 7 jours.
    </p>

    <div class="scroll-reveal mt-10">
      <a
        href="#devis"
        class="inline-flex items-center justify-center h-14 px-9 text-sm font-outfit font-semibold uppercase tracking-[0.22em] rounded-full bg-agap-rose text-agap-violet-fonce hover:bg-agap-lin transition-colors"
        style="box-shadow: 0 12px 32px rgb(232 212 217 / 0.30);"
      >
        Demander un devis
      </a>
    </div>
  </div>
</section>
