---
import data from '../../../data/templates/seve.json';
---

<section id="fondatrice" class="bg-seve-marine py-20 md:py-28 relative overflow-hidden">
  <!-- Ornement floral discret en filigrane -->
  <svg viewBox="0 0 600 400" class="absolute -right-20 top-10 w-[500px] text-seve-or/10" aria-hidden="true">
    <g fill="none" stroke="currentColor" stroke-width="0.6">
      <path d="M0 200 Q150 120 300 200 T600 200" />
      <path d="M0 230 Q150 150 300 230 T600 230" />
      <circle cx="100" cy="190" r="20" />
      <circle cx="300" cy="200" r="14" />
      <circle cx="500" cy="210" r="18" />
    </g>
  </svg>

  <div class="max-w-content mx-auto px-6 md:px-10 relative">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-center">

      <!-- Visuel : portrait stylisé typographique -->
      <div class="md:col-span-5">
        <div class="relative aspect-[4/5] bg-seve-ivoire/5 border border-seve-or/30 flex items-center justify-center overflow-hidden">
          <!-- Initiales géantes -->
          <div class="font-italianno text-seve-or text-[280px] md:text-[340px] leading-none">
            CH
          </div>
          <!-- Filets en croix -->
          <div class="absolute inset-x-6 top-6 h-px bg-seve-or/30" aria-hidden="true"></div>
          <div class="absolute inset-x-6 bottom-6 h-px bg-seve-or/30" aria-hidden="true"></div>
          <!-- Tampon -->
          <div class="absolute bottom-6 right-6 text-right">
            <p class="font-outfit text-[10px] uppercase tracking-[0.25em] text-seve-ivoire/70">Fondatrice</p>
            <p class="font-italianno text-seve-ivoire text-3xl leading-none mt-1">Cléa</p>
          </div>
        </div>
      </div>

      <!-- Texte -->
      <div class="md:col-span-7">
        <p class="font-outfit text-[11px] uppercase tracking-[0.3em] text-seve-or mb-4">— La fondatrice —</p>
        <h2 class="font-cormorant text-4xl md:text-5xl text-seve-ivoire leading-tight">
          {data.fondatrice.nom}
        </h2>
        <p class="font-italianno text-seve-or text-3xl md:text-4xl mt-2 leading-none">
          {data.fondatrice.titre}
        </p>

        <div class="mt-7 space-y-5 font-outfit text-[14.5px] md:text-base text-seve-ivoire/85 leading-relaxed">
          <p>{data.fondatrice.bio}</p>
          <blockquote class="border-l-2 border-seve-or pl-5 font-cormorant italic text-xl md:text-2xl text-seve-ivoire leading-snug">
            « {data.fondatrice.promesse} »
          </blockquote>
        </div>

        <div class="mt-8 pt-6 border-t border-seve-or/30 grid grid-cols-3 gap-4">
          <div>
            <div class="font-cormorant text-3xl text-seve-or">9 ans</div>
            <div class="font-outfit text-[10px] uppercase tracking-[0.18em] text-seve-ivoire/60 mt-1">d'expérience</div>
          </div>
          <div>
            <div class="font-cormorant text-3xl text-seve-or">3 langues</div>
            <div class="font-outfit text-[10px] uppercase tracking-[0.18em] text-seve-ivoire/60 mt-1">FR · EN · créole</div>
          </div>
          <div>
            <div class="font-cormorant text-3xl text-seve-or">70%</div>
            <div class="font-outfit text-[10px] uppercase tracking-[0.18em] text-seve-ivoire/60 mt-1">couples internationaux</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
