---
import data from '../../../data/templates/seve.json';
---

<section class="bg-seve-creme py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">

    <div class="text-center max-w-2xl mx-auto mb-14 md:mb-16">
      <p class="font-outfit text-[11px] uppercase tracking-[0.3em] text-seve-or mb-4">— Ils se sont dit oui —</p>
      <h2 class="font-cormorant text-4xl md:text-5xl text-seve-marine leading-tight">
        Trois histoires, <em class="font-italianno text-seve-corail text-5xl md:text-6xl not-italic">trois oui</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {data.couples.map((c) => (
        <article class="bg-white p-7 md:p-8 border border-seve-or/20 flex flex-col">
          <div class="flex gap-1 text-seve-or text-lg mb-4" aria-label={`${c.etoiles} étoiles`}>
            {Array.from({ length: c.etoiles }).map(() => <span>★</span>)}
          </div>

          <p class="font-italianno text-seve-marine text-4xl leading-none">{c.prenoms}</p>
          <p class="mt-2 font-outfit text-[11px] uppercase tracking-[0.18em] text-seve-or">
            {c.origine} · {c.date}
          </p>

          <blockquote class="mt-5 font-cormorant italic text-[16.5px] md:text-[17px] text-seve-marine/85 leading-relaxed flex-1">
            « {c.texte} »
          </blockquote>
        </article>
      ))}
    </div>

    <p class="text-center mt-10 font-outfit text-sm text-seve-marine/65">
      <span class="font-cormorant text-2xl text-seve-marine">{data.info.ceremonies2025}</span> cérémonies célébrées en 2025 ·
      <span class="font-cormorant text-2xl text-seve-marine">{data.info.ceremoniesPrevues2026}</span> programmées en 2026
    </p>
  </div>
</section>
