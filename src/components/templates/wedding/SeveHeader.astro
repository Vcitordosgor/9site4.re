---
/**
 * SeveHeader — header sticky transparent qui devient ivoire au scroll.
 * Identité wedding luxueuse : wordmark Italianno + bouton 'Premier appel'.
 */
import data from '../../../data/templates/seve.json';

const navLinks = [
  { href: '#ceremonies', label: 'Cérémonies' },
  { href: '#lieux', label: 'Lieux' },
  { href: '#fondatrice', label: 'Cléa' },
  { href: '#demarches', label: 'Démarches' },
];
---

<header
  id="seve-header"
  data-scrolled="false"
  class="sticky top-0 z-50 transition-[background-color,backdrop-filter,box-shadow,border-color] duration-500 ease-out border-b border-transparent"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">
    <a href="#top" class="flex items-baseline gap-1 group" aria-label="Sève & Sel — accueil">
      <span class="font-italianno text-seve-marine text-3xl md:text-4xl leading-none">Sève</span>
      <span class="font-italianno text-seve-or text-3xl md:text-4xl leading-none">&amp;</span>
      <span class="font-italianno text-seve-marine text-3xl md:text-4xl leading-none">Sel</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 lg:gap-9 font-outfit text-[12px] uppercase tracking-[0.18em] font-medium" aria-label="Navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-seve-marine/85 hover:text-seve-corail transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="#contact"
      class="hidden md:inline-flex items-center justify-center h-10 px-5 bg-seve-marine text-seve-ivoire font-outfit font-semibold text-[12px] uppercase tracking-[0.18em] rounded-full hover:bg-seve-corail transition-colors duration-300"
    >
      Premier appel
    </a>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="md:hidden inline-flex items-center justify-center h-10 px-4 bg-seve-marine text-seve-ivoire font-outfit font-semibold text-[12px] uppercase tracking-wider rounded-full"
      aria-label="Appeler"
    >
      Appeler
    </a>
  </div>
</header>

<style>
  #seve-header[data-scrolled='true'] {
    background-color: rgb(250 244 234 / 0.92);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    box-shadow: 0 1px 3px rgb(42 63 92 / 0.06);
    border-bottom-color: rgb(42 63 92 / 0.08);
  }
</style>

<script>
  const header = document.getElementById('seve-header');
  if (header) {
    const update = () => {
      header.dataset.scrolled = String(window.scrollY > 8);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
