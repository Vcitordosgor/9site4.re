---
import data from '../../../data/templates/seve.json';
---

<section id="lieux" class="bg-seve-creme py-20 md:py-28 relative overflow-hidden">
  <!-- Filets dorés -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-seve-or/40 to-transparent" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-seve-or/40 to-transparent" aria-hidden="true"></div>

  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="text-center max-w-2xl mx-auto mb-14 md:mb-16">
      <p class="font-outfit text-[11px] uppercase tracking-[0.3em] text-seve-or mb-4">— Lieux iconiques —</p>
      <h2 class="font-cormorant text-4xl md:text-5xl text-seve-marine leading-tight">
        Quatre décors pour vos <em class="font-italianno text-seve-corail text-5xl md:text-6xl not-italic">vœux</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      {data.lieuxIconiques.map((lieu) => (
        <article class="group relative bg-white overflow-hidden">
          <div class="aspect-[3/4] overflow-hidden bg-seve-marine/10">
            <img
              src={lieu.photo}
              alt={`${lieu.nom} — La Réunion`}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
          </div>
          <div class="p-5">
            <h3 class="font-cormorant text-xl md:text-2xl text-seve-marine leading-tight">{lieu.nom}</h3>
            <p class="mt-2 font-outfit text-[12.5px] text-seve-marine/75 leading-relaxed">{lieu.ambiance}</p>
            <p class="mt-3 pt-3 border-t border-seve-or/30 font-outfit text-[10.5px] uppercase tracking-[0.18em] text-seve-or">
              {lieu.moment}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
