---
import data from '../../../data/templates/seve.json';
const wa = `https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent('Bonjour Cléa, je souhaiterais organiser notre mariage à La Réunion.')}`;
---

<section id="contact" class="bg-seve-ivoire py-20 md:py-28 relative overflow-hidden">
  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14">

      <!-- Texte invitation -->
      <div class="md:col-span-7">
        <p class="font-outfit text-[11px] uppercase tracking-[0.3em] text-seve-or mb-4">— Premier contact —</p>
        <h2 class="font-cormorant text-4xl md:text-5xl text-seve-marine leading-tight">
          Et si on en parlait <em class="font-italianno text-seve-corail text-5xl md:text-6xl not-italic">autour d'un café</em> ?
        </h2>
        <p class="mt-6 font-outfit text-[15px] text-seve-marine/75 leading-relaxed max-w-xl">
          30 minutes au téléphone (ou en visio depuis l'autre bout du monde), gratuites, sans engagement.
          On parle de votre histoire, de votre rêve, et du budget réaliste pour le réaliser à La Réunion.
        </p>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href={`tel:${data.info.telephoneHref}`} class="group flex flex-col p-5 bg-white border border-seve-or/20 hover:border-seve-or transition-colors duration-300">
            <span class="font-outfit text-[10px] uppercase tracking-[0.2em] text-seve-or">Téléphone</span>
            <span class="mt-1 font-cormorant text-2xl text-seve-marine group-hover:text-seve-corail transition-colors">{data.info.telephone}</span>
          </a>
          <a href={`mailto:${data.info.email}`} class="group flex flex-col p-5 bg-white border border-seve-or/20 hover:border-seve-or transition-colors duration-300">
            <span class="font-outfit text-[10px] uppercase tracking-[0.2em] text-seve-or">Email</span>
            <span class="mt-1 font-cormorant text-xl text-seve-marine group-hover:text-seve-corail transition-colors break-all">{data.info.email}</span>
          </a>
        </div>

        <div class="mt-5">
          <a
            href={wa}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 h-12 px-6 bg-seve-vert text-white font-outfit font-semibold text-[12px] uppercase tracking-[0.18em] rounded-full hover:opacity-90 transition-opacity"
          >
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp — réponse sous 2h
          </a>
        </div>
      </div>

      <!-- Carte info -->
      <div class="md:col-span-5">
        <div class="bg-seve-marine text-seve-ivoire p-7 md:p-9 h-full flex flex-col">
          <p class="font-outfit text-[10px] uppercase tracking-[0.25em] text-seve-or mb-2">Bureau & rendez-vous</p>
          <p class="font-cormorant text-2xl leading-tight">{data.info.adresseLigne1}</p>
          <p class="font-cormorant text-2xl leading-tight">{data.info.adresseLigne2}</p>

          <div class="mt-6 pt-6 border-t border-seve-or/30 space-y-3 font-outfit text-[13px]">
            <div class="flex justify-between gap-3">
              <span class="text-seve-ivoire/60 uppercase tracking-wider text-[11px]">Lundi → vendredi</span>
              <span>9h — 18h</span>
            </div>
            <div class="flex justify-between gap-3">
              <span class="text-seve-ivoire/60 uppercase tracking-wider text-[11px]">Samedi</span>
              <span>sur rendez-vous</span>
            </div>
            <div class="flex justify-between gap-3">
              <span class="text-seve-ivoire/60 uppercase tracking-wider text-[11px]">Visio internationale</span>
              <span>7j/7</span>
            </div>
          </div>

          <div class="mt-auto pt-8">
            <p class="font-outfit text-[10px] uppercase tracking-[0.25em] text-seve-or mb-2">Disponibilités 2026</p>
            <p class="font-cormorant italic text-lg text-seve-ivoire leading-snug">
              {data.saison.mariagesEntierementDispos}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
