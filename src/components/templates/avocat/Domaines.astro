---
import data from '../../../data/templates/roussin.json';
---

<section id="domaines" class="bg-roussin-papier text-roussin-nuit py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">

    <div class="max-w-2xl mb-14 md:mb-20 text-center mx-auto">
      <p class="font-public-sans text-[11px] uppercase tracking-[0.4em] text-roussin-or mb-4">— Compétences du cabinet —</p>
      <h2 class="font-eb-garamond text-roussin-nuit text-5xl md:text-6xl leading-[0.95]">
        Quatre domaines<br/>
        <em class="text-roussin-or italic">d'intervention.</em>
      </h2>
    </div>

    <ul class="space-y-6 md:space-y-8">
      {data.domaines.map((d) => (
        <li class="bg-roussin-velin border border-roussin-or/40 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 p-7 md:p-9 relative">

          <!-- Filet interne -->
          <div class="absolute inset-2 border border-roussin-or/15 pointer-events-none" aria-hidden="true"></div>

          <!-- Référence -->
          <div class="md:col-span-3 flex md:flex-col items-baseline md:items-start gap-3 md:gap-2 relative">
            <p class="font-public-sans text-[10px] uppercase tracking-[0.25em] text-roussin-or">{d.code}</p>
            <h3 class="font-eb-garamond text-roussin-nuit text-2xl md:text-[28px] leading-tight">{d.titre}</h3>
            <p class="font-eb-garamond italic text-roussin-bordeaux text-lg leading-tight md:mt-2">« {d.tagline} »</p>
          </div>

          <!-- Description + missions -->
          <div class="md:col-span-6 relative">
            <p class="font-public-sans text-[14.5px] text-roussin-nuit/85 leading-relaxed">
              {d.description}
            </p>

            <div class="mt-5">
              <p class="font-public-sans text-[10px] uppercase tracking-[0.25em] text-roussin-or mb-2">Missions principales</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
                {d.missions.map((m) => (
                  <li class="flex gap-2 font-public-sans text-[12.5px] text-roussin-nuit/85 leading-snug">
                    <span class="text-roussin-or shrink-0">▸</span><span>{m}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Tarif + responsable + CTA -->
          <div class="md:col-span-3 relative md:border-l md:border-roussin-or/30 md:pl-6 flex flex-col gap-3">
            <div>
              <p class="font-public-sans text-[10px] uppercase tracking-[0.2em] text-roussin-or">Tarif d'entrée</p>
              <p class="font-eb-garamond text-roussin-nuit text-xl leading-tight mt-1">{d.tarif}</p>
            </div>
            <div>
              <p class="font-public-sans text-[10px] uppercase tracking-[0.2em] text-roussin-or">Responsable</p>
              <p class="font-eb-garamond text-roussin-nuit text-base italic leading-tight mt-1">{d.responsable}</p>
            </div>
            <a
              href="#contact"
              class="mt-2 inline-flex items-center justify-center h-10 px-4 bg-roussin-nuit text-roussin-velin font-public-sans font-semibold text-[11px] uppercase tracking-[0.18em] hover:bg-roussin-bordeaux transition-colors whitespace-nowrap"
            >
              Demander un RDV
            </a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
