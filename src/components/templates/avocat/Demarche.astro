---
import data from '../../../data/templates/roussin.json';
---

<section id="demarche" class="bg-roussin-velin text-roussin-nuit py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">

    <div class="max-w-2xl mx-auto text-center mb-14 md:mb-20">
      <p class="font-public-sans text-[11px] uppercase tracking-[0.4em] text-roussin-or mb-4">— Notre méthode —</p>
      <h2 class="font-eb-garamond text-roussin-nuit text-5xl md:text-6xl leading-[0.95]">
        De l'écoute<br/>
        <em class="text-roussin-or italic">au bilan écrit.</em>
      </h2>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-4 gap-5 md:gap-6">
      {data.demarches.map((d) => (
        <li class="bg-roussin-papier border border-roussin-or/40 p-6 md:p-7 relative flex flex-col">
          <div class="absolute inset-1.5 border border-roussin-or/15 pointer-events-none" aria-hidden="true"></div>
          <div class="relative">
            <p class="font-eb-garamond text-roussin-or text-6xl md:text-7xl leading-none italic">{d.etape}</p>
            <h3 class="mt-3 font-eb-garamond text-roussin-nuit text-xl md:text-[22px] leading-tight">
              {d.titre}
            </h3>
            <p class="mt-3 font-public-sans text-[13.5px] text-roussin-nuit/80 leading-relaxed">{d.texte}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
