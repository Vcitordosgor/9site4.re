---
import data from '../../../data/templates/roussin.json';
---

<section id="associes" class="bg-roussin-nuit text-roussin-velin py-20 md:py-28 relative overflow-hidden">

  <div class="max-w-content mx-auto px-6 md:px-10 relative">

    <!-- Filet doré -->
    <div class="flex justify-center mb-10" aria-hidden="true">
      <span class="block w-24 h-px bg-roussin-or"></span>
    </div>

    <div class="max-w-2xl mx-auto text-center mb-14 md:mb-16">
      <p class="font-public-sans text-[11px] uppercase tracking-[0.4em] text-roussin-or mb-4">— Les associés —</p>
      <h2 class="font-eb-garamond text-roussin-velin text-5xl md:text-6xl leading-[0.95]">
        Trois avocats,<br/>
        <em class="text-roussin-or italic">une étude.</em>
      </h2>
    </div>

    <!-- Grille associés style cartes officielles -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-16 md:mb-20">
      {data.associes.map((a, i) => (
        <article class="bg-roussin-velin text-roussin-nuit relative">
          <!-- Filets -->
          <div class="absolute top-2 inset-x-2 h-px bg-roussin-or" aria-hidden="true"></div>
          <div class="absolute bottom-2 inset-x-2 h-px bg-roussin-or" aria-hidden="true"></div>

          <div class="p-6 md:p-7">
            <p class="font-public-sans text-[10px] uppercase tracking-[0.25em] text-roussin-or mb-1">— Associé n°{String(i+1).padStart(2,'0')} —</p>
            <h3 class="font-eb-garamond text-roussin-nuit text-2xl md:text-[26px] leading-tight">
              Maître {a.prenom} <span class="block">{a.nom}</span>
            </h3>
            <p class="font-eb-garamond italic text-roussin-bordeaux text-base mt-2">{a.titre}</p>

            <div class="mt-5 pt-4 border-t border-roussin-or/40 space-y-2 font-public-sans text-[12.5px]">
              <div>
                <p class="text-[9.5px] uppercase tracking-[0.18em] text-roussin-or">Inscription</p>
                <p class="text-roussin-nuit/85">{a.barreau}</p>
              </div>
              <div>
                <p class="text-[9.5px] uppercase tracking-[0.18em] text-roussin-or">Spécialités</p>
                <p class="text-roussin-nuit/85">{a.specialite}</p>
              </div>
              <div>
                <p class="text-[9.5px] uppercase tracking-[0.18em] text-roussin-or">Expérience</p>
                <p class="font-eb-garamond text-roussin-nuit text-lg">{a.annees}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Fondateur — texte long -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-start max-w-5xl mx-auto pt-12 md:pt-16 border-t border-roussin-or/30">
      <div class="md:col-span-5">
        <p class="font-public-sans text-[10px] uppercase tracking-[0.3em] text-roussin-or mb-3">— Le fondateur —</p>
        <h3 class="font-eb-garamond text-roussin-velin text-4xl md:text-5xl leading-tight">{data.fondateur.nom}</h3>
        <p class="font-eb-garamond italic text-roussin-or text-lg mt-2">{data.fondateur.titre}</p>

        <div class="mt-7 pt-5 border-t border-roussin-or/30">
          <p class="font-public-sans text-[10px] uppercase tracking-[0.25em] text-roussin-or mb-3">Engagements & titres</p>
          <ul class="space-y-2">
            {data.fondateur.engagements.map((e) => (
              <li class="flex gap-2.5 font-public-sans text-[13px] text-roussin-velin/85 leading-snug">
                <span class="text-roussin-or">⚖</span><span>{e}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="md:col-span-7">
        <p class="font-public-sans text-[15px] md:text-base text-roussin-velin/85 leading-relaxed">
          {data.fondateur.bio}
        </p>
        <blockquote class="mt-7 border-l-2 border-roussin-or pl-5 font-eb-garamond italic text-2xl md:text-3xl text-roussin-velin leading-snug">
          {data.fondateur.credo}
        </blockquote>
      </div>
    </div>
  </div>
</section>
