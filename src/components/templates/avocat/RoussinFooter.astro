---
import data from '../../../data/templates/roussin.json';
---

<footer class="bg-roussin-nuit text-roussin-velin relative">
  <div class="absolute top-0 inset-x-0 h-[2px] bg-roussin-or" aria-hidden="true"></div>

  <div class="max-w-content mx-auto px-6 md:px-10 py-14 md:py-16">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <div class="md:col-span-5">
        <div class="flex items-center gap-3">
          <svg viewBox="0 0 32 32" class="w-9 h-9 text-roussin-or" aria-hidden="true">
            <line x1="16" y1="4" x2="16" y2="28" stroke="currentColor" stroke-width="1.2"/>
            <line x1="8" y1="9" x2="24" y2="9" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5 16 Q8 18 11 16" fill="none" stroke="currentColor" stroke-width="1"/>
            <path d="M21 16 Q24 18 27 16" fill="none" stroke="currentColor" stroke-width="1"/>
            <line x1="13" y1="28" x2="19" y2="28" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <div class="leading-none">
            <p class="font-eb-garamond text-2xl">{data.info.wordmark1}</p>
            <p class="font-eb-garamond italic text-roussin-or text-[13px] mt-1">{data.info.wordmark2}</p>
          </div>
        </div>
        <p class="mt-5 font-eb-garamond italic text-roussin-or text-base">
          ❦ {data.info.deviseLatine} ❦
        </p>
        <p class="mt-3 font-public-sans text-[14px] text-roussin-velin/80 max-w-sm leading-relaxed">
          {data.info.tagline} — Cabinet d'avocats à Saint-Pierre, La Réunion, depuis {data.info.annee}.
        </p>
      </div>

      <div class="md:col-span-3">
        <p class="font-public-sans text-[10px] uppercase tracking-[0.25em] text-roussin-or mb-3">Cabinet</p>
        <ul class="space-y-2 font-public-sans text-[13.5px]">
          <li><a href="#domaines" class="hover:text-roussin-or transition-colors">Domaines</a></li>
          <li><a href="#associes" class="hover:text-roussin-or transition-colors">Associés</a></li>
          <li><a href="#demarche" class="hover:text-roussin-or transition-colors">Démarche</a></li>
          <li><a href="#contact" class="hover:text-roussin-or transition-colors">Rendez-vous</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="font-public-sans text-[10px] uppercase tracking-[0.25em] text-roussin-or mb-3">Coordonnées</p>
        <ul class="space-y-2 font-public-sans text-[13.5px]">
          <li>{data.info.adresseLigne1}</li>
          <li>{data.info.adresseLigne2}</li>
          <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-roussin-or transition-colors">{data.info.telephone}</a></li>
          <li><a href={`mailto:${data.info.email}`} class="hover:text-roussin-or transition-colors">{data.info.email}</a></li>
          <li class="text-roussin-velin/65">{data.info.ordreBarreau}</li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-roussin-or/30 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-public-sans text-[11px] text-roussin-velin/60">
      <p>© {data.info.annee}–2026 {data.info.nom} · SIRET {data.info.siret} · Membre de l'Ordre des Avocats</p>
      <p class="font-eb-garamond italic text-roussin-or text-base">— Le droit, sans la posture.</p>
    </div>
  </div>
</footer>
