---
import data from '../../../data/templates/volta.json';
---

<section class="bg-volta-cyan py-14 md:py-20 px-6 md:px-10">
  <div class="max-w-content mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">

    <div class="flex items-start gap-5">
      <div class="shrink-0 w-12 h-12 flex items-center justify-center bg-volta-noir/15 rounded-sm">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="text-volta-noir" aria-hidden="true">
          <path d="M13 2L4.5 13.5H11L10 22L20.5 10H14L13 2Z"/>
        </svg>
      </div>
      <div>
        <p class="font-syne font-bold text-volta-noir leading-tight" style="font-size: clamp(22px, 3vw, 32px);">
          {data.urgence.label}
        </p>
        <p class="mt-2 font-space-grotesk text-sm text-volta-noir/75 leading-relaxed max-w-lg">
          {data.urgence.details}
        </p>
      </div>
    </div>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="shrink-0 inline-flex items-center gap-3 h-14 px-8 bg-volta-noir text-volta-cyan font-space-grotesk font-bold text-sm uppercase tracking-[0.18em] rounded-sm hover:bg-volta-acier transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
      </svg>
      <span class="tabular-nums">{data.info.telephone}</span>
    </a>

  </div>
</section>
