---
import data from '../../../data/templates/volta.json';
const waBase = `https://wa.me/${data.info.whatsapp}`;
---

<section id="devis" class="bg-volta-acier py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start max-w-5xl mx-auto">

      <div>
        <p class="scroll-reveal flex items-center gap-3 text-xs font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan">
          <span class="block w-8 h-px bg-volta-cyan/50" aria-hidden="true"></span>
          Devis gratuit
        </p>
        <h2 class="scroll-reveal mt-4 font-syne font-bold text-volta-blanc leading-[1.05]" style="font-size: clamp(30px, 4.5vw, 50px);">
          Un projet électrique ?
          <span class="block text-volta-fumee/60">On vient voir sur place.</span>
        </h2>
        <p class="scroll-reveal mt-5 font-space-grotesk text-sm text-volta-fumee/60 leading-relaxed">
          Décrivez votre besoin en quelques mots. On vous rappelle sous 24h pour fixer un passage — sans engagement, sans frais de déplacement dans notre zone.
        </p>

        <ul class="scroll-reveal mt-8 space-y-3">
          {[
            'Déplacement gratuit dans les 7 communes',
            'Devis détaillé sous 48h',
            'Électriciens certifiés RGE Qualifelec',
          ].map((item) => (
            <li class="flex items-start gap-3 font-space-grotesk text-sm text-volta-fumee/70">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-volta-cyan mt-0.5 shrink-0" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="scroll-reveal">
        <form
          id="volta-devis-form"
          class="space-y-4"
          novalidate
        >
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="vd-nom" class="block mb-1.5 text-xs font-space-grotesk font-medium text-volta-fumee/60 uppercase tracking-[0.18em]">Nom</label>
              <input
                id="vd-nom"
                name="nom"
                type="text"
                autocomplete="name"
                placeholder="Votre nom"
                required
                class="w-full h-11 px-4 bg-volta-noir border border-volta-fumee/15 focus:border-volta-cyan rounded-sm font-space-grotesk text-sm text-volta-blanc placeholder:text-volta-fumee/30 outline-none transition-colors"
              />
            </div>
            <div>
              <label for="vd-tel" class="block mb-1.5 text-xs font-space-grotesk font-medium text-volta-fumee/60 uppercase tracking-[0.18em]">Téléphone</label>
              <input
                id="vd-tel"
                name="telephone"
                type="tel"
                autocomplete="tel"
                placeholder="0692 xx xx xx"
                required
                class="w-full h-11 px-4 bg-volta-noir border border-volta-fumee/15 focus:border-volta-cyan rounded-sm font-space-grotesk text-sm text-volta-blanc placeholder:text-volta-fumee/30 outline-none transition-colors tabular-nums"
              />
            </div>
          </div>

          <div>
            <label for="vd-type" class="block mb-1.5 text-xs font-space-grotesk font-medium text-volta-fumee/60 uppercase tracking-[0.18em]">Type de travaux</label>
            <select
              id="vd-type"
              name="type"
              class="w-full h-11 px-4 bg-volta-noir border border-volta-fumee/15 focus:border-volta-cyan rounded-sm font-space-grotesk text-sm text-volta-blanc outline-none transition-colors appearance-none cursor-pointer"
            >
              <option value="">Choisir un service…</option>
              {data.services.map((s) => (
                <option value={s.id}>{s.titre}</option>
              ))}
              <option value="autre">Autre / Je ne sais pas encore</option>
            </select>
          </div>

          <div>
            <label for="vd-message" class="block mb-1.5 text-xs font-space-grotesk font-medium text-volta-fumee/60 uppercase tracking-[0.18em]">Description</label>
            <textarea
              id="vd-message"
              name="message"
              rows="4"
              placeholder="Décrivez brièvement votre projet ou la panne constatée…"
              class="w-full px-4 py-3 bg-volta-noir border border-volta-fumee/15 focus:border-volta-cyan rounded-sm font-space-grotesk text-sm text-volta-blanc placeholder:text-volta-fumee/30 outline-none transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-3 text-sm font-space-grotesk font-semibold uppercase tracking-[0.18em] rounded-sm bg-volta-cyan text-volta-noir hover:bg-volta-blanc transition-colors"
            style="height: 52px;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24h-.01a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83 8.25 8.25 0 0 1-8.24 8.22z"/>
            </svg>
            Envoyer via WhatsApp
          </button>
        </form>
      </div>
    </div>

  </div>
</section>

<script define:vars={{ waBase }}>
  const form = document.getElementById('volta-devis-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const nom = fd.get('nom') || '';
      const tel = fd.get('telephone') || '';
      const type = fd.get('type') || '';
      const msg = fd.get('message') || '';
      const text = [
        'Bonjour Volta, je souhaite un devis.',
        nom ? `Nom : ${nom}` : '',
        tel ? `Tél : ${tel}` : '',
        type ? `Service : ${type}` : '',
        msg ? `Détails : ${msg}` : '',
      ].filter(Boolean).join('\n');
      window.open(`${waBase}?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
    });
  }
</script>
