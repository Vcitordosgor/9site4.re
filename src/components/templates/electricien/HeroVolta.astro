---
import data from '../../../data/templates/volta.json';
---

<section id="top" class="relative min-h-dvh flex items-center bg-volta-noir overflow-hidden">

  <!-- Photo hero en overlay sombre -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src={data.info.photoHero}
      alt=""
      class="w-full h-full object-cover object-center" loading="eager" fetchpriority="high" decoding="async">
    <div class="absolute inset-0" style="background: linear-gradient(110deg, rgb(15 17 21 / 0.92) 0%, rgb(15 17 21 / 0.75) 55%, rgb(15 17 21 / 0.60) 100%);"></div>
  </div>

  <!-- Ornement circuit : lignes SVG décoratives -->
  <svg
    class="absolute right-0 top-0 h-full w-1/2 opacity-[0.04] hidden lg:block"
    viewBox="0 0 400 800"
    fill="none"
    stroke="#06D4F5"
    stroke-width="1"
    aria-hidden="true"
  >
    <path d="M400 100 H300 V200 H200 V350 H320 V450 H200 V600 H350 V700"/>
    <path d="M400 250 H260 V150 H160 V300 H80 V480 H200 V580 H100 V680"/>
    <path d="M400 400 H280 V500 H180 V620 H300 V720"/>
    <circle cx="300" cy="200" r="4" fill="#06D4F5"/>
    <circle cx="200" cy="350" r="4" fill="#06D4F5"/>
    <circle cx="200" cy="600" r="4" fill="#06D4F5"/>
    <circle cx="260" cy="150" r="3" fill="#06D4F5"/>
    <circle cx="180" cy="500" r="3" fill="#06D4F5"/>
    <circle cx="280" cy="500" r="3" fill="#06D4F5"/>
  </svg>

  <div class="relative max-w-content mx-auto px-6 md:px-10 pt-32 pb-20 md:pt-40 md:pb-28 w-full">
    <div class="max-w-2xl">

      <!-- Badge urgence pulsant -->
      <div class="flex items-center gap-3 mb-8">
        <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-volta-cyan opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-volta-cyan"></span>
        </span>
        <span class="font-space-grotesk text-xs font-semibold uppercase tracking-[0.28em] text-volta-cyan">
          {data.urgence.label} · 7j/7
        </span>
      </div>

      <!-- Titre principal -->
      <h1 class="font-syne font-extrabold text-volta-blanc leading-[1.0]" style="font-size: clamp(42px, 7vw, 88px);">
        L'électricité,<br/>
        <span class="text-volta-cyan">c'est sérieux.</span>
      </h1>

      <!-- Sous-titre -->
      <p class="mt-6 font-space-grotesk text-volta-fumee/75 leading-relaxed max-w-md" style="font-size: clamp(15px, 1.5vw, 18px);">
        {data.info.description}
      </p>

      <!-- Certification badge -->
      <p class="mt-4 font-space-grotesk text-xs text-volta-cyan-fonce tracking-wide">
        <span class="mr-1 text-volta-cuivre">⚡</span>{data.info.certification}
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#devis"
          class="inline-flex items-center justify-center px-8 text-sm font-space-grotesk font-semibold uppercase tracking-[0.18em] rounded-sm bg-volta-cyan text-volta-noir hover:bg-volta-blanc transition-colors"
          style="height: 52px;"
        >
          Demander un devis
        </a>
        <a
          href={`tel:${data.info.telephoneHref}`}
          class="inline-flex items-center gap-2 px-8 text-sm font-space-grotesk font-medium text-volta-fumee border border-volta-fumee/25 hover:border-volta-cyan hover:text-volta-cyan transition-colors rounded-sm"
          style="height: 52px;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
          </svg>
          <span class="tabular-nums">{data.info.telephone}</span>
        </a>
      </div>

    </div>

    <!-- Stats flottantes -->
    <div class="mt-16 md:mt-20 grid grid-cols-3 gap-6 md:gap-10 max-w-lg border-t border-volta-fumee/10 pt-10">
      {[
        { val: '10+', label: 'ans d\'expérience' },
        { val: '7', label: 'communes desservies' },
        { val: '2h', label: 'délai urgence' },
      ].map(({ val, label }) => (
        <div>
          <p class="font-syne font-bold text-volta-cyan" style="font-size: clamp(28px, 3.5vw, 40px);">{val}</p>
          <p class="mt-1 font-space-grotesk text-xs text-volta-fumee/55 uppercase tracking-[0.18em] leading-snug">{label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
