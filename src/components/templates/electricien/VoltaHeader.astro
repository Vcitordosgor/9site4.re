---
import data from '../../../data/templates/volta.json';
---

<header
  id="volta-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-volta-noir/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-volta-cyan/10"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <!-- Wordmark -->
    <a href="#top" class="flex items-center gap-2.5 group" aria-label="Volta — accueil">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-volta-cyan" aria-hidden="true">
        <path d="M13 2L4.5 13.5H11L10 22L20.5 10H14L13 2Z"/>
      </svg>
      <span class="font-syne font-bold text-volta-blanc text-xl tracking-tight group-hover:text-volta-cyan transition-colors">
        {data.info.wordmark}
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navigation principale">
      {[
        { href: '#services', label: 'Services' },
        { href: '#process', label: 'Comment ça marche' },
        { href: '#galerie', label: 'Réalisations' },
        { href: '#avis', label: 'Avis' },
        { href: '#trouver', label: 'Contact' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class="text-sm font-space-grotesk text-volta-fumee/70 hover:text-volta-cyan transition-colors"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA devis -->
    <a
      href="#devis"
      class="hidden md:inline-flex items-center gap-2 h-9 px-5 text-xs font-space-grotesk font-semibold uppercase tracking-[0.18em] rounded-sm bg-volta-cyan text-volta-noir hover:bg-volta-blanc transition-colors"
    >
      Devis gratuit
    </a>

    <!-- Urgence mobile -->
    <a
      href={`tel:${data.info.telephoneHref}`}
      class="md:hidden inline-flex items-center gap-1.5 text-xs font-space-grotesk font-semibold text-volta-cyan"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
      </svg>
      Urgence
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('volta-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
