---
import data from '../../../data/templates/volta.json';
const year = new Date().getFullYear();
---

<footer class="bg-volta-acier text-volta-fumee/75 py-12 px-6 md:px-10 border-t border-volta-cyan/10">
  <div class="max-w-content mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="flex items-center gap-2.5 leading-none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-volta-cyan" aria-hidden="true">
            <path d="M13 2L4.5 13.5H11L10 22L20.5 10H14L13 2Z"/>
          </svg>
          <span class="font-syne font-bold text-volta-blanc text-xl tracking-tight">{data.info.wordmark}</span>
        </p>
        <p class="mt-2 font-space-grotesk text-xs text-volta-fumee/45">
          Saint-André · {data.info.certification}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 text-sm font-space-grotesk">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-volta-cyan transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-flex w-1 h-1 rounded-full bg-volta-cyan/30" aria-hidden="true"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-volta-cyan transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-10 mb-6 h-px" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgb(6 212 245 / 0.25) 30%, rgb(6 212 245 / 0.25) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 text-xs uppercase tracking-[0.25em] text-volta-fumee/40 font-space-grotesk">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="font-semibold text-volta-fumee/70 hover:text-volta-cyan transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
