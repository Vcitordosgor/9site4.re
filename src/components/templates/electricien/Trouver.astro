---
import data from '../../../data/templates/volta.json';
const waUrl = `https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent(
  'Bonjour, je voudrais des informations sur ' + data.info.nom + '.'
)}`;
---

<section id="trouver" class="bg-volta-noir py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center max-w-3xl mx-auto mb-14 md:mb-20">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan">
        <span class="block w-8 h-px bg-volta-cyan/50" aria-hidden="true"></span>
        Nous trouver
        <span class="block w-8 h-px bg-volta-cyan/50" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-4 font-syne font-bold text-volta-blanc leading-[1.05]" style="font-size: clamp(30px, 4.5vw, 50px);">
        Basés à Saint-André,<br/>
        <span class="text-volta-cyan">on intervient dans l'Est.</span>
      </h2>
    </header>

    <div class="grid lg:grid-cols-3 gap-10 lg:gap-14 max-w-5xl mx-auto mb-14">

      <div class="scroll-reveal text-center lg:text-left">
        <p class="text-[10px] font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan mb-3">Adresse</p>
        <p class="font-syne font-semibold text-volta-blanc leading-snug" style="font-size: 18px;">
          {data.info.adresseLigne1}<br/>
          {data.info.adresseLigne2}
        </p>
        <p class="mt-4 text-[10px] uppercase tracking-[0.22em] text-volta-fumee/40 font-space-grotesk">Atelier</p>
        <p class="mt-1 text-sm font-space-grotesk text-volta-fumee/55">Sur RDV uniquement — l'équipe est sur les chantiers.</p>
      </div>

      <div class="scroll-reveal text-center lg:text-left">
        <p class="text-[10px] font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan mb-3">Contact</p>
        <ul class="space-y-3">
          <li>
            <a href={`tel:${data.info.telephoneHref}`} class="font-syne font-semibold text-volta-blanc hover:text-volta-cyan transition-colors tabular-nums" style="font-size: 18px;">
              {data.info.telephone}
            </a>
          </li>
          <li>
            <a href={waUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 font-syne text-volta-blanc hover:text-volta-cyan transition-colors" style="font-size: 16px;">
              WhatsApp
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24h-.01a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83 8.25 8.25 0 0 1-8.24 8.22z"/>
              </svg>
            </a>
          </li>
          <li>
            <a href={`mailto:${data.info.email}`} class="font-space-grotesk text-volta-fumee/60 hover:text-volta-cyan transition-colors break-all" style="font-size: 14px;">
              {data.info.email}
            </a>
          </li>
        </ul>
      </div>

      <div class="scroll-reveal text-center lg:text-left">
        <p class="text-[10px] font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan mb-3">Horaires</p>
        <ul class="divide-y divide-volta-fumee/10">
          {data.horaires.map((h) => (
            <li class="flex items-baseline justify-between gap-4 py-2.5">
              <span class="font-space-grotesk text-volta-blanc text-sm">{h.jour}</span>
              <span class:list={['text-xs tabular-nums font-space-grotesk text-right', h.ouvert ? 'text-volta-fumee/65' : 'italic text-volta-fumee/35']}>
                {h.label}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="bg-volta-acier p-8 md:p-10 max-w-5xl mx-auto border border-volta-fumee/5">
      <p class="scroll-reveal text-[10px] font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan mb-5 text-center">
        {data.zones.length} communes desservies — Est de La Réunion
      </p>
      <ul class="scroll-reveal flex flex-wrap justify-center gap-2">
        {data.zones.map((z) => (
          <li class="inline-flex items-center px-4 h-9 bg-volta-noir border border-volta-cyan/15 hover:border-volta-cyan hover:text-volta-cyan transition-colors text-sm font-space-grotesk text-volta-fumee/70 rounded-sm">
            {z}
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>
