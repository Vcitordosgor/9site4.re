---
import data from '../../../data/templates/volta.json';
---

<section id="process" class="bg-volta-noir py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-20 max-w-2xl">
      <p class="scroll-reveal flex items-center gap-3 text-xs font-space-grotesk font-semibold uppercase tracking-[0.32em] text-volta-cyan">
        <span class="block w-8 h-px bg-volta-cyan/50" aria-hidden="true"></span>
        Comment ça marche
      </p>
      <h2 class="scroll-reveal mt-4 font-syne font-bold text-volta-blanc leading-[1.05]" style="font-size: clamp(32px, 5vw, 56px);">
        Simple, transparent,<br/>
        <span class="text-volta-cyan">sans mauvaises surprises.</span>
      </h2>
    </header>

    <div class="grid md:grid-cols-3 gap-10 md:gap-14">
      {data.etapes.map((e, i) => (
        <div class="scroll-reveal relative">
          {i < data.etapes.length - 1 && (
            <div class="hidden md:block absolute top-6 left-full w-14 h-px bg-volta-cyan/20 -translate-x-7" aria-hidden="true"></div>
          )}

          <p class="font-syne font-extrabold text-volta-cyan/25 mb-4 select-none" style="font-size: clamp(48px, 6vw, 72px); line-height: 1;">
            {e.num}
          </p>

          <h3 class="font-syne font-semibold text-volta-blanc text-lg mb-3">{e.titre}</h3>
          <p class="font-space-grotesk text-sm text-volta-fumee/60 leading-relaxed">{e.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
