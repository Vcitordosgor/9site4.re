---
/**
 * LeChef — portrait + bio + signature.
 * Section unique aux templates : crée un récit autour du chef
 * (n'existe ni dans pizzeria, salon, spa).
 * Layout asymétrique : portrait à gauche (col 5), bio à droite (col 7).
 */
import data from '../../../data/templates/jardin.json';
---

<section id="chef" class="relative bg-resto-bleu-encre text-resto-blanc-casse py-24 md:py-36 px-6 md:px-10 overflow-hidden">

  <!-- Halo or laiton subtle bas -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute bottom-0 right-0 w-[40rem] h-[40rem] rounded-full"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(200 166 94 / 0.10) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative max-w-content mx-auto">

    <!-- Eyebrow + titre -->
    <header class="text-center max-w-2xl mx-auto mb-16 md:mb-20">
      <p class="scroll-reveal font-manrope font-medium text-[11px] uppercase tracking-[0.42em] text-resto-or">
        <span aria-hidden="true">·</span> Le chef <span aria-hidden="true">·</span>
      </p>
      <h2 class="scroll-reveal mt-6 font-bodoni text-resto-blanc-casse leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 64px);">
        Le geste,
        <span class="italic text-resto-or">la mémoire.</span>
      </h2>
    </header>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center max-w-5xl mx-auto">

      <!-- Portrait : verticale 4/5 avec ornement or par-dessus -->
      <figure class="scroll-reveal lg:col-span-5 relative">
        <div class="relative mx-auto max-w-[360px] lg:max-w-none">
          <!-- Filet or décoratif derrière, décalé -->
          <div class="hidden lg:block absolute -top-3 -left-3 right-6 bottom-6 ring-1 ring-resto-or/50 rounded-sm pointer-events-none" aria-hidden="true"></div>

          <div class="relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
            <img
              src={data.info.photoChef}
              alt={data.info.photoChefAlt}
              width="900"
              height="1125"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover grayscale-[0.15]"
              style="box-shadow: 0 24px 64px rgb(0 0 0 / 0.40);"
            />
            <span class="absolute inset-0 ring-1 ring-resto-or/15 pointer-events-none" aria-hidden="true"></span>
          </div>
        </div>
      </figure>

      <!-- Bio + signature -->
      <div class="lg:col-span-7 lg:pl-6">
        <p class="scroll-reveal font-manrope font-medium text-[11px] uppercase tracking-[0.32em] text-resto-or">
          {data.chef.titre}
        </p>
        <h3 class="scroll-reveal mt-3 font-bodoni italic text-resto-blanc-casse leading-tight" style="font-size: clamp(36px, 5vw, 56px);">
          {data.chef.nom}
        </h3>

        <!-- Filet or séparateur -->
        <div class="scroll-reveal mt-6 mb-7 w-12 h-px bg-resto-or" aria-hidden="true"></div>

        <p class="scroll-reveal font-manrope text-resto-blanc-casse/85 leading-[1.85]" style="font-size: 16.5px;">
          {data.chef.bio}
        </p>

        <!-- Citation signature : grand guillemet Bodoni -->
        <blockquote class="scroll-reveal mt-10 relative pl-8 sm:pl-10">
          <span class="absolute left-0 -top-2 font-bodoni text-resto-or" aria-hidden="true" style="font-size: 64px; line-height: 1;">«</span>
          <p class="font-bodoni italic text-resto-blanc-casse leading-[1.5]" style="font-size: clamp(18px, 2vw, 22px);">
            {data.chef.signature}
          </p>
        </blockquote>
      </div>
    </div>
  </div>
</section>
