---
/**
 * RestoHeader — header transparent au top, bleu encre au scroll.
 * Wordmark "Le jardin perdu" en Bodoni italique. CTA réserver bleu roi.
 * Mobile : drawer plein écran fond blanc cassé.
 */
import data from '../../../data/templates/jardin.json';

const navLinks = [
  { href: '#carte',       label: 'La carte' },
  { href: '#chef',        label: 'Le chef' },
  { href: '#cave',        label: 'Cave' },
  { href: '#reservation', label: 'Réserver' },
];
---

<header
  id="resto-header"
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500 ease-out"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">
    <a href="#top" class="flex items-baseline gap-1.5 leading-none transition-colors">
      <span class="font-bodoni italic text-2xl md:text-[26px] text-resto-blanc-casse">{data.info.wordmark1}</span>
      <span class="font-bodoni italic text-2xl md:text-[26px] text-resto-or">{data.info.wordmark2}</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 lg:gap-10" aria-label="Navigation">
      {navLinks.map((l) => (
        <a
          href={l.href}
          class="text-[11px] uppercase tracking-[0.3em] font-manrope font-medium text-resto-blanc-casse/80 hover:text-resto-or transition-colors"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href="#reservation"
      class="hidden md:inline-flex items-center justify-center h-10 px-5 text-[11px] font-semibold uppercase tracking-[0.22em] font-manrope rounded-full bg-resto-or text-resto-bleu-encre hover:bg-resto-blanc-casse transition-colors"
    >
      Réserver une table
    </a>

    <button
      id="resto-menu-toggle"
      type="button"
      data-open="false"
      aria-expanded="false"
      aria-controls="resto-mobile-menu"
      aria-label="Ouvrir le menu"
      class="group md:hidden relative w-10 h-10 -mr-2 flex items-center justify-center"
    >
      <span class="sr-only">Menu</span>
      <span class="relative flex flex-col items-center justify-center gap-1.5 w-6 h-6">
        <span class="block w-6 h-0.5 bg-resto-blanc-casse rounded-full transition-transform duration-300 origin-center group-data-[open=true]:rotate-45 group-data-[open=true]:translate-y-2"></span>
        <span class="block w-6 h-0.5 bg-resto-blanc-casse rounded-full transition-opacity duration-200 group-data-[open=true]:opacity-0"></span>
        <span class="block w-6 h-0.5 bg-resto-blanc-casse rounded-full transition-transform duration-300 origin-center group-data-[open=true]:-rotate-45 group-data-[open=true]:-translate-y-2"></span>
      </span>
    </button>
  </div>
</header>

<!-- Menu mobile plein écran -->
<div
  id="resto-mobile-menu"
  data-open="false"
  aria-hidden="true"
  inert
  class="md:hidden fixed inset-0 top-16 z-40 bg-resto-bleu-encre transition-opacity duration-300 ease-out data-[open=false]:opacity-0 data-[open=false]:pointer-events-none data-[open=true]:opacity-100"
>
  <nav class="h-full flex flex-col px-6 pt-10 pb-10" aria-label="Navigation mobile">
    <ul class="flex-1 flex flex-col gap-2">
      {navLinks.map((l) => (
        <li>
          <a href={l.href} data-resto-link class="block py-4 font-bodoni italic text-resto-blanc-casse hover:text-resto-or transition-colors" style="font-size: 32px;">
            {l.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="pt-6 border-t border-resto-or/20">
      <a
        href="#reservation"
        data-resto-link
        class="inline-flex items-center justify-center w-full h-14 text-sm font-semibold uppercase tracking-[0.22em] font-manrope rounded-full bg-resto-or text-resto-bleu-encre hover:bg-resto-blanc-casse transition-colors"
      >
        Réserver une table
      </a>
    </div>
  </nav>
</div>

<style>
  /* Header transparent au top (sur le hero bleu encre), opaque/blur au scroll */
  #resto-header[data-scrolled='true'] {
    background-color: rgb(19 26 54 / 0.92);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    backdrop-filter: saturate(140%) blur(12px);
    box-shadow: 0 1px 0 rgb(200 166 94 / 0.18);
  }
</style>

<script>
  const header = document.getElementById('resto-header');
  if (header) {
    const update = () => {
      header.dataset.scrolled = String(window.scrollY > 60);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  const toggle = document.getElementById('resto-menu-toggle');
  const menu = document.getElementById('resto-mobile-menu');
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.dataset.open = String(open);
      toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
      menu.dataset.open = String(open);
      menu.setAttribute('aria-hidden', String(!open));
      if (open) menu.removeAttribute('inert');
      else menu.setAttribute('inert', '');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });
    menu.querySelectorAll<HTMLElement>('[data-resto-link]').forEach((el) => {
      el.addEventListener('click', () => setOpen(false));
    });
  }
</script>
