---
/**
 * Ambiance — 3 photos cinématographiques en mosaïque éditoriale.
 * Layout différent du bento spa : ici, séquence horizontale linéaire
 * (3 photos alignées en grille équilibrée) façon planche-contact.
 */
import data from '../../../data/templates/jardin.json';
---

<section id="ambiance" class="relative bg-resto-bleu-encre text-resto-blanc-casse py-24 md:py-36 px-6 md:px-10 overflow-hidden">

  <!-- Eyebrow + titre -->
  <header class="relative text-center max-w-2xl mx-auto mb-14 md:mb-20">
    <p class="scroll-reveal font-manrope font-medium text-[11px] uppercase tracking-[0.42em] text-resto-or">
      <span aria-hidden="true">·</span> L'ambiance <span aria-hidden="true">·</span>
    </p>
    <h2 class="scroll-reveal mt-6 font-bodoni text-resto-blanc-casse leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 64px);">
      L'assiette,
      <span class="italic text-resto-or">le lieu.</span>
    </h2>
  </header>

  <!-- 3 photos en mosaïque éditoriale - 2/1 puis 1 large -->
  <div class="relative max-w-content mx-auto grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 md:gap-5">

    <!-- Photo 1 : dressage gastronomique - col 1 mobile, col 1 desktop -->
    <figure class="scroll-reveal relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
      <img
        src={data.info.photoAmbiance1}
        alt={data.info.photoAmbiance1Alt}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
      />
      <span class="absolute inset-0 ring-1 ring-resto-or/15 pointer-events-none" aria-hidden="true"></span>
    </figure>

    <!-- Photo 2 : terrasse - col 2 mobile, col 2 desktop -->
    <figure class="scroll-reveal relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
      <img
        src={data.info.photoAmbiance2}
        alt={data.info.photoAmbiance2Alt}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
      />
      <span class="absolute inset-0 ring-1 ring-resto-or/15 pointer-events-none" aria-hidden="true"></span>
    </figure>

    <!-- Photo 3 : bar à vins - cols 1-2 mobile (full width), col 3 desktop -->
    <figure class="scroll-reveal col-span-2 lg:col-span-1 relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
      <img
        src={data.info.photoAmbiance3}
        alt={data.info.photoAmbiance3Alt}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
      />
      <span class="absolute inset-0 ring-1 ring-resto-or/15 pointer-events-none" aria-hidden="true"></span>
    </figure>
  </div>
</section>
