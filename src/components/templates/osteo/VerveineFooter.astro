---
import data from '../../../data/templates/verveine.json';
const year = new Date().getFullYear();
---

<footer class="bg-verveine-creme text-verveine-beton py-12 px-6 md:px-10 border-t border-verveine-encre/12">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <!-- Wordmark + praticienne -->
      <div>
        <p class="flex items-baseline gap-2.5">
          <span class="font-cardo text-verveine-encre text-2xl leading-none">{data.info.wordmark}</span>
          <span class="font-karla text-[10px] uppercase tracking-[0.25em] text-verveine-beton">
            D.O.
          </span>
        </p>
        <p class="mt-2 font-cardo italic text-verveine-beton text-sm">
          {data.info.titre} · {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <!-- Contact -->
      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-public-sans text-sm">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-verveine-encre transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-verveine-sauge" aria-hidden="true"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-verveine-encre transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <!-- Filet sauge -->
    <div class="h-px mb-6 bg-gradient-to-r from-transparent via-verveine-sauge/50 to-transparent" aria-hidden="true"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-karla text-[10px] uppercase tracking-[0.25em] text-verveine-beton/65">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret} · ADELI {data.info.adeli}</p>
      <p>
        Site créé par
        <a href="/" class="text-verveine-beton hover:text-verveine-encre transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
