---
import data from '../../../data/templates/verveine.json';
---

<header
  id="verveine-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-verveine-creme/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-verveine-encre/8"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <!-- Wordmark : Cardo serif sobre + label discipline -->
    <a href="#top" class="flex items-baseline gap-2.5 group" aria-label="Cabinet Verveine — accueil">
      <span class="font-cardo text-verveine-encre text-2xl leading-none">{data.info.wordmark}</span>
      <span class="hidden sm:inline-block font-karla text-[10px] uppercase tracking-[0.25em] text-verveine-beton">
        D.O.
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-7 font-public-sans text-[13px] text-verveine-encre/75" aria-label="Navigation">
      <a href="#approche" class="hover:text-verveine-encre transition-colors">Approche</a>
      <a href="#motifs" class="hover:text-verveine-encre transition-colors">Motifs</a>
      <a href="#seance" class="hover:text-verveine-encre transition-colors">La séance</a>
      <a href="#tarifs" class="hover:text-verveine-encre transition-colors">Tarifs</a>
    </nav>

    <!-- CTA discret rectangle bordé -->
    <a
      href="#rendez-vous"
      class="inline-flex items-center h-9 px-4 border border-verveine-encre text-verveine-encre font-public-sans text-[13px] font-medium hover:bg-verveine-encre hover:text-verveine-creme transition-colors duration-300"
    >
      Prendre rendez-vous
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('verveine-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
