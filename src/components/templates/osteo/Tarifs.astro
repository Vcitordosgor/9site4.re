---
/**
 * Tarifs — tableau ligne par ligne, sobre.
 * Format facture / fiche d'honoraires : label + note + prix tabulaire.
 * Aucune card, pas de pricing comparatif. Mention conventions/mutuelles.
 */
import data from '../../../data/templates/verveine.json';
---

<section id="tarifs" class="bg-verveine-creme py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <header class="mb-14 md:mb-16">
      <p class="font-karla text-[10px] uppercase tracking-[0.32em] text-verveine-beton mb-6">
        Honoraires
      </p>
      <h2 class="font-cardo text-verveine-encre leading-[1.1]" style="font-size: clamp(36px, 5vw, 56px);">
        Les tarifs.
      </h2>
    </header>

    <!-- Tableau honoraires -->
    <div class="border-t-2 border-verveine-encre">
      {data.tarifs.map((t, i) => (
        <div class:list={[
          'grid grid-cols-12 gap-4 py-6 items-baseline border-b border-verveine-encre/15',
          i === 0 ? 'pt-7' : '',
        ]}>
          <!-- Label + note -->
          <div class="col-span-9 sm:col-span-8">
            <p class="font-cardo text-verveine-encre text-lg md:text-xl">
              {t.label}
            </p>
            <p class="mt-1 font-cardo italic text-verveine-beton text-sm">
              {t.note}
            </p>
          </div>

          <!-- Prix tabulaire -->
          <div class="col-span-3 sm:col-span-4 text-right">
            <p class="font-cardo text-verveine-encre text-xl md:text-2xl tabular-nums">
              {t.prix}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Mention conventions / mutuelles -->
    <div class="mt-12 p-6 md:p-8 bg-verveine-glacier/40 border-l-2 border-verveine-sauge">
      <p class="font-karla text-[10px] uppercase tracking-[0.25em] text-verveine-beton mb-3">
        Conventions & remboursement
      </p>
      <p class="font-cardo text-verveine-encre/85 text-base md:text-lg leading-[1.75]">
        {data.remboursement}
      </p>
    </div>

  </div>
</section>
