---
/**
 * Motifs — liste à puces minimalistes avec icônes ligne fine.
 * 8 motifs en grid 2x4. PAS de cards, juste du texte aligné, icône SVG
 * stroke 1, séparateurs hairlines. Format index/sommaire.
 */
import data from '../../../data/templates/verveine.json';

const motifIcons: Record<string, string> = {
  lombaire: 'M12 3v18M8 7l4-4 4 4M8 17l4 4 4-4',
  cervical: 'M12 4a4 4 0 0 0-4 4v3M12 4a4 4 0 0 1 4 4v3M5 12h14M7 16l5 4 5-4',
  digestif: 'M6 8q3-3 6 0t6 0v6q-3 3-6 0t-6 0z',
  postpartum: 'M12 12m-7 0a7 7 0 1 0 14 0 7 7 0 1 0-14 0M9 12a3 3 0 1 0 6 0 3 3 0 1 0-6 0',
  sportif: 'M5 7l3-3 8 8-3 3zM12 14l3 3 4-4-3-3M5 17l3-3 3 3-3 3zM12 4l3 3-3 3-3-3z',
  pediatrie: 'M12 2C9 2 7 4 7 6.5S9 11 12 11s5-2 5-4.5S15 2 12 2zM6 20q3-5 6-5t6 5',
  stress: 'M3 12h3l3-7 4 14 3-7h5',
  epaule: 'M4 12a8 8 0 1 0 16 0M9 12a3 3 0 1 0 6 0M12 4v8',
};
---

<section id="motifs" class="bg-verveine-creme py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <!-- Header -->
    <header class="mb-14 md:mb-20 max-w-2xl">
      <p class="font-karla text-[10px] uppercase tracking-[0.32em] text-verveine-beton mb-6">
        Motifs de consultation
      </p>
      <h2 class="font-cardo text-verveine-encre leading-[1.1]" style="font-size: clamp(36px, 5vw, 56px);">
        Pour quelles raisons consulter ?
      </h2>
      <p class="mt-6 font-cardo italic text-verveine-beton text-lg leading-relaxed">
        Cette liste n'est pas exhaustive — en cas de doute, mieux vaut un appel pour vérifier que la consultation est bien indiquée.
      </p>
    </header>

    <!-- Grid de motifs en 2x4 -->
    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-px">
      {data.motifs.map((m, i) => (
        <li class="flex items-start gap-4 py-6 border-t border-verveine-encre/15 group hover:border-verveine-encre/40 transition-colors">

          <!-- Icône SVG ligne fine -->
          <span class="shrink-0 mt-1 w-6 h-6 flex items-center justify-center text-verveine-sauge group-hover:text-verveine-encre transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={motifIcons[m.id] ?? motifIcons.lombaire}/>
            </svg>
          </span>

          <!-- Texte motif -->
          <div class="flex-1">
            <p class="font-karla text-[10px] uppercase tracking-[0.25em] text-verveine-beton mb-1">
              {String(i + 1).padStart(2, '0')}
            </p>
            <p class="font-cardo text-verveine-encre text-base md:text-lg leading-snug">
              {m.label}
            </p>
          </div>
        </li>
      ))}
    </ul>

    <!-- Note légale médicale -->
    <p class="mt-14 font-cardo italic text-verveine-beton text-sm leading-relaxed max-w-2xl">
      L'ostéopathie ne se substitue pas à un avis médical. En présence d'une douleur aiguë inexpliquée, d'une fièvre ou d'un traumatisme important, consultez d'abord votre médecin traitant ou un service d'urgences.
    </p>
  </div>
</section>
