---
/**
 * Approche — 3 paragraphes courts type article scientifique vulgarisé.
 * Layout 2 colonnes : titre éditorial à gauche, paragraphes à droite avec
 * H3 en sans + corps en serif Cardo. Pas de cards.
 */
import data from '../../../data/templates/verveine.json';
---

<section id="approche" class="bg-verveine-papier py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">

      <!-- Colonne gauche : titre + intro -->
      <div class="lg:col-span-5">
        <p class="font-karla text-[10px] uppercase tracking-[0.32em] text-verveine-beton mb-6">
          L'approche
        </p>
        <h2 class="font-cardo text-verveine-encre leading-[1.1]" style="font-size: clamp(36px, 5vw, 60px);">
          Comprendre,<br/>
          puis traiter.
        </h2>
        <p class="mt-8 font-cardo italic text-verveine-beton text-lg md:text-xl leading-[1.7] max-w-md">
          {data.approche.intro}
        </p>
      </div>

      <!-- Colonne droite : 3 paragraphes -->
      <div class="lg:col-span-7 lg:pt-3 space-y-12">
        {data.approche.paragraphes.map((p, i) => (
          <article class="border-t border-verveine-encre/15 pt-7">
            <p class="font-karla text-[10px] uppercase tracking-[0.28em] text-verveine-sauge mb-3">
              § {String(i + 1).padStart(2, '0')}
            </p>
            <h3 class="font-public-sans text-verveine-encre text-xl md:text-2xl font-medium mb-4">
              {p.titre}
            </h3>
            <p class="font-cardo text-verveine-encre/85 text-base md:text-lg leading-[1.85]">
              {p.texte}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
