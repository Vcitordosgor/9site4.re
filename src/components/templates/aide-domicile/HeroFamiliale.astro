---
/**
 * HeroFamiliale — grande photo chaleureuse aide + personne âgée.
 * Sticker agrément en haut. Annotation Homemade Apple.
 */
import data from '../../../data/templates/doudou.json';
---

<section id="top" class="relative bg-doudou-creme overflow-hidden">

  <!-- Forme arrondie en arrière-plan ciel -->
  <div class="absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full bg-doudou-ciel/30 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-40 -left-32 w-[600px] h-[600px] rounded-full bg-doudou-soleil/30 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-content mx-auto px-6 md:px-10 pt-32 pb-20 md:pt-40 md:pb-28 grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">

    <!-- Texte gauche -->
    <div class="lg:col-span-6">

      <!-- Sticker agrément -->
      <p class="inline-flex items-center gap-2 font-be-vietnam text-[11px] uppercase tracking-wider font-semibold text-doudou-bourgeon mb-6 bg-doudou-bourgeon/10 px-3 py-1.5 rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-doudou-bourgeon"></span>
        ✓ {data.info.agrement}
      </p>

      <h1 class="font-nunito font-bold text-doudou-encre leading-[1.05] tracking-tight" style="font-size: clamp(40px, 7vw, 96px);">
        Une présence quotidienne,<br/>
        <span class="text-doudou-bleu">à La Réunion.</span>
      </h1>

      <!-- Annotation manuscrite Homemade Apple -->
      <p class="mt-6 font-homemade text-doudou-rose text-2xl md:text-3xl rotate-[-1deg] leading-none">
        depuis {data.info.annee}, on prend soin
      </p>

      <p class="mt-6 font-be-vietnam text-doudou-encre/85 text-base md:text-lg leading-relaxed max-w-xl">
        Aide à domicile pour personnes âgées, handicapées et en sortie d'hospitalisation. Aidants diplômés et formés, pris en charge APA / PCH / crédit d'impôt 50 %.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="#demande"
          class="inline-flex items-center justify-center h-13 px-8 bg-doudou-bleu text-doudou-creme font-be-vietnam font-semibold text-base rounded-full hover:bg-doudou-rose transition-colors"
          style="height: 52px;"
        >
          Visite à domicile gratuite ♡
        </a>
        <a
          href={`tel:${data.info.telephoneHref}`}
          class="font-be-vietnam font-semibold text-doudou-bleu text-base underline underline-offset-4 decoration-2 decoration-doudou-rose tabular-nums"
        >
          {data.info.telephone}
        </a>
      </div>
    </div>

    <!-- Composition graphique : pas de portrait stock, scène évoquée par
         dégradés doux + stickers manuscrits + ornements floraux. -->
    <div class="lg:col-span-6">
      <div class="relative aspect-[4/5] max-w-md mx-auto rounded-3xl overflow-hidden flex items-center justify-center" role="img" aria-label="Maguy, aidante, en visite chez Mme R., 87 ans">
        <!-- Dégradé chaleureux ciel → soleil → rose -->
        <div class="absolute inset-0" style="background: linear-gradient(155deg, #C9DBE7 0%, #F8E9C4 45%, #F2C5B5 100%);" aria-hidden="true"></div>
        <!-- Mini soleil radial en haut-droite -->
        <div class="absolute top-8 right-8 w-16 h-16 rounded-full" style="background: radial-gradient(circle, #FCD34D 0%, transparent 70%);" aria-hidden="true"></div>
        <!-- Pictogramme maison ♡ stylisée au centre -->
        <svg class="relative w-24 h-24 text-doudou-rose/85" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
          <!-- Maison toit + corps -->
          <path d="M50 18 L18 46 L26 46 L26 78 L74 78 L74 46 L82 46 Z" opacity="0.85"/>
          <!-- Cœur dans la maison -->
          <path d="M50 60 C 42 52 32 56 32 64 C 32 70 42 76 50 76 C 58 76 68 70 68 64 C 68 56 58 52 50 60 Z" fill="#FEFEFA" opacity="0.9"/>
        </svg>
        <!-- Petites annotations Homemade autour -->
        <p class="absolute top-[35%] left-[12%] font-homemade text-doudou-bleu text-lg rotate-[-6deg] opacity-75" aria-hidden="true">tisane ♡</p>
        <p class="absolute bottom-[30%] right-[14%] font-homemade text-doudou-bourgeon text-base rotate-[5deg] opacity-75" aria-hidden="true">les fleurs</p>

        <!-- Sticker prénom (conservé) -->
        <div class="absolute top-4 left-4 bg-doudou-creme/95 px-4 py-2.5 rounded-full shadow-sm">
          <p class="font-homemade text-doudou-rose text-2xl leading-none">Maguy &</p>
          <p class="font-be-vietnam text-doudou-encre text-sm font-medium leading-tight mt-0.5">
            Mme R., 87 ans
          </p>
        </div>
        <!-- Sticker rose pâle bas (conservé) -->
        <div class="absolute bottom-6 right-6 bg-doudou-rose text-doudou-creme px-4 py-3 rounded-2xl rotate-[3deg] shadow-sm">
          <p class="font-homemade text-2xl leading-none">7 jours / 7</p>
          <p class="font-be-vietnam text-[10px] uppercase tracking-wider mt-1 opacity-90">07h – 22h</p>
        </div>
      </div>
    </div>

    <!-- Bandeau de réassurance financière : signal métier aide à domicile -->
    <div class="lg:col-span-12 mt-6 md:mt-10 grid sm:grid-cols-2 gap-3 sm:gap-4 rounded-3xl bg-doudou-ciel/30 ring-1 ring-doudou-ciel/60 p-5 md:p-6">
      <div class="flex items-start gap-3">
        <span class="flex w-10 h-10 rounded-full bg-doudou-rose/30 text-doudou-rose items-center justify-center shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 21s-7-4.5-7-11a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 6.5-7 11-7 11h-4z"/>
          </svg>
        </span>
        <div>
          <p class="font-nunito font-bold text-doudou-encre uppercase tracking-wide text-sm">
            Crédit d'impôt 50 %
          </p>
          <p class="mt-0.5 font-be-vietnam text-doudou-encre/75 text-sm leading-snug">
            Vous récupérez la moitié de ce que vous payez.
          </p>
        </div>
      </div>
      <div class="flex items-start gap-3 sm:border-l sm:border-doudou-encre/15 sm:pl-4">
        <span class="flex w-10 h-10 rounded-full bg-doudou-soleil/40 text-doudou-bourgeon items-center justify-center shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 21s-7-4.5-7-11a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 6.5-7 11-7 11h-4z"/>
          </svg>
        </span>
        <div>
          <p class="font-nunito font-bold text-doudou-encre uppercase tracking-wide text-sm">
            APA / PCH
          </p>
          <p class="mt-0.5 font-be-vietnam text-doudou-encre/75 text-sm leading-snug">
            Prise en charge intégrale selon votre dossier.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
