---
import data from '../../../data/templates/doudou.json';
---

<section id="services" class="bg-doudou-creme py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-16 max-w-2xl">
      <p class="font-homemade text-doudou-rose text-3xl mb-3 leading-none">
        ce qu'on fait
      </p>
      <h2 class="font-nunito font-bold text-doudou-encre leading-[1.1]" style="font-size: clamp(32px, 5vw, 56px);">
        Nos services,<br/>
        <span class="text-doudou-bleu">au quotidien.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {data.services.map((s, i) => (
        <li class="bg-doudou-soleil/30 p-6 rounded-3xl border-2 border-transparent hover:border-doudou-bleu transition-colors">
          <span class="inline-flex items-center justify-center w-10 h-10 bg-doudou-bleu text-doudou-creme rounded-full font-nunito font-bold text-sm mb-4 tabular-nums">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="font-nunito font-bold text-doudou-encre text-xl leading-tight mb-3">
            {s.titre}
          </h3>
          <p class="font-be-vietnam text-doudou-encre/75 text-sm leading-relaxed">
            {s.texte}
          </p>
        </li>
      ))}
    </ul>

    <p class="mt-10 text-center font-homemade text-doudou-rose text-2xl leading-none">
      ↓ et beaucoup d'écoute en plus ↓
    </p>
  </div>
</section>
