---
import data from '../../../data/templates/doudou.json';

const icons: Record<string, string> = {
  maison: 'M3 12L12 3l9 9M5 10v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V10',
  coeur: 'M21 8.5c0 5.5-9 11.5-9 11.5s-9-6-9-11.5C3 5.5 5.5 3 8.5 3a4.5 4.5 0 0 1 3.5 1.7A4.5 4.5 0 0 1 15.5 3C18.5 3 21 5.5 21 8.5z',
  diplome: 'M22 10v6M2 10l10-5 10 5-10 5-10-5zM6 12v5c3 3 9 3 12 0v-5',
  main: 'M9 11V6a2 2 0 1 1 4 0v5M5 11v3a7 7 0 0 0 14 0v-2M9 11h6',
};
---

<section id="engagements" class="bg-doudou-ciel/40 py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-16 max-w-2xl mx-auto">
      <p class="font-homemade text-doudou-rose text-3xl md:text-4xl mb-3 leading-none rotate-[-1deg]">
        nos engagements
      </p>
      <h2 class="font-nunito font-bold text-doudou-encre leading-[1.1]" style="font-size: clamp(32px, 5vw, 56px);">
        Quatre choses qui<br/>
        <span class="text-doudou-bleu">comptent vraiment pour nous.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {data.engagements.map((e) => (
        <li class="bg-doudou-creme p-7 rounded-3xl text-center group hover:bg-doudou-blanc transition-colors">

          <!-- Icône SVG dans cercle ciel -->
          <span class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-doudou-bleu text-doudou-creme mb-5 group-hover:bg-doudou-rose transition-colors">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icons[e.icone] ?? icons.coeur}/>
            </svg>
          </span>

          <h3 class="font-nunito font-bold text-doudou-encre text-xl mb-3">
            {e.titre}
          </h3>

          <p class="font-be-vietnam text-doudou-encre/75 text-sm leading-relaxed">
            {e.texte}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
