---
import data from '../../../data/templates/doudou.json';
---

<section class="bg-doudou-creme py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-16 max-w-2xl mx-auto">
      <p class="font-homemade text-doudou-rose text-3xl mb-3 leading-none rotate-[-1deg]">
        merci à eux
      </p>
      <h2 class="font-nunito font-bold text-doudou-encre leading-[1.1]" style="font-size: clamp(32px, 5vw, 56px);">
        Ce que les familles<br/>
        <span class="text-doudou-bleu">nous ont écrit.</span>
      </h2>
    </header>

    <ul class="grid lg:grid-cols-3 gap-5">
      {data.temoignages.map((t, i) => (
        <li class:list={[
          'p-7 md:p-8 rounded-3xl',
          i === 0 ? 'bg-doudou-rose/15' : i === 1 ? 'bg-doudou-soleil/30' : 'bg-doudou-ciel/40',
        ]}>

          <!-- Coeur -->
          <p class="font-homemade text-doudou-rose text-3xl mb-5 leading-none">
            ♡
          </p>

          <!-- Citation longue -->
          <blockquote class="font-be-vietnam text-doudou-encre/85 text-[15px] leading-[1.85] mb-6">
            « {t.texte} »
          </blockquote>

          <!-- Auteur -->
          <footer class="pt-5 border-t border-doudou-encre/15">
            <p class="font-nunito font-bold text-doudou-bleu text-base">
              — {t.auteur}
            </p>
            <p class="mt-1 font-be-vietnam text-[11px] uppercase tracking-wider text-doudou-encre/55">
              {t.lieu}
            </p>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>
