---
import data from '../../../data/templates/doudou.json';
---

<section id="aidants" class="bg-doudou-ciel/40 py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-16 max-w-2xl mx-auto">
      <p class="font-homemade text-doudou-rose text-3xl mb-3 leading-none">
        notre équipe
      </p>
      <h2 class="font-nunito font-bold text-doudou-encre leading-[1.1]" style="font-size: clamp(32px, 5vw, 56px);">
        Quatre aidants,<br/>
        <span class="text-doudou-bleu">une même attention.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {data.aidants.map((a) => (
        <li>
          <article class="bg-doudou-creme p-6 rounded-3xl text-center group hover:bg-doudou-blanc transition-colors h-full flex flex-col">

            <!-- Photo ronde grande -->
            <div class="relative w-32 h-32 mx-auto mb-5 rounded-full overflow-hidden ring-4 ring-doudou-rose/40 group-hover:ring-doudou-rose transition-all">
              <img
                src={a.photo}
                alt={`Portrait de ${a.prenom}`}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>

            <p class="font-homemade text-doudou-bleu text-3xl leading-none mb-1">
              {a.prenom}
            </p>
            <p class="font-be-vietnam text-[10px] uppercase tracking-[0.18em] font-semibold text-doudou-rose mb-3">
              ✓ {a.diplome} · {a.experience}
            </p>

            <p class="font-be-vietnam text-doudou-encre/85 text-sm leading-relaxed mt-auto pt-4 border-t border-doudou-encre/10">
              {a.specialite}
            </p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>
