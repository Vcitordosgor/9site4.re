---
import data from '../../../data/templates/doudou.json';
---

<section class="bg-doudou-rose/15 py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-16 max-w-2xl mx-auto">
      <p class="font-homemade text-doudou-bleu text-3xl mb-3 leading-none rotate-[1deg]">
        on accompagne
      </p>
      <h2 class="font-nunito font-bold text-doudou-encre leading-[1.1]" style="font-size: clamp(32px, 5vw, 56px);">
        À qui nous<br/>
        <span class="text-doudou-rose">nous adressons.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {data.publics.map((p, i) => (
        <li class="bg-doudou-creme p-6 rounded-3xl">
          <span class="font-homemade text-doudou-rose text-3xl leading-none mb-4 inline-block">
            {String(i + 1).padStart(2, '0')}.
          </span>
          <h3 class="font-nunito font-bold text-doudou-encre text-lg leading-tight mb-3">
            {p.titre}
          </h3>
          <p class="font-be-vietnam text-doudou-encre/75 text-sm leading-relaxed">
            {p.texte}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
