---
/**
 * Pourquoi — 4 piliers en grille 2x2 ou 4 cols, avec icônes SVG fines.
 * Style éditorial sobre — pas de cards lourdes.
 */
import data from '../../../data/templates/salon.json';

const icons: Record<string, string> = {
  // Stéthoscope (diagnostic)
  stethoscope: '<path d="M11 2v2"/><path d="M5 2v2"/><path d="M5 3H4a2 2 0 0 0-2 2v4a6 6 0 0 0 12 0V5a2 2 0 0 0-2-2h-1"/><path d="M8 15a6 6 0 0 0 12 0v-3"/><circle cx="20" cy="10" r="2"/>',
  // Conversation (conseils)
  chat: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  // Feuille (produits)
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  // Maison (atelier)
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
};
---

<section id="pourquoi" class="relative bg-salon-blanc py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <!-- Header de section -->
    <header class="text-center max-w-2xl mx-auto mb-16">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-salon-cuivre">
        <span class="inline-block w-8 h-px bg-salon-cuivre" aria-hidden="true"></span>
        <span>Pourquoi nous choisir</span>
        <span class="inline-block w-8 h-px bg-salon-cuivre" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-playfair font-bold text-salon-encre leading-tight" style="font-size: clamp(36px, 4.5vw, 56px);">
        Le temps, le geste,
        <span class="italic font-medium text-salon-cuivre">la confiance.</span>
      </h2>
    </header>

    <!-- 4 piliers — sobres, sans card -->
    <ul class="grid md:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12 max-w-6xl mx-auto">
      {data.pourquoi.map((p, i) => (
        <li class="scroll-reveal text-center md:text-left" style={`transition-delay: ${i * 80}ms`}>
          <!-- Icône SVG fine en cercle laiton -->
          <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-salon-cuivre/10 text-salon-cuivre ring-1 ring-salon-cuivre/20">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[p.icon] || icons.home} />
          </span>

          <h3 class="mt-6 font-playfair font-semibold text-xl text-salon-encre leading-snug">
            {p.titre}
          </h3>
          <p class="mt-3 text-sm text-salon-encre/70 leading-[1.7]">
            {p.description}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
