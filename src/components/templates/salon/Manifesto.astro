---
/**
 * Manifesto — citation Playfair italique grande, fond blanc.
 * Filets dorés haut/bas pour cadrer la phrase.
 */
import data from '../../../data/templates/salon.json';
---

<section class="relative bg-salon-blanc py-20 md:py-32 px-6 md:px-10 border-y border-salon-laiton/30">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Filet doré supérieur -->
    <div class="scroll-reveal mx-auto w-12 h-px bg-salon-laiton mb-10" aria-hidden="true"></div>

    <blockquote class="scroll-reveal">
      <p class="font-playfair italic text-salon-encre leading-[1.3]" style="font-size: clamp(28px, 3.8vw, 44px);">
        « {data.manifesto} »
      </p>
    </blockquote>

    <!-- Filet doré inférieur -->
    <div class="scroll-reveal mx-auto w-12 h-px bg-salon-laiton mt-10" aria-hidden="true"></div>
  </div>
</section>
