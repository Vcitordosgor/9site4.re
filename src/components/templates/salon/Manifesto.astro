---
/**
 * Manifesto — citation Fraunces italique grande, fond gris très clair.
 * Filets verts haut/bas pour cadrer la phrase.
 */
import data from '../../../data/templates/salon.json';
---

<section class="relative bg-salon-gris py-20 md:py-32 px-6 md:px-10 border-y border-salon-vert-clair/20">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Filet vert supérieur -->
    <div class="scroll-reveal mx-auto w-12 h-px bg-salon-vert-clair mb-10" aria-hidden="true"></div>

    <blockquote class="scroll-reveal">
      <p class="font-fraunces italic text-salon-noir leading-[1.3]" style="font-size: clamp(26px, 4vw, 44px);">
        « {data.manifesto} »
      </p>
    </blockquote>

    <!-- Filet vert inférieur -->
    <div class="scroll-reveal mx-auto w-12 h-px bg-salon-vert-clair mt-10" aria-hidden="true"></div>
  </div>
</section>
