---
/**
 * RendezVous — wrapper de la section "Prise de rendez-vous".
 * Charge le formulaire en Astro Island Preact (interactivité côté client).
 * Le formulaire ouvre WhatsApp pré-rempli avec le récapitulatif (cf RdvForm.tsx).
 */
import data from '../../../data/templates/salon.json';
import RdvForm from './RdvForm.tsx';
---

<section id="rendez-vous" class="relative bg-salon-blanc py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">
    <header class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-salon-vert">
        <span class="inline-block w-8 h-px bg-salon-vert" aria-hidden="true"></span>
        <span>Prendre rendez-vous</span>
        <span class="inline-block w-8 h-px bg-salon-vert" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-fraunces font-bold text-salon-noir leading-tight" style="font-size: clamp(32px, 5vw, 56px);">
        Réservez votre créneau
        <span class="block italic font-medium text-salon-vert">en quelques minutes.</span>
      </h2>
      <p class="scroll-reveal mt-5 text-salon-noir/70 leading-relaxed">
        Réponse à votre demande sous 24h ouvrées. Diagnostic offert avant le rendez-vous.
      </p>
    </header>

    <div class="scroll-reveal">
      <RdvForm
        client:load
        prestations={data.prestations}
        longueurs={data.longueurs}
        creneaux={data.creneaux}
        whatsapp={data.info.whatsapp}
        salonNom={data.info.nom}
      />
    </div>
  </div>
</section>
