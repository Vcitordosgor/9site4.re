---
/**
 * RendezVous — wrapper de la section "Prise de rendez-vous".
 * Charge le formulaire en Astro Island Preact (interactivité côté client).
 */
import data from '../../../data/templates/salon.json';
import RdvForm from './RdvForm.tsx';
---

<section id="rendez-vous" class="relative bg-salon-creme py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">
    <header class="text-center max-w-2xl mx-auto mb-14">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-salon-cuivre">
        <span class="inline-block w-8 h-px bg-salon-cuivre" aria-hidden="true"></span>
        <span>Prendre rendez-vous</span>
        <span class="inline-block w-8 h-px bg-salon-cuivre" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-playfair font-bold text-salon-encre leading-tight" style="font-size: clamp(36px, 4.5vw, 56px);">
        Réservez votre créneau
        <span class="block italic font-medium text-salon-cuivre">en quelques minutes.</span>
      </h2>
      <p class="scroll-reveal mt-5 text-salon-encre/70 leading-relaxed">
        Réponse à votre demande sous 24h ouvrées. Diagnostic offert avant le rendez-vous.
      </p>
    </header>

    <div class="scroll-reveal">
      <RdvForm
        client:load
        prestations={data.prestations}
        longueurs={data.longueurs}
        creneaux={data.creneaux}
      />
    </div>
  </div>
</section>
