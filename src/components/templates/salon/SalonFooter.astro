---
import data from '../../../data/templates/salon.json';
const year = new Date().getFullYear();
---

<footer class="bg-salon-noir text-salon-blanc/85 py-12 px-6 md:px-10 border-t border-salon-vert-clair/20">
  <div class="max-w-content mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="flex items-baseline gap-2 leading-none">
          <span class="font-dm-sans font-medium uppercase tracking-[0.25em] text-sm text-salon-blanc/85">{data.info.wordmark1}</span>
          <span class="font-fraunces italic font-bold text-2xl text-salon-vert-clair">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-fraunces italic text-salon-blanc/65 text-sm">
          Saint-Gilles-les-Bains · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 text-sm">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-salon-vert-clair transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-flex w-1 h-1 rounded-full bg-salon-vert-clair/50" aria-hidden="true"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-salon-vert-clair transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <!-- Filet vert séparateur -->
    <div class="mt-10 mb-6 h-px" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgb(92 122 102 / 0.5) 30%, rgb(92 122 102 / 0.5) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 text-xs uppercase tracking-[0.18em] text-salon-blanc/70">
      <p>© {year} {data.info.nom}</p>
      <p>
        Site créé par
        <a href="/" class="font-semibold text-salon-blanc hover:text-salon-vert-clair transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
