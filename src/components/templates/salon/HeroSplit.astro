---
/**
 * HeroSplit — mobile-first.
 * Mobile : photo en haut compacte (4:5 max ~280px), puis texte centré, CTA full-width.
 * Desktop : split-screen 60% texte / 40% photo en colonnes côte à côte.
 */
import data from '../../../data/templates/salon.json';
---

<section class="relative bg-salon-blanc pt-24 sm:pt-28 lg:pt-36 pb-16 md:pb-24 lg:pb-32 px-6 md:px-10 overflow-hidden">
  <!-- Filet vert décoratif vertical (desktop only) -->
  <div class="hidden lg:block absolute left-1/2 top-32 bottom-32 w-px bg-salon-vert-clair/30" aria-hidden="true"></div>

  <div class="max-w-content mx-auto grid lg:grid-cols-12 gap-8 sm:gap-10 lg:gap-16 items-center">

    <!-- Photo : 1er sur mobile, 2e (droite) sur desktop -->
    <figure class="hero-photo order-1 lg:order-2 lg:col-span-5 relative">
      <div class="relative mx-auto max-w-[260px] sm:max-w-[340px] lg:max-w-none">
        <!-- Filet vert décoratif derrière (desktop only) -->
        <div class="hidden lg:block absolute -top-4 -left-4 right-8 bottom-8 ring-1 ring-salon-vert-clair/40 rounded-sm pointer-events-none" aria-hidden="true"></div>

        <div class="relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
          <img
            src={data.info.photoHero}
            alt={data.info.photoHeroAlt}
            width="900"
            height="1125"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="absolute inset-0 w-full h-full object-cover"
            style="box-shadow: 0 16px 48px rgb(10 10 10 / 0.18);"
          />
        </div>
      </div>
    </figure>

    <!-- Texte : 2e sur mobile, 1er sur desktop -->
    <div class="order-2 lg:order-1 lg:col-span-7 text-center lg:text-left">
      <p class="hero-eyebrow flex items-center justify-center lg:justify-start gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-salon-vert">
        <span class="inline-block w-10 h-px bg-salon-vert" aria-hidden="true"></span>
        <span>Salon · Saint-Gilles</span>
      </p>

      <h1 class="hero-title mt-5 sm:mt-6 font-fraunces font-bold text-salon-noir leading-[1.0]" style="font-size: clamp(40px, 7vw, 88px);">
        {data.info.tagline}
        <span class="block italic font-semibold text-salon-vert mt-1 sm:mt-2">
          {data.info.taglineItalic}
        </span>
      </h1>

      <p class="hero-intro mt-5 sm:mt-7 text-salon-noir/75 leading-[1.7] max-w-xl mx-auto lg:mx-0" style="font-size: 17px;">
        {data.info.intro}
      </p>

      <div class="hero-cta mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 sm:justify-center lg:justify-start">
        <a
          href="#rendez-vous"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-semibold uppercase tracking-[0.2em] rounded-full bg-salon-vert text-salon-blanc hover:bg-[#1F3328] transition-all"
          style="box-shadow: 0 8px 24px rgb(45 74 58 / 0.3);"
        >
          Prendre rendez-vous
        </a>
        <a
          href="#prestations"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-semibold uppercase tracking-[0.2em] rounded-full bg-transparent text-salon-noir ring-1 ring-salon-noir/30 hover:ring-salon-noir transition-all"
        >
          Voir les prestations
        </a>
      </div>

      <!-- Tags d'info -->
      <ul class="hero-tags mt-8 sm:mt-10 flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-2 text-sm text-salon-noir/65">
        {data.info.tags.map((tag, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && <span class="hidden sm:inline-block w-1 h-1 rounded-full bg-salon-vert-clair" aria-hidden="true"></span>}
            <span>{tag}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  /* Animations d'entrée — apparition éditoriale en cascade */
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-photo-in {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }
  .hero-eyebrow { animation: hero-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 100ms; }
  .hero-title   { animation: hero-rise 900ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 250ms; }
  .hero-intro   { animation: hero-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 500ms; }
  .hero-cta     { animation: hero-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 700ms; }
  .hero-tags    { animation: hero-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 850ms; }
  .hero-photo   { animation: hero-photo-in 1000ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 350ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-title, .hero-intro, .hero-cta, .hero-tags, .hero-photo {
      animation: none !important;
      opacity: 1;
      transform: none !important;
    }
  }
</style>
