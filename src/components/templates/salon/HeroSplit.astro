---
/**
 * HeroSplit — split-screen 60% texte / 40% portrait.
 * Fond crème lumineux, photo verticale 4:5 en cadre arrondi avec ombre douce.
 */
import data from '../../../data/templates/salon.json';
---

<section class="relative bg-salon-creme pt-32 md:pt-36 pb-20 md:pb-32 px-6 md:px-10 overflow-hidden">
  <!-- Filet doré décoratif vertical (desktop) -->
  <div class="hidden lg:block absolute left-1/2 top-32 bottom-32 w-px bg-salon-laiton/30" aria-hidden="true"></div>

  <div class="max-w-content mx-auto grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

    <!-- Colonne texte — 60% (7/12) -->
    <div class="lg:col-span-7">
      <p class="hero-eyebrow flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-salon-cuivre">
        <span class="inline-block w-10 h-px bg-salon-cuivre" aria-hidden="true"></span>
        <span>Salon · Saint-Gilles</span>
      </p>

      <h1 class="hero-title mt-6 font-playfair font-bold text-salon-encre leading-[1.0]" style="font-size: clamp(48px, 6.5vw, 88px);">
        {data.info.tagline}
        <span class="block italic font-semibold text-salon-cuivre mt-2">
          {data.info.taglineItalic}
        </span>
      </h1>

      <p class="hero-intro mt-7 text-salon-encre/75 leading-[1.7] max-w-xl" style="font-size: 18px;">
        {data.info.intro}
      </p>

      <div class="hero-cta mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a
          href="#rendez-vous"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-semibold uppercase tracking-[0.2em] rounded-full bg-salon-cuivre text-salon-blanc hover:bg-[#974D34] transition-all"
          style="box-shadow: 0 8px 24px rgb(181 105 77 / 0.3);"
        >
          Prendre rendez-vous
        </a>
        <a
          href="#prestations"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-semibold uppercase tracking-[0.2em] rounded-full bg-transparent text-salon-encre ring-1 ring-salon-encre/30 hover:ring-salon-encre transition-all"
        >
          Voir les prestations
        </a>
      </div>

      <!-- Tags d'info — petites informations utiles -->
      <ul class="hero-tags mt-10 flex flex-wrap gap-x-6 gap-y-2 text-sm text-salon-encre/65">
        {data.info.tags.map((tag, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && <span class="hidden sm:inline-block w-1 h-1 rounded-full bg-salon-laiton" aria-hidden="true"></span>}
            <span>{tag}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Colonne photo — 40% (5/12) — verticale 4:5 portrait -->
    <figure class="hero-photo lg:col-span-5 relative">
      <div class="relative mx-auto max-w-[420px] lg:max-w-none">
        <!-- Filet doré décoratif derrière (desktop) -->
        <div class="hidden lg:block absolute -top-4 -left-4 right-8 bottom-8 ring-1 ring-salon-laiton/40 rounded-sm pointer-events-none" aria-hidden="true"></div>

        <div class="relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
          <img
            src={data.info.photoHero}
            alt={data.info.photoHeroAlt}
            width="900"
            height="1125"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="absolute inset-0 w-full h-full object-cover"
            style="box-shadow: 0 24px 64px rgb(42 37 32 / 0.18);"
          />
        </div>
      </div>
    </figure>

  </div>
</section>

<style>
  /* Animations d'entrée — apparition éditoriale en cascade */
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-photo-in {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }
  .hero-eyebrow { animation: hero-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 100ms; }
  .hero-title   { animation: hero-rise 900ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 250ms; }
  .hero-intro   { animation: hero-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 500ms; }
  .hero-cta     { animation: hero-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 700ms; }
  .hero-tags    { animation: hero-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 850ms; }
  .hero-photo   { animation: hero-photo-in 1000ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 350ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-title, .hero-intro, .hero-cta, .hero-tags, .hero-photo {
      animation: none !important;
      opacity: 1;
      transform: none !important;
    }
  }
</style>
