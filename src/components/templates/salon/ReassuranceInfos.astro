---
/**
 * ReassuranceInfos — section combinée :
 * - Gauche : 4 blocs de réassurance générique (sans faux témoignages)
 * - Droite : adresse, horaires, téléphone, WhatsApp
 */
import data from '../../../data/templates/salon.json';
const waUrl = `https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent(
  'Bonjour, je voudrais prendre rendez-vous chez ' + data.info.nom + '.'
)}`;
---

<section id="trouver" class="relative bg-salon-gris py-20 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-salon-vert">
        <span class="inline-block w-8 h-px bg-salon-vert" aria-hidden="true"></span>
        <span>Trouver le salon</span>
        <span class="inline-block w-8 h-px bg-salon-vert" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-fraunces font-bold text-salon-noir leading-tight" style="font-size: clamp(32px, 5vw, 56px);">
        À Saint-Gilles,
        <span class="italic font-medium text-salon-vert">à 5 minutes de la plage.</span>
      </h2>
    </header>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">

      <!-- Colonne gauche : 4 blocs de réassurance (5 cols) -->
      <div class="lg:col-span-5">
        <p class="scroll-reveal text-xs font-semibold uppercase tracking-[0.25em] text-salon-vert mb-6">Nos engagements</p>
        <ul class="space-y-6">
          {data.reassurance.map((r, i) => (
            <li class="scroll-reveal flex items-start gap-4" style={`transition-delay: ${i * 60}ms`}>
              <span class="flex-shrink-0 mt-1 inline-flex items-center justify-center w-8 h-8 rounded-full bg-salon-vert/10 text-salon-vert">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
              </span>
              <div>
                <h3 class="font-fraunces font-semibold text-lg text-salon-noir">{r.titre}</h3>
                <p class="mt-1 text-sm text-salon-noir/70 leading-relaxed">{r.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Colonne droite : infos pratiques (7 cols) -->
      <div class="lg:col-span-7 space-y-10">

        <!-- Photo intérieur salon -->
        <figure class="scroll-reveal">
          <div class="relative overflow-hidden rounded-sm" style="aspect-ratio: 16/10;">
            <img
              src={data.info.photoSalon}
              alt={data.info.photoSalonAlt}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover"
            />
          </div>
        </figure>

        <!-- Adresse + horaires + contact -->
        <div class="grid sm:grid-cols-2 gap-8">
          <div class="scroll-reveal">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-salon-vert mb-3">Adresse</p>
            <p class="font-fraunces text-salon-noir leading-snug" style="font-size: 18px;">
              {data.info.adresse}
            </p>
            <p class="mt-4 text-xs uppercase tracking-[0.18em] text-salon-noir/55">Accès</p>
            <p class="mt-1 text-sm text-salon-noir/75">Parking gratuit · 5 min à pied de la plage des Roches Noires.</p>
          </div>

          <div class="scroll-reveal">
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-salon-vert mb-3">Contact direct</p>
            <ul class="space-y-2">
              <li>
                <a href={`tel:${data.info.telephoneHref}`} class="font-fraunces text-salon-noir hover:text-salon-vert transition-colors tabular-nums" style="font-size: 18px;">
                  {data.info.telephone}
                </a>
              </li>
              <li>
                <a href={waUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 font-fraunces text-salon-noir hover:text-salon-vert transition-colors" style="font-size: 18px;">
                  WhatsApp
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24h-.01a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83 8.25 8.25 0 0 1-8.24 8.22z"/>
                  </svg>
                </a>
              </li>
              <li>
                <a href={`mailto:${data.info.email}`} class="font-fraunces text-salon-noir hover:text-salon-vert transition-colors break-all" style="font-size: 16px;">
                  {data.info.email}
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Horaires -->
        <div class="scroll-reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-salon-vert mb-4">Horaires d'ouverture</p>
          <ul class="divide-y divide-salon-noir/10">
            {data.info.horaires.map((h) => (
              <li class="flex items-baseline justify-between py-2.5">
                <span class="font-fraunces text-salon-noir">{h.jour}</span>
                <span class:list={['text-sm tabular-nums', h.ouvert ? 'text-salon-noir/75' : 'italic text-salon-noir/45']}>
                  {h.label}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
