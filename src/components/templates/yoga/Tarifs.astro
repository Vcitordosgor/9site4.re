---
/**
 * Tarifs — présentation linéaire façon "menu de restaurant".
 * Liste verticale avec dotted leaders entre le label et le prix.
 * Pas de pricing cards modernes : un menu serif élégant.
 */
import data from '../../../data/templates/souffle.json';
---

<section id="tarifs" class="bg-yoga-papier py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-2xl mx-auto">

    <!-- Header -->
    <header class="text-center mb-16 md:mb-20">
      <p class="font-lexend text-[10px] uppercase tracking-[0.4em] text-yoga-pierre mb-6">
        Tarifs
      </p>
      <h2 class="font-dm-serif text-yoga-encre leading-[1.1]" style="font-size: clamp(36px, 5.5vw, 56px);">
        Simple.
        <span class="italic font-spectral font-light text-yoga-ocre">Sans abonnement piégé.</span>
      </h2>
    </header>

    <!-- Liste menu -->
    <ul class="space-y-6">
      {data.tarifs.map((t) => (
        <li class="group flex items-baseline gap-4">
          <!-- Label + détail -->
          <div class="shrink-0">
            <p class="font-dm-serif text-yoga-encre text-xl md:text-2xl leading-tight">
              {t.label}
            </p>
            <p class="mt-1 font-spectral italic text-yoga-encre/55 text-sm">
              {t.detail}
            </p>
          </div>

          <!-- Dotted leader (extensible) -->
          <span class="flex-1 mt-2 border-b border-dotted border-yoga-encre/30" aria-hidden="true"></span>

          <!-- Prix -->
          <p class="shrink-0 font-dm-serif text-yoga-encre text-xl md:text-2xl tabular-nums">
            {t.prix}
          </p>
        </li>
      ))}
    </ul>

    <!-- Note de bas de menu -->
    <p class="mt-16 text-center font-spectral italic text-yoga-encre/60 text-base leading-relaxed">
      Les carnets sont nominatifs et transmissibles en famille.<br/>
      Le pass mensuel est mensualisé sans engagement de durée.
    </p>

    <!-- CTA discret -->
    <div class="mt-12 text-center">
      <a
        href="#reservation"
        class="inline-flex items-center justify-center h-12 px-8 bg-yoga-encre text-yoga-creme font-lexend text-[12px] uppercase tracking-[0.18em] font-light hover:bg-yoga-ocre transition-colors duration-500"
      >
        Réserver un cours
      </a>
    </div>

  </div>
</section>
