---
/**
 * CTAFinal — clôture poétique très épurée.
 * Une seule phrase serif italique sur crème, beaucoup d'air.
 * Aucune pression commerciale : juste une invitation.
 */
import data from '../../../data/templates/souffle.json';
---

<section class="bg-yoga-creme py-32 md:py-44 px-6 md:px-10 text-center">
  <div class="max-w-2xl mx-auto">

    <!-- Petit ornement linéaire ocre -->
    <div class="flex items-center justify-center gap-3 mb-12" aria-hidden="true">
      <span class="block h-px w-12 bg-yoga-ocre/40"></span>
      <span class="block w-1.5 h-1.5 rounded-full bg-yoga-ocre"></span>
      <span class="block h-px w-12 bg-yoga-ocre/40"></span>
    </div>

    <h2 class="font-dm-serif italic text-yoga-encre leading-[1.05]" style="font-size: clamp(40px, 6.5vw, 80px);">
      Vous êtes
      <span class="block">attendu·e.</span>
    </h2>

    <p class="mt-10 font-spectral text-yoga-encre/70 leading-relaxed max-w-md mx-auto text-base md:text-lg">
      Pas besoin d'avoir déjà pratiqué. Pas besoin d'être souple, ni calme.
      <span class="italic">Venez tel·le que vous êtes.</span>
    </p>

    <a
      href="#reservation"
      class="mt-14 inline-flex items-center justify-center h-14 px-10 bg-yoga-encre text-yoga-creme font-lexend text-[12px] uppercase tracking-[0.18em] font-light hover:bg-yoga-ocre transition-colors duration-500"
    >
      Réserver mon cours d'essai
    </a>

    <p class="mt-8 font-spectral italic text-yoga-encre/55 text-sm">
      {data.info.wordmark} {data.info.wordmark2} · {data.info.ville} · depuis {data.info.annee}
    </p>

  </div>
</section>
