---
import data from '../../../data/templates/motorpiton.json';
---

<footer class="bg-piton-asphalte text-piton-beton border-t border-piton-fonte/40 relative">
  <!-- Caution tape top -->
  <div class="absolute top-0 inset-x-0 h-1.5" aria-hidden="true"
       style="background: repeating-linear-gradient(45deg, #FF5A1F 0 12px, #0F1014 12px 24px);"></div>

  <div class="max-w-content mx-auto px-6 md:px-10 py-14 md:py-16">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <div class="md:col-span-5">
        <div class="flex items-center gap-3">
          <svg viewBox="0 0 32 32" class="w-9 h-9 text-piton-feu" aria-hidden="true">
            <rect x="10" y="3" width="12" height="14" rx="1" fill="currentColor"/>
            <rect x="9" y="14" width="14" height="2.5" fill="#0F1014"/>
            <rect x="11" y="20" width="10" height="3" fill="currentColor"/>
            <rect x="14" y="22" width="4" height="7" fill="currentColor"/>
          </svg>
          <span class="font-bebas text-piton-blanc text-3xl tracking-[0.05em]">MOTOR<span class="text-piton-feu">PITON</span></span>
        </div>
        <p class="mt-5 font-inter-tight text-piton-beton/75 text-[14px] leading-relaxed max-w-sm">
          {data.info.tagline} — Garage mécanique multimarque au Tampon depuis {data.info.annee}.
        </p>
      </div>

      <div class="md:col-span-3">
        <p class="font-jetbrains text-[10px] uppercase tracking-[0.25em] text-piton-feu mb-3">Atelier</p>
        <ul class="space-y-2 font-jetbrains text-[12.5px]">
          <li><a href="#interventions" class="hover:text-piton-feu transition-colors">Interventions</a></li>
          <li><a href="#equipe" class="hover:text-piton-feu transition-colors">Équipe</a></li>
          <li><a href="#engagements" class="hover:text-piton-feu transition-colors">Engagements</a></li>
          <li><a href="#contact" class="hover:text-piton-feu transition-colors">Devis 24h</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="font-jetbrains text-[10px] uppercase tracking-[0.25em] text-piton-feu mb-3">Contact</p>
        <ul class="space-y-2 font-jetbrains text-[12.5px]">
          <li>{data.info.adresseLigne1}</li>
          <li>{data.info.adresseLigne2}</li>
          <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-piton-feu transition-colors">{data.info.telephone}</a></li>
          <li><a href={`mailto:${data.info.email}`} class="hover:text-piton-feu transition-colors">{data.info.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-piton-fonte/40 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-jetbrains text-[10.5px] uppercase tracking-[0.15em] text-piton-beton/60">
      <p>© {data.info.annee}–2026 {data.info.nom} · SIRET {data.info.siret}</p>
      <p class="text-piton-feu font-bebas text-base tracking-[0.08em]">▸ MÉCANIQUE HONNÊTE, DEVIS SANS DÉTOUR ▸</p>
    </div>
  </div>
</footer>
