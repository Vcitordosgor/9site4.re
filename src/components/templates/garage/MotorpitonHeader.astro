---
import data from '../../../data/templates/motorpiton.json';

const navLinks = [
  { href: '#interventions', label: 'Interventions' },
  { href: '#equipe', label: 'Équipe' },
  { href: '#engagements', label: 'Engagements' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  id="piton-header"
  data-scrolled="false"
  class="sticky top-0 z-50 bg-piton-asphalte border-b border-piton-fonte/40 transition-shadow duration-300"
>
  <!-- Bandeau urgence top -->
  <div class="bg-piton-feu text-piton-asphalte font-jetbrains text-[11px] uppercase tracking-[0.18em] py-1 px-6 text-center font-semibold">
    ▸ Dépannage atelier · {data.info.horaires}
  </div>

  <div class="max-w-content mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">
    <a href="#top" class="flex items-center gap-3" aria-label="Atelier Motorpiton — accueil">
      <!-- Picto piston SVG -->
      <svg viewBox="0 0 32 32" class="w-9 h-9 text-piton-feu" aria-hidden="true">
        <rect x="10" y="3" width="12" height="14" rx="1" fill="currentColor"/>
        <rect x="9" y="14" width="14" height="2.5" fill="#0F1014"/>
        <rect x="9" y="17.5" width="14" height="1.5" fill="#0F1014"/>
        <rect x="11" y="20" width="10" height="3" rx="0.5" fill="currentColor"/>
        <rect x="14" y="22" width="4" height="7" fill="currentColor"/>
      </svg>
      <div class="flex flex-col leading-none">
        <span class="font-bebas text-piton-blanc text-2xl md:text-[26px] tracking-[0.05em]">{data.info.wordmark1}<span class="text-piton-feu">{data.info.wordmark2}</span></span>
        <span class="font-jetbrains text-piton-fonte text-[9px] uppercase tracking-[0.25em] mt-0.5">Atelier · Le Tampon</span>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-7 lg:gap-9 font-jetbrains text-[12px] uppercase tracking-[0.16em] font-medium" aria-label="Navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="text-piton-beton/85 hover:text-piton-feu transition-colors duration-200">
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="hidden md:inline-flex items-center justify-center h-10 px-5 bg-piton-feu text-piton-asphalte font-bebas text-base tracking-[0.08em] hover:bg-piton-feu-fonce transition-colors"
    >
      Devis · {data.info.telephone}
    </a>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="md:hidden inline-flex items-center justify-center h-10 px-4 bg-piton-feu text-piton-asphalte font-bebas text-base tracking-wider"
      aria-label="Appeler"
    >
      Appeler
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('piton-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 8); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>

<style>
  #piton-header[data-scrolled='true'] {
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.4);
  }
</style>
