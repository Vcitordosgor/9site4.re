---
import data from '../../../data/templates/motorpiton.json';
---

<section id="interventions" class="bg-piton-acier text-piton-beton py-20 md:py-28 relative overflow-hidden">

  <div class="max-w-content mx-auto px-6 md:px-10">

    <div class="max-w-2xl mb-12 md:mb-16">
      <p class="font-jetbrains text-[11px] uppercase tracking-[0.4em] text-piton-feu mb-4">▸ Catalogue interventions</p>
      <h2 class="font-bebas text-piton-blanc text-5xl md:text-7xl leading-[0.9] tracking-[0.02em]">
        SIX INTERVENTIONS<br/>
        <span class="text-piton-feu">RÉCURRENTES.</span>
      </h2>
      <p class="mt-5 font-inter-tight text-piton-beton/75 text-[15px] leading-relaxed">
        Tarifs publiés à partir de. Devis ferme remis avant chaque intervention. Pas de prix planqué.
      </p>
    </div>

    <ul class="space-y-3 md:space-y-4">
      {data.interventions.map((i) => (
        <li class="bg-piton-asphalte border-l-4 border-piton-feu p-5 md:p-7 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 hover:bg-piton-fonte/40 transition-colors">

          <!-- Code intervention -->
          <div class="md:col-span-2 flex md:flex-col items-baseline md:items-start gap-3 md:gap-1.5">
            <p class="font-jetbrains text-[10px] uppercase tracking-[0.18em] text-piton-feu">Code</p>
            <p class="font-jetbrains text-piton-blanc text-base md:text-lg tabular-nums">{i.code}</p>
          </div>

          <!-- Texte central -->
          <div class="md:col-span-7">
            <h3 class="font-bebas text-piton-blanc text-2xl md:text-3xl leading-tight tracking-[0.04em]">
              {i.titre}
            </h3>
            <p class="font-inter-tight italic text-piton-feu text-[14px] mt-1">
              « {i.tagline} »
            </p>
            <p class="mt-3 font-inter-tight text-piton-beton/85 text-[14px] leading-relaxed">
              {i.description}
            </p>

            <div class="mt-3 flex flex-wrap gap-2">
              {i.outils.map((o) => (
                <span class="inline-flex items-center px-2 py-0.5 bg-piton-fonte/60 border border-piton-fonte text-piton-beton font-jetbrains text-[10px] uppercase tracking-wider">
                  {o}
                </span>
              ))}
            </div>
            <p class="mt-2 font-jetbrains text-[10.5px] uppercase tracking-[0.15em] text-piton-beton/55">
              ▸ {i.marques}
            </p>
          </div>

          <!-- Prix + durée + CTA -->
          <div class="md:col-span-3 flex flex-row md:flex-col items-end md:items-end gap-4 md:gap-3 justify-between md:text-right border-t md:border-t-0 md:border-l border-piton-fonte/40 pt-4 md:pt-0 md:pl-5">
            <div>
              <p class="font-jetbrains text-[10px] uppercase tracking-[0.18em] text-piton-feu">Tarif</p>
              <p class="font-bebas text-piton-blanc text-3xl md:text-4xl leading-none mt-0.5">{i.prix}</p>
              <p class="font-jetbrains text-[10px] tabular-nums text-piton-beton/65 mt-1">⏱ {i.duree}</p>
            </div>
            <a
              href={`https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent(`Bonjour, je voudrais un devis pour : ${i.titre} (${i.code}).`)}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center h-11 px-4 bg-piton-feu text-piton-asphalte font-bebas tracking-[0.06em] hover:bg-piton-feu-fonce transition-colors whitespace-nowrap"
            >
              Devis ▸
            </a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
