---
import data from '../../../data/templates/cap-anglais.json';
---

<header
  id="cap-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-cap-papier/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-cap-charbon/12"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <!-- Wordmark : pictogramme épingle topo + nom -->
    <a href="#top" class="flex items-center gap-2 group" aria-label="Le Cap Anglais — accueil">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="text-cap-rouge" aria-hidden="true">
        <path d="M12 2L4 8l8 14 8-14-8-6z"/>
        <circle cx="12" cy="9" r="2.5" fill="currentColor"/>
      </svg>
      <span class="font-bricolage font-semibold text-cap-charbon text-base leading-none group-hover:text-cap-mousse transition-colors">
        {data.info.wordmark}
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-7 font-bricolage text-[13px] text-cap-charbon/75" aria-label="Navigation">
      <a href="#fiche" class="hover:text-cap-mousse transition-colors">Le gîte</a>
      <a href="#chambres" class="hover:text-cap-mousse transition-colors">Chambres</a>
      <a href="#calendrier" class="hover:text-cap-mousse transition-colors">Disponibilités</a>
      <a href="#alentours" class="hover:text-cap-mousse transition-colors">Randonnées</a>
      <a href="#tarifs" class="hover:text-cap-mousse transition-colors">Tarifs</a>
    </nav>

    <!-- CTA mousse -->
    <a
      href="#reservation"
      class="inline-flex items-center h-9 px-4 bg-cap-mousse text-cap-papier font-bricolage text-[13px] font-semibold hover:bg-cap-charbon transition-colors"
    >
      Réserver
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('cap-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
