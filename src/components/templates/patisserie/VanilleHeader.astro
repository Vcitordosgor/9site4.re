---
import data from '../../../data/templates/vanille.json';

const navLinks = [
  { href: '#specialites', label: 'Spécialités' },
  { href: '#saisons', label: 'Saisons' },
  { href: '#patissiere', label: 'Stéphanie' },
  { href: '#commandes', label: 'Commandes' },
];
---

<header
  id="vanille-header"
  data-scrolled="false"
  class="sticky top-0 z-50 transition-[background-color,backdrop-filter,box-shadow] duration-500 border-b border-vanille-gousse/10"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">

    <a href="#top" class="flex items-center gap-2 group" aria-label="La Vanille de Bel-Air — accueil">
      <!-- Picto gousse -->
      <svg viewBox="0 0 32 32" class="w-7 h-7 text-vanille-caramel" aria-hidden="true">
        <path d="M6 24 Q12 14 22 8 Q24 7 25 9 Q24 12 18 18 Q12 24 8 26 Q5 27 6 24 Z" fill="currentColor" />
        <circle cx="14" cy="18" r="0.8" fill="#FBF3E2" />
        <circle cx="17" cy="14" r="0.8" fill="#FBF3E2" />
        <circle cx="20" cy="11" r="0.8" fill="#FBF3E2" />
      </svg>
      <div class="flex flex-col leading-none">
        <span class="font-yeseva text-vanille-gousse text-lg md:text-xl">La Vanille</span>
        <span class="font-yeseva text-vanille-caramel text-[11px] md:text-xs italic -mt-0.5">de Bel-Air</span>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-7 lg:gap-9 font-karla text-[12.5px] uppercase tracking-[0.15em] font-medium" aria-label="Navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="text-vanille-gousse hover:text-vanille-caramel transition-colors duration-300">
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="hidden md:inline-flex items-center justify-center h-10 px-5 bg-vanille-gousse text-vanille-creme font-karla font-semibold text-[12px] uppercase tracking-[0.16em] rounded-full hover:bg-vanille-caramel transition-colors duration-300"
    >
      Commander
    </a>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="md:hidden inline-flex items-center justify-center h-10 px-4 bg-vanille-gousse text-vanille-creme font-karla font-semibold text-[12px] uppercase tracking-wider rounded-full"
      aria-label="Appeler"
    >
      Appeler
    </a>
  </div>
</header>

<style>
  #vanille-header {
    background-color: rgb(251 243 226 / 0.96);
  }
  #vanille-header[data-scrolled='true'] {
    background-color: rgb(251 243 226 / 0.97);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    box-shadow: 0 1px 3px rgb(92 58 30 / 0.08);
  }
</style>

<script>
  const header = document.getElementById('vanille-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 8); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
