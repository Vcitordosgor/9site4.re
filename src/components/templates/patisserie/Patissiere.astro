---
import data from '../../../data/templates/vanille.json';
---

<section id="patissiere" class="bg-vanille-grain py-20 md:py-28 relative overflow-hidden">
  <!-- Texture -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04]" aria-hidden="true">
    <filter id="grain-pat"><feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="2"/></filter>
    <rect width="100%" height="100%" filter="url(#grain-pat)"/>
  </svg>

  <div class="max-w-content mx-auto px-6 md:px-10 relative">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-center">

      <!-- Portrait Stéphanie -->
      <div class="md:col-span-5">
        <div class="relative aspect-[4/5] overflow-hidden border-[3px] border-double border-vanille-caramel">
          <img
            src="https://plus.unsplash.com/premium_photo-1661630495688-c0e75d70cdc6?q=80&w=900&auto=format&fit=crop"
            alt={`Portrait de ${data.patissiere.nom}, pâtissière`}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute top-5 left-1/2 -translate-x-1/2 font-karla text-[10px] uppercase tracking-[0.3em] text-vanille-creme bg-vanille-grain/70 px-3 py-1">— La Pâtissière —</div>
          <div class="absolute bottom-5 left-1/2 -translate-x-1/2 text-center bg-vanille-grain/70 px-4 py-2">
            <p class="font-yeseva text-vanille-creme text-2xl leading-tight">Stéphanie</p>
            <p class="font-karla text-[10px] uppercase tracking-[0.2em] text-vanille-caramel mt-1">Saint-André · {data.info.annee}</p>
          </div>
        </div>
      </div>

      <!-- Texte -->
      <div class="md:col-span-7">
        <p class="font-karla text-[11px] uppercase tracking-[0.4em] text-vanille-caramel mb-4">— Portrait —</p>
        <h2 class="font-yeseva text-vanille-creme text-4xl md:text-5xl leading-tight">
          {data.patissiere.nom}
        </h2>
        <p class="font-italianno text-vanille-caramel text-3xl md:text-4xl mt-2 leading-none">
          {data.patissiere.titre}
        </p>

        <p class="mt-7 font-karla text-[15px] md:text-base text-vanille-creme/85 leading-relaxed">
          {data.patissiere.bio}
        </p>

        <blockquote class="mt-7 border-l-2 border-vanille-caramel pl-5 font-yeseva italic text-xl md:text-2xl text-vanille-creme leading-snug">
          {data.patissiere.credo}
        </blockquote>

        <!-- Diplômes -->
        <div class="mt-8 pt-6 border-t border-vanille-caramel/30 grid grid-cols-2 gap-3">
          {data.patissiere.certif.map((c) => (
            <div class="flex gap-2 items-start">
              <span class="text-vanille-caramel mt-1" aria-hidden="true">✦</span>
              <span class="font-karla text-[12.5px] text-vanille-creme/85 leading-snug">{c}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
