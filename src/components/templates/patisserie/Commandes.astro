---
import data from '../../../data/templates/vanille.json';
---

<section id="commandes" class="bg-vanille-creme py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">

    <div class="text-center max-w-2xl mx-auto mb-14 md:mb-20">
      <p class="font-karla text-[11px] uppercase tracking-[0.4em] text-vanille-caramel mb-4">— Comment commander —</p>
      <h2 class="font-yeseva text-vanille-gousse text-4xl md:text-5xl leading-tight">
        Quatre manières
        <em class="font-italianno text-vanille-caramel text-5xl md:text-6xl not-italic">de se faire plaisir</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
      {data.commandes.map((c) => (
        <article class="bg-vanille-blanc border border-vanille-gousse/25 p-7 md:p-8 relative flex flex-col">
          <div class="flex items-baseline gap-4 mb-4">
            <span class="font-yeseva text-vanille-caramel text-5xl md:text-6xl leading-none">{c.etape}</span>
            <h3 class="font-yeseva text-vanille-gousse text-xl md:text-2xl leading-tight">{c.titre}</h3>
          </div>
          <p class="font-karla text-[14.5px] text-vanille-gousse/85 leading-relaxed">{c.texte}</p>
        </article>
      ))}
    </div>
  </div>
</section>
