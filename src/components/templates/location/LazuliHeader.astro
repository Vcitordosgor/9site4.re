---
import data from '../../../data/templates/lazuli.json';
---

<header
  id="lazuli-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-500 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-lazuli-casse/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-lazuli-marine/10"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <a href="#top" class="flex items-baseline gap-2 group" aria-label="Villa Lazuli — accueil">
      <span class="font-italianno text-lazuli-lagon text-3xl leading-none">Villa</span>
      <span class="font-yeseva text-lazuli-marine text-xl leading-none tracking-wide group-hover:text-lazuli-lagon transition-colors">{data.info.wordmark}</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 font-geist text-[13px] text-lazuli-marine/75" aria-label="Navigation">
      <a href="#visite" class="hover:text-lazuli-lagon transition-colors">Visite</a>
      <a href="#equipements" class="hover:text-lazuli-lagon transition-colors">Équipements</a>
      <a href="#tarifs" class="hover:text-lazuli-lagon transition-colors">Tarifs</a>
      <a href="#avis" class="hover:text-lazuli-lagon transition-colors">Avis</a>
    </nav>

    <a
      href="#reservation"
      class="inline-flex items-center h-9 px-5 bg-lazuli-terracotta text-lazuli-casse font-geist text-[13px] font-medium rounded-full hover:bg-lazuli-marine transition-colors"
    >
      Réserver
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('lazuli-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
