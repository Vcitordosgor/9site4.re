---
/**
 * Reservation — Wizard Villa Lazuli 4 étapes best-in-class.
 * 1. Dates (arrivée + départ + durée live)
 * 2. Voyageurs (compteurs adultes/enfants/bébés)
 * 3. Préférences (équipements, occasion spéciale)
 * 4. Coordonnées
 * Sidebar récap "Votre séjour" avec PRIX LIVE selon saison
 * (basse 180€ / moyenne 220€ / haute 320€ / très haute 450€).
 */
import data from '../../../data/templates/lazuli.json';
const waBase = `https://wa.me/${data.info.whatsapp}`;
---

<section id="reservation" class="bg-lazuli-casse py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-12 max-w-2xl mx-auto">
      <p class="font-geist text-[10px] uppercase tracking-[0.32em] text-lazuli-terracotta font-semibold mb-5">
        ✦ Réserver la villa
      </p>
      <h2 class="font-yeseva text-lazuli-marine leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Votre séjour à
        <span class="font-italianno text-lazuli-lagon normal-case"> Lazuli.</span>
      </h2>
      <p class="mt-4 font-geist text-lazuli-marine/70 text-base">
        4 questions, prix calculé automatiquement selon la saison.
      </p>
    </header>

    <div class="grid lg:grid-cols-12 gap-8 items-start">

      <!-- LEFT : Wizard -->
      <div class="lg:col-span-8">
        <form id="l-form" class="bg-lazuli-marine text-lazuli-casse p-7 md:p-10" novalidate>

          <p class="font-italianno text-lazuli-coco text-3xl mb-2 leading-none">
            Demande de réservation
          </p>

          <!-- Progress -->
          <div class="mb-7">
            <div class="flex items-center justify-between mb-2">
              <p class="font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco font-semibold">
                Étape <span id="l-step-current" class="text-lazuli-terracotta tabular-nums">1</span>/4
              </p>
              <p id="l-step-label" class="font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco">Vos dates</p>
            </div>
            <div class="h-[2px] bg-lazuli-casse/15 overflow-hidden">
              <div id="l-progress" class="h-full bg-lazuli-terracotta transition-all duration-500" style="width: 25%;"></div>
            </div>
          </div>

          <!-- ÉTAPE 1 : Dates -->
          <fieldset class="l-step" data-step="1">
            <legend class="font-yeseva text-lazuli-casse text-xl md:text-2xl mb-5 leading-tight">
              Quand venez-vous ?
            </legend>
            <div class="grid sm:grid-cols-2 gap-4 mb-3">
              <div>
                <label for="l-arrivee" class="block font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco mb-2 font-semibold">Arrivée</label>
                <input id="l-arrivee" name="arrivee" type="date" required
                  class="w-full h-12 px-4 bg-lazuli-marine border border-lazuli-casse/25 focus:border-lazuli-coco font-geist text-lazuli-casse text-base outline-none transition-colors tabular-nums" />
              </div>
              <div>
                <label for="l-depart" class="block font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco mb-2 font-semibold">Départ</label>
                <input id="l-depart" name="depart" type="date" required
                  class="w-full h-12 px-4 bg-lazuli-marine border border-lazuli-casse/25 focus:border-lazuli-coco font-geist text-lazuli-casse text-base outline-none transition-colors tabular-nums" />
              </div>
            </div>

            <div id="l-saison-info" class="hidden p-4 bg-lazuli-coco/10 border-l-2 border-lazuli-coco rounded-r">
              <p class="font-geist text-[10px] uppercase tracking-[0.22em] text-lazuli-coco mb-1 font-semibold">▸ Période détectée</p>
              <p class="font-italianno text-lazuli-coco text-2xl leading-none mb-1">
                <span id="l-saison-name">—</span>
              </p>
              <p class="font-geist text-lazuli-casse/85 text-sm">
                <span id="l-nuits-count" class="font-bold tabular-nums">0</span> nuit(s) · <span id="l-prix-nuit" class="tabular-nums">—</span>/nuit
              </p>
              <p id="l-min-nuits" class="hidden mt-1 font-geist text-lazuli-terracotta text-xs">⚠ Minimum requis pour cette période : <span id="l-min-nuits-val">3</span> nuits</p>
            </div>
          </fieldset>

          <!-- ÉTAPE 2 : Voyageurs -->
          <fieldset class="l-step hidden" data-step="2">
            <legend class="font-yeseva text-lazuli-casse text-xl md:text-2xl mb-5 leading-tight">
              Combien êtes-vous ?
            </legend>

            <div class="space-y-3">
              <div class="flex items-center justify-between gap-4 p-4 bg-lazuli-marine/40 border border-lazuli-casse/15">
                <div>
                  <p class="font-yeseva text-lazuli-casse text-lg">Adultes</p>
                  <p class="font-italianno italic text-lazuli-coco/85 text-base">12 ans et +</p>
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" data-l-counter="adultes" data-action="dec"
                    class="w-9 h-9 flex items-center justify-center bg-lazuli-marine border border-lazuli-casse/30 hover:border-lazuli-coco text-lazuli-casse font-yeseva text-lg cursor-pointer">−</button>
                  <span id="l-c-adultes" class="font-yeseva text-lazuli-casse w-8 text-center tabular-nums text-lg">2</span>
                  <button type="button" data-l-counter="adultes" data-action="inc"
                    class="w-9 h-9 flex items-center justify-center bg-lazuli-coco text-lazuli-marine font-yeseva text-lg cursor-pointer">+</button>
                </div>
              </div>

              <div class="flex items-center justify-between gap-4 p-4 bg-lazuli-marine/40 border border-lazuli-casse/15">
                <div>
                  <p class="font-yeseva text-lazuli-casse text-lg">Enfants</p>
                  <p class="font-italianno italic text-lazuli-coco/85 text-base">3-11 ans</p>
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" data-l-counter="enfants" data-action="dec"
                    class="w-9 h-9 flex items-center justify-center bg-lazuli-marine border border-lazuli-casse/30 hover:border-lazuli-coco text-lazuli-casse font-yeseva text-lg cursor-pointer">−</button>
                  <span id="l-c-enfants" class="font-yeseva text-lazuli-casse w-8 text-center tabular-nums text-lg">0</span>
                  <button type="button" data-l-counter="enfants" data-action="inc"
                    class="w-9 h-9 flex items-center justify-center bg-lazuli-coco text-lazuli-marine font-yeseva text-lg cursor-pointer">+</button>
                </div>
              </div>

              <div class="flex items-center justify-between gap-4 p-4 bg-lazuli-marine/40 border border-lazuli-casse/15">
                <div>
                  <p class="font-yeseva text-lazuli-casse text-lg">Bébés</p>
                  <p class="font-italianno italic text-lazuli-coco/85 text-base">moins de 3 ans · gratuit</p>
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" data-l-counter="bebes" data-action="dec"
                    class="w-9 h-9 flex items-center justify-center bg-lazuli-marine border border-lazuli-casse/30 hover:border-lazuli-coco text-lazuli-casse font-yeseva text-lg cursor-pointer">−</button>
                  <span id="l-c-bebes" class="font-yeseva text-lazuli-casse w-8 text-center tabular-nums text-lg">0</span>
                  <button type="button" data-l-counter="bebes" data-action="inc"
                    class="w-9 h-9 flex items-center justify-center bg-lazuli-coco text-lazuli-marine font-yeseva text-lg cursor-pointer">+</button>
                </div>
              </div>
            </div>

            <p class="mt-4 font-italianno italic text-lazuli-coco/85 text-base">
              Capacité max : 8 voyageurs (hors bébés).
            </p>
          </fieldset>

          <!-- ÉTAPE 3 : Préférences -->
          <fieldset class="l-step hidden" data-step="3">
            <legend class="font-yeseva text-lazuli-casse text-xl md:text-2xl mb-5 leading-tight">
              Quelques préférences ?
            </legend>

            <p class="font-geist text-[10px] uppercase tracking-[0.22em] text-lazuli-coco mb-3 font-semibold">Occasion spéciale</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {[
                'Aucune', 'Voyage en couple', 'Famille', 'Anniversaire', 'Lune de miel', 'Entre amis', 'Télétravail'
              ].map((o, i) => (
                <label class="cursor-pointer">
                  <input type="radio" name="occasion" value={o} class="peer sr-only" checked={i === 0} />
                  <span class="inline-flex items-center px-4 h-11 sm:h-10 bg-lazuli-marine/40 border border-lazuli-casse/15 peer-checked:border-lazuli-coco peer-checked:bg-lazuli-coco/10 font-geist text-lazuli-casse text-sm transition-colors">
                    {o}
                  </span>
                </label>
              ))}
            </div>

            <p class="font-geist text-[10px] uppercase tracking-[0.22em] text-lazuli-coco mb-3 font-semibold">Options à la carte</p>
            <div class="space-y-2">
              <label class="cursor-pointer block">
                <input type="checkbox" name="menage_hebdo" class="peer sr-only" />
                <span class="flex items-baseline gap-3 p-3 bg-lazuli-marine/40 border border-lazuli-casse/15 peer-checked:border-lazuli-coco peer-checked:bg-lazuli-coco/10 transition-all">
                  <span class="flex-1 font-geist text-lazuli-casse text-sm">Ménage hebdomadaire</span>
                  <span class="font-yeseva text-lazuli-coco tabular-nums text-base shrink-0">+ 80 €</span>
                </span>
              </label>
              <label class="cursor-pointer block">
                <input type="checkbox" name="petitdej" class="peer sr-only" />
                <span class="flex items-baseline gap-3 p-3 bg-lazuli-marine/40 border border-lazuli-casse/15 peer-checked:border-lazuli-coco peer-checked:bg-lazuli-coco/10 transition-all">
                  <span class="flex-1 font-geist text-lazuli-casse text-sm">Petit-déjeuner livré</span>
                  <span class="font-yeseva text-lazuli-coco tabular-nums text-base shrink-0">+ 12 €/pers</span>
                </span>
              </label>
              <label class="cursor-pointer block">
                <input type="checkbox" name="lit_bebe" class="peer sr-only" />
                <span class="flex items-baseline gap-3 p-3 bg-lazuli-marine/40 border border-lazuli-casse/15 peer-checked:border-lazuli-coco peer-checked:bg-lazuli-coco/10 transition-all">
                  <span class="flex-1 font-geist text-lazuli-casse text-sm">Lit bébé + chaise haute</span>
                  <span class="font-yeseva text-lazuli-coco shrink-0">Offert</span>
                </span>
              </label>
            </div>
          </fieldset>

          <!-- ÉTAPE 4 : Coordonnées -->
          <fieldset class="l-step hidden" data-step="4">
            <legend class="font-yeseva text-lazuli-casse text-xl md:text-2xl mb-5 leading-tight">
              Pour confirmer.
            </legend>

            <div class="grid sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label for="l-nom" class="block font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco mb-2 font-semibold">Nom complet</label>
                <input id="l-nom" name="nom" type="text" required autocomplete="name"
                  class="w-full h-12 px-4 bg-lazuli-marine border border-lazuli-casse/25 focus:border-lazuli-coco font-geist text-lazuli-casse text-base outline-none transition-colors" />
              </div>
              <div>
                <label for="l-tel" class="block font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco mb-2 font-semibold">Téléphone</label>
                <input id="l-tel" name="telephone" type="tel" inputmode="tel" required autocomplete="tel"
                  class="w-full h-12 px-4 bg-lazuli-marine border border-lazuli-casse/25 focus:border-lazuli-coco font-geist text-lazuli-casse text-base outline-none transition-colors tabular-nums" />
              </div>
            </div>
            <div class="mb-4">
              <label for="l-email" class="block font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco mb-2 font-semibold">Email</label>
              <input id="l-email" name="email" type="email" inputmode="email" autocomplete="email"
                class="w-full h-12 px-4 bg-lazuli-marine border border-lazuli-casse/25 focus:border-lazuli-coco font-geist text-lazuli-casse text-base outline-none transition-colors" />
            </div>
            <div>
              <label for="l-message" class="block font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco mb-2 font-semibold">
                Précisions <span class="font-italianno italic normal-case tracking-normal">(facultatif)</span>
              </label>
              <textarea id="l-message" name="message" rows="3" placeholder="Allergies, demande spéciale, animal de compagnie…"
                class="w-full px-4 py-3 bg-lazuli-marine border border-lazuli-casse/25 focus:border-lazuli-coco font-geist text-lazuli-casse text-base placeholder:text-lazuli-casse/40 outline-none transition-colors resize-none"></textarea>
            </div>
          </fieldset>

          <!-- Navigation -->
          <div class="mt-7 flex flex-wrap items-center justify-between gap-3">
            <button type="button" id="l-btn-prev"
              class="hidden inline-flex items-center gap-1 h-10 px-4 border border-lazuli-casse/30 text-lazuli-casse/85 font-geist text-[11px] uppercase tracking-wider hover:border-lazuli-coco hover:text-lazuli-coco transition-colors cursor-pointer">
              ← Retour
            </button>
            <button type="button" id="l-btn-next"
              class="ml-auto inline-flex items-center justify-center h-12 px-7 bg-lazuli-terracotta text-lazuli-casse font-geist font-medium text-sm hover:bg-lazuli-coco hover:text-lazuli-marine transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer rounded-full">
              Continuer →
            </button>
            <button type="submit" id="l-btn-submit"
              class="hidden ml-auto inline-flex items-center justify-center h-13 px-9 bg-lazuli-coco text-lazuli-marine font-geist font-medium text-base hover:bg-lazuli-casse transition-colors cursor-pointer rounded-full"
              style="height: 52px;">
              Envoyer la demande →
            </button>
          </div>

          <p class="mt-4 font-italianno italic text-lazuli-coco/80 text-base text-center">
            Réponse de Stéphane ou Marina sous 4 h.
          </p>
        </form>
      </div>

      <!-- RIGHT : Sidebar -->
      <aside class="lg:col-span-4 lg:sticky lg:top-24 space-y-4">
        <div class="bg-lazuli-marine text-lazuli-casse p-6">
          <p class="font-geist text-[10px] uppercase tracking-[0.32em] text-lazuli-coco font-semibold mb-4">
            ✦ Votre séjour
          </p>
          <ul class="space-y-3 text-sm">
            <li class="pb-2 border-b border-lazuli-casse/15">
              <span class="block font-geist text-[9px] uppercase tracking-[0.22em] text-lazuli-casse/60">Dates</span>
              <span id="l-recap-dates" class="font-yeseva text-lazuli-casse">—</span>
            </li>
            <li class="pb-2 border-b border-lazuli-casse/15">
              <span class="block font-geist text-[9px] uppercase tracking-[0.22em] text-lazuli-casse/60">Voyageurs</span>
              <span id="l-recap-voyageurs" class="font-yeseva text-lazuli-casse">2 adultes</span>
            </li>
            <li class="pb-2 border-b border-lazuli-casse/15">
              <span class="block font-geist text-[9px] uppercase tracking-[0.22em] text-lazuli-casse/60">Tarif/nuit</span>
              <span id="l-recap-prix-nuit" class="font-yeseva text-lazuli-casse tabular-nums">—</span>
            </li>
            <li id="l-recap-options-wrap" class="hidden pb-2 border-b border-lazuli-casse/15">
              <span class="block font-geist text-[9px] uppercase tracking-[0.22em] text-lazuli-casse/60">Options</span>
              <span id="l-recap-options" class="font-yeseva text-lazuli-casse text-xs leading-relaxed">—</span>
            </li>
            <li class="pt-1">
              <span class="block font-geist text-[9px] uppercase tracking-[0.32em] text-lazuli-coco font-semibold">Total estimé</span>
              <span id="l-recap-total" class="font-italianno text-lazuli-coco text-3xl tabular-nums">—</span>
            </li>
          </ul>
        </div>

        <div class="p-5 bg-lazuli-sable/40 border-l-2 border-lazuli-terracotta">
          <p class="font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-terracotta font-semibold mb-2">
            ✦ Avant de réserver
          </p>
          <ul class="space-y-1.5 font-italianno italic text-lazuli-marine/85 text-base leading-snug">
            <li>· Caution 1 500 € (chèque/virement)</li>
            <li>· Annulation gratuite jusqu'à J-7</li>
            <li>· Pas de carte bancaire</li>
            <li>· Note 4,8/5 sur 87 avis</li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</section>

<script define:vars={{ waBase }}>
  const form = document.getElementById('l-form');
  if (form) {
    const steps = form.querySelectorAll('.l-step');
    const stepLabels = ['Vos dates', 'Voyageurs', 'Préférences', 'Coordonnées'];
    const totalSteps = steps.length;
    let currentStep = 1;
    let counters = { adultes: 2, enfants: 0, bebes: 0 };

    function getNuits() {
      const a = document.getElementById('l-arrivee')?.value;
      const d = document.getElementById('l-depart')?.value;
      if (!a || !d) return 0;
      const diff = Math.round((new Date(d) - new Date(a)) / (1000 * 60 * 60 * 24));
      return diff > 0 ? diff : 0;
    }

    function getSaisonInfo(arrivee) {
      if (!arrivee) return { name: '—', prix: 0, min: 0 };
      const m = new Date(arrivee).getMonth() + 1;
      if (m === 7 || m === 8)               return { name: 'Haute saison',       prix: 320, min: 7 };
      if (m === 12 || m === 1)              return { name: 'Très haute saison',  prix: 450, min: 14 };
      if (m === 3 || m === 4 || m === 11)   return { name: 'Moyenne saison',     prix: 220, min: 3 };
      return                                       { name: 'Basse saison',       prix: 180, min: 3 };
    }

    function fmtDate(s) {
      if (!s) return '—';
      return new Date(s).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
    }

    function updateRecap() {
      const arrivee = document.getElementById('l-arrivee')?.value;
      const depart = document.getElementById('l-depart')?.value;
      const nuits = getNuits();
      const saison = getSaisonInfo(arrivee);
      const menage = form.querySelector('input[name="menage_hebdo"]')?.checked;
      const petitdej = form.querySelector('input[name="petitdej"]')?.checked;
      const personnes = counters.adultes + counters.enfants;

      /* Show saison info */
      const info = document.getElementById('l-saison-info');
      if (nuits > 0 && info) {
        info.classList.remove('hidden');
        document.getElementById('l-saison-name').textContent = saison.name;
        document.getElementById('l-nuits-count').textContent = nuits;
        document.getElementById('l-prix-nuit').textContent = `${saison.prix} €`;
        const minWrap = document.getElementById('l-min-nuits');
        if (nuits < saison.min) {
          minWrap.classList.remove('hidden');
          document.getElementById('l-min-nuits-val').textContent = saison.min;
        } else {
          minWrap.classList.add('hidden');
        }
      } else if (info) {
        info.classList.add('hidden');
      }

      /* Recap */
      let datesText = '—';
      if (arrivee && depart && nuits > 0) {
        datesText = `${fmtDate(arrivee)} → ${fmtDate(depart)} (${nuits} nuits)`;
      }
      document.getElementById('l-recap-dates').textContent = datesText;

      const parts = [];
      if (counters.adultes) parts.push(`${counters.adultes} adulte${counters.adultes > 1 ? 's' : ''}`);
      if (counters.enfants) parts.push(`${counters.enfants} enfant${counters.enfants > 1 ? 's' : ''}`);
      if (counters.bebes) parts.push(`${counters.bebes} bébé${counters.bebes > 1 ? 's' : ''}`);
      document.getElementById('l-recap-voyageurs').textContent = parts.join(' · ') || '—';

      document.getElementById('l-recap-prix-nuit').textContent = saison.prix > 0 ? `${saison.prix} €` : '—';

      const opts = [];
      if (menage) opts.push('Ménage hebdo');
      if (petitdej) opts.push(`Petit-déj × ${personnes || 0}`);
      const optsWrap = document.getElementById('l-recap-options-wrap');
      if (opts.length && optsWrap) {
        optsWrap.classList.remove('hidden');
        document.getElementById('l-recap-options').textContent = opts.join(' · ');
      } else if (optsWrap) {
        optsWrap.classList.add('hidden');
      }

      let total = 0;
      if (nuits > 0) {
        total = saison.prix * nuits;
        if (menage) total += 80 * Math.ceil(nuits / 7);
        if (petitdej) total += 12 * personnes * nuits;
      }
      document.getElementById('l-recap-total').textContent = total > 0 ? `${total} €` : '—';
    }

    function showStep(n) {
      steps.forEach((s) => s.classList.add('hidden'));
      form.querySelector(`.l-step[data-step="${n}"]`)?.classList.remove('hidden');
      currentStep = n;
      document.getElementById('l-step-current').textContent = String(n);
      document.getElementById('l-step-label').textContent = stepLabels[n - 1];
      document.getElementById('l-progress').style.width = `${(n / totalSteps) * 100}%`;
      document.getElementById('l-btn-prev').classList.toggle('hidden', n === 1);
      document.getElementById('l-btn-next').classList.toggle('hidden', n === totalSteps);
      document.getElementById('l-btn-submit').classList.toggle('hidden', n !== totalSteps);
      validateCurrent();
    }

    function validateCurrent() {
      let valid = false;
      if (currentStep === 1) {
        const a = document.getElementById('l-arrivee')?.value;
        const d = document.getElementById('l-depart')?.value;
        const n = getNuits();
        const s = getSaisonInfo(a);
        valid = !!a && !!d && n >= s.min;
      } else if (currentStep === 2) {
        valid = (counters.adultes + counters.enfants) > 0 && (counters.adultes + counters.enfants) <= 8;
      } else if (currentStep === 3) valid = true;
      else if (currentStep === 4) valid = !!form.querySelector('#l-nom')?.value.trim() && !!form.querySelector('#l-tel')?.value.trim();
      document.getElementById('l-btn-next').disabled = !valid;
    }

    form.querySelectorAll('[data-l-counter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const c = btn.dataset.lCounter;
        const action = btn.dataset.action;
        if (action === 'inc') counters[c]++;
        else if (action === 'dec') counters[c] = Math.max(0, counters[c] - 1);
        if (c === 'adultes' && counters.adultes < 1) counters.adultes = 1;
        /* Cap max 8 adultes+enfants */
        const total = counters.adultes + counters.enfants;
        if (total > 8 && action === 'inc') {
          counters[c] = Math.max(0, counters[c] - 1);
        }
        document.getElementById(`l-c-${c}`).textContent = counters[c];
        updateRecap();
        validateCurrent();
      });
    });

    form.querySelectorAll('input, textarea').forEach((input) => {
      input.addEventListener('change', () => { validateCurrent(); updateRecap(); });
      input.addEventListener('input', () => { validateCurrent(); updateRecap(); });
    });
    document.getElementById('l-btn-next').addEventListener('click', () => { if (currentStep < totalSteps) showStep(currentStep + 1); });
    document.getElementById('l-btn-prev').addEventListener('click', () => { if (currentStep > 1) showStep(currentStep - 1); });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const nuits = getNuits();
      const saison = getSaisonInfo(fd.get('arrivee'));
      const total = document.getElementById('l-recap-total').textContent;
      const opts = [];
      if (form.querySelector('input[name="menage_hebdo"]')?.checked) opts.push('Ménage hebdo');
      if (form.querySelector('input[name="petitdej"]')?.checked) opts.push('Petit-déj livré');
      if (form.querySelector('input[name="lit_bebe"]')?.checked) opts.push('Lit bébé');

      const text = [
        'Bonjour, je souhaite réserver la Villa Lazuli.',
        '',
        '— SÉJOUR —',
        fd.get('arrivee') ? `Arrivée : ${fd.get('arrivee')}` : '',
        fd.get('depart') ? `Départ : ${fd.get('depart')}` : '',
        nuits ? `Durée : ${nuits} nuits (${saison.name}, ${saison.prix} €/nuit)` : '',
        '',
        '— VOYAGEURS —',
        `Adultes : ${counters.adultes}`,
        counters.enfants ? `Enfants : ${counters.enfants}` : '',
        counters.bebes ? `Bébés : ${counters.bebes}` : '',
        '',
        fd.get('occasion') && fd.get('occasion') !== 'Aucune' ? `— OCCASION —\n${fd.get('occasion')}` : '',
        '',
        opts.length ? `— OPTIONS —\n${opts.join(', ')}` : '',
        '',
        `TOTAL ESTIMÉ : ${total}`,
        '',
        '— CONTACT —',
        fd.get('nom') ? `Nom : ${fd.get('nom')}` : '',
        fd.get('telephone') ? `Tél : ${fd.get('telephone')}` : '',
        fd.get('email') ? `Email : ${fd.get('email')}` : '',
        fd.get('message') ? `\nDemande : ${fd.get('message')}` : '',
      ].filter(Boolean).join('\n');

      window.open(`${waBase}?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
    });

    /* Init */
    const today = new Date();
    const tomorrow = new Date(today.getTime() + 86400000);
    document.getElementById('l-arrivee').min = today.toISOString().split('T')[0];
    document.getElementById('l-depart').min = tomorrow.toISOString().split('T')[0];

    validateCurrent();
    updateRecap();
  }
</script>
