---
/**
 * TarifsSaisons — tableau 4 saisons + caution + extras.
 */
import data from '../../../data/templates/lazuli.json';
---

<section id="tarifs" class="bg-lazuli-sable py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-16 max-w-2xl mx-auto">
      <p class="font-geist text-[10px] uppercase tracking-[0.32em] text-lazuli-terracotta font-semibold mb-5">
        ✦ Tarifs par saison
      </p>
      <h2 class="font-yeseva text-lazuli-marine leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        4 saisons,
        <span class="font-italianno text-lazuli-lagon normal-case">4 ambiances.</span>
      </h2>
    </header>

    <!-- 4 saisons -->
    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 max-w-6xl mx-auto">
      {data.tarifs.map((t, i) => (
        <li class:list={[
          'relative bg-lazuli-casse p-7 md:p-8 transition-transform duration-500 hover:-translate-y-1',
          t.populaire ? 'ring-2 ring-lazuli-terracotta' : '',
        ]}>
          {t.populaire && (
            <span class="absolute -top-3 left-6 inline-block bg-lazuli-terracotta text-lazuli-casse font-geist text-[10px] uppercase tracking-[0.22em] font-bold px-3 py-1.5 rounded-full">
              ★ + demandée
            </span>
          )}

          <p class="font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-lagon font-semibold mb-2">
            Saison {String(i + 1).padStart(2, '0')}
          </p>

          <h3 class="font-yeseva text-lazuli-marine text-2xl md:text-3xl leading-tight">
            {t.saison}
          </h3>
          <p class="mt-2 font-italianno text-lazuli-bois text-xl">
            {t.periode}
          </p>

          <p class="mt-6 font-yeseva text-lazuli-terracotta tabular-nums leading-none" style="font-size: clamp(40px, 4vw, 56px);">
            {t.prix}
          </p>
          <p class="mt-1 font-geist text-lazuli-marine/65 text-sm">
            par nuit
          </p>

          <p class="mt-5 pt-4 border-t border-lazuli-marine/15 font-geist text-[11px] uppercase tracking-[0.22em] text-lazuli-marine/70">
            Min. {t.minimum}
          </p>
        </li>
      ))}
    </ul>

    <!-- Caution + extras -->
    <div class="mt-14 max-w-3xl mx-auto grid md:grid-cols-2 gap-6">
      <div class="bg-lazuli-marine text-lazuli-casse p-7">
        <p class="font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-coco font-semibold mb-3">
          Caution
        </p>
        <p class="font-italianno text-lazuli-coco text-3xl mb-3">
          1 500 €
        </p>
        <p class="font-geist text-lazuli-casse/80 text-sm leading-relaxed">
          {data.caution}
        </p>
      </div>
      <div class="bg-lazuli-casse border border-lazuli-marine/15 p-7">
        <p class="font-geist text-[10px] uppercase tracking-[0.28em] text-lazuli-terracotta font-semibold mb-3">
          Extras
        </p>
        <p class="font-italianno text-lazuli-terracotta text-3xl mb-3">
          À la carte.
        </p>
        <p class="font-geist text-lazuli-marine/80 text-sm leading-relaxed">
          {data.tarifsExtras}
        </p>
      </div>
    </div>
  </div>
</section>
