---
import data from '../../../data/templates/lazuli.json';
const year = new Date().getFullYear();
---

<footer class="bg-lazuli-marine text-lazuli-casse/75 py-12 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-italianno text-lazuli-coco text-3xl leading-none">Villa</span>
          <span class="font-yeseva text-lazuli-casse text-xl leading-none tracking-wide">{data.info.wordmark}</span>
        </p>
        <p class="mt-3 font-italianno text-lazuli-coco/70 text-xl leading-snug">
          {data.info.soustitre} · {data.info.ville}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-geist text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-lazuli-coco transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-lazuli-terracotta" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-lazuli-coco transition-colors break-all">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-lazuli-terracotta" aria-hidden="true"></li>
        <li class="font-italianno text-lazuli-coco text-xl">{data.info.instagram}</li>
      </ul>
    </div>

    <div class="h-px mb-6 bg-gradient-to-r from-transparent via-lazuli-coco/40 to-transparent" aria-hidden="true"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-geist text-[10px] uppercase tracking-[0.25em] text-lazuli-casse/45">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-lazuli-casse/70 hover:text-lazuli-coco transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
