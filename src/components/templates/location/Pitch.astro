---
/**
 * Pitch — 3 paragraphes Geist + chiffre clé en gros.
 */
import data from '../../../data/templates/lazuli.json';
---

<section class="bg-lazuli-casse py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">

      <!-- Colonne gauche : chiffre clé -->
      <div class="lg:col-span-5">
        <p class="font-geist text-[10px] uppercase tracking-[0.32em] text-lazuli-lagon font-semibold mb-6">
          La villa en bref
        </p>
        <p class="font-italianno text-lazuli-terracotta text-5xl md:text-6xl leading-none mb-3">
          120 m²
        </p>
        <h2 class="font-yeseva text-lazuli-marine leading-[1.0]" style="font-size: clamp(40px, 6vw, 88px);">
          Pour les<br/>vrais séjours.
        </h2>
        <p class="mt-6 font-italianno text-lazuli-lagon text-3xl md:text-4xl leading-snug">
          Calme, vue mer, et zéro voisins.
        </p>
      </div>

      <!-- Colonne droite : 3 paragraphes -->
      <div class="lg:col-span-7 space-y-7 lg:pt-3">
        {data.pitch.map((p) => (
          <p class="font-geist text-lazuli-marine/85 text-base md:text-lg leading-[1.85]">
            {p}
          </p>
        ))}
        <!-- Signature italique -->
        <p class="pt-4 font-italianno text-lazuli-terracotta text-2xl md:text-3xl">
          — {data.info.hotes}
        </p>
      </div>
    </div>
  </div>
</section>
