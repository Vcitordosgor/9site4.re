---
/**
 * UrgenceBar — bandeau urgence noir collé en haut de la page,
 * AVANT le header. Affiche le téléphone urgence cliquable
 * et un badge clignotant "URGENCE 24/7" rouge.
 *
 * Spécifique au métier de plombier : les clients d'urgence appellent
 * en priorité, le numéro doit être visible immédiatement.
 */
import data from '../../../data/templates/bernard.json';
---

<div class="bp-urgence-bar bg-bp-anthracite text-bp-blanc border-b-2 border-bp-jaune">
  <div class="max-w-content mx-auto px-4 sm:px-6 md:px-10 h-9 sm:h-10 flex items-center justify-between gap-3 sm:gap-6">

    <!-- Badge URGENCE 24/7 clignotant -->
    <span class="inline-flex items-center gap-1.5 sm:gap-2 text-[10px] sm:text-[11px] font-archivo font-bold uppercase tracking-[0.18em] sm:tracking-[0.2em] text-bp-blanc">
      <span class="bp-pulse inline-block w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-bp-rouge" aria-hidden="true"></span>
      <span class="hidden xs:inline">Urgence</span> 24/7
    </span>

    <!-- Téléphone direct (clic = appel) -->
    <a
      href={`tel:${data.info.telephoneHref}`}
      class="inline-flex items-center gap-2 text-[12px] sm:text-sm font-archivo font-semibold text-bp-jaune hover:text-bp-blanc transition-colors tabular-nums"
      aria-label="Appeler Bernard en urgence"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden sm:block">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span class="uppercase tracking-wide">Appeler</span>
      <span class="text-bp-blanc">·</span>
      <span>{data.info.telephoneCompact}</span>
    </a>
  </div>
</div>

<style>
  /* Pulse rouge URGENCE — animation lente accessible */
  @keyframes bp-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%      { opacity: 0.45; transform: scale(0.8); }
  }
  .bp-pulse { animation: bp-pulse 1800ms cubic-bezier(0.4, 0, 0.6, 1) infinite; }

  @media (prefers-reduced-motion: reduce) {
    .bp-pulse { animation: none !important; opacity: 1; transform: none !important; }
  }

  /* xs breakpoint pour mobile très étroit */
  @media (min-width: 380px) {
    .xs\:inline { display: inline; }
  }
</style>
