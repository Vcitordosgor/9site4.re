---
import data from '../../../data/templates/bernard.json';
const year = new Date().getFullYear();
---

<footer class="bg-bp-anthracite text-bp-blanc/85 py-10 px-6 md:px-10 border-t-2 border-bp-jaune">
  <div class="max-w-content mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="flex items-baseline gap-2 leading-none">
          <span class="block w-2.5 h-2.5 bg-bp-jaune" aria-hidden="true"></span>
          <span class="font-bebas tracking-wide text-bp-blanc text-2xl">{data.info.wordmark1}</span>
          <span class="font-bebas tracking-wide text-bp-blanc/65 text-2xl">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-archivo text-bp-blanc/60 text-sm">
          {data.info.adresse}
        </p>
        <p class="mt-1 font-archivo text-bp-blanc/45 text-xs uppercase tracking-[0.2em]">
          SIRET {data.info.siret} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 text-sm font-archivo">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-bp-jaune transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-flex w-1 h-1 rounded-full bg-bp-jaune/45" aria-hidden="true"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-bp-jaune transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <!-- Filet jaune séparateur -->
    <div class="mt-8 mb-6 h-[2px] bg-bp-jaune/30" aria-hidden="true"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 text-xs uppercase tracking-[0.22em] text-bp-blanc/60 font-archivo">
      <p>© {year} {data.info.nom}</p>
      <p>
        Site créé par
        <a href="/" class="font-bold text-bp-blanc hover:text-bp-jaune transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
