---
/**
 * Intervention — wrapper de la section "Demande d'intervention".
 * Charge le formulaire en Astro Island Preact (interactivité).
 * Le formulaire ouvre WhatsApp pré-rempli.
 */
import data from '../../../data/templates/bernard.json';
import RdvForm from './RdvForm.tsx';
---

<section id="intervention" class="relative bg-bp-acier text-bp-blanc py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-12 md:mb-16 max-w-3xl">
      <p class="scroll-reveal inline-flex items-center gap-3 text-[11px] sm:text-xs font-archivo font-bold uppercase tracking-[0.32em] text-bp-jaune">
        <span class="block w-8 h-[3px] bg-bp-jaune" aria-hidden="true"></span>
        <span>Demander une intervention</span>
      </p>
      <h2 class="scroll-reveal mt-5 font-bebas uppercase text-bp-blanc leading-[0.95] tracking-tight" style="font-size: clamp(40px, 6vw, 84px);">
        Trois étapes,<br/>
        <span class="text-bp-jaune">trente secondes.</span>
      </h2>
      <p class="scroll-reveal mt-6 max-w-xl font-archivo text-bp-blanc/75 leading-[1.7]">
        Décrivez le problème, on vous rappelle dans les 15 minutes
        avec un créneau et un devis estimatif.
      </p>
    </header>

    <div class="scroll-reveal">
      <RdvForm
        client:load
        problemes={data.typesProblemes}
        urgences={data.urgences}
        whatsapp={data.info.whatsapp}
        artisanNom={data.info.nom}
      />
    </div>
  </div>
</section>
