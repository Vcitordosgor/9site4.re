---
/**
 * HeroPoster — bloc poster industriel.
 * Mobile : pile centré.
 * Desktop : grand bloc anthracite à gauche avec énorme typo Bebas
 * uppercase + téléphone XXL + 2 CTA. À droite : bloc jaune avec
 * 3 promesses utilitaires (urgence sous 1h, devis gratuit, etc.).
 *
 * Vraiment différent : aucune photo dominante, aucune élégance —
 * juste de la typo poster massive, du contraste max, de l'urgence.
 */
import data from '../../../data/templates/bernard.json';
---

<section class="relative isolate bg-bp-anthracite text-bp-blanc">
  <div class="grid lg:grid-cols-12 lg:min-h-[calc(100svh-5.25rem)]">

    <!-- BLOC GAUCHE : poster typographique anthracite -->
    <div class="relative lg:col-span-8 px-6 sm:px-10 md:px-14 py-16 sm:py-20 md:py-28 lg:py-32 flex flex-col justify-center overflow-hidden">

      <!-- Trame pointillée jaune en arrière-plan (technical pattern) -->
      <div class="pointer-events-none absolute inset-0 opacity-[0.045]" aria-hidden="true"
           style="background-image: radial-gradient(circle, rgb(255 199 44) 1px, transparent 1px); background-size: 16px 16px;">
      </div>

      <!-- Eyebrow avec barre jaune -->
      <p class="hero-eyebrow relative inline-flex items-center gap-3 text-[11px] sm:text-xs font-archivo font-bold uppercase tracking-[0.32em] text-bp-jaune">
        <span class="block w-8 h-[3px] bg-bp-jaune" aria-hidden="true"></span>
        <span>Plombier · Le Tampon · Sud Réunion</span>
      </p>

      <!-- Titre poster MASSIF -->
      <h1 class="hero-title relative mt-8 sm:mt-10 font-bebas uppercase text-bp-blanc leading-[0.88] tracking-tight">
        <span class="block">{data.tagline}</span>
        <!-- Ligne avec mot principal en jaune + soulignage jaune épais -->
        <span class="block text-bp-jaune mt-2" style="font-size: 1em;">
          {data.taglineLarge}
        </span>
      </h1>
      <style>
        .hero-title { font-size: clamp(54px, 11vw, 168px); }
      </style>

      <!-- Sous-titre utilitaire -->
      <p class="hero-sub relative mt-8 max-w-xl font-archivo text-bp-blanc/80 leading-[1.6]" style="font-size: clamp(15px, 1.6vw, 17px);">
        {data.info.intro}
      </p>

      <!-- TÉLÉPHONE XXL : action #1 pour un client en urgence -->
      <div class="hero-tel relative mt-10 sm:mt-12 inline-flex items-baseline gap-3 sm:gap-4">
        <span class="text-[10px] sm:text-xs font-archivo font-bold uppercase tracking-[0.3em] text-bp-blanc/55 self-end pb-1 sm:pb-2">
          Appelez<br/>direct
        </span>
        <a
          href={`tel:${data.info.telephoneHref}`}
          class="inline-flex items-baseline gap-3 font-bebas text-bp-jaune hover:text-bp-blanc transition-colors leading-none tabular-nums tracking-wide"
          style="font-size: clamp(36px, 6vw, 64px);"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="self-center">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {data.info.telephoneCompact}
        </a>
      </div>

      <!-- 2 CTA secondaires avec bordures épaisses (style poster) -->
      <div class="hero-cta relative mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3">
        <a
          href="#intervention"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-archivo font-bold uppercase tracking-[0.18em] bg-bp-jaune text-bp-anthracite border-2 border-bp-jaune hover:bg-transparent hover:text-bp-jaune transition-colors"
        >
          Demander un devis gratuit
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center h-14 px-7 text-sm font-archivo font-bold uppercase tracking-[0.18em] bg-transparent text-bp-blanc border-2 border-bp-blanc/30 hover:border-bp-jaune hover:text-bp-jaune transition-colors"
        >
          Voir les services
        </a>
      </div>
    </div>

    <!-- BLOC DROIT : promesses sur fond jaune (caution tape vibe) -->
    <aside class="hero-aside relative lg:col-span-4 bg-bp-jaune text-bp-anthracite px-6 sm:px-10 md:px-12 py-12 sm:py-16 lg:py-32 flex flex-col justify-center">
      <!-- Diagonale anthracite en bas (motif chantier) -->
      <span class="absolute top-0 left-0 right-0 h-2 bg-bp-anthracite hidden lg:block" aria-hidden="true"></span>
      <span class="absolute top-2 left-0 right-0 h-px hidden lg:block" aria-hidden="true"
            style="background: repeating-linear-gradient(90deg, rgb(26 29 36) 0 12px, transparent 12px 24px);">
      </span>

      <p class="text-xs font-archivo font-bold uppercase tracking-[0.3em] text-bp-anthracite/70">Nos engagements</p>

      <ul class="mt-6 space-y-5">
        <li class="flex items-baseline gap-3">
          <span class="font-bebas text-bp-anthracite leading-none" style="font-size: 36px;">1H</span>
          <span class="font-archivo font-semibold text-bp-anthracite leading-snug" style="font-size: 15px;">
            Intervention urgence en moins d'une heure
          </span>
        </li>
        <li class="flex items-baseline gap-3 border-t-2 border-bp-anthracite/15 pt-5">
          <span class="font-bebas text-bp-anthracite leading-none" style="font-size: 36px;">0€</span>
          <span class="font-archivo font-semibold text-bp-anthracite leading-snug" style="font-size: 15px;">
            Devis gratuit, déplacement compris
          </span>
        </li>
        <li class="flex items-baseline gap-3 border-t-2 border-bp-anthracite/15 pt-5">
          <span class="font-bebas text-bp-anthracite leading-none" style="font-size: 36px;">18</span>
          <span class="font-archivo font-semibold text-bp-anthracite leading-snug" style="font-size: 15px;">
            Ans d'expérience au Tampon
          </span>
        </li>
        <li class="flex items-baseline gap-3 border-t-2 border-bp-anthracite/15 pt-5">
          <span class="font-bebas text-bp-anthracite leading-none" style="font-size: 36px;">★★★★★</span>
        </li>
        <li class="font-archivo text-bp-anthracite/80 text-sm leading-snug -mt-3">
          124 avis Google · note moyenne 4,9/5
        </li>
      </ul>

      <!-- Mention assurance en bas -->
      <p class="mt-8 pt-5 border-t-2 border-bp-anthracite/15 text-[11px] font-archivo uppercase tracking-[0.2em] text-bp-anthracite/70">
        Décennale & RC pro · RGE QualiPAC
      </p>
    </aside>
  </div>
</section>

<style>
  @keyframes bp-rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow { animation: bp-rise 600ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 100ms; }
  .hero-title   { animation: bp-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 250ms; }
  .hero-sub     { animation: bp-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 450ms; }
  .hero-tel     { animation: bp-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 600ms; }
  .hero-cta     { animation: bp-rise 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 750ms; }
  .hero-aside   { animation: bp-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) backwards; animation-delay: 350ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-title, .hero-sub, .hero-tel, .hero-cta, .hero-aside {
      animation: none !important; opacity: 1; transform: none !important;
    }
  }
</style>
