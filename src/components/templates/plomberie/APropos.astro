---
/**
 * APropos — section "À propos de Bernard".
 * Layout : portrait à gauche (col 5), bio + certifications à
 * droite (col 7) sur fond acier sombre.
 *
 * Style brut : pas de fioritures, juste une présentation honnête.
 */
import data from '../../../data/templates/bernard.json';
---

<section id="apropos" class="relative bg-bp-acier text-bp-blanc py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-16 max-w-3xl">
      <p class="scroll-reveal inline-flex items-center gap-3 text-[11px] sm:text-xs font-archivo font-bold uppercase tracking-[0.32em] text-bp-jaune">
        <span class="block w-8 h-[3px] bg-bp-jaune" aria-hidden="true"></span>
        <span>L'artisan</span>
      </p>
      <h2 class="scroll-reveal mt-5 font-bebas uppercase text-bp-blanc leading-[0.95] tracking-tight" style="font-size: clamp(40px, 6vw, 84px);">
        Bernard,<br/>
        <span class="text-bp-jaune">depuis 18 ans.</span>
      </h2>
    </header>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center max-w-5xl mx-auto">

      <!-- Portrait : verticale 4:5 avec cadre jaune -->
      <figure class="scroll-reveal lg:col-span-5 relative">
        <div class="relative mx-auto max-w-[360px] lg:max-w-none">
          <!-- Cadre jaune décalé derrière -->
          <div class="hidden lg:block absolute -top-3 -left-3 right-6 bottom-6 bg-bp-jaune pointer-events-none" aria-hidden="true"></div>

          <div class="relative overflow-hidden bg-bp-anthracite border-2 border-bp-jaune" style="aspect-ratio: 4/5;">
            <img
              src={data.info.photoBernard}
              alt={data.info.photoBernardAlt}
              width="900"
              height="1125"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover"
            />
          </div>

          <!-- Étiquette nom en bas (style ouvrier) -->
          <span class="absolute -bottom-3 left-3 inline-flex items-center px-4 h-9 bg-bp-anthracite text-bp-jaune font-archivo font-bold text-xs uppercase tracking-[0.2em] border-2 border-bp-jaune">
            {data.bernard.nom}
          </span>
        </div>
      </figure>

      <!-- Bio + certifications -->
      <div class="lg:col-span-7 lg:pl-4">
        <p class="scroll-reveal text-[10px] font-archivo font-bold uppercase tracking-[0.32em] text-bp-jaune">
          {data.bernard.titre}
        </p>
        <h3 class="scroll-reveal mt-3 font-bebas uppercase text-bp-blanc leading-tight tracking-wide" style="font-size: clamp(36px, 5vw, 54px);">
          {data.bernard.experience} d'expérience.<br/>
          <span class="text-bp-jaune">Pas de sous-traitance.</span>
        </h3>

        <p class="scroll-reveal mt-7 font-archivo text-bp-blanc/85 leading-[1.85]" style="font-size: 16px;">
          {data.bernard.bio}
        </p>

        <!-- Certifications en liste avec puces jaunes -->
        <div class="scroll-reveal mt-8 pt-8 border-t-2 border-bp-blanc/10">
          <p class="text-[10px] font-archivo font-bold uppercase tracking-[0.32em] text-bp-jaune mb-4">
            Certifications &amp; assurances
          </p>
          <ul class="space-y-2">
            {data.bernard.certifications.map((c) => (
              <li class="flex items-baseline gap-3 font-archivo text-bp-blanc/90 text-sm">
                <span class="flex-shrink-0 inline-block w-2.5 h-2.5 bg-bp-jaune mt-1.5" aria-hidden="true"></span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
