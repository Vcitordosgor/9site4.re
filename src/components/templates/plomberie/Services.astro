---
/**
 * Services — 6 services en grille bordée (style poster industriel).
 * Chaque service = bloc bordé épais avec icône outil, titre Bebas
 * uppercase, description Archivo, badge "délai" jaune en bas.
 */
import data from '../../../data/templates/bernard.json';

const icons: Record<string, string> = {
  // wrench - clé à molette
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  // flame
  flame: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
  // drain — pipe with circle (drain icon)
  drain: '<rect x="3" y="14" width="18" height="6" rx="1"/><path d="M5 14V6a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v8"/><path d="M9 18h6"/>',
  // drop - water drop
  drop: '<path d="M12 2.69 5.6 9.8a8.5 8.5 0 1 0 12.8 0L12 2.69z"/>',
  // tool - screwdriver crossed
  tool: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  // home - house with pipe
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
};
---

<section id="services" class="relative bg-bp-ciment py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <!-- Header de section -->
    <header class="mb-14 md:mb-16 max-w-3xl">
      <p class="scroll-reveal inline-flex items-center gap-3 text-[11px] sm:text-xs font-archivo font-bold uppercase tracking-[0.32em] text-bp-anthracite/70">
        <span class="block w-8 h-[3px] bg-bp-jaune" aria-hidden="true"></span>
        <span>Nos services</span>
      </p>
      <h2 class="scroll-reveal mt-5 font-bebas uppercase text-bp-anthracite leading-[0.95] tracking-tight" style="font-size: clamp(40px, 6vw, 84px);">
        Tout ce qui coule,<br/>
        <span class="text-bp-anthracite/60">tout ce qui bouche.</span>
      </h2>
      <p class="scroll-reveal mt-6 max-w-xl font-archivo text-bp-anthracite/70 leading-[1.7]">
        Bernard intervient sur toutes les problématiques de plomberie
        sanitaire et chauffage. Pas de sous-traitance.
      </p>
    </header>

    <!-- Grille 6 services -->
    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
      {data.services.map((s, i) => (
        <li class="scroll-reveal group relative bg-bp-blanc border-2 border-bp-anthracite p-7 md:p-8 hover:bg-bp-jaune transition-colors flex flex-col" style={`transition-delay: ${i * 60}ms`}>
          <!-- Icône carrée jaune fond + outil noir -->
          <span class="inline-flex items-center justify-center w-14 h-14 bg-bp-jaune border-2 border-bp-anthracite text-bp-anthracite group-hover:bg-bp-anthracite group-hover:text-bp-jaune transition-colors">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[s.icon] || icons.wrench} />
          </span>

          <h3 class="mt-6 font-bebas uppercase text-bp-anthracite leading-tight tracking-wide" style="font-size: 28px;">
            {s.titre}
          </h3>
          <p class="mt-3 flex-1 font-archivo text-bp-anthracite/75 group-hover:text-bp-anthracite/85 leading-[1.65]" style="font-size: 14.5px;">
            {s.description}
          </p>

          <!-- Badge délai en bas, format ticket -->
          <div class="mt-6 pt-5 border-t-2 border-bp-anthracite/10 group-hover:border-bp-anthracite/25 flex items-center justify-between text-[11px] font-archivo font-bold uppercase tracking-[0.18em] text-bp-anthracite">
            <span class="flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>{s.delai}</span>
            </span>
            <span class="opacity-0 group-hover:opacity-100 transition-opacity inline-flex items-center gap-1">
              <span>Devis</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
