---
/**
 * CTAFinal — bandeau anthracite avec gros téléphone XXL et 2 CTA.
 * Style poster final, rappel de l'urgence et de la disponibilité.
 */
import data from '../../../data/templates/bernard.json';
---

<section class="relative bg-bp-anthracite text-bp-blanc py-20 md:py-28 px-6 md:px-10 overflow-hidden">

  <!-- Trame pointillée jaune -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.05]" aria-hidden="true"
       style="background-image: radial-gradient(circle, rgb(255 199 44) 1px, transparent 1px); background-size: 16px 16px;">
  </div>

  <div class="relative max-w-content mx-auto text-center">
    <p class="scroll-reveal inline-flex items-center justify-center gap-3 text-[11px] sm:text-xs font-archivo font-bold uppercase tracking-[0.32em] text-bp-jaune">
      <span class="bp-pulse inline-block w-2.5 h-2.5 rounded-full bg-bp-rouge" aria-hidden="true"></span>
      <span>Astreinte 24/7 — toute l'année</span>
    </p>

    <h2 class="scroll-reveal mt-6 font-bebas uppercase text-bp-blanc leading-[0.92] tracking-tight" style="font-size: clamp(48px, 7vw, 100px);">
      Une fuite ?<br/>
      <span class="text-bp-jaune">Appelez.</span>
    </h2>

    <!-- TÉLÉPHONE XXL central -->
    <a
      href={`tel:${data.info.telephoneHref}`}
      class="scroll-reveal mt-10 inline-flex items-baseline gap-3 sm:gap-4 font-bebas text-bp-jaune hover:text-bp-blanc transition-colors leading-none tabular-nums tracking-wide"
      style="font-size: clamp(40px, 7vw, 80px);"
    >
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="self-center">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {data.info.telephoneCompact}
    </a>

    <p class="scroll-reveal mt-8 font-archivo text-bp-blanc/75 leading-relaxed max-w-md mx-auto">
      Réponse dans les 15 minutes. Devis gratuit.
      <br/>Si Bernard ne répond pas, il rappelle dans la demi-heure.
    </p>

    <div class="scroll-reveal mt-10 flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="#intervention"
        class="inline-flex items-center justify-center h-14 px-8 text-sm font-archivo font-bold uppercase tracking-[0.22em] bg-bp-jaune text-bp-anthracite border-2 border-bp-jaune hover:bg-transparent hover:text-bp-jaune transition-colors"
      >
        Devis en ligne
      </a>
      <a
        href={`https://wa.me/${data.info.whatsapp}`}
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 h-14 px-8 text-sm font-archivo font-bold uppercase tracking-[0.22em] bg-transparent text-bp-blanc border-2 border-bp-blanc/30 hover:border-bp-jaune hover:text-bp-jaune transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.91-7.01zm-7.01 15.24h-.01a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.25-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.83 8.25 8.25 0 0 1-8.24 8.22z"/>
        </svg>
        WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes bp-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%      { opacity: 0.45; transform: scale(0.7); }
  }
  .bp-pulse { animation: bp-pulse 1800ms cubic-bezier(0.4, 0, 0.6, 1) infinite; }
  @media (prefers-reduced-motion: reduce) {
    .bp-pulse { animation: none !important; opacity: 1; transform: none !important; }
  }
</style>
