---
/**
 * Tarifs — 3 formats simples (audit / mensuel / projet).
 * Format Substack pricing : sobre, lisible, prix tabulaire.
 */
import data from '../../../data/templates/lucas.json';
---

<section id="tarifs" class="bg-lucas-noir text-lucas-blanc py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-16 max-w-2xl">
      <p class="font-space-mono text-[11px] tracking-tight text-lucas-vert mb-5">
        ▶ # tarifs
      </p>
      <h2 class="font-instrument italic text-lucas-blanc leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Trois formats,<br/>
        <span class="not-italic font-hanken font-semibold text-lucas-perle">pas de surprise.</span>
      </h2>
    </header>

    <ul class="grid md:grid-cols-3 gap-px bg-lucas-encre/30 max-w-6xl">
      {data.tarifs.map((t) => (
        <li class:list={[
          'relative p-7 md:p-9 flex flex-col',
          t.populaire ? 'bg-lucas-vert text-lucas-noir' : 'bg-lucas-noir text-lucas-blanc',
        ]}>
          {t.populaire && (
            <span class="absolute -top-3 left-7 inline-block bg-lucas-noir text-lucas-vert font-space-mono text-[10px] uppercase tracking-[0.18em] px-3 py-1.5">
              ▶ recommandé
            </span>
          )}

          <p class:list={['font-space-mono text-[11px] tracking-tight mb-4', t.populaire ? 'text-lucas-noir/65' : 'text-lucas-vert']}>
            {t.format}
          </p>

          <h3 class:list={['font-hanken font-semibold text-2xl md:text-3xl leading-tight mb-2', t.populaire ? 'text-lucas-noir' : 'text-lucas-blanc']}>
            {t.titre}
          </h3>
          <p class:list={['font-instrument italic text-base mb-6', t.populaire ? 'text-lucas-noir/70' : 'text-lucas-perle/65']}>
            {t.duree}
          </p>

          <p class:list={['font-instrument italic leading-none tabular-nums mb-6', t.populaire ? 'text-lucas-noir' : 'text-lucas-blanc']} style="font-size: clamp(36px, 4vw, 52px);">
            {t.prix}
          </p>

          <p class:list={['font-hanken text-[15px] leading-[1.7] mb-6 flex-1', t.populaire ? 'text-lucas-noir/80' : 'text-lucas-perle/75']}>
            {t.description}
          </p>

          <ul class="space-y-2 mb-7">
            {t.inclus.map((i) => (
              <li class:list={['flex items-start gap-2.5 font-hanken text-[14px]', t.populaire ? 'text-lucas-noir/85' : 'text-lucas-perle/85']}>
                <span class:list={['shrink-0 mt-1.5 block w-1.5 h-1.5 rounded-full', t.populaire ? 'bg-lucas-noir' : 'bg-lucas-vert']} aria-hidden="true"></span>
                {i}
              </li>
            ))}
          </ul>

          <a
            href="#rendez-vous"
            class:list={[
              'inline-flex items-center gap-2 font-hanken font-semibold text-sm hover:gap-3 transition-all',
              t.populaire ? 'text-lucas-noir hover:text-lucas-anthracite' : 'text-lucas-vert hover:text-lucas-blanc',
            ]}
          >
            En parler →
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-12 font-space-mono text-[11px] text-lucas-encre max-w-3xl leading-relaxed">
      ▶ # paiement à 30 jours · facture à la fin de chaque mois pour l'accompagnement,
      à la livraison pour l'audit, à 30/60/10 pour les projets
    </p>
  </div>
</section>
