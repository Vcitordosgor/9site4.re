---
/**
 * HeroPortfolio — text-first portfolio. Pas de photo plein écran.
 * Avatar 80px circulaire + curseur clignotant terminal dans l'eyebrow.
 */
import data from '../../../data/templates/lucas.json';
---

<section id="top" class="relative bg-lucas-noir text-lucas-blanc overflow-hidden min-h-[90svh] flex items-center">

  <!-- Subtil gradient en arrière-plan -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-lucas-vert/40 to-transparent" aria-hidden="true"></div>

  <div class="relative max-w-content mx-auto px-6 md:px-10 pt-32 pb-20 md:pt-40 md:pb-28 w-full">

    <!-- Eyebrow terminal-style avec curseur clignotant -->
    <div class="flex items-baseline gap-2 mb-12 md:mb-16 font-space-mono text-[11px] md:text-[12px] tracking-tight">
      <span class="text-lucas-vert">▶</span>
      <span class="text-lucas-encre">$</span>
      <span class="text-lucas-perle">whoami</span>
      <span class="text-lucas-encre">→</span>
      <span class="text-lucas-blanc">{data.info.wordmark}</span>
      <span class="text-lucas-encre hidden md:inline">·</span>
      <span class="hidden md:inline text-lucas-encre">{data.info.soustitre}</span>
      <span class="text-lucas-vert ml-1 cursor-blink" aria-hidden="true">▮</span>
    </div>

    <!-- H1 Instrument Serif italique ample -->
    <h1 class="font-instrument italic text-lucas-blanc leading-[1.0]" style="font-size: clamp(48px, 8vw, 128px);">
      J'aide les entreprises à <span class="text-lucas-vert">vraiment</span> utiliser le digital.
    </h1>

    <!-- Sous-titre court neutre -->
    <p class="mt-10 font-hanken text-lucas-perle/85 text-lg md:text-xl leading-relaxed max-w-2xl">
      Stratégie, exécution, mesure. {data.info.experience} ans d'expérience entre la métropole et La Réunion. {data.info.disponibilite}.
    </p>

    <!-- Pseudo-log d'activité 'now.log' : preuve de pratique freelance -->
    <pre class="mt-10 max-w-xl overflow-x-auto rounded-sm bg-lucas-noir ring-1 ring-lucas-vert/20 px-4 py-3.5 font-space-mono text-[11px] md:text-[12px] leading-[1.7] tabular-nums">
<span class="text-lucas-vert">$</span> <span class="text-lucas-perle">tail -f now.log</span>
<span class="text-lucas-encre">─────────────────────────────────────────────</span>
<span class="text-lucas-encre">[2026-01-22]</span> <span class="text-lucas-vert">▸</span> <span class="text-lucas-blanc">Refonte stratégie content B2B</span> <span class="text-lucas-encre">· industrie</span>
<span class="text-lucas-encre">[2026-01-15]</span> <span class="text-lucas-vert">▸</span> <span class="text-lucas-blanc">Audit SEO e-commerce mode</span> <span class="text-lucas-encre">· en cours</span>
<span class="text-lucas-encre">[2026-01-08]</span> <span class="text-lucas-vert">✓</span> <span class="text-lucas-perle/70">Atelier acquisition B2B</span> <span class="text-lucas-encre">· livré</span>
<span class="text-lucas-encre">─────────────────────────────────────────────</span>
    </pre>

    <!-- Avatar + ligne d'identité minimale -->
    <div class="mt-12 flex items-center gap-4">
      <img
        src={data.info.photoAvatar}
        alt={`Avatar de ${data.info.wordmark}`}
        class="w-14 h-14 md:w-16 md:h-16 rounded-full object-cover ring-2 ring-lucas-vert/40"
        fetchpriority="high"
        decoding="async"
      />
      <div>
        <p class="font-hanken font-semibold text-lucas-blanc text-base">{data.info.wordmark}</p>
        <p class="font-space-mono text-[11px] text-lucas-encre">{data.info.ville} · La Réunion</p>
      </div>
    </div>

    <!-- 3 CTAs : sobres, alignés horizontaux -->
    <div class="mt-14 flex flex-wrap items-center gap-x-8 gap-y-3">
      <a
        href="#missions"
        class="inline-flex items-center gap-2 font-hanken font-semibold text-lucas-vert text-base hover:text-lucas-blanc transition-colors"
      >
        Voir mes missions
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="#rendez-vous"
        class="inline-flex items-center h-12 px-6 bg-lucas-vert text-lucas-noir font-hanken font-semibold text-sm hover:bg-lucas-blanc transition-colors"
      >
        Prendre rendez-vous
      </a>
      <a
        href="#cv"
        class="inline-flex items-center font-hanken text-lucas-perle text-base underline underline-offset-4 decoration-lucas-encre hover:decoration-lucas-vert hover:text-lucas-vert transition-colors"
      >
        Mon CV en PDF
      </a>
    </div>

    <!-- Footer hero : line ID -->
    <div class="mt-20 pt-6 border-t border-lucas-encre/30 flex flex-wrap items-baseline justify-between gap-3 font-space-mono text-[11px] text-lucas-encre">
      <span>~/portfolio · last commit: 2026-01-15</span>
      <span class="hidden md:inline">↓ scroll for more</span>
    </div>
  </div>

  <style>
    .cursor-blink {
      animation: blink 1s step-end infinite;
    }
    @keyframes blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .cursor-blink { animation: none; }
    }
  </style>
</section>
