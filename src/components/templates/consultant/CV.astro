---
import data from '../../../data/templates/lucas.json';
---

<section id="cv" class="bg-lucas-anthracite py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-4xl mx-auto">

    <div class="bg-lucas-noir border border-lucas-encre/30 p-8 md:p-12 grid lg:grid-cols-12 gap-8 items-center">

      <div class="lg:col-span-8">
        <p class="font-space-mono text-[11px] tracking-tight text-lucas-vert mb-3">
          ▶ # download · 0.4 MB · pdf
        </p>
        <h2 class="font-instrument italic text-lucas-blanc leading-[1.1]" style="font-size: clamp(28px, 3.5vw, 44px);">
          Mon CV en PDF.
        </h2>
        <p class="mt-4 font-hanken text-lucas-perle/75 text-base leading-relaxed">
          Détail des missions, références, formations, parcours. Mise à jour le 15 janvier 2026.
        </p>
      </div>

      <div class="lg:col-span-4 lg:text-right">
        <a
          href="#"
          onclick="event.preventDefault(); alert('Démo : le CV serait téléchargé ici.');"
          class="inline-flex items-center gap-3 h-12 px-6 bg-lucas-vert text-lucas-noir font-hanken font-semibold text-sm hover:bg-lucas-blanc transition-colors"
        >
          <span class="font-space-mono">↓</span>
          Télécharger
        </a>
        <p class="mt-3 font-space-mono text-[11px] text-lucas-encre">
          lucas-ferrier-cv-2026.pdf
        </p>
      </div>
    </div>
  </div>
</section>
