---
import data from '../../../data/templates/lucas.json';
---

<section class="bg-lucas-anthracite text-lucas-blanc py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">

      <!-- Colonne gauche : intro -->
      <div class="lg:col-span-5">
        <p class="font-space-mono text-[11px] tracking-tight text-lucas-vert mb-5">
          ▶ # pitch
        </p>
        <p class="font-instrument italic text-lucas-blanc leading-[1.15]" style="font-size: clamp(28px, 4vw, 44px);">
          {data.pitch.intro}
        </p>
      </div>

      <!-- Colonne droite : 3 bullets compétences clés -->
      <div class="lg:col-span-7 space-y-px bg-lucas-encre/30">
        {data.pitch.bullets.map((b, i) => (
          <article class="bg-lucas-anthracite p-7 md:p-8 group hover:bg-lucas-noir transition-colors">
            <div class="flex items-baseline gap-4 mb-3">
              <span class="font-space-mono text-lucas-vert text-sm">/{String(i + 1).padStart(2, '0')}</span>
              <h3 class="font-hanken font-semibold text-lucas-blanc text-xl md:text-2xl leading-tight">
                {b.titre}
              </h3>
            </div>
            <p class="font-hanken text-lucas-perle/75 text-base leading-relaxed pl-9">
              {b.detail}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
