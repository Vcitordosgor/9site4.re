---
import data from '../../../data/templates/lucas.json';
const year = new Date().getFullYear();
---

<footer class="bg-lucas-noir text-lucas-encre py-12 px-6 md:px-10 border-t border-lucas-encre/30">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="text-lucas-vert text-base" aria-hidden="true">▶</span>
          <span class="font-hanken font-medium text-lucas-blanc text-base leading-none">{data.info.wordmark}</span>
          <span class="font-space-mono text-lucas-encre text-xs leading-none">/ consultant</span>
        </p>
        <p class="mt-2 font-space-mono text-[11px] text-lucas-encre">
          {data.info.ville} · La Réunion · indep. depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-hanken text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="text-lucas-perle hover:text-lucas-vert transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-lucas-vert" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="text-lucas-perle hover:text-lucas-vert transition-colors break-all">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-lucas-vert" aria-hidden="true"></li>
        <li><a href={`https://linkedin.com/in/${data.info.linkedin}`} target="_blank" rel="noopener noreferrer" class="text-lucas-perle hover:text-lucas-vert transition-colors">LinkedIn</a></li>
      </ul>
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-space-mono text-[11px] text-lucas-encre/55">
      <p>© {year} {data.info.wordmark} · SIRET {data.info.siret}</p>
      <p>
        ▶ site by
        <a href="/" class="text-lucas-perle hover:text-lucas-vert transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
