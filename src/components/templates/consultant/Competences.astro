---
/**
 * Competences — 3 colonnes texte pur (Stratégie / Exécution / Outils).
 * AUCUNE icône. Juste des listes propres en sans-serif neutre.
 */
import data from '../../../data/templates/lucas.json';

const cols = [data.competences.strategie, data.competences.execution, data.competences.outils];
---

<section id="competences" class="bg-lucas-anthracite text-lucas-blanc py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-16 max-w-2xl">
      <p class="font-space-mono text-[11px] tracking-tight text-lucas-vert mb-5">
        ▶ # competences
      </p>
      <h2 class="font-instrument italic text-lucas-blanc leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Ce que je sais faire<br/>
        <span class="not-italic font-hanken font-semibold text-lucas-perle">vraiment bien.</span>
      </h2>
    </header>

    <div class="grid md:grid-cols-3 gap-x-12 gap-y-12">
      {cols.map((col, i) => (
        <div>
          <p class="font-space-mono text-[10px] tracking-tight text-lucas-vert mb-2">
            /{String(i + 1).padStart(2, '0')}
          </p>
          <h3 class="font-hanken font-semibold text-lucas-blanc text-2xl md:text-3xl mb-7 pb-5 border-b border-lucas-encre/30">
            {col.titre}
          </h3>
          <ul class="space-y-3">
            {col.items.map((item) => (
              <li class="font-hanken text-lucas-perle/80 text-[15px] leading-relaxed">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="mt-14 font-space-mono text-[11px] text-lucas-encre max-w-3xl leading-relaxed">
      ▶ # certifications · Google Analytics 4, Looker Studio, HubSpot Marketing & Sales,
      Shopify Plus Partner. Mises à jour annuelles.
    </p>
  </div>
</section>
