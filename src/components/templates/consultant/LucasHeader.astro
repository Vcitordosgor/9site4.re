---
import data from '../../../data/templates/lucas.json';
---

<header
  id="lucas-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-lucas-noir/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-lucas-vert/15"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <a href="#top" class="flex items-baseline gap-2 group" aria-label="Lucas Ferrier — accueil">
      <span class="text-lucas-vert text-base leading-none" aria-hidden="true">▶</span>
      <span class="font-hanken font-medium text-lucas-blanc text-base leading-none group-hover:text-lucas-vert transition-colors">
        {data.info.wordmark}
      </span>
      <span class="font-space-mono text-lucas-encre text-xs leading-none">/ consultant</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 font-hanken text-[13px] text-lucas-perle/70" aria-label="Navigation">
      <a href="#missions" class="hover:text-lucas-vert transition-colors">Missions</a>
      <a href="#competences" class="hover:text-lucas-vert transition-colors">Compétences</a>
      <a href="#tarifs" class="hover:text-lucas-vert transition-colors">Tarifs</a>
      <a href="#principes" class="hover:text-lucas-vert transition-colors">Méthode</a>
    </nav>

    <a
      href="#rendez-vous"
      class="inline-flex items-center h-9 px-4 bg-lucas-vert text-lucas-noir font-hanken text-[13px] font-semibold hover:bg-lucas-blanc transition-colors"
    >
      Prendre RDV
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('lucas-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
