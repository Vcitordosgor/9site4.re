---
/**
 * Trouver — adresse + horaires en bandeau magazine.
 * Layout simple, 2 colonnes adresse/horaires sur fond papier.
 */
import data from '../../../data/templates/mona.json';
---

<section class="bg-mona-creme py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <!-- Adresse -->
      <div>
        <p class="font-jakarta text-[10px] uppercase tracking-[0.32em] text-mona-vert-fonce mb-5">
          Le cabinet
        </p>
        <h2 class="font-newsreader text-mona-cacao leading-[1.05]" style="font-size: clamp(34px, 4.5vw, 52px);">
          {data.info.adresseLigne1}
        </h2>
        <p class="mt-2 font-newsreader italic text-mona-cacao/70 text-xl">
          {data.info.adresseLigne2}
        </p>

        <p class="mt-8 font-jakarta text-mona-cacao/70 text-base leading-[1.75] max-w-md">
          Au cœur du Tampon, le cabinet est facilement accessible en voiture comme en transport. Parking visiteurs gratuit en face.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href={`tel:${data.info.telephoneHref}`}
            class="inline-flex items-center h-11 px-5 bg-mona-cacao text-mona-creme font-jakarta text-[13px] font-semibold rounded-full hover:bg-mona-terracotta transition-colors tabular-nums"
          >
            {data.info.telephone}
          </a>
          <a
            href={`mailto:${data.info.email}`}
            class="inline-flex items-center font-newsreader text-mona-cacao text-base underline underline-offset-4 decoration-mona-vert/60 hover:decoration-mona-vert-fonce hover:text-mona-vert-fonce transition-colors break-all"
          >
            {data.info.email}
          </a>
        </div>
      </div>

      <!-- Horaires -->
      <div>
        <p class="font-jakarta text-[10px] uppercase tracking-[0.32em] text-mona-terracotta mb-5">
          Horaires de consultation
        </p>
        <ul class="border-t border-mona-cacao/15">
          {data.horaires.map((h) => (
            <li class="grid grid-cols-2 items-baseline gap-3 py-3 border-b border-mona-cacao/15">
              <span class="font-newsreader text-mona-cacao text-lg">{h.jour}</span>
              <span class:list={['font-jakarta text-right tabular-nums', h.ouvert ? 'text-mona-vert-fonce font-medium' : 'italic text-mona-cacao/45']}>
                {h.label}
              </span>
            </li>
          ))}
        </ul>

        <p class="mt-6 font-reenie text-mona-terracotta text-xl">
          → en cas d'absence, laissez un message ✿
        </p>
      </div>
    </div>
  </div>
</section>
