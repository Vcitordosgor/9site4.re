---
/**
 * Piliers — 3 piliers en bandeau horizontal large.
 * Numéros en grand newsreader italique, descriptions courtes.
 */
import data from '../../../data/templates/mona.json';
---

<section class="bg-mona-creme py-20 md:py-28 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <p class="font-reenie text-mona-terracotta text-3xl md:text-4xl text-center mb-2 transform -rotate-1">
      mon approche
    </p>

    <h2 class="font-newsreader text-mona-cacao text-center leading-tight mb-14 md:mb-20" style="font-size: clamp(34px, 5vw, 56px);">
      Trois choses qui comptent.
    </h2>

    <div class="grid md:grid-cols-3 gap-x-8 gap-y-12">
      {data.piliers.map((p, i) => (
        <article class="text-center md:text-left">
          <p class="font-newsreader italic text-mona-vert leading-none mb-3" style="font-size: clamp(72px, 9vw, 120px);">
            0{i + 1}
          </p>
          <h3 class="font-newsreader text-mona-cacao text-2xl md:text-3xl mb-3">
            {p.titre}<span class="text-mona-terracotta">.</span>
          </h3>
          <p class="font-jakarta text-mona-cacao/70 text-[15px] leading-[1.75]">
            {p.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
