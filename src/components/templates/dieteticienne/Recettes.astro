---
/**
 * Recettes coup de cœur — grid 4 photos food avec nom + temps + ingrédient phare.
 * Format food blogger / Pinterest. Bloc inédit qui n'existe nulle part ailleurs.
 */
import data from '../../../data/templates/mona.json';
---

<section id="recettes" class="bg-mona-creme py-24 md:py-36 px-6 md:px-10 relative">

  <!-- Annotation manuscrite -->
  <p class="absolute top-12 right-6 md:right-12 font-reenie text-mona-terracotta text-2xl md:text-3xl rotate-2" aria-hidden="true">
    bonus ✿
  </p>

  <div class="max-w-content mx-auto">

    <header class="mb-12 md:mb-16 max-w-xl">
      <p class="font-jakarta text-[10px] uppercase tracking-[0.32em] text-mona-terracotta mb-5">
        Recettes coup de cœur
      </p>
      <h2 class="font-newsreader text-mona-cacao leading-[1.1]" style="font-size: clamp(34px, 5vw, 56px);">
        Quatre idées
        <span class="italic text-mona-vert-fonce">simples & saines.</span>
      </h2>
      <p class="mt-5 font-jakarta text-mona-cacao/65 text-base">
        Ces recettes reviennent souvent en consultation. Faciles, rapides, équilibrées — à essayer chez vous, sans pression.
      </p>
    </header>

    <ul class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {data.recettes.map((r, i) => (
        <li class="group">
          <article>
            <!-- Photo carrée -->
            <div class="relative aspect-square overflow-hidden bg-mona-papier">
              <img
                src={r.photo}
                alt={r.nom}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <!-- Numéro recette en superposition -->
              <span class="absolute top-3 left-3 inline-flex items-center justify-center w-9 h-9 rounded-full bg-mona-creme/95 font-newsreader italic text-mona-cacao text-base">
                {i + 1}
              </span>
              <!-- Badge ingrédient phare -->
              <span class="absolute bottom-3 left-3 inline-flex items-center gap-1.5 bg-mona-vert-fonce text-mona-creme px-3 py-1 rounded-full font-jakarta text-[11px] font-semibold">
                <span aria-hidden="true">●</span> {r.ingredient}
              </span>
            </div>

            <!-- Texte sous photo -->
            <h3 class="mt-4 font-newsreader text-mona-cacao text-lg md:text-xl leading-tight">
              {r.nom}
            </h3>
            <p class="mt-1 font-jakarta text-mona-cacao/55 text-xs uppercase tracking-wider tabular-nums">
              ⏱ {r.tempsTotal}
            </p>
          </article>
        </li>
      ))}
    </ul>

    <p class="mt-12 font-jakarta italic text-mona-cacao/55 text-sm text-center">
      Une dizaine d'autres recettes vous est remise lors de la première consultation.
    </p>
  </div>
</section>
