---
/**
 * Etapes — 3 étapes en bandeau timeline horizontal à filets terracotta.
 */
import data from '../../../data/templates/mona.json';
---

<section class="bg-mona-creme py-20 md:py-28 px-6 md:px-10 relative">

  <!-- Filet vert décoratif -->
  <span class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-mona-vert/30 to-transparent" aria-hidden="true"></span>

  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-20 max-w-xl mx-auto">
      <p class="font-jakarta text-[10px] uppercase tracking-[0.32em] text-mona-terracotta mb-5">
        Comment ça se passe
      </p>
      <h2 class="font-newsreader text-mona-cacao leading-[1.1]" style="font-size: clamp(34px, 5vw, 56px);">
        Trois étapes,<br/>
        <span class="italic text-mona-vert-fonce">simples et durables.</span>
      </h2>
    </header>

    <div class="relative grid md:grid-cols-3 gap-12 md:gap-8">

      <!-- Filet terracotta horizontal traversant les 3 étapes (desktop) -->
      <span class="hidden md:block absolute top-12 left-[16.66%] right-[16.66%] h-px border-t border-dashed border-mona-terracotta/40" aria-hidden="true"></span>

      {data.etapes.map((e) => (
        <article class="text-center relative">
          <!-- Numéro rond terracotta -->
          <span class="relative inline-flex items-center justify-center w-24 h-24 rounded-full bg-mona-terracotta text-mona-creme font-newsreader text-4xl mb-6">
            {e.num}
          </span>

          <!-- Titre -->
          <h3 class="font-newsreader text-mona-cacao text-2xl md:text-3xl mb-2">
            {e.titre}
          </h3>

          <!-- Durée micro -->
          <p class="font-reenie text-mona-vert-fonce text-xl mb-4">
            ↳ {e.duree}
          </p>

          <!-- Description -->
          <p class="font-jakarta text-mona-cacao/70 text-[15px] leading-relaxed max-w-xs mx-auto">
            {e.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
