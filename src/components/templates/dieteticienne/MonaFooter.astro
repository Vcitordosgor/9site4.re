---
import data from '../../../data/templates/mona.json';
const year = new Date().getFullYear();
---

<footer class="bg-mona-cacao text-mona-creme/80 py-12 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-newsreader text-mona-creme text-2xl leading-none">{data.info.wordmark}</span>
          <span class="block w-1.5 h-1.5 rounded-full bg-mona-vert" aria-hidden="true"></span>
        </p>
        <p class="mt-2 font-newsreader italic text-mona-creme/60 text-sm">
          {data.info.soustitre} · {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-jakarta text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-mona-vert transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-mona-vert/50" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-mona-vert transition-colors">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-mona-vert/50" aria-hidden="true"></li>
        <li class="font-newsreader italic text-mona-creme/55">{data.info.instagram}</li>
      </ul>
    </div>

    <div class="h-px bg-mona-creme/15 mb-6"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-jakarta text-[10px] uppercase tracking-[0.25em] text-mona-creme/45">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret} · ADELI {data.info.adeli}</p>
      <p>
        Site créé par
        <a href="/" class="text-mona-creme/70 hover:text-mona-vert transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
