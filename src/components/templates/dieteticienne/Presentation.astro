---
/**
 * Presentation — format interview Q-R magazine.
 * Photo portrait verticale à gauche, 4 questions/réponses à droite.
 * Questions en italique grand serif, réponses en sans plus calmes.
 */
import data from '../../../data/templates/mona.json';
---

<section id="presentation" class="bg-mona-papier py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- Photo portrait + caption -->
      <div class="lg:col-span-5 lg:sticky lg:top-24">
        <div class="relative aspect-[3/4] max-w-md mx-auto bg-mona-creme overflow-hidden">
          <img
            src={data.info.photoMona}
            alt="Portrait de Mona Levray, diététicienne"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
          <!-- Filet vert vertical à gauche -->
          <div class="absolute top-0 bottom-0 left-0 w-1 bg-mona-vert"></div>

          <!-- Étiquette : caption photo style magazine -->
          <div class="absolute bottom-4 left-4 right-4 bg-mona-creme/95 backdrop-blur-sm p-4">
            <p class="font-newsreader italic text-mona-cacao text-base leading-tight">
              « C'est notre relation aux aliments qu'il faut soigner, pas seulement notre poids. »
            </p>
            <p class="mt-2 font-jakarta text-[10px] uppercase tracking-[0.25em] text-mona-vert-fonce">
              Mona, en consultation
            </p>
          </div>
        </div>

        <!-- Diplômes en marge -->
        <div class="mt-8 pl-4 border-l border-mona-cacao/15">
          <p class="font-jakarta text-[10px] uppercase tracking-[0.28em] text-mona-vert-fonce mb-3">
            Formation
          </p>
          <ul class="space-y-1.5">
            {data.diplomes.map((d) => (
              <li class="font-newsreader text-mona-cacao/80 text-sm leading-snug">{d}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Interview Q-R -->
      <div class="lg:col-span-7">

        <p class="font-jakarta text-[10px] uppercase tracking-[0.32em] text-mona-vert-fonce mb-6">
          Interview · 4 questions
        </p>

        <h2 class="font-newsreader text-mona-cacao leading-[1.05]" style="font-size: clamp(36px, 5vw, 60px);">
          Rencontre avec
          <span class="italic text-mona-terracotta">Mona Levray.</span>
        </h2>

        <!-- Q-R format -->
        <div class="mt-12 space-y-12">
          {data.presentation.map((qr, i) => (
            <article class="border-t border-mona-cacao/15 pt-8">
              <p class="font-jakarta text-[10px] uppercase tracking-[0.28em] text-mona-terracotta mb-4">
                Question {String(i + 1).padStart(2, '0')}
              </p>
              <h3 class="font-newsreader italic text-mona-cacao text-2xl md:text-3xl leading-tight mb-5">
                « {qr.question} »
              </h3>
              <p class="font-jakarta text-mona-cacao/80 text-base md:text-lg leading-[1.8] pl-6 border-l-2 border-mona-vert/40">
                — {qr.reponse}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
