---
/**
 * CTAFinal — bandeau full-width sombre, citation finale + bouton terracotta.
 * Halo radial terracotta pour donner de la chaleur.
 */
import data from '../../../data/templates/spa.json';
---

<section class="relative bg-spa-cacao text-spa-creme py-24 md:py-36 px-6 md:px-10 text-center overflow-hidden">
  <!-- Halo terracotta subtle -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[44rem] h-[44rem] rounded-full"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(198 123 92 / 0.22) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative max-w-2xl mx-auto">
    <p class="scroll-reveal flex items-center justify-center gap-3 text-xs sm:text-sm uppercase tracking-[0.4em] text-spa-rose font-raleway font-medium">
      <span class="inline-block w-8 h-px bg-spa-rose/55" aria-hidden="true"></span>
      <span>{data.info.wordmark1} {data.info.wordmark2}</span>
      <span class="inline-block w-8 h-px bg-spa-rose/55" aria-hidden="true"></span>
    </p>

    <h2 class="scroll-reveal mt-6 font-lora text-spa-creme leading-[1.1]" style="font-size: clamp(36px, 5.5vw, 64px);">
      Offrez-vous
      <span class="italic font-normal text-spa-rose">une parenthèse.</span>
    </h2>

    <p class="scroll-reveal mt-6 text-spa-creme/75 font-raleway leading-[1.8]">
      Trois heures de soin, une journée d'évasion, ou simplement un massage
      d'une heure. Le temps qu'il vous faut, on s'en occupe.
    </p>

    <div class="scroll-reveal mt-10">
      <a
        href="#reservation"
        class="inline-flex items-center justify-center h-14 px-9 text-sm font-semibold uppercase tracking-[0.22em] rounded-full bg-spa-terracotta text-spa-blanc hover:bg-spa-argile transition-colors"
        style="box-shadow: 0 12px 32px rgb(198 123 92 / 0.45);"
      >
        Réserver un soin
      </a>
    </div>
  </div>
</section>
