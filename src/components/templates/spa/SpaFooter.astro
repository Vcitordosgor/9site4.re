---
import data from '../../../data/templates/spa.json';
const year = new Date().getFullYear();
---

<footer class="bg-spa-cacao text-spa-creme/85 py-12 px-6 md:px-10 border-t border-spa-rose/15">
  <div class="max-w-content mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="flex items-baseline gap-2 leading-none">
          <span class="font-lora italic font-medium text-2xl text-spa-rose">{data.info.wordmark1}</span>
          <span class="font-raleway font-light uppercase tracking-[0.3em] text-xs text-spa-creme/85">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-lora italic text-spa-creme/65 text-sm">
          Saint-Pierre · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 text-sm font-raleway">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-spa-rose transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-flex w-1 h-1 rounded-full bg-spa-rose/40" aria-hidden="true"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-spa-rose transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <!-- Filet rose poudre séparateur -->
    <div class="mt-10 mb-6 h-px" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgb(232 201 184 / 0.4) 30%, rgb(232 201 184 / 0.4) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 text-xs uppercase tracking-[0.22em] text-spa-creme/70 font-raleway">
      <p>© {year} {data.info.nom}</p>
      <p>
        Site créé par
        <a href="/" class="font-semibold text-spa-creme hover:text-spa-rose transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
