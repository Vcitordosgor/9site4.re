---
/**
 * Cabines — gallerie bento asymétrique (4 photos verticales/horizontales
 * de tailles variées). Vraiment différent du salon (photo unique cadrée)
 * et de la pizzeria (cards rectangulaires alignés).
 */
import data from '../../../data/templates/spa.json';
---

<section id="cabines" class="relative bg-spa-cacao text-spa-creme py-24 md:py-36 px-6 md:px-10 overflow-hidden">
  <!-- Halo terracotta subtle -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-40 -left-40 w-[36rem] h-[36rem] rounded-full"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(198 123 92 / 0.15) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative max-w-content mx-auto">

    <!-- Header de section -->
    <header class="text-center max-w-2xl mx-auto mb-14 md:mb-20">
      <p class="scroll-reveal text-xs sm:text-sm uppercase tracking-[0.4em] text-spa-rose font-raleway font-medium">
        Le lieu
      </p>
      <h2 class="scroll-reveal mt-5 font-lora text-spa-creme leading-[1.1]" style="font-size: clamp(32px, 5vw, 52px);">
        Cabines insonorisées,
        <span class="italic font-normal text-spa-rose">lumière naturelle.</span>
      </h2>
      <p class="scroll-reveal mt-6 text-spa-creme/70 font-raleway leading-[1.8]">
        Trois cabines individuelles, une cabine duo, une tisanerie ouverte
        sur le jardin. Tout est pensé pour le silence.
      </p>
    </header>

    <!-- Bento asymétrique : 4 photos avec spans variables -->
    <!-- Mobile: empilement simple. Desktop: 12-col grid bento. -->
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-3 sm:gap-4 md:gap-5">
      <!-- Grande photo verticale gauche (cabine principale) — span 7×2 -->
      <figure class="scroll-reveal col-span-2 lg:col-span-7 lg:row-span-2 relative overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
        <img
          src={data.info.photoCabine1}
          alt={data.info.photoCabine1Alt}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
        />
        <figcaption class="absolute left-4 sm:left-6 bottom-4 sm:bottom-6 font-lora italic text-spa-creme text-base sm:text-lg" style="text-shadow: 0 2px 12px rgb(0 0 0 / 0.6);">
          La cabine signature
        </figcaption>
      </figure>

      <!-- Photo carrée pierres chaudes — span 5×1 -->
      <figure class="scroll-reveal col-span-1 lg:col-span-5 relative overflow-hidden rounded-sm" style="aspect-ratio: 4/3;">
        <img
          src={data.info.photoCabine2}
          alt={data.info.photoCabine2Alt}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
        />
      </figure>

      <!-- Photo carrée eucalyptus — span 5×1 -->
      <figure class="scroll-reveal col-span-1 lg:col-span-5 relative overflow-hidden rounded-sm" style="aspect-ratio: 4/3;">
        <img
          src={data.info.photoCabine3}
          alt={data.info.photoCabine3Alt}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
        />
      </figure>

      <!-- Photo horizontale tisanerie pleine largeur — span 12 -->
      <figure class="scroll-reveal col-span-2 lg:col-span-12 relative overflow-hidden rounded-sm" style="aspect-ratio: 21/9;">
        <img
          src={data.info.photoCabine4}
          alt={data.info.photoCabine4Alt}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
        />
        <figcaption class="absolute left-4 sm:left-6 bottom-4 sm:bottom-6 font-lora italic text-spa-creme text-base sm:text-lg" style="text-shadow: 0 2px 12px rgb(0 0 0 / 0.6);">
          La tisanerie · ouverte sur le jardin
        </figcaption>
      </figure>
    </div>
  </div>
</section>
