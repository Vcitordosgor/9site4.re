---
import data from '../../../data/templates/latitude.json';
---

<section id="auteur" class="bg-latitude-noir text-latitude-blanc py-20 md:py-28 relative overflow-hidden">

  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-center">

      <!-- Portrait typo -->
      <div class="md:col-span-5">
        <div class="relative aspect-[4/5] bg-latitude-charbon border border-latitude-or/40 flex items-center justify-center overflow-hidden">
          <div class="font-dm-serif text-latitude-or text-[280px] md:text-[340px] leading-none italic">AM</div>
          <div class="absolute top-5 left-5 font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-blanc/70">PORTRAIT N° 001</div>
          <div class="absolute bottom-5 right-5 text-right">
            <p class="font-caveat text-latitude-or text-3xl leading-none">A. Maillot</p>
            <p class="font-hanken text-[9.5px] uppercase tracking-[0.2em] text-latitude-blanc/60 mt-1">Saint-Denis · 2026</p>
          </div>
          <!-- Coins repérage style argentique -->
          <span class="absolute top-2 left-2 w-3 h-3 border-l border-t border-latitude-or/60" aria-hidden="true"></span>
          <span class="absolute top-2 right-2 w-3 h-3 border-r border-t border-latitude-or/60" aria-hidden="true"></span>
          <span class="absolute bottom-2 left-2 w-3 h-3 border-l border-b border-latitude-or/60" aria-hidden="true"></span>
          <span class="absolute bottom-2 right-2 w-3 h-3 border-r border-b border-latitude-or/60" aria-hidden="true"></span>
        </div>
      </div>

      <!-- Texte -->
      <div class="md:col-span-7">
        <p class="font-hanken text-[11px] uppercase tracking-[0.4em] text-latitude-or mb-4">✦ L'auteur</p>
        <h2 class="font-dm-serif text-latitude-blanc text-5xl md:text-6xl leading-[0.95] tracking-tight">
          {data.fondateur.nom}
        </h2>
        <p class="font-instrument italic text-latitude-or text-2xl md:text-3xl mt-2">
          {data.fondateur.titre}
        </p>

        <p class="mt-7 font-hanken text-[15px] md:text-base text-latitude-blanc/85 leading-relaxed">
          {data.fondateur.bio}
        </p>

        <blockquote class="mt-7 border-l-2 border-latitude-or pl-5 font-instrument italic text-2xl md:text-3xl text-latitude-blanc leading-snug">
          {data.fondateur.credo}
        </blockquote>

        <!-- Expositions -->
        <div class="mt-8 pt-6 border-t border-latitude-cendre/50">
          <p class="font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-or mb-3">Expositions sélectionnées</p>
          <ul class="space-y-2">
            {data.fondateur.expositions.map((e) => (
              <li class="flex gap-3 font-hanken text-[13.5px] text-latitude-blanc/85 leading-relaxed">
                <span class="text-latitude-or">✦</span><span>{e}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
