---
import data from '../../../data/templates/latitude.json';
const wa = `https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent("Bonjour Aurélien, je voudrais discuter d'un projet photo.")}`;
---

<section id="contact" class="bg-latitude-noir text-latitude-blanc py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14">

      <div class="md:col-span-7">
        <p class="font-hanken text-[11px] uppercase tracking-[0.4em] text-latitude-or mb-4">✦ Premier échange</p>
        <h2 class="font-dm-serif text-latitude-blanc text-5xl md:text-6xl leading-[0.95] tracking-tight">
          Parlons de<br/>
          <span class="italic text-latitude-or">votre image.</span>
        </h2>
        <p class="mt-6 font-hanken text-[15px] text-latitude-blanc/80 leading-relaxed max-w-xl">
          Décrivez le projet en quelques lignes (et si vous avez des images de référence, partagez-les). Je reviens sous 48h avec une note d'intention et un devis.
        </p>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href={`tel:${data.info.telephoneHref}`} class="group block p-5 bg-latitude-charbon border border-latitude-cendre hover:border-latitude-or transition-colors">
            <span class="font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-or">Téléphone</span>
            <p class="mt-1 font-dm-serif text-2xl text-latitude-blanc group-hover:text-latitude-or transition-colors">{data.info.telephone}</p>
          </a>
          <a href={`mailto:${data.info.email}`} class="group block p-5 bg-latitude-charbon border border-latitude-cendre hover:border-latitude-or transition-colors">
            <span class="font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-or">Email</span>
            <p class="mt-1 font-dm-serif text-lg text-latitude-blanc group-hover:text-latitude-or transition-colors break-all">{data.info.email}</p>
          </a>
        </div>

        <div class="mt-5">
          <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 h-12 px-6 bg-latitude-labo text-latitude-blanc font-hanken font-semibold text-[12px] uppercase tracking-[0.2em] hover:opacity-90 transition-opacity">
            ✦ WhatsApp · réponse studio sous 24h
          </a>
        </div>
      </div>

      <div class="md:col-span-5">
        <div class="bg-latitude-charbon border border-latitude-or/40 p-6 md:p-7 h-full flex flex-col">
          <div class="flex items-center justify-between pb-4 mb-4 border-b border-latitude-cendre/60">
            <p class="font-caveat text-latitude-or text-2xl leading-none">— Le studio</p>
            <p class="font-hanken text-[10px] uppercase tracking-wider text-latitude-blanc/50">SIRET · {data.info.siret.slice(-5)}</p>
          </div>

          <p class="font-dm-serif text-latitude-blanc text-2xl leading-tight">{data.info.adresseLigne1}</p>
          <p class="font-dm-serif text-latitude-blanc text-2xl leading-tight">{data.info.adresseLigne2}</p>

          <div class="mt-6 pt-5 border-t border-latitude-cendre/60 space-y-2 font-hanken text-[13px]">
            <div class="flex justify-between gap-3">
              <span class="text-[10px] uppercase tracking-wider text-latitude-or">Studio (sur RDV)</span>
              <span class="text-latitude-blanc">Mardi → samedi</span>
            </div>
            <div class="flex justify-between gap-3">
              <span class="text-[10px] uppercase tracking-wider text-latitude-or">Reportage extérieur</span>
              <span class="text-latitude-blanc">7j/7 sur calage</span>
            </div>
            <div class="flex justify-between gap-3">
              <span class="text-[10px] uppercase tracking-wider text-latitude-or">Instagram</span>
              <span class="text-latitude-blanc">{data.info.instagram}</span>
            </div>
          </div>

          <div class="mt-auto pt-7">
            <p class="font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-or mb-2">Tirages d'art</p>
            <p class="font-instrument italic text-latitude-blanc text-lg leading-snug">
              {data.infosCles.tiragesEditesAn} tirages baryté édités par an · numérotés et signés au crayon graphite.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
