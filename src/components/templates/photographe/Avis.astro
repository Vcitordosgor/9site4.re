---
import data from '../../../data/templates/latitude.json';
---

<section class="bg-latitude-papier text-latitude-noir py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="max-w-2xl mb-14 md:mb-16">
      <p class="font-hanken text-[11px] uppercase tracking-[0.4em] text-latitude-or mb-4">✦ Quelques retours</p>
      <h2 class="font-dm-serif text-latitude-noir text-5xl md:text-6xl leading-[0.95] tracking-tight">
        Trois clients,<br/>
        <span class="italic text-latitude-or">trois projets.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-7">
      {data.avis.map((a) => (
        <article class="bg-latitude-creme border border-latitude-or/40 p-7 md:p-8 flex flex-col relative">
          <span class="absolute top-3 right-5 font-dm-serif italic text-latitude-or/30 text-7xl leading-none" aria-hidden="true">"</span>

          <div class="flex gap-1 text-latitude-or text-base mb-4" aria-label={`${a.etoiles} étoiles`}>
            {Array.from({ length: a.etoiles }).map(() => <span>★</span>)}
          </div>

          <blockquote class="flex-1 font-instrument italic text-[16.5px] md:text-[17px] text-latitude-noir/90 leading-relaxed">
            {a.texte}
          </blockquote>

          <div class="mt-5 pt-4 border-t border-latitude-or/40">
            <p class="font-dm-serif text-latitude-noir text-xl leading-tight">{a.prenom}</p>
            <p class="font-hanken text-[10.5px] uppercase tracking-[0.2em] text-latitude-or mt-1">{a.metier}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
