---
import data from '../../../data/templates/latitude.json';
---

<section id="series" class="bg-latitude-papier text-latitude-noir py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">

    <div class="max-w-2xl mb-14 md:mb-20">
      <p class="font-hanken text-[11px] uppercase tracking-[0.4em] text-latitude-or mb-4">✦ Catalogue des séries</p>
      <h2 class="font-dm-serif text-latitude-noir text-5xl md:text-6xl leading-[0.95] tracking-tight">
        Quatre formats,<br/>
        <span class="italic text-latitude-or">une exigence.</span>
      </h2>
    </div>

    <ul class="space-y-12 md:space-y-16">
      {data.series.map((s, i) => (
        <li class={`grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-start ${i % 2 === 1 ? 'md:[&>:first-child]:order-2' : ''}`}>

          <!-- Plaque-cartouche n° + format -->
          <div class="md:col-span-4">
            <div class="bg-latitude-noir text-latitude-blanc p-6 relative">
              <!-- Encoches sprocket décoratives -->
              <div class="absolute top-1.5 inset-x-2 flex justify-around" aria-hidden="true">
                {Array.from({length:8}).map(()=>(<span class="block w-2 h-1.5 bg-latitude-charbon rounded-sm"></span>))}
              </div>
              <div class="absolute bottom-1.5 inset-x-2 flex justify-around" aria-hidden="true">
                {Array.from({length:8}).map(()=>(<span class="block w-2 h-1.5 bg-latitude-charbon rounded-sm"></span>))}
              </div>

              <div class="py-6">
                <p class="font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-or mb-2">{s.code}</p>
                <h3 class="font-dm-serif text-latitude-blanc text-3xl md:text-4xl leading-tight tracking-tight">
                  {s.titre}
                </h3>
                <p class="font-instrument italic text-latitude-or text-xl mt-1">{s.tagline}</p>

                <ul class="mt-5 pt-5 border-t border-latitude-cendre/40 space-y-1.5 font-hanken text-[12px]">
                  <li><span class="text-latitude-or/85 uppercase tracking-wider text-[10px]">Format</span><br/>{s.format}</li>
                  <li><span class="text-latitude-or/85 uppercase tracking-wider text-[10px]">Durée</span><br/>{s.duree}</li>
                  <li><span class="text-latitude-or/85 uppercase tracking-wider text-[10px]">Livraison</span><br/>{s.livraison}</li>
                </ul>

                <p class="mt-5 pt-4 border-t border-latitude-cendre/40 font-dm-serif text-latitude-blanc text-2xl md:text-[26px]">
                  {s.prix}
                </p>
              </div>
            </div>
          </div>

          <!-- Description + moments -->
          <div class="md:col-span-8">
            <p class="font-hanken text-[10px] uppercase tracking-[0.3em] text-latitude-or mb-3">Série n°{String(i+1).padStart(2,'0')}</p>
            <p class="font-hanken text-[15.5px] md:text-base text-latitude-noir/85 leading-relaxed max-w-xl">
              {s.description}
            </p>

            <div class="mt-7">
              <p class="font-hanken text-[10px] uppercase tracking-[0.25em] text-latitude-noir/55 mb-3">— Sujets / moments couverts</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {s.moments.map((m) => (
                  <li class="flex items-center gap-2.5 font-instrument italic text-lg text-latitude-noir/85">
                    <span class="text-latitude-or">✦</span> {m}
                  </li>
                ))}
              </ul>
            </div>

            <a
              href={`https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent(`Bonjour Aurélien, je voudrais discuter d'un projet : ${s.titre}.`)}`}
              target="_blank"
              rel="noopener"
              class="mt-7 inline-flex items-center justify-center h-11 px-6 bg-latitude-noir text-latitude-blanc font-hanken font-semibold text-[12px] uppercase tracking-[0.18em] hover:bg-latitude-or hover:text-latitude-noir transition-colors"
            >
              Discuter ce projet ✦
            </a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
