---
/**
 * CTAFinal — manifesto closer minimal et brutal.
 * Une seule question monumentale + un seul CTA. Pas d'ornements.
 */
import data from '../../../data/templates/foudre.json';
---

<section class="bg-coach-lime py-24 md:py-36 px-5 md:px-8 text-coach-noir">
  <div class="max-w-content mx-auto text-center">

    <p class="font-jetbrains text-[11px] uppercase tracking-widest text-coach-noir/60 mb-8">
      [ {data.info.wordmark} · 974 ]
    </p>

    <h2 class="font-big-shoulders font-black uppercase leading-[0.85] mb-10" style="font-size: clamp(64px, 12vw, 200px);">
      On commence<br/>quand ?
    </h2>

    <a
      href="#essai"
      class="inline-flex items-center justify-center h-16 px-12 bg-coach-noir text-coach-lime font-big-shoulders font-bold text-lg uppercase tracking-wider hover:bg-coach-charbon transition-colors"
    >
      Réserver maintenant
      <svg class="ml-3" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" aria-hidden="true">
        <path d="M5 12h14M14 5l7 7-7 7"/>
      </svg>
    </a>

    <p class="mt-8 font-barlow text-coach-noir/70 text-sm">
      Première séance offerte · Aucune carte demandée
    </p>

  </div>
</section>
