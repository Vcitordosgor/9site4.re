---
/**
 * Programmes — fiches-séances en bandeaux empilés horizontaux.
 * PAS de grille de cards uniformes. Chaque programme = strip pleine largeur
 * avec layout split (nom · durée · intensité barre · lieu · prix).
 * Hover : translate-x + bordure gauche lime.
 */
import data from '../../../data/templates/foudre.json';
---

<section id="programmes" class="bg-coach-noir py-20 md:py-28 px-5 md:px-8">
  <div class="max-w-content mx-auto">

    <!-- Header section : numéro + titre alignés à gauche -->
    <header class="flex items-baseline gap-4 mb-12 md:mb-16">
      <span class="font-jetbrains text-coach-lime text-sm">[01]</span>
      <h2 class="font-big-shoulders font-black text-coach-blanc uppercase leading-none" style="font-size: clamp(40px, 6vw, 72px);">
        Les programmes
      </h2>
    </header>

    <!-- Bandeaux empilés -->
    <ul class="border-t border-coach-blanc/10">
      {data.programmes.map((p) => (
        <li class="programme-band group border-b border-coach-blanc/10">
          <a href="#essai" class="grid grid-cols-12 gap-4 md:gap-6 items-center py-6 md:py-8 px-2 md:px-6 hover:bg-coach-charbon hover:pl-4 md:hover:pl-10 transition-all duration-200 relative">

            <!-- Trait gauche lime au hover -->
            <span class="absolute left-0 top-0 bottom-0 w-1 bg-coach-lime scale-y-0 group-hover:scale-y-100 origin-center transition-transform duration-200"></span>

            <!-- Nom programme -->
            <div class="col-span-12 md:col-span-3">
              <p class="font-jetbrains text-[10px] uppercase tracking-widest text-coach-gris mb-1">{p.id.padStart(2, '0')}</p>
              <p class="font-big-shoulders font-black text-coach-blanc group-hover:text-coach-lime uppercase leading-none transition-colors" style="font-size: clamp(28px, 3.5vw, 44px);">
                {p.nom}
              </p>
            </div>

            <!-- Description -->
            <p class="col-span-12 md:col-span-4 font-barlow text-coach-blanc/65 text-sm md:text-base leading-relaxed">
              {p.description}
            </p>

            <!-- Métadonnées : durée + intensité + lieu -->
            <div class="col-span-8 md:col-span-3 flex flex-col gap-2 font-jetbrains text-[11px] uppercase tracking-wide">
              <div class="flex items-center justify-between">
                <span class="text-coach-gris">Durée</span>
                <span class="text-coach-blanc">{p.duree}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-coach-gris">Intensité</span>
                <span class="flex gap-1" aria-label={`Intensité ${p.intensite} sur 3`}>
                  {[1, 2, 3].map((n) => (
                    <span class:list={['block w-3 h-1.5', n <= p.intensite ? 'bg-coach-lime' : 'bg-coach-blanc/15']}></span>
                  ))}
                </span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-coach-gris">Lieu</span>
                <span class="text-coach-blanc text-right">{p.lieu}</span>
              </div>
            </div>

            <!-- Prix + flèche -->
            <div class="col-span-4 md:col-span-2 text-right">
              <p class="font-big-shoulders font-black text-coach-blanc group-hover:text-coach-lime leading-none transition-colors" style="font-size: clamp(22px, 2.5vw, 32px);">
                {p.prix}
              </p>
              <p class="font-jetbrains text-[10px] uppercase tracking-widest text-coach-gris mt-1">{p.frequence}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
