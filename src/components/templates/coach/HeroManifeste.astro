---
/**
 * HeroManifeste — pas de photo plein écran. Layout asymétrique :
 * - À gauche : citation impérative oversized en Big Shoulders 900 uppercase
 * - À droite : photo recadrée portrait (4:5) + 3 stats stackées en JetBrains Mono
 * Mobile : H1 → photo → stats horizontales → CTA.
 */
import data from '../../../data/templates/foudre.json';
---

<section id="top" class="relative bg-coach-noir text-coach-blanc pt-24 pb-12 md:pt-32 md:pb-20 px-5 md:px-8 overflow-hidden">

  <!-- Bandeau supérieur : badge année + lieu -->
  <div class="max-w-content mx-auto mb-10 md:mb-16 flex items-center justify-between font-jetbrains text-[11px] tracking-widest text-coach-gris">
    <span>EST. {data.info.annee}</span>
    <span class="flex items-center gap-2">
      <span class="block w-1.5 h-1.5 bg-coach-lime"></span>
      {data.info.ville}
    </span>
  </div>

  <div class="max-w-content mx-auto grid lg:grid-cols-12 gap-8 lg:gap-12 items-end">

    <!-- Colonne gauche : H1 manifeste -->
    <div class="lg:col-span-7">
      <h1 class="font-big-shoulders font-black uppercase text-coach-blanc leading-[0.85] tracking-tight" style="font-size: clamp(56px, 11vw, 168px);">
        Ton corps<br/>
        <span class="text-coach-blanc">mérite mieux</span><br/>
        <span class="block">que des</span>
        <span class="text-coach-lime">excuses.</span>
      </h1>

      <!-- Description courte tutoiement -->
      <p class="mt-8 font-barlow text-coach-blanc/65 leading-relaxed max-w-md text-base md:text-lg">
        Coach certifié à Saint-Pierre. <span class="text-coach-blanc">À domicile, sur la plage, ou en salle.</span> On commence quand tu veux — la séance d'essai est offerte.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="#essai"
          class="inline-flex items-center justify-center h-14 px-8 bg-coach-lime text-coach-noir font-big-shoulders font-bold text-base uppercase tracking-wider hover:bg-coach-blanc transition-colors"
        >
          Réserver ma séance d'essai
          <svg class="ml-2" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" aria-hidden="true">
            <path d="M5 12h14M14 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href={`tel:${data.info.telephoneHref}`}
          class="inline-flex items-center h-14 px-6 border border-coach-blanc/25 text-coach-blanc/80 font-jetbrains text-sm hover:border-coach-lime hover:text-coach-lime transition-colors"
        >
          {data.info.telephone}
        </a>
      </div>
    </div>

    <!-- Colonne droite : photo + stats -->
    <div class="lg:col-span-5 lg:pl-8">
      <div class="relative aspect-[4/5] max-w-[420px] mx-auto lg:mx-0 lg:ml-auto bg-coach-graphite overflow-hidden">
        <img
          src={data.info.photoHero} srcset={`${(data.info.photoHero).replace(/\.webp$/, "-640.webp")} 640w, ${(data.info.photoHero).replace(/\.webp$/, "-1024.webp")} 1024w, ${data.info.photoHero} 1600w`} sizes="100vw"
          alt=""
          class="w-full h-full object-cover object-center grayscale contrast-110" loading="eager" fetchpriority="high" decoding="async">
        <!-- Overlay lime en bas -->
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-coach-lime"></div>
        <!-- Étiquette coach -->
        <div class="absolute top-4 left-4 bg-coach-noir/85 backdrop-blur-sm px-3 py-1.5">
          <p class="font-jetbrains text-[10px] uppercase tracking-widest text-coach-lime">Coach</p>
          <p class="font-big-shoulders font-bold text-coach-blanc text-sm uppercase">{data.info.coach}</p>
        </div>
      </div>

      <!-- Stats stackées sous la photo (desktop) / horizontales (mobile) -->
      <div class="mt-6 lg:max-w-[420px] lg:ml-auto grid grid-cols-3 lg:grid-cols-1 gap-4 lg:gap-3 lg:divide-y lg:divide-coach-blanc/10">
        {data.stats.map((s, i) => (
          <div class:list={['flex lg:items-baseline lg:justify-between flex-col lg:flex-row', i > 0 ? 'lg:pt-3' : '']}>
            <span class="font-big-shoulders font-black text-coach-lime text-3xl md:text-4xl lg:text-5xl leading-none tabular-nums" data-counter={s.valeur}>
              {s.valeur}
            </span>
            <span class="mt-1 lg:mt-0 font-jetbrains text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-coach-gris lg:text-right">
              {s.label}
            </span>
          </div>
        ))}
      </div>
    </div>

  </div>

  <!-- Bandeau 'Programme de la semaine' façon signage de salle de sport.
       Touche WOD pro, monospace JetBrains, full-width. -->
  <div class="mt-12 md:mt-16 -mx-5 md:-mx-8 px-5 md:px-10 py-4 md:py-5 border-t border-coach-lime/40 bg-coach-noir">
    <div class="max-w-content mx-auto flex items-center gap-4 md:gap-6 overflow-x-auto">
      <span class="flex items-center gap-2 shrink-0 font-jetbrains text-[10px] md:text-[11px] uppercase tracking-[0.22em] text-coach-lime">
        <span class="block w-1.5 h-1.5 bg-coach-lime rounded-full" aria-hidden="true"></span>
        Programme de la semaine
      </span>
      <ul class="flex items-center gap-x-5 md:gap-x-8 font-jetbrains text-[11px] md:text-[12px] text-coach-blanc/85 whitespace-nowrap">
        {[
          { jour: 'LUN', wod: 'squat 5×5' },
          { jour: 'MAR', wod: 'hiit 30 min' },
          { jour: 'MER', wod: 'repos' },
          { jour: 'JEU', wod: 'push & pull' },
          { jour: 'VEN', wod: 'cardio sprint' },
          { jour: 'SAM', wod: 'mobilité' },
          { jour: 'DIM', wod: 'off' },
        ].map((d) => (
          <li class="flex items-baseline gap-1.5">
            <span class="text-coach-lime font-bold">{d.jour}</span>
            <span class="text-coach-blanc/55">—</span>
            <span class="lowercase">{d.wod}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
