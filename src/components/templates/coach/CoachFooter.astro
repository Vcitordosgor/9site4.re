---
import data from '../../../data/templates/foudre.json';
const year = new Date().getFullYear();
---

<footer class="bg-coach-noir text-coach-blanc/70 py-12 px-5 md:px-8 border-t border-coach-blanc/10">
  <div class="max-w-content mx-auto">

    <div class="grid md:grid-cols-12 gap-8 mb-10">

      <!-- Wordmark + tagline -->
      <div class="md:col-span-5">
        <p class="flex items-baseline gap-1">
          <span class="font-big-shoulders font-black text-coach-blanc text-3xl tracking-tight leading-none">{data.info.wordmark}</span>
          <span class="font-jetbrains text-coach-lime text-xs">/974</span>
        </p>
        <p class="mt-3 font-barlow text-coach-blanc/55 text-sm max-w-xs leading-relaxed">
          Coaching sportif personnalisé à La Réunion. {data.info.coach}, certifié {data.info.certification}.
        </p>
      </div>

      <!-- Contact -->
      <div class="md:col-span-3">
        <p class="font-jetbrains text-[10px] uppercase tracking-widest text-coach-lime mb-3">Contact</p>
        <ul class="space-y-2 font-barlow text-sm">
          <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-coach-lime transition-colors tabular-nums">{data.info.telephone}</a></li>
          <li><a href={`mailto:${data.info.email}`} class="hover:text-coach-lime transition-colors break-all">{data.info.email}</a></li>
          <li class="text-coach-blanc/60">{data.info.instagram}</li>
        </ul>
      </div>

      <!-- Plan -->
      <div class="md:col-span-4">
        <p class="font-jetbrains text-[10px] uppercase tracking-widest text-coach-lime mb-3">Plan</p>
        <ul class="grid grid-cols-2 gap-y-2 font-barlow text-sm">
          <li><a href="#programmes" class="hover:text-coach-lime transition-colors">Programmes</a></li>
          <li><a href="#tarifs" class="hover:text-coach-lime transition-colors">Tarifs</a></li>
          <li><a href="#transformations" class="hover:text-coach-lime transition-colors">Résultats</a></li>
          <li><a href="#essai" class="hover:text-coach-lime transition-colors">Séance d'essai</a></li>
        </ul>
      </div>
    </div>

    <!-- Filet lime + signature -->
    <div class="h-px bg-coach-blanc/10 mb-6"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-jetbrains text-[10px] uppercase tracking-widest text-coach-blanc/40">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-coach-blanc/70 hover:text-coach-lime transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
