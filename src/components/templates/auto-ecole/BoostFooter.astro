---
import data from '../../../data/templates/boost.json';
const year = new Date().getFullYear();
---

<footer class="bg-boost-noir text-boost-route/75 py-12 px-5 md:px-8">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-1.5">
          <span class="inline-flex items-center justify-center w-7 h-7 bg-boost-jaune text-boost-noir rounded-full text-sm font-funnel-display font-bold">B</span>
          <span class="font-funnel-display font-bold text-boost-route text-xl tracking-tight">{data.info.wordmark}</span>
          <span class="font-funnel-display font-light text-boost-route/65 text-xl tracking-tight">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-geist-mono text-[11px] text-boost-route/55">
          ▸ {data.info.adresseLigne1} · {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-funnel-sans text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-boost-jaune transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-boost-jaune" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-boost-jaune transition-colors break-all">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-boost-jaune" aria-hidden="true"></li>
        <li class="text-boost-jaune">{data.info.instagram}</li>
      </ul>
    </div>

    <!-- Filet jaune -->
    <div class="h-1 mb-6 bg-boost-jaune" aria-hidden="true"></div>

    <!-- Mention agrément obligatoire -->
    <p class="mb-6 font-geist-mono text-[10px] uppercase tracking-[0.22em] text-boost-route/55">
      ✓ {data.info.agrement} · Centre agréé conduite supervisée et accompagnée (AAC)
    </p>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-geist-mono text-[10px] uppercase tracking-[0.22em] text-boost-route/45">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        ▸ Site
        <a href="/" class="text-boost-jaune hover:text-boost-route transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
