---
import data from '../../../data/templates/boost.json';

// Avatars graphiques (substitut aux portraits Unsplash stock recyclés sur
// d'autres templates). Cycle de 4 couleurs route ⇄ jaune ⇄ feu ⇄ acier.
const avatarVariants = [
  'bg-boost-noir text-boost-jaune',
  'bg-boost-jaune text-boost-noir',
  'bg-boost-feu text-boost-route',
  'bg-boost-acier text-boost-route',
];
---

<section id="moniteurs" class="bg-boost-route py-20 md:py-28 px-5 md:px-8 border-t-4 border-boost-jaune">
  <div class="max-w-content mx-auto">

    <header class="mb-12 md:mb-16 max-w-2xl">
      <p class="font-geist-mono text-[10px] uppercase tracking-[0.28em] text-boost-feu mb-4 font-medium">
        ▸ L'équipe
      </p>
      <h2 class="font-funnel-display font-bold text-boost-noir leading-[0.95] tracking-tight" style="font-size: clamp(40px, 7vw, 88px);">
        Quatre moniteurs.<br/>
        <span class="text-boost-feu">Quatre styles.</span>
      </h2>
    </header>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {data.moniteurs.map((m, i) => (
        <li class="group">
          <article class="bg-boost-jaune/15 hover:bg-boost-jaune p-5 rounded-3xl transition-colors h-full flex flex-col">

            <!-- Avatar graphique : cercle initiale + ring noir épais (rappel panneau routier) -->
            <div
              class:list={[
                'relative w-24 h-24 mx-auto mb-5 rounded-full overflow-hidden ring-4 ring-boost-noir flex items-center justify-center',
                avatarVariants[i % avatarVariants.length],
              ]}
              role="img"
              aria-label={`Avatar de ${m.prenom}`}
            >
              <span
                class="font-funnel-display font-black leading-none select-none"
                style="font-size: 44px;"
                aria-hidden="true"
              >
                {m.prenom.charAt(0)}
              </span>
              <!-- Mini-pastille feu en haut-droite (signal panneau) -->
              <span class="absolute top-0 right-0 w-3 h-3 rounded-full bg-boost-feu ring-2 ring-boost-route" aria-hidden="true"></span>
            </div>

            <!-- Identité -->
            <p class="text-center font-funnel-display font-bold text-boost-noir text-2xl leading-tight">
              {m.prenom}
            </p>
            <p class="mt-1 text-center font-geist-mono text-[10px] uppercase tracking-wider text-boost-asphalte">
              ▸ {m.experience} d'expérience
            </p>

            <!-- Spécialité badge -->
            <p class="mt-4 inline-block bg-boost-noir text-boost-jaune font-funnel-display font-bold text-xs uppercase tracking-wider px-3 py-1.5 rounded-full self-center">
              {m.specialite}
            </p>

            <!-- Trait -->
            <p class="mt-4 pt-4 border-t border-boost-noir/15 font-funnel-sans italic text-boost-asphalte text-sm leading-relaxed text-center flex-1">
              {m.trait}
            </p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>
