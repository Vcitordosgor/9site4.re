---
/**
 * HeroPizzaScene — composition hero premium :
 * - Photo pizza centrale (légèrement décalée)
 * - 6 ingrédients SVG détourés flottants autour, profondeurs variées
 * - Parallaxe mousemove (desktop) avec retour fluide
 * - Flottement autonome continu (subtil) sur chaque élément
 * - Désactivé sous prefers-reduced-motion (composition statique)
 *
 * Pour remplacer les SVG par tes vrais PNG détourés : remplace
 * chaque <svg>...</svg> par <img src="/templates/pizzeria/ingredients/X.png" />.
 */
---

<div
  class="pizza-scene relative w-full h-[360px] md:h-[540px] mx-auto"
  data-pizza-scene
>
  <!-- ======== Pizza centrale ======== -->
  <div class="pizza-main absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[280px] md:w-[420px] aspect-square">
    <div class="parallax-layer" data-depth="0.4">
      <div class="float-layer" style="--float-delay: 0s; --float-amp: 6px;">
        <img
          src="https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=800&q=80"
          alt="Pizza Margherita au four à bois"
          width="420"
          height="420"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="w-full h-full object-cover rounded-full"
          style="box-shadow: 0 30px 90px rgba(0,0,0,0.55), 0 8px 20px rgba(200,16,46,0.15);"
        />
      </div>
    </div>
  </div>

  <!-- ======== Ingrédients flottants — 6 SVG détourés ======== -->
  <!-- Olive verte (top-left, profond, bouge plus) -->
  <div class="ing absolute" style="top: 6%; left: 4%;" aria-hidden="true">
    <div class="parallax-layer" data-depth="1.5">
      <div class="float-layer" style="--float-delay: 0s; --float-amp: 10px;" style:rotate="-12deg">
        <svg viewBox="0 0 60 60" class="w-[44px] md:w-[64px] h-auto" style="filter: drop-shadow(0 8px 16px rgba(0,0,0,0.5));">
          <defs>
            <radialGradient id="olive-g" cx="38%" cy="28%" r="72%">
              <stop offset="0%" stop-color="#B5D087"/>
              <stop offset="55%" stop-color="#5D8A2E"/>
              <stop offset="100%" stop-color="#2A4710"/>
            </radialGradient>
          </defs>
          <ellipse cx="30" cy="30" rx="20" ry="26" fill="url(#olive-g)"/>
          <ellipse cx="22" cy="18" rx="5" ry="3" fill="#FFFFFF" opacity="0.45" transform="rotate(-25 22 18)"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Feuille de basilic (top-right, depth moyen) -->
  <div class="ing absolute" style="top: 10%; right: 2%;" aria-hidden="true">
    <div class="parallax-layer" data-depth="0.8">
      <div class="float-layer" style="--float-delay: 0.7s; --float-amp: 8px;">
        <svg viewBox="0 0 60 60" class="w-[56px] md:w-[80px] h-auto" style="filter: drop-shadow(0 8px 16px rgba(0,0,0,0.45)); transform: rotate(18deg);">
          <defs>
            <linearGradient id="basil-g" x1="20%" y1="10%" x2="80%" y2="90%">
              <stop offset="0%" stop-color="#7AB58A"/>
              <stop offset="55%" stop-color="#2D6A4F"/>
              <stop offset="100%" stop-color="#0F3525"/>
            </linearGradient>
          </defs>
          <path d="M30 4 Q12 14 10 30 Q14 52 30 56 Q46 52 50 30 Q48 14 30 4 Z" fill="url(#basil-g)"/>
          <path d="M30 4 L30 56" stroke="#0F3525" stroke-width="0.8" fill="none" opacity="0.65"/>
          <path d="M30 16 Q22 19 17 26" stroke="#0F3525" stroke-width="0.5" fill="none" opacity="0.55"/>
          <path d="M30 16 Q38 19 43 26" stroke="#0F3525" stroke-width="0.5" fill="none" opacity="0.55"/>
          <path d="M30 30 Q22 33 16 39" stroke="#0F3525" stroke-width="0.5" fill="none" opacity="0.55"/>
          <path d="M30 30 Q38 33 44 39" stroke="#0F3525" stroke-width="0.5" fill="none" opacity="0.55"/>
          <path d="M30 44 Q24 46 20 50" stroke="#0F3525" stroke-width="0.4" fill="none" opacity="0.55"/>
          <path d="M30 44 Q36 46 40 50" stroke="#0F3525" stroke-width="0.4" fill="none" opacity="0.55"/>
          <ellipse cx="22" cy="20" rx="5" ry="2" fill="#FFFFFF" opacity="0.20" transform="rotate(-25 22 20)"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Rondelle de tomate (mid-left) -->
  <div class="ing absolute" style="top: 50%; left: -2%;" aria-hidden="true">
    <div class="parallax-layer" data-depth="1.2">
      <div class="float-layer" style="--float-delay: 1.4s; --float-amp: 12px;">
        <svg viewBox="0 0 60 60" class="w-[52px] md:w-[72px] h-auto" style="filter: drop-shadow(0 8px 16px rgba(0,0,0,0.5));">
          <defs>
            <radialGradient id="tom-g" cx="38%" cy="32%" r="68%">
              <stop offset="0%" stop-color="#FF8B8B"/>
              <stop offset="60%" stop-color="#E63946"/>
              <stop offset="100%" stop-color="#9C0E1F"/>
            </radialGradient>
          </defs>
          <circle cx="30" cy="30" r="26" fill="url(#tom-g)"/>
          <ellipse cx="22" cy="22" rx="2.5" ry="3.4" fill="#FFE5BC" opacity="0.85"/>
          <ellipse cx="38" cy="22" rx="2.5" ry="3.4" fill="#FFE5BC" opacity="0.85"/>
          <ellipse cx="22" cy="38" rx="2.5" ry="3.4" fill="#FFE5BC" opacity="0.85"/>
          <ellipse cx="38" cy="38" rx="2.5" ry="3.4" fill="#FFE5BC" opacity="0.85"/>
          <ellipse cx="30" cy="30" rx="2.5" ry="3.4" fill="#FFE5BC" opacity="0.85"/>
          <ellipse cx="22" cy="18" rx="6" ry="3" fill="#FFFFFF" opacity="0.45" transform="rotate(-30 22 18)"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Champignon (mid-right) -->
  <div class="ing absolute" style="top: 45%; right: -3%;" aria-hidden="true">
    <div class="parallax-layer" data-depth="1.0">
      <div class="float-layer" style="--float-delay: 2.1s; --float-amp: 10px;">
        <svg viewBox="0 0 60 60" class="w-[50px] md:w-[68px] h-auto" style="filter: drop-shadow(0 8px 16px rgba(0,0,0,0.45)); transform: rotate(-8deg);">
          <defs>
            <radialGradient id="mush-cap" cx="40%" cy="28%" r="70%">
              <stop offset="0%" stop-color="#DDB68C"/>
              <stop offset="60%" stop-color="#9C7344"/>
              <stop offset="100%" stop-color="#4A3318"/>
            </radialGradient>
          </defs>
          <!-- Pied -->
          <path d="M22 35 L23 54 Q23 56 25 56 L35 56 Q37 56 37 54 L38 35 Z" fill="#FAF0D7"/>
          <path d="M22 35 L23 54 Q23 56 25 56 L35 56 Q37 56 37 54 L38 35 Z" fill="#9C7344" opacity="0.10"/>
          <!-- Chapeau -->
          <path d="M8 30 Q10 10 30 10 Q50 10 52 30 Q52 38 46 38 L14 38 Q8 38 8 30 Z" fill="url(#mush-cap)"/>
          <ellipse cx="20" cy="20" rx="6" ry="3" fill="#FFFFFF" opacity="0.40" transform="rotate(-30 20 20)"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Pepperoni (bottom-left, plus proche) -->
  <div class="ing absolute" style="bottom: 6%; left: 12%;" aria-hidden="true">
    <div class="parallax-layer" data-depth="1.4">
      <div class="float-layer" style="--float-delay: 2.8s; --float-amp: 12px;">
        <svg viewBox="0 0 60 60" class="w-[54px] md:w-[76px] h-auto" style="filter: drop-shadow(0 8px 16px rgba(0,0,0,0.5)); transform: rotate(15deg);">
          <defs>
            <radialGradient id="pepp-g" cx="35%" cy="30%" r="72%">
              <stop offset="0%" stop-color="#E2604E"/>
              <stop offset="55%" stop-color="#A82A1F"/>
              <stop offset="100%" stop-color="#5C140C"/>
            </radialGradient>
          </defs>
          <circle cx="30" cy="30" r="26" fill="url(#pepp-g)"/>
          <!-- Taches grasses -->
          <circle cx="20" cy="25" r="2.6" fill="#FFF1D6" opacity="0.55"/>
          <circle cx="38" cy="22" r="2.2" fill="#FFF1D6" opacity="0.55"/>
          <circle cx="42" cy="38" r="3" fill="#FFF1D6" opacity="0.50"/>
          <circle cx="22" cy="40" r="2.2" fill="#FFF1D6" opacity="0.55"/>
          <circle cx="32" cy="33" r="1.6" fill="#FFF1D6" opacity="0.45"/>
          <ellipse cx="22" cy="20" rx="6" ry="3" fill="#FFFFFF" opacity="0.30" transform="rotate(-30 22 20)"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Cube de fromage (bottom-right) -->
  <div class="ing absolute" style="bottom: 10%; right: 8%;" aria-hidden="true">
    <div class="parallax-layer" data-depth="0.7">
      <div class="float-layer" style="--float-delay: 3.5s; --float-amp: 8px;">
        <svg viewBox="0 0 60 60" class="w-[48px] md:w-[64px] h-auto" style="filter: drop-shadow(0 8px 16px rgba(0,0,0,0.5)); transform: rotate(-10deg);">
          <defs>
            <linearGradient id="cheese-front" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#FFE082"/>
              <stop offset="100%" stop-color="#D49A2E"/>
            </linearGradient>
            <linearGradient id="cheese-top" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#FFEFB0"/>
              <stop offset="100%" stop-color="#E8C66A"/>
            </linearGradient>
            <linearGradient id="cheese-side" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#C9881C"/>
              <stop offset="100%" stop-color="#8E5F0E"/>
            </linearGradient>
          </defs>
          <!-- Face arrière (latérale) -->
          <path d="M48 18 L52 12 L52 44 L48 50 Z" fill="url(#cheese-side)"/>
          <!-- Face supérieure (perspective) -->
          <path d="M8 12 L52 12 L48 18 L12 18 Z" fill="url(#cheese-top)"/>
          <!-- Face avant -->
          <path d="M12 18 L48 18 L48 50 L12 50 Z" fill="url(#cheese-front)"/>
          <!-- Trous emmental -->
          <ellipse cx="22" cy="32" rx="3" ry="2.3" fill="#A87B0F" opacity="0.55"/>
          <ellipse cx="36" cy="38" rx="3.2" ry="2.5" fill="#A87B0F" opacity="0.55"/>
          <ellipse cx="40" cy="26" rx="2.5" ry="2" fill="#A87B0F" opacity="0.50"/>
          <ellipse cx="20" cy="44" rx="2" ry="1.5" fill="#A87B0F" opacity="0.50"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<style>
  /* ======== Parallax (mousemove) ======== */
  /* Custom properties pilotées par le JS, transition douce pour retour fluide. */
  .parallax-layer {
    --tx: 0px;
    --ty: 0px;
    transform: translate3d(var(--tx), var(--ty), 0);
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  /* ======== Flottement autonome continu ======== */
  /* Animation infinie subtile, amplitude et délai paramétrables via CSS vars. */
  @keyframes gentle-float {
    0%, 100% { transform: translate3d(0, calc(var(--float-amp, 8px) * -0.5), 0); }
    50%      { transform: translate3d(0, calc(var(--float-amp, 8px) * 0.5), 0); }
  }
  .float-layer {
    animation: gentle-float 5s ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
    will-change: transform;
  }

  /* ======== Apparition initiale staggered ======== */
  @keyframes scene-fade-in {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }
  .pizza-main {
    animation: scene-fade-in 900ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
    animation-delay: 200ms;
  }
  .ing {
    animation: scene-fade-in 700ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  .ing:nth-child(2) { animation-delay: 600ms; }
  .ing:nth-child(3) { animation-delay: 750ms; }
  .ing:nth-child(4) { animation-delay: 900ms; }
  .ing:nth-child(5) { animation-delay: 1050ms; }
  .ing:nth-child(6) { animation-delay: 1200ms; }
  .ing:nth-child(7) { animation-delay: 1350ms; }

  /* ======== prefers-reduced-motion ======== */
  @media (prefers-reduced-motion: reduce) {
    .parallax-layer,
    .float-layer,
    .pizza-main,
    .ing {
      animation: none !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  /**
   * Parallaxe au mouvement de la souris (desktop uniquement).
   * Calcule la position relative du curseur dans la scène (-0.5 → +0.5)
   * et pousse chaque calque selon sa profondeur (data-depth).
   * Utilise requestAnimationFrame pour la fluidité.
   */
  (() => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    const init = () => {
      const scenes = document.querySelectorAll<HTMLElement>('[data-pizza-scene]');
      if (!scenes.length) return;

      scenes.forEach((scene) => {
        if ((scene as any)._parallaxBound) return;
        (scene as any)._parallaxBound = true;

        const layers = scene.querySelectorAll<HTMLElement>('.parallax-layer');
        if (!layers.length) return;

        // Désactivé sur écrans tactiles / mobiles (pas de mousemove utile)
        const isTouch = window.matchMedia('(hover: none)').matches;
        if (isTouch) return;

        let rect = scene.getBoundingClientRect();
        let pendingX = 0;
        let pendingY = 0;
        let ticking = false;

        const updateRect = () => {
          rect = scene.getBoundingClientRect();
        };
        window.addEventListener('resize', updateRect, { passive: true });

        const apply = () => {
          layers.forEach((layer) => {
            const depth = parseFloat(layer.dataset.depth || '1');
            // Amplitude max ~22px à profondeur 1
            const tx = pendingX * depth * 22;
            const ty = pendingY * depth * 22;
            layer.style.setProperty('--tx', `${tx}px`);
            layer.style.setProperty('--ty', `${ty}px`);
          });
          ticking = false;
        };

        scene.addEventListener('mousemove', (e) => {
          // Position relative normalisée : -0.5 (haut/gauche) → +0.5 (bas/droite)
          pendingX = (e.clientX - rect.left) / rect.width - 0.5;
          pendingY = (e.clientY - rect.top) / rect.height - 0.5;
          if (!ticking) {
            requestAnimationFrame(apply);
            ticking = true;
          }
        }, { passive: true });

        scene.addEventListener('mouseleave', () => {
          pendingX = 0;
          pendingY = 0;
          if (!ticking) {
            requestAnimationFrame(apply);
            ticking = true;
          }
        }, { passive: true });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    // Re-bind après navigation View Transitions
    document.addEventListener('astro:page-load', init);
  })();
</script>
