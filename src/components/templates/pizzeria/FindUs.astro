---
/**
 * FindUs — section "Trouver le restaurant".
 * Layout asymétrique : carte placeholder à gauche, infos pratiques à droite.
 * Photo intérieur restaurant en arrière-plan flou pour ambiance.
 */
import data from '../../../data/templates/pizzeria.json';
---

<section id="contact" class="relative bg-pizza-charbon text-pizza-creme py-24 md:py-32 px-6 md:px-10 overflow-hidden">
  <div class="max-w-content mx-auto">

    <header class="text-center max-w-2xl mx-auto mb-16">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-pizza-dore">
        <span class="inline-block w-8 h-px bg-pizza-dore" aria-hidden="true"></span>
        <span>Trouver le restaurant</span>
        <span class="inline-block w-8 h-px bg-pizza-dore" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-playfair font-bold text-pizza-creme leading-tight" style="font-size: clamp(36px, 4.5vw, 56px);">
        On vous attend
        <span class="italic font-medium text-pizza-dore">à Saint-Paul.</span>
      </h2>
    </header>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16">

      <!-- Carte / illustration géographique (5 cols) -->
      <figure class="scroll-reveal lg:col-span-5">
        <div class="relative aspect-[4/5] rounded-sm overflow-hidden bg-pizza-creme/5 ring-1 ring-pizza-dore/30">
          <!-- Photo de couverture (intérieur ou extérieur) avec teinte chaude -->
          <img
            src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=900&q=80"
            alt="Salle du restaurant Pizza Lé O à Saint-Paul"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
            style="filter: brightness(0.7) contrast(1.1);"
          />
          <!-- Overlay dégradé -->
          <div class="absolute inset-0" style="background: linear-gradient(180deg, rgb(28 26 23 / 0.2) 0%, rgb(28 26 23 / 0.6) 100%);" aria-hidden="true"></div>
          <!-- Badge épingle adresse -->
          <div class="absolute bottom-6 left-6 right-6">
            <p class="text-xs uppercase tracking-[0.25em] text-pizza-dore mb-2">L'adresse</p>
            <p class="font-playfair italic text-pizza-creme leading-snug" style="font-size: 22px;">
              {data.info.adresse}
            </p>
          </div>
        </div>
      </figure>

      <!-- Infos pratiques (7 cols) -->
      <div class="lg:col-span-7 space-y-12">

        <!-- Horaires -->
        <div class="scroll-reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-pizza-dore">Horaires</p>
          <ul class="mt-5 divide-y divide-pizza-creme/10">
            {data.info.horaires.map((h) => (
              <li class="flex items-baseline justify-between py-3 first:pt-0">
                <span class="font-playfair text-lg text-pizza-creme">{h.jour}</span>
                <span class:list={['font-inter text-sm tabular-nums', h.ouvert ? 'text-pizza-creme/80' : 'italic text-pizza-creme/45']}>
                  {h.label}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact direct -->
        <div class="scroll-reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-pizza-dore">Nous contacter</p>
          <ul class="mt-5 space-y-3">
            <li>
              <a href={`tel:${data.info.telephoneHref}`} class="group inline-flex items-center gap-3 text-pizza-creme hover:text-pizza-dore transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <span class="font-playfair tabular-nums">{data.info.telephone}</span>
              </a>
            </li>
            <li>
              <a href={`mailto:${data.info.email}`} class="group inline-flex items-center gap-3 text-pizza-creme hover:text-pizza-dore transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="m22 7-10 5L2 7" />
                </svg>
                <span class="font-playfair break-all">{data.info.email}</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- CTA commande -->
        <div class="scroll-reveal pt-2">
          <a
            href="#commander"
            class="inline-flex items-center gap-3 h-14 px-8 text-sm font-semibold uppercase tracking-[0.18em] rounded-sm bg-pizza-rouge text-pizza-creme hover:bg-[#8B1F2A] transition-all"
            style="box-shadow: 0 8px 24px rgb(168 37 50 / 0.35);"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 10h18" />
              <path d="M5 10v9a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-9" />
              <path d="M5 10 7 4h10l2 6" />
            </svg>
            Commander ma pizza
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
