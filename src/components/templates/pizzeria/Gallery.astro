---
/**
 * Gallery — collage de 6 photos (2 lignes × 3 colonnes desktop).
 * Mise en page asymétrique pour effet éditorial : 1 grande + 5 standards.
 * Hover : zoom photo subtile.
 */
import data from '../../../data/templates/pizzeria.json';
---

<section id="atelier" class="relative bg-pizza-charbon text-pizza-creme py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">
    <header class="text-center max-w-xl mx-auto mb-16">
      <p class="scroll-reveal flex items-center justify-center gap-3 text-xs font-semibold uppercase tracking-[0.3em] text-pizza-dore">
        <span class="inline-block w-8 h-px bg-pizza-dore" aria-hidden="true"></span>
        <span>L'atelier</span>
        <span class="inline-block w-8 h-px bg-pizza-dore" aria-hidden="true"></span>
      </p>
      <h2 class="scroll-reveal mt-5 font-playfair font-bold text-pizza-creme leading-tight" style="font-size: clamp(36px, 4.5vw, 56px);">
        Le feu, la pâte, le geste.
      </h2>
    </header>

    <!-- Grille asymétrique : 1 grande + 5 standards -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      {data.gallery.map((g, i) => {
        // 1ère et 4ème photos en double largeur sur desktop
        const span = i === 0 ? 'md:col-span-2 md:row-span-2' : '';
        const aspect = i === 0 ? 'aspect-square md:aspect-auto md:h-full' : 'aspect-square';
        return (
          <figure class:list={['scroll-reveal group relative overflow-hidden rounded-sm', span, aspect]} style={`transition-delay: ${(i % 4) * 80}ms`}>
            <img
              src={g.src}
              alt={g.alt}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
            />
            <div class="absolute inset-0 bg-pizza-charbon/0 group-hover:bg-pizza-charbon/15 transition-colors duration-500" aria-hidden="true"></div>
          </figure>
        );
      })}
    </div>
  </div>
</section>
