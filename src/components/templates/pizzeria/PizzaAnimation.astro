---
/**
 * PizzaAnimation — scène motion design premium.
 * Construction de la pizza en 5 étapes : pâte → sauce → fromage →
 * olives → garnitures. Cycle 12s avec rendu final pulsant et boucle
 * fluide. Light source top-left cohérente, gradients multi-stop,
 * easing cubic-bezier(0.16, 1, 0.3, 1).
 *
 * Désactivée sous prefers-reduced-motion : pizza statique complète.
 */
---

<div class="pizza-anim relative w-full max-w-[420px] mx-auto" aria-hidden="true">
  <!-- Ombre portée qui pulse subtilement avec la finale -->
  <div class="pizza-shadow absolute inset-x-10 bottom-3 h-10 rounded-[50%]"></div>

  <svg viewBox="0 0 220 220" class="pizza-svg relative w-full aspect-square">
    <defs>
      <!-- Croûte : multi-stop pour relief doré premium, light source top-left -->
      <radialGradient id="croute-grad" cx="42%" cy="38%" r="62%">
        <stop offset="0%"   stop-color="#FFE3A3" />
        <stop offset="35%"  stop-color="#F2C766" />
        <stop offset="65%"  stop-color="#D49A3F" />
        <stop offset="88%"  stop-color="#9C6A1F" />
        <stop offset="100%" stop-color="#5C3D10" />
      </radialGradient>
      <!-- Intérieur de la pâte cuite -->
      <radialGradient id="pate-int" cx="42%" cy="38%" r="65%">
        <stop offset="0%"   stop-color="#FFF1C8" />
        <stop offset="60%"  stop-color="#F4DBA0" />
        <stop offset="100%" stop-color="#D9B66A" />
      </radialGradient>
      <!-- Sauce tomate avec profondeur -->
      <radialGradient id="sauce-grad" cx="42%" cy="38%" r="62%">
        <stop offset="0%"   stop-color="#E5453B" />
        <stop offset="55%"  stop-color="#C8102E" />
        <stop offset="100%" stop-color="#7A0815" />
      </radialGradient>
      <!-- Fromage fondu : highlight chaud -->
      <radialGradient id="fromage-grad" cx="35%" cy="30%" r="80%">
        <stop offset="0%"   stop-color="#FFFFFF" />
        <stop offset="35%"  stop-color="#FFF6D1" />
        <stop offset="75%"  stop-color="#F8DE8A" />
        <stop offset="100%" stop-color="#D9AC4A" />
      </radialGradient>
      <!-- Olive : reflet vert profond -->
      <radialGradient id="olive-grad" cx="35%" cy="30%" r="70%">
        <stop offset="0%"   stop-color="#5A5A5A" />
        <stop offset="50%"  stop-color="#1A1A1A" />
        <stop offset="100%" stop-color="#000000" />
      </radialGradient>
      <!-- Tomate cerise : reflet vif -->
      <radialGradient id="tomate-grad" cx="32%" cy="28%" r="72%">
        <stop offset="0%"   stop-color="#FFB8B8" />
        <stop offset="35%"  stop-color="#E63946" />
        <stop offset="100%" stop-color="#9C0E1F" />
      </radialGradient>
      <!-- Basilic : feuille verte avec ombre -->
      <linearGradient id="basilic-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%"   stop-color="#3F8B68" />
        <stop offset="60%"  stop-color="#2D6A4F" />
        <stop offset="100%" stop-color="#1A4A35" />
      </linearGradient>
      <!-- Filtre ombre subtile pour les ingrédients -->
      <filter id="ing-shadow" x="-30%" y="-30%" width="160%" height="160%">
        <feDropShadow dx="0.4" dy="1.2" stdDeviation="0.8" flood-color="#000" flood-opacity="0.35"/>
      </filter>
      <!-- Grain subtil sur la croûte -->
      <filter id="croute-grain" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="2" seed="3"/>
        <feColorMatrix values="0 0 0 0 0.4
                                0 0 0 0 0.25
                                0 0 0 0 0.05
                                0 0 0 0.18 0"/>
        <feComposite in2="SourceGraphic" operator="in"/>
        <feBlend mode="multiply" in2="SourceGraphic"/>
      </filter>
    </defs>

    <!-- ========== STAGE 1 : pâte (croûte + intérieur) ========== -->
    <g class="pizza-stage pizza-stage-1">
      <!-- Croûte avec relief, légèrement plus grande -->
      <circle cx="110" cy="110" r="100" fill="url(#croute-grad)" />
      <!-- Bord soufflé (sous-couche d'ombre) -->
      <circle cx="110" cy="110" r="100" fill="none" stroke="#5C3D10" stroke-width="0.8" opacity="0.5" />
      <!-- Intérieur de la pâte (où poseront les ingrédients) -->
      <circle cx="110" cy="110" r="85" fill="url(#pate-int)" />
      <!-- Bulles four à bois (taches sombres aléatoires) -->
      <circle cx="32" cy="92" r="2.5" fill="#3A1F00" opacity="0.45"/>
      <circle cx="190" cy="125" r="2" fill="#3A1F00" opacity="0.40"/>
      <circle cx="105" cy="20" r="2" fill="#3A1F00" opacity="0.40"/>
      <circle cx="180" cy="62" r="1.8" fill="#3A1F00" opacity="0.35"/>
      <circle cx="42" cy="170" r="2.2" fill="#3A1F00" opacity="0.40"/>
      <circle cx="155" cy="190" r="1.8" fill="#3A1F00" opacity="0.35"/>
      <!-- Highlight light-source top-left -->
      <circle cx="80" cy="78" r="22" fill="#FFFFFF" opacity="0.10"/>
    </g>

    <!-- ========== STAGE 2 : sauce tomate (clip-path radial qui s'étend) ========== -->
    <g class="pizza-stage pizza-stage-2">
      <g class="sauce-reveal">
        <circle cx="110" cy="110" r="80" fill="url(#sauce-grad)" />
        <!-- Texture sauce : tâches plus sombres -->
        <circle cx="92" cy="98" r="6" fill="#7A0815" opacity="0.40"/>
        <circle cx="128" cy="115" r="5" fill="#7A0815" opacity="0.35"/>
        <circle cx="105" cy="135" r="4.5" fill="#7A0815" opacity="0.35"/>
        <circle cx="78" cy="130" r="3.5" fill="#7A0815" opacity="0.30"/>
        <circle cx="135" cy="92" r="3" fill="#7A0815" opacity="0.30"/>
      </g>
    </g>

    <!-- ========== STAGE 3 : fromage fondu (blobs organiques) ========== -->
    <g class="pizza-stage pizza-stage-3" filter="url(#ing-shadow)">
      <path d="M76,82 Q66,88 70,100 Q78,108 92,104 Q102,98 99,86 Q94,76 84,77 Q78,78 76,82 Z"
            fill="url(#fromage-grad)" />
      <path d="M126,90 Q118,96 122,108 Q132,114 142,108 Q148,98 142,88 Q134,82 128,86 Z"
            fill="url(#fromage-grad)" />
      <path d="M93,118 Q82,126 90,138 Q102,144 117,140 Q128,134 124,120 Q116,110 102,113 Q95,114 93,118 Z"
            fill="url(#fromage-grad)" />
      <path d="M138,128 Q130,134 134,144 Q143,151 154,146 Q161,138 156,128 Q150,120 142,124 Z"
            fill="url(#fromage-grad)" />
      <path d="M68,140 Q60,148 66,158 Q76,164 87,158 Q92,148 86,140 Q78,134 72,137 Z"
            fill="url(#fromage-grad)" />
      <path d="M115,68 Q108,73 111,82 Q120,86 128,80 Q132,72 125,66 Q119,63 115,68 Z"
            fill="url(#fromage-grad)" />
      <path d="M155,152 Q148,158 152,168 Q161,172 168,166 Q172,158 165,152 Z"
            fill="url(#fromage-grad)" />
      <!-- Highlights blancs sur le fromage (effet brillant) -->
      <ellipse cx="84" cy="86" rx="3.5" ry="2" fill="#FFFFFF" opacity="0.7"/>
      <ellipse cx="132" cy="96" rx="3" ry="1.8" fill="#FFFFFF" opacity="0.7"/>
      <ellipse cx="103" cy="124" rx="4.5" ry="2.5" fill="#FFFFFF" opacity="0.65"/>
    </g>

    <!-- ========== STAGE 4 : olives noires ========== -->
    <g class="pizza-stage pizza-stage-4" filter="url(#ing-shadow)">
      <ellipse cx="98" cy="108" rx="5" ry="3.8" fill="url(#olive-grad)"/>
      <ellipse cx="97" cy="106" rx="2" ry="1.2" fill="#888888" opacity="0.55"/>

      <ellipse cx="125" cy="122" rx="5" ry="3.8" fill="url(#olive-grad)"/>
      <ellipse cx="124" cy="120" rx="2" ry="1.2" fill="#888888" opacity="0.55"/>

      <ellipse cx="110" cy="150" rx="5" ry="3.8" fill="url(#olive-grad)"/>
      <ellipse cx="109" cy="148" rx="2" ry="1.2" fill="#888888" opacity="0.55"/>

      <ellipse cx="78" cy="148" rx="4.5" ry="3.4" fill="url(#olive-grad)"/>
      <ellipse cx="77" cy="146" rx="1.8" ry="1.1" fill="#888888" opacity="0.50"/>

      <ellipse cx="148" cy="92" rx="4.5" ry="3.4" fill="url(#olive-grad)"/>
      <ellipse cx="147" cy="90" rx="1.8" ry="1.1" fill="#888888" opacity="0.50"/>
    </g>

    <!-- ========== STAGE 5 : garnitures finales (basilic + tomates cerises) ========== -->
    <g class="pizza-stage pizza-stage-5" filter="url(#ing-shadow)">
      <!-- Tomates cerises avec reflets -->
      <g>
        <circle cx="68" cy="108" r="6.5" fill="url(#tomate-grad)"/>
        <ellipse cx="65" cy="105" rx="2.2" ry="1.4" fill="#FFE5E5" opacity="0.75"/>
        <circle cx="66" cy="104" r="0.9" fill="#FFFFFF"/>
      </g>
      <g>
        <circle cx="152" cy="115" r="6.5" fill="url(#tomate-grad)"/>
        <ellipse cx="149" cy="112" rx="2.2" ry="1.4" fill="#FFE5E5" opacity="0.75"/>
        <circle cx="150" cy="111" r="0.9" fill="#FFFFFF"/>
      </g>
      <g>
        <circle cx="110" cy="68" r="6.5" fill="url(#tomate-grad)"/>
        <ellipse cx="107" cy="65" rx="2.2" ry="1.4" fill="#FFE5E5" opacity="0.75"/>
        <circle cx="108" cy="64" r="0.9" fill="#FFFFFF"/>
      </g>
      <!-- Feuilles de basilic avec nervures -->
      <g transform="translate(80, 78) rotate(-22)">
        <path d="M0,0 Q5,-12 14,-9 Q16,2 9,9 Q2,9 0,0 Z" fill="url(#basilic-grad)"/>
        <path d="M0,0 Q5,-12 14,-9" stroke="#0F3525" stroke-width="0.5" fill="none"/>
        <path d="M2,-2 Q6,-4 10,-3" stroke="#0F3525" stroke-width="0.4" fill="none"/>
        <path d="M3,2 Q7,-1 11,-1" stroke="#0F3525" stroke-width="0.4" fill="none"/>
      </g>
      <g transform="translate(140, 80) rotate(18)">
        <path d="M0,0 Q5,-11 13,-8 Q15,3 8,8 Q1,8 0,0 Z" fill="url(#basilic-grad)"/>
        <path d="M0,0 Q5,-11 13,-8" stroke="#0F3525" stroke-width="0.5" fill="none"/>
        <path d="M2,-1 Q5,-3 9,-2" stroke="#0F3525" stroke-width="0.4" fill="none"/>
      </g>
      <g transform="translate(92, 142) rotate(-12)">
        <path d="M0,0 Q5,-12 14,-9 Q16,3 9,9 Q1,9 0,0 Z" fill="url(#basilic-grad)"/>
        <path d="M0,0 Q5,-12 14,-9" stroke="#0F3525" stroke-width="0.5" fill="none"/>
        <path d="M3,-2 Q7,-4 11,-3" stroke="#0F3525" stroke-width="0.4" fill="none"/>
      </g>
      <g transform="translate(135, 145) rotate(28)">
        <path d="M0,0 Q4,-10 12,-7 Q14,2 7,7 Q1,7 0,0 Z" fill="url(#basilic-grad)"/>
        <path d="M0,0 Q4,-10 12,-7" stroke="#0F3525" stroke-width="0.5" fill="none"/>
      </g>
    </g>
  </svg>
</div>

<style>
  /* ========== Cycle global de l'animation ========== */
  /* Durée : 12s — séquence reveal 6s + rendu final 4s + reset 2s */

  /* Stage : apparition douce (scale + fade) puis stay puis fade out */
  .pizza-stage {
    opacity: 0;
    transform-origin: 110px 110px;
    transform-box: fill-box;
    animation: stage-cycle 12s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }
  /* Décalage entre les stages : 1.1s (révèle complète à ~6s) */
  .pizza-stage-1 { animation-delay: 0s; }
  .pizza-stage-2 { animation-delay: 1.0s; }
  .pizza-stage-3 { animation-delay: 2.0s; }
  .pizza-stage-4 { animation-delay: 3.0s; }
  .pizza-stage-5 { animation-delay: 4.0s; }

  @keyframes stage-cycle {
    0%   { opacity: 0; transform: scale(0.88); }
    /* Apparition douce sur 800ms (~7% de 12s) */
    7%   { opacity: 1; transform: scale(1.025); }
    11%  { transform: scale(1); }
    /* Visible jusqu'à 80% (9.6s) */
    80%  { opacity: 1; transform: scale(1); }
    /* Fade out gracieux 80-90% */
    90%  { opacity: 0; transform: scale(1.015); }
    /* Pause invisible 90-100% (1.2s) */
    100% { opacity: 0; transform: scale(0.88); }
  }

  /* Sauce tomate : effet "vague" qui se verse depuis le centre */
  .sauce-reveal {
    transform-origin: 110px 110px;
    transform-box: fill-box;
    animation: sauce-spread 12s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    animation-delay: 1.0s;
    clip-path: circle(0% at 50% 50%);
  }
  @keyframes sauce-spread {
    0%   { clip-path: circle(0% at 50% 50%); }
    7%   { clip-path: circle(50% at 50% 50%); }
    80%  { clip-path: circle(50% at 50% 50%); }
    90%  { clip-path: circle(0% at 50% 50%); }
    100% { clip-path: circle(0% at 50% 50%); }
  }

  /* Pizza complète : pulse subtil au moment du rendu final */
  .pizza-svg {
    animation: pizza-finale 12s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    transform-origin: 50% 50%;
  }
  @keyframes pizza-finale {
    0%, 45%   { transform: scale(1); }
    /* Pulse subtil entre 50% et 65% (rendu final, après que tout soit posé) */
    55%       { transform: scale(1.025); }
    65%       { transform: scale(1); }
    100%      { transform: scale(1); }
  }

  /* Ombre portée qui pulse avec la finale */
  .pizza-shadow {
    background: radial-gradient(50% 50% at 50% 50%, rgb(0 0 0 / 0.45) 0%, transparent 70%);
    filter: blur(10px);
    animation: shadow-finale 12s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    transform-origin: 50% 50%;
  }
  @keyframes shadow-finale {
    0%, 45%   { transform: scale(0.92); opacity: 0.85; }
    55%       { transform: scale(1.08); opacity: 1; }
    65%       { transform: scale(1); opacity: 0.95; }
    100%      { transform: scale(0.92); opacity: 0.85; }
  }

  /* ========== Fallback prefers-reduced-motion ========== */
  @media (prefers-reduced-motion: reduce) {
    .pizza-svg, .pizza-shadow, .pizza-stage, .sauce-reveal {
      animation: none !important;
      transform: none !important;
      opacity: 1 !important;
      clip-path: none !important;
    }
  }
</style>
