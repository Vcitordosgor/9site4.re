---
/**
 * PizzaAnimation — pizza vue du dessus avec relief, ombre portée, croûte dorée.
 * Garnitures qui tombent une à une depuis le haut avec rotation et rebond.
 * Cycle de 8s (drop séquentiel sur 2.8s + 4s visibles + 1.2s reset).
 * Désactivé sous prefers-reduced-motion (pizza statique complète).
 */
---

<div class="pizza-anim relative w-full max-w-[420px] mx-auto" aria-hidden="true">
  <!-- Ombre portée sous la pizza -->
  <div class="pizza-shadow absolute inset-x-8 bottom-2 h-12 rounded-[50%]"
       style="background: radial-gradient(50% 50% at 50% 50%, rgb(0 0 0 / 0.45) 0%, transparent 70%); filter: blur(8px);">
  </div>

  <svg viewBox="0 0 200 200" class="pizza-svg relative w-full aspect-square">
    <defs>
      <!-- Dégradé doré pour la croûte -->
      <radialGradient id="croute-grad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#F5C76A" />
        <stop offset="78%" stop-color="#D4A94A" />
        <stop offset="92%" stop-color="#A87930" />
        <stop offset="100%" stop-color="#7C5A20" />
      </radialGradient>
      <!-- Dégradé pour la sauce tomate -->
      <radialGradient id="sauce-grad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#E03A2F" />
        <stop offset="100%" stop-color="#9C0E1F" />
      </radialGradient>
      <!-- Dégradé mozzarella -->
      <radialGradient id="mozza-grad" cx="35%" cy="30%" r="80%">
        <stop offset="0%" stop-color="#FFFCF0" />
        <stop offset="60%" stop-color="#FFF1C8" />
        <stop offset="100%" stop-color="#E8D08A" />
      </radialGradient>
      <!-- Filtre flou léger pour les ombres internes -->
      <filter id="ing-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="0.6" />
      </filter>
    </defs>

    <!-- Croûte (couche statique, toujours visible) -->
    <g class="pizza-base">
      <circle cx="100" cy="100" r="92" fill="url(#croute-grad)" />
      <!-- Bord plus sombre et soufflé -->
      <circle cx="100" cy="100" r="92" fill="none" stroke="#6B4818" stroke-width="1.5" opacity="0.6" />
      <!-- Petites bulles sur la croûte (effet four à bois) -->
      <circle cx="22" cy="80" r="3" fill="#3A2810" opacity="0.35" />
      <circle cx="178" cy="115" r="2.5" fill="#3A2810" opacity="0.30" />
      <circle cx="100" cy="14" r="2" fill="#3A2810" opacity="0.30" />
      <circle cx="170" cy="60" r="2" fill="#3A2810" opacity="0.25" />
      <circle cx="35" cy="155" r="2.5" fill="#3A2810" opacity="0.30" />
    </g>

    <!-- Couche 1 : pâte intérieure (base où les ingrédients vont tomber) -->
    <g class="pizza-ing pizza-ing-1">
      <circle cx="100" cy="100" r="78" fill="#F2DBA1" />
      <!-- Léger gradient pour donner du relief -->
      <circle cx="100" cy="100" r="78" fill="url(#mozza-grad)" opacity="0.15" />
    </g>

    <!-- Couche 2 : sauce tomate -->
    <g class="pizza-ing pizza-ing-2">
      <circle cx="100" cy="100" r="74" fill="url(#sauce-grad)" />
      <!-- Texture sauce -->
      <circle cx="88" cy="92" r="5" fill="#7A0815" opacity="0.35" />
      <circle cx="118" cy="105" r="4" fill="#7A0815" opacity="0.30" />
      <circle cx="100" cy="125" r="4" fill="#7A0815" opacity="0.30" />
      <circle cx="76" cy="120" r="3" fill="#7A0815" opacity="0.30" />
    </g>

    <!-- Couche 3 : mozzarella (formes organiques irrégulières) -->
    <g class="pizza-ing pizza-ing-3">
      <path d="M70,70 Q62,75 65,86 Q70,94 82,92 Q92,89 90,78 Q88,68 78,67 Q72,67 70,70 Z"
            fill="url(#mozza-grad)" filter="url(#ing-shadow)" />
      <path d="M118,80 Q112,85 116,95 Q124,100 132,94 Q137,86 132,78 Q126,73 120,76 Z"
            fill="url(#mozza-grad)" filter="url(#ing-shadow)" />
      <path d="M85,108 Q76,114 82,124 Q92,131 105,127 Q116,122 113,110 Q108,100 95,102 Q88,103 85,108 Z"
            fill="url(#mozza-grad)" filter="url(#ing-shadow)" />
      <path d="M125,115 Q118,120 121,130 Q128,137 138,133 Q146,127 143,118 Q138,110 130,112 Z"
            fill="url(#mozza-grad)" filter="url(#ing-shadow)" />
      <path d="M62,128 Q56,134 61,142 Q70,148 79,143 Q85,135 80,128 Q72,123 65,125 Z"
            fill="url(#mozza-grad)" filter="url(#ing-shadow)" />
      <path d="M105,65 Q98,70 102,78 Q110,82 117,77 Q121,70 115,64 Q110,61 105,65 Z"
            fill="url(#mozza-grad)" filter="url(#ing-shadow)" />
      <!-- Reflets blancs -->
      <ellipse cx="78" cy="78" rx="3" ry="2" fill="#FFFFFF" opacity="0.6" />
      <ellipse cx="124" cy="86" rx="3" ry="2" fill="#FFFFFF" opacity="0.6" />
      <ellipse cx="95" cy="115" rx="4" ry="2.5" fill="#FFFFFF" opacity="0.6" />
    </g>

    <!-- Couche 4 : basilic avec nervures -->
    <g class="pizza-ing pizza-ing-4">
      <g transform="translate(75, 73) rotate(-20)">
        <path d="M0,0 Q4,-10 12,-8 Q14,2 8,8 Q2,8 0,0 Z" fill="#2D6A4F" />
        <path d="M0,0 Q4,-10 12,-8" stroke="#1A4A35" stroke-width="0.5" fill="none" />
        <path d="M2,-2 Q5,-4 8,-3" stroke="#1A4A35" stroke-width="0.4" fill="none" />
        <path d="M3,2 Q6,-2 10,-2" stroke="#1A4A35" stroke-width="0.4" fill="none" />
      </g>
      <g transform="translate(128, 78) rotate(15)">
        <path d="M0,0 Q4,-9 11,-7 Q13,2 7,7 Q1,7 0,0 Z" fill="#2D6A4F" />
        <path d="M0,0 Q4,-9 11,-7" stroke="#1A4A35" stroke-width="0.5" fill="none" />
        <path d="M2,-1 Q5,-3 8,-2" stroke="#1A4A35" stroke-width="0.4" fill="none" />
      </g>
      <g transform="translate(85, 130) rotate(-10)">
        <path d="M0,0 Q5,-11 13,-9 Q15,2 8,8 Q1,8 0,0 Z" fill="#2D6A4F" />
        <path d="M0,0 Q5,-11 13,-9" stroke="#1A4A35" stroke-width="0.5" fill="none" />
        <path d="M3,-2 Q6,-4 10,-4" stroke="#1A4A35" stroke-width="0.4" fill="none" />
        <path d="M3,2 Q7,-2 11,-2" stroke="#1A4A35" stroke-width="0.4" fill="none" />
      </g>
      <g transform="translate(122, 130) rotate(25)">
        <path d="M0,0 Q4,-9 11,-7 Q13,2 7,7 Q1,7 0,0 Z" fill="#2D6A4F" />
        <path d="M0,0 Q4,-9 11,-7" stroke="#1A4A35" stroke-width="0.5" fill="none" />
      </g>
    </g>

    <!-- Couche 5 : tomates cerises avec reflet -->
    <g class="pizza-ing pizza-ing-5">
      <g>
        <ellipse cx="62" cy="100" rx="6.5" ry="5.5" fill="#7A0E1A" opacity="0.4" transform="translate(1,1.5)" />
        <circle cx="62" cy="100" r="6" fill="#E63946" />
        <circle cx="60" cy="98" r="2" fill="#FFE5E5" opacity="0.7" />
        <circle cx="61" cy="97" r="0.8" fill="#FFFFFF" />
      </g>
      <g>
        <ellipse cx="138" cy="105" rx="6.5" ry="5.5" fill="#7A0E1A" opacity="0.4" transform="translate(1,1.5)" />
        <circle cx="138" cy="105" r="6" fill="#E63946" />
        <circle cx="136" cy="103" r="2" fill="#FFE5E5" opacity="0.7" />
        <circle cx="137" cy="102" r="0.8" fill="#FFFFFF" />
      </g>
      <g>
        <ellipse cx="100" cy="58" rx="6.5" ry="5.5" fill="#7A0E1A" opacity="0.4" transform="translate(1,1.5)" />
        <circle cx="100" cy="58" r="6" fill="#E63946" />
        <circle cx="98" cy="56" r="2" fill="#FFE5E5" opacity="0.7" />
        <circle cx="99" cy="55" r="0.8" fill="#FFFFFF" />
      </g>
    </g>

    <!-- Couche 6 : olives noires -->
    <g class="pizza-ing pizza-ing-6">
      <g>
        <ellipse cx="89" cy="103" rx="5" ry="3.8" fill="#1A1A1A" />
        <ellipse cx="88" cy="101" rx="2" ry="1.2" fill="#3A3A3A" opacity="0.7" />
      </g>
      <g>
        <ellipse cx="113" cy="108" rx="5" ry="3.8" fill="#1A1A1A" />
        <ellipse cx="112" cy="106" rx="2" ry="1.2" fill="#3A3A3A" opacity="0.7" />
      </g>
      <g>
        <ellipse cx="100" cy="138" rx="5" ry="3.8" fill="#1A1A1A" />
        <ellipse cx="99" cy="136" rx="2" ry="1.2" fill="#3A3A3A" opacity="0.7" />
      </g>
      <g>
        <ellipse cx="76" cy="138" rx="4.5" ry="3.4" fill="#1A1A1A" />
        <ellipse cx="75" cy="136" rx="1.8" ry="1.1" fill="#3A3A3A" opacity="0.7" />
      </g>
    </g>

    <!-- Couche 7 : champignons -->
    <g class="pizza-ing pizza-ing-7" filter="url(#ing-shadow)">
      <g>
        <ellipse cx="115" cy="78" rx="7" ry="4.5" fill="#A48464" />
        <ellipse cx="115" cy="77" rx="6" ry="3" fill="#C8A582" opacity="0.7" />
        <rect x="112.5" y="77.5" width="5" height="5" fill="#FFF8E7" rx="0.5" />
      </g>
      <g>
        <ellipse cx="76" cy="115" rx="7" ry="4.5" fill="#A48464" />
        <ellipse cx="76" cy="114" rx="6" ry="3" fill="#C8A582" opacity="0.7" />
        <rect x="73.5" y="114.5" width="5" height="5" fill="#FFF8E7" rx="0.5" />
      </g>
      <g>
        <ellipse cx="128" cy="138" rx="6" ry="4" fill="#A48464" />
        <ellipse cx="128" cy="137" rx="5" ry="2.5" fill="#C8A582" opacity="0.7" />
        <rect x="126" y="137.5" width="4" height="4" fill="#FFF8E7" rx="0.5" />
      </g>
    </g>
  </svg>
</div>

<style>
  /* Légère oscillation continue de la pizza (vie) */
  .pizza-svg {
    animation: pizza-sway 6s ease-in-out infinite;
    transform-origin: 50% 50%;
  }
  @keyframes pizza-sway {
    0%, 100% { transform: rotate(-1.5deg); }
    50% { transform: rotate(1.5deg); }
  }

  /* L'ombre portée pulse légèrement avec la pizza */
  .pizza-shadow {
    animation: pizza-shadow-pulse 6s ease-in-out infinite;
  }
  @keyframes pizza-shadow-pulse {
    0%, 100% { transform: scale(0.95); opacity: 0.85; }
    50% { transform: scale(1.05); opacity: 1; }
  }

  /* Drop des ingrédients : depuis le haut avec rotation, rebond, puis stay,
     puis fade out à la fin du cycle pour reboucler proprement */
  .pizza-ing {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation: pizza-drop 8s ease-out infinite;
  }
  .pizza-ing-1 { animation-delay: 0s; }
  .pizza-ing-2 { animation-delay: 0.4s; }
  .pizza-ing-3 { animation-delay: 0.8s; }
  .pizza-ing-4 { animation-delay: 1.2s; }
  .pizza-ing-5 { animation-delay: 1.6s; }
  .pizza-ing-6 { animation-delay: 2.0s; }
  .pizza-ing-7 { animation-delay: 2.4s; }

  @keyframes pizza-drop {
    0%   { opacity: 0; transform: translateY(-80px) rotate(-15deg); }
    /* drop 600ms */
    6%   { opacity: 1; transform: translateY(8px) rotate(3deg); }
    9%   { transform: translateY(-3px) rotate(-1deg); }
    12%  { transform: translateY(0) rotate(0); }
    /* visible */
    85%  { opacity: 1; transform: translateY(0); }
    /* fade out 8% */
    93%  { opacity: 0; transform: translateY(0) scale(0.92); }
    /* pause invisible 7% avant reset */
    100% { opacity: 0; transform: translateY(-80px) rotate(-15deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pizza-svg, .pizza-shadow {
      animation: none !important;
    }
    .pizza-ing {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
