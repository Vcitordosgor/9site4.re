---
/**
 * PizzeriaFooter — minimal éditorial.
 */
import data from '../../../data/templates/pizzeria.json';
const year = new Date().getFullYear();
---

<footer class="bg-pizza-charbon text-pizza-creme/85 py-14 px-6 md:px-10 border-t border-pizza-dore/30">
  <div class="max-w-content mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <div>
        <p class="font-playfair font-bold text-pizza-creme leading-none" style="font-size: 28px;">
          Pizza <span class="italic font-medium text-pizza-dore">Lé O</span>
        </p>
        <p class="mt-3 font-playfair italic text-pizza-creme/65 text-sm">
          {data.info.tagline} · Saint-Paul, depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 text-sm">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-pizza-dore transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="hidden md:inline-flex w-1 h-1 rounded-full bg-pizza-dore/50"></li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-pizza-dore transition-colors">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>

    <!-- Filet doré séparateur -->
    <div class="mt-10 mb-6 h-px" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgb(184 151 102 / 0.6) 30%, rgb(184 151 102 / 0.6) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 text-xs uppercase tracking-[0.18em] text-pizza-creme/45">
      <p>© {year} {data.info.nom}</p>
      <p>
        Site créé par
        <a href="/" class="font-semibold text-pizza-creme/75 hover:text-pizza-dore transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
