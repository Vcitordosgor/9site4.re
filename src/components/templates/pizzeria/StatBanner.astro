---
/**
 * StatBanner — bandeau 3 chiffres clés, fond charbon, séparateurs dorés.
 * Style éditorial premium, sobre, pas de décoration superflue.
 */
import data from '../../../data/templates/pizzeria.json';
---

<section class="relative bg-pizza-charbon text-pizza-creme py-12 md:py-16 px-6 md:px-10">
  <div class="max-w-content mx-auto">
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-0 md:divide-x md:divide-pizza-dore/30">
      {data.stats.map((stat) => (
        <li class="text-center md:px-8">
          <p class="font-playfair font-bold leading-none text-pizza-dore" style="font-size: clamp(40px, 5vw, 64px);">
            {stat.valeur}
          </p>
          <p class="mt-3 text-xs md:text-sm uppercase tracking-[0.3em] text-pizza-creme/65">
            {stat.label}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
