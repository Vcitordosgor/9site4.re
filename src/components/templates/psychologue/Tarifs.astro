---
/**
 * Tarifs — tableau ligne par ligne sobre + note mutuelles.
 * Format honoraires éthique : durée + prix tabulaire.
 */
import data from '../../../data/templates/aubry.json';
---

<section id="tarifs" class="bg-aubry-papier py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-3xl mx-auto">

    <header class="mb-14 md:mb-16">
      <p class="font-plex-mono text-[10px] uppercase tracking-[0.32em] text-aubry-prune mb-5">
        Chapitre IV — Modalités
      </p>
      <h2 class="font-caslon text-aubry-encre leading-[1.05]" style="font-size: clamp(36px, 5vw, 60px);">
        Honoraires<span class="italic text-aubry-prune"> & remboursement.</span>
      </h2>
    </header>

    <!-- Tableau honoraires -->
    <div class="border-t-2 border-aubry-encre">
      {data.tarifs.map((t) => (
        <div class="grid grid-cols-12 gap-4 py-5 items-baseline border-b border-aubry-encre/15">
          <div class="col-span-7 sm:col-span-7">
            <p class="font-caslon text-aubry-encre text-lg md:text-xl">{t.label}</p>
          </div>
          <div class="col-span-3 sm:col-span-3">
            <p class="font-plex-mono text-[11px] uppercase tracking-[0.22em] text-aubry-prune tabular-nums">
              {t.duree}
            </p>
          </div>
          <div class="col-span-2 text-right">
            <p class="font-caslon text-aubry-encre text-xl md:text-2xl tabular-nums">{t.prix}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Note mutuelles dans encart prune subtil -->
    <div class="mt-12 p-6 md:p-8 bg-aubry-prune/8 border-l-2 border-aubry-prune">
      <p class="font-plex-mono text-[10px] uppercase tracking-[0.28em] text-aubry-prune mb-3">
        Note sur le remboursement
      </p>
      <p class="font-caslon text-aubry-encre/85 text-base md:text-lg leading-[1.8]">
        {data.noteTarif}
      </p>
    </div>
  </div>
</section>
