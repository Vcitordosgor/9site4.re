---
/**
 * PremiereSession — 4 étapes en chiffres romains, format manuel posé.
 * Pas de cards. Liste verticale max-w-2xl, ton pédagogique calme.
 */
import data from '../../../data/templates/aubry.json';
---

<section class="bg-aubry-perle py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-3xl mx-auto">

    <header class="mb-14 md:mb-20">
      <p class="font-plex-mono text-[10px] uppercase tracking-[0.32em] text-aubry-prune mb-5">
        Chapitre V — La première séance
      </p>
      <h2 class="font-caslon text-aubry-encre leading-[1.05]" style="font-size: clamp(36px, 5vw, 60px);">
        Quatre temps,<span class="italic text-aubry-prune"> sans engagement.</span>
      </h2>
    </header>

    <!-- Liste numérotée chiffres romains -->
    <ol class="space-y-12 md:space-y-14">
      {data.premiere.map((e) => (
        <li class="grid grid-cols-12 gap-5 md:gap-8 items-start">

          <!-- Chiffre romain -->
          <span class="col-span-2 md:col-span-1 font-caslon italic text-aubry-rose text-3xl md:text-4xl tabular-nums leading-none pt-2 select-none">
            {e.num}
          </span>

          <!-- Contenu -->
          <div class="col-span-10 md:col-span-11">
            <h3 class="font-caslon text-aubry-encre text-2xl md:text-3xl leading-tight mb-3">
              {e.titre}<span class="text-aubry-rose">.</span>
            </h3>
            <p class="font-albert text-aubry-encre/75 text-base md:text-lg leading-[1.85] max-w-xl">
              {e.description}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
