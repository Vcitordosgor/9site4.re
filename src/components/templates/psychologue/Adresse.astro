---
/**
 * Adresse — composition très simple monochrome, juste l'adresse + horaires.
 * Pas de photo, pas d'icônes voiture/transport. Texte qui parle.
 */
import data from '../../../data/templates/aubry.json';
---

<section class="bg-aubry-perle py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- Adresse -->
      <div class="lg:col-span-7">
        <p class="font-plex-mono text-[10px] uppercase tracking-[0.32em] text-aubry-prune mb-6">
          Adresse
        </p>
        <h2 class="font-caslon text-aubry-encre leading-[1.05]" style="font-size: clamp(34px, 5vw, 56px);">
          Le cabinet est<span class="italic text-aubry-prune"> au cœur de Saint-Denis,</span>
          <span class="block">dans un immeuble calme.</span>
        </h2>

        <div class="mt-10">
          <p class="font-caslon text-aubry-encre text-2xl md:text-3xl">
            {data.info.adresseLigne1}
          </p>
          <p class="font-caslon italic text-aubry-encre/70 text-xl md:text-2xl">
            {data.info.adresseLigne2}
          </p>
        </div>

        <p class="mt-10 font-albert text-aubry-encre/75 text-base md:text-lg leading-[1.85] max-w-md">
          Bâtiment ancien, deuxième étage. Interphone au nom de "Aubry". Salle d'attente discrète et insonorisée. Les rendez-vous sont décalés pour qu'aucun·e patient·e ne croise un·e autre.
        </p>
      </div>

      <!-- Horaires -->
      <div class="lg:col-span-5">
        <p class="font-plex-mono text-[10px] uppercase tracking-[0.32em] text-aubry-prune mb-6">
          Horaires
        </p>
        <ul class="border-t border-aubry-encre/15">
          {data.horaires.map((h) => (
            <li class="grid grid-cols-2 items-baseline gap-3 py-3 border-b border-aubry-encre/15">
              <span class="font-caslon text-aubry-encre text-base">{h.jour}</span>
              <span class:list={['font-caslon text-right tabular-nums text-base', h.ouvert ? 'text-aubry-encre/85' : 'italic text-aubry-encre/40']}>
                {h.label}
              </span>
            </li>
          ))}
        </ul>

        <!-- Contact discret -->
        <ul class="mt-10 space-y-3 font-caslon">
          <li>
            <a href={`tel:${data.info.telephoneHref}`} class="text-aubry-encre text-lg tabular-nums underline underline-offset-4 decoration-aubry-rose hover:decoration-aubry-encre transition-colors">
              {data.info.telephone}
            </a>
          </li>
          <li>
            <a href={`mailto:${data.info.email}`} class="text-aubry-encre/80 text-base italic underline underline-offset-4 decoration-aubry-rose/60 hover:decoration-aubry-encre transition-colors break-all">
              {data.info.email}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
