---
import data from '../../../data/templates/aubry.json';
---

<header
  id="aubry-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-500 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-aubry-perle/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-aubry-encre/8"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <!-- Wordmark : sobre, juste un nom -->
    <a href="#top" class="font-caslon text-aubry-encre text-lg leading-none hover:text-aubry-prune transition-colors duration-500" aria-label="Camille Aubry — accueil">
      {data.info.wordmark}<span class="text-aubry-rose">.</span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-7 font-albert text-[13px] text-aubry-encre/65 font-light" aria-label="Navigation">
      <a href="#publics" class="hover:text-aubry-encre transition-colors duration-500">Pour qui</a>
      <a href="#approche" class="hover:text-aubry-encre transition-colors duration-500">Approche</a>
      <a href="#cadre" class="hover:text-aubry-encre transition-colors duration-500">Cadre</a>
      <a href="#tarifs" class="hover:text-aubry-encre transition-colors duration-500">Modalités</a>
    </nav>

    <!-- CTA discret souligné -->
    <a
      href="#rendez-vous"
      class="font-caslon italic text-aubry-encre text-[15px] underline underline-offset-[6px] decoration-aubry-rose hover:decoration-aubry-encre transition-colors duration-500"
    >
      Prendre rendez-vous
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('aubry-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
