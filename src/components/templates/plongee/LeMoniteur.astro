---
/**
 * LeMoniteur — bio Antoine Roussel + diplômes en colonne
 * + composition graphique (pas de photo stock recyclée).
 */
import data from '../../../data/templates/bleulagon.json';
---

<section id="moniteur" class="bg-plongee-marine text-plongee-ecume py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

    <!-- Colonne avatar graphique -->
    <div class="lg:col-span-5">
      <div class="relative aspect-[4/5] max-w-md mx-auto rounded-2xl overflow-hidden bg-plongee-abysse" role="img" aria-label={`Portrait d'${data.moniteur.nom}, moniteur`}>
        <!-- Caustiques fond -->
        <svg class="absolute inset-0 w-full h-full opacity-20 pointer-events-none" viewBox="0 0 800 1000" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <filter id="caustic-bio" x="-50%" y="-50%" width="200%" height="200%">
              <feTurbulence type="fractalNoise" baseFrequency="0.008 0.015" numOctaves="2" seed="7"/>
              <feColorMatrix values="0 0 0 0 0.25  0 0 0 0 0.66  0 0 0 0 0.84  0 0 0 1 0"/>
            </filter>
          </defs>
          <rect width="800" height="1000" filter="url(#caustic-bio)"/>
        </svg>
        <!-- Initiales géantes -->
        <span class="absolute inset-0 flex items-center justify-center font-space-grotesk font-bold text-plongee-lagon leading-none select-none" style="font-size: clamp(140px, 22vw, 240px);" aria-hidden="true">
          AR
        </span>
        <!-- Étiquette identité bas -->
        <div class="absolute bottom-4 left-4 right-4 bg-plongee-abysse/85 backdrop-blur-sm px-4 py-3 rounded-xl ring-1 ring-plongee-ecume/15">
          <p class="font-jetbrains text-[10px] uppercase tracking-[0.22em] text-plongee-corail mb-0.5">
            ▼ Moniteur · MF2 · PADI MSDT
          </p>
          <p class="font-space-grotesk font-bold text-plongee-ecume text-xl leading-tight">
            {data.moniteur.nom}
          </p>
        </div>
      </div>
    </div>

    <!-- Colonne contenu -->
    <div class="lg:col-span-7">
      <p class="font-jetbrains text-[10px] uppercase tracking-[0.32em] text-plongee-corail font-medium mb-5">
        ▼ Le moniteur
      </p>
      <h2 class="font-space-grotesk font-bold text-plongee-ecume leading-[1.0]" style="font-size: clamp(36px, 5vw, 64px);">
        {data.moniteur.titre}
      </h2>

      <p class="mt-7 font-inter text-plongee-ecume/85 text-lg leading-relaxed">
        {data.moniteur.bio}
      </p>

      <!-- Diplômes -->
      <ul class="mt-10 space-y-2.5">
        {data.moniteur.diplomes.map((d) => (
          <li class="flex items-start gap-3 font-inter text-plongee-ecume/85">
            <span class="flex w-6 h-6 rounded-full bg-plongee-lagon/20 items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-plongee-lagon">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </span>
            <span class="text-sm leading-relaxed pt-0.5">{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
