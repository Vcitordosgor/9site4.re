---
/**
 * BleuLagonHeader — header sticky transparent qui devient opaque au scroll.
 * Identité plongée : wordmark + bouton baptême en accent corail.
 */
import data from '../../../data/templates/bleulagon.json';

const navLinks = [
  { href: '#formules', label: 'Formules' },
  { href: '#moniteur', label: 'Le moniteur' },
  { href: '#securite', label: 'Sécurité' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  id="bleulagon-header"
  data-scrolled="false"
  class="sticky top-0 z-50 transition-[background-color,backdrop-filter,box-shadow,border-color] duration-300 ease-out border-b border-transparent"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">
    <a href="#top" class="flex items-baseline gap-1.5 group" aria-label="Bleu Lagon Plongée — accueil">
      <span class="font-space-grotesk font-bold text-plongee-abysse text-base md:text-lg tracking-tight">
        Bleu&nbsp;Lagon
      </span>
      <span class="font-space-grotesk font-light text-plongee-lagon text-base md:text-lg tracking-tight">
        Plongée
      </span>
      <span class="text-plongee-corail text-[10px] ml-1" aria-hidden="true">●</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 lg:gap-9 font-inter text-[13px] font-medium" aria-label="Navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-plongee-marine/85 hover:text-plongee-abysse transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="#formules"
      class="hidden md:inline-flex items-center justify-center h-10 px-5 bg-plongee-corail text-plongee-ecume font-inter font-semibold text-sm rounded-full hover:bg-plongee-abysse transition-colors duration-300"
    >
      Réserver
    </a>

    <a
      href={`tel:${data.info.telephoneHref}`}
      class="md:hidden inline-flex items-center justify-center h-10 px-4 bg-plongee-corail text-plongee-ecume font-inter font-semibold text-sm rounded-full"
      aria-label="Appeler le centre"
    >
      ☎ Appeler
    </a>
  </div>
</header>

<style>
  #bleulagon-header[data-scrolled='true'] {
    background-color: rgb(240 247 251 / 0.92);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    box-shadow: 0 1px 3px rgb(10 35 66 / 0.06);
    border-bottom-color: rgb(10 35 66 / 0.08);
  }
</style>

<script>
  const header = document.getElementById('bleulagon-header');
  if (header) {
    const update = () => {
      header.dataset.scrolled = String(window.scrollY > 8);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
