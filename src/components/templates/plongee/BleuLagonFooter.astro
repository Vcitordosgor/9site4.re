---
/**
 * BleuLagonFooter — footer minimal palette plongée.
 */
import data from '../../../data/templates/bleulagon.json';

const currentYear = new Date().getFullYear();
---

<footer class="bg-plongee-charbon text-plongee-ecume py-12 px-6 md:px-10 ring-1 ring-plongee-marine/40 ring-inset">
  <div class="max-w-content mx-auto grid md:grid-cols-3 gap-8 items-start">

    <div>
      <p class="font-space-grotesk font-bold text-plongee-ecume text-lg flex items-baseline gap-1.5">
        Bleu&nbsp;Lagon
        <span class="font-light text-plongee-lagon">Plongée</span>
        <span class="text-plongee-corail text-[10px] ml-1" aria-hidden="true">●</span>
      </p>
      <p class="mt-3 font-inter text-plongee-ecume/65 text-sm leading-relaxed max-w-xs">
        {data.info.soustitre} · Réserve marine de l'île
      </p>
      <p class="mt-4 font-jetbrains text-[10px] uppercase tracking-[0.22em] text-plongee-lagon/75">
        {data.info.agrement}
      </p>
    </div>

    <div>
      <h2 class="font-jetbrains text-[10px] uppercase tracking-[0.28em] text-plongee-corail font-medium mb-3">
        Où nous trouver
      </h2>
      <p class="font-inter text-plongee-ecume/85 text-sm leading-relaxed">
        {data.info.adresseLigne1}<br />
        {data.info.adresseLigne2}
      </p>
    </div>

    <div>
      <h2 class="font-jetbrains text-[10px] uppercase tracking-[0.28em] text-plongee-corail font-medium mb-3">
        Contact
      </h2>
      <ul class="space-y-1.5 font-inter text-sm">
        <li>
          <a href={`mailto:${data.info.email}`} class="text-plongee-ecume/85 hover:text-plongee-lagon transition-colors break-all">
            {data.info.email}
          </a>
        </li>
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="text-plongee-ecume/85 hover:text-plongee-lagon transition-colors tabular-nums">
            {data.info.telephone}
          </a>
        </li>
        <li class="text-plongee-ecume/55 text-xs">
          Instagram {data.info.instagram}
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-content mx-auto mt-10 pt-6 border-t border-plongee-ecume/10 flex flex-wrap justify-between gap-3 font-jetbrains text-[10px] uppercase tracking-[0.22em] text-plongee-ecume/45">
    <span>© {currentYear} {data.info.nom}</span>
    <span>SIRET {data.info.siret}</span>
  </div>
</footer>
