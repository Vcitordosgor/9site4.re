---
/**
 * Formules — 5 cards formules de plongée style 'fiche technique d'instrument'.
 * Chaque card = profondeur + durée + niveau + prix + inclus en bullets.
 * Mix dense (data plongeur) + empathique (description en clair).
 */
import Icon from '../../ui/Icon.astro';
import data from '../../../data/templates/bleulagon.json';

const iconMap: Record<string, string> = {
  'spark': 'sparkle',
  'waves': 'globe',
  'leaf': 'shield-check',
  'compass': 'calendar-clock',
  'shield': 'shield-check',
};
---

<section id="formules" class="bg-plongee-ecume py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="mb-14 md:mb-20 max-w-3xl">
      <p class="font-jetbrains text-[10px] uppercase tracking-[0.32em] text-plongee-corail font-medium mb-5">
        ▼ 5 formules · de baptême au passage de niveau
      </p>
      <h2 class="font-space-grotesk font-bold text-plongee-abysse leading-[1.0]" style="font-size: clamp(40px, 6vw, 76px);">
        Choisissez votre
        <span class="italic font-light text-plongee-lagon">profondeur.</span>
      </h2>
      <p class="mt-6 font-inter text-plongee-marine/85 text-lg leading-relaxed">
        Du premier baptême en surface à la formation PADI Open Water, on adapte la sortie à votre niveau, votre envie, votre rythme. Toutes les formules incluent le matériel et l'encadrement.
      </p>
    </header>

    <ul class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {data.formules.map((f, i) => (
        <li class:list={[
          'group relative bg-plongee-abysse text-plongee-ecume rounded-2xl p-6 md:p-7 ring-1 ring-plongee-marine/40 hover:ring-plongee-corail transition-all hover:-translate-y-1 flex flex-col',
          i === 3 ? 'lg:col-start-2' : '',
        ]}>
          <!-- Icône + niveau badge -->
          <div class="flex items-start justify-between gap-3 mb-5">
            <span class="flex w-12 h-12 rounded-xl bg-plongee-lagon/15 text-plongee-lagon items-center justify-center">
              <Icon name={iconMap[f.icone] ?? 'sparkle'} size={22} strokeWidth={1.75} />
            </span>
            <span class="inline-flex items-center h-6 px-2.5 bg-plongee-corail/15 text-plongee-corail font-jetbrains text-[10px] uppercase tracking-wider rounded-full">
              {f.niveau}
            </span>
          </div>

          <!-- Titre -->
          <h3 class="font-space-grotesk font-bold text-plongee-ecume text-2xl leading-tight">
            {f.titre}
          </h3>

          <!-- Données techniques en grille type instrument -->
          <dl class="mt-4 grid grid-cols-2 gap-x-3 gap-y-2 pt-3 border-t border-plongee-ecume/10 font-jetbrains text-[10px] uppercase tracking-[0.18em]">
            <div>
              <dt class="text-plongee-lagon mb-0.5">Durée</dt>
              <dd class="text-plongee-ecume tabular-nums">{f.duree}</dd>
            </div>
            <div>
              <dt class="text-plongee-lagon mb-0.5">Profondeur</dt>
              <dd class="text-plongee-ecume tabular-nums">{f.profondeur}</dd>
            </div>
          </dl>

          <!-- Description -->
          <p class="mt-5 font-inter text-plongee-ecume/75 text-sm leading-relaxed">
            {f.description}
          </p>

          <!-- Inclus -->
          <ul class="mt-5 space-y-2 flex-1">
            {f.inclus.map((item) => (
              <li class="flex items-start gap-2 font-inter text-[13px] text-plongee-ecume/85 leading-snug">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="text-plongee-lagon shrink-0 mt-0.5" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <!-- Prix + CTA -->
          <div class="mt-6 pt-5 border-t border-plongee-ecume/10 flex items-end justify-between gap-3">
            <p class="font-space-grotesk font-bold text-plongee-corail leading-none tabular-nums" style="font-size: 36px;">
              {f.prix}
            </p>
            <a
              href={`https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent(`Bonjour, je voudrais réserver : ${f.titre}`)}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 font-inter font-semibold text-plongee-ecume text-sm hover:text-plongee-corail transition-colors"
            >
              Réserver
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
