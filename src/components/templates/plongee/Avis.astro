---
/**
 * Avis — 3 témoignages en cards horizontales.
 * Citations en serif italic, étoiles + métier en mono.
 */
import data from '../../../data/templates/bleulagon.json';
---

<section id="avis" class="bg-plongee-marine text-plongee-ecume py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-20 max-w-2xl mx-auto">
      <p class="font-jetbrains text-[10px] uppercase tracking-[0.32em] text-plongee-corail font-medium mb-5">
        ▼ Avis vérifiés · Google
      </p>
      <h2 class="font-space-grotesk font-bold text-plongee-ecume leading-[1.0]" style="font-size: clamp(36px, 5vw, 60px);">
        Ce que les plongeurs
        <span class="block italic font-light text-plongee-lagon">disent de nous.</span>
      </h2>
    </header>

    <ul class="grid md:grid-cols-3 gap-5 md:gap-6">
      {data.avis.map((a) => (
        <li class="bg-plongee-abysse rounded-2xl p-6 md:p-7 ring-1 ring-plongee-ecume/15 flex flex-col">
          <!-- Étoiles -->
          <p class="flex items-center gap-0.5 text-plongee-corail mb-4" aria-label={`${a.etoiles} étoiles sur 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={[i < a.etoiles ? 'text-plongee-corail' : 'text-plongee-ecume/15']} aria-hidden="true">★</span>
            ))}
          </p>

          <!-- Citation -->
          <blockquote class="font-inter text-plongee-ecume/90 text-base leading-relaxed flex-1 italic">
            « {a.texte} »
          </blockquote>

          <!-- Signature -->
          <footer class="mt-6 pt-5 border-t border-plongee-ecume/10">
            <p class="font-space-grotesk font-bold text-plongee-ecume text-base">{a.prenom}</p>
            <p class="font-jetbrains text-[10px] uppercase tracking-[0.22em] text-plongee-lagon mt-0.5">
              {a.metier} · {a.date}
            </p>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>
