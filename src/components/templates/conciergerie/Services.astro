---
/**
 * Services — 8 services présentés en menu d'hôtel.
 * Format liste à puces dorées, pas de cards photo.
 */
import data from '../../../data/templates/concierge.json';
---

<section id="services" class="bg-concierge-champagne py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-16 md:mb-20 max-w-2xl mx-auto">
      <p class="font-hubot text-[10px] uppercase tracking-[0.4em] text-concierge-laiton mb-6 font-medium">
        ✦ Nos services ✦
      </p>
      <h2 class="font-volkhov text-concierge-nuit leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Huit prestations,
        <span class="block italic text-concierge-laiton">à composer librement.</span>
      </h2>
    </header>

    <!-- Grid 2x4 services -->
    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 md:gap-y-14">
      {data.services.map((s, i) => (
        <li>
          <p class="font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton mb-3 font-medium">
            ✦ {String(i + 1).padStart(2, '0')}
          </p>
          <h3 class="font-volkhov text-concierge-nuit text-xl md:text-2xl leading-tight mb-3">
            {s.titre}
          </h3>
          <p class="font-hubot text-concierge-graphite text-sm leading-[1.75]">
            {s.description}
          </p>
          <span class="block mt-4 h-px w-12 bg-concierge-laiton/40" aria-hidden="true"></span>
        </li>
      ))}
    </ul>
  </div>
</section>
