---
import data from '../../../data/templates/concierge.json';
---

<section id="temoignages" class="bg-concierge-champagne py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-14 md:mb-16 max-w-2xl mx-auto">
      <p class="font-hubot text-[10px] uppercase tracking-[0.4em] text-concierge-laiton mb-6 font-medium">
        ✦ Témoignages ✦
      </p>
      <h2 class="font-volkhov text-concierge-nuit leading-[1.05]" style="font-size: clamp(36px, 5vw, 60px);">
        Quelques mots,
        <span class="italic text-concierge-laiton">sous initiales.</span>
      </h2>
      <p class="mt-5 font-volkhov italic text-concierge-graphite text-base md:text-lg leading-relaxed">
        Pour respecter la discrétion de nos clients, ils sont identifiés par leurs initiales et leur ville.
      </p>
    </header>

    <ul class="grid md:grid-cols-2 gap-5">
      {data.temoignages.map((t) => (
        <li class="bg-concierge-blanc p-7 md:p-9 border border-concierge-laiton/30">

          <div class="flex items-baseline justify-between gap-4 mb-5 pb-5 border-b border-concierge-laiton/30">
            <p class="font-volkhov italic text-concierge-nuit text-2xl tabular-nums leading-none">
              {t.initiales}
            </p>
            <p class="font-hubot text-[10px] uppercase tracking-[0.28em] text-concierge-laiton">
              ✦ {t.lieu}
            </p>
          </div>

          <blockquote class="font-volkhov italic text-concierge-graphite text-base md:text-lg leading-[1.85] mb-5">
            « {t.texte} »
          </blockquote>

          <p class="font-hubot text-[10px] uppercase tracking-[0.28em] text-concierge-graphite/65">
            ↳ {t.anciennete}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
