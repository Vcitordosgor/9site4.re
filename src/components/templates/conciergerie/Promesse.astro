---
import data from '../../../data/templates/concierge.json';
---

<section class="bg-concierge-blanc py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-3xl mx-auto">

    <p class="font-hubot text-[10px] uppercase tracking-[0.4em] text-concierge-laiton text-center mb-10 font-medium">
      ✦ Notre promesse ✦
    </p>

    <div class="space-y-10 text-center">
      {data.promesse.map((p, i) => (
        <p class:list={[
          'font-volkhov leading-[1.65]',
          i === 0 ? 'italic text-concierge-nuit text-2xl md:text-3xl' : 'text-concierge-graphite text-lg md:text-xl',
        ]}>
          {p}
        </p>
      ))}
    </div>

    <!-- Signature manuscrite Pinyon -->
    <p class="mt-14 text-center font-pinyon text-concierge-laiton text-5xl leading-none">
      {data.info.fondatrice}
    </p>
    <p class="mt-2 text-center font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-graphite">
      Fondatrice · {data.info.wordmark1} {data.info.wordmark2}
    </p>
  </div>
</section>
