---
import data from '../../../data/templates/concierge.json';
const waBase = `https://wa.me/${data.info.whatsapp}`;
---

<section id="demande" class="bg-concierge-blanc py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-3xl mx-auto">

    <header class="text-center mb-14">
      <p class="font-hubot text-[10px] uppercase tracking-[0.4em] text-concierge-laiton mb-6 font-medium">
        ✦ Demande de service ✦
      </p>
      <h2 class="font-volkhov text-concierge-nuit leading-[1.05]" style="font-size: clamp(36px, 5vw, 60px);">
        Premier contact,
        <span class="italic text-concierge-laiton">simple et discret.</span>
      </h2>
    </header>

    <form id="concierge-form" class="bg-concierge-champagne p-7 md:p-10 border border-concierge-laiton/30 space-y-6" novalidate>

      <p class="font-pinyon text-concierge-laiton text-3xl rotate-[-1deg] mb-2 leading-none">
        Merci de prendre contact.
      </p>

      <!-- Service souhaité -->
      <div>
        <label for="cc-service" class="block font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton font-medium mb-2">
          Service souhaité
        </label>
        <select
          id="cc-service"
          name="service"
          required
          class="w-full h-12 px-4 bg-concierge-blanc border border-concierge-graphite/25 focus:border-concierge-laiton font-volkhov text-concierge-nuit text-base outline-none transition-colors cursor-pointer"
        >
          <option value="">— Sélectionner —</option>
          {data.services.map((s) => <option value={s.titre}>{s.titre}</option>)}
          <option value="formule">Renseignements sur les formules</option>
          <option value="autre">Autre / À discuter</option>
        </select>
      </div>

      <!-- Formule envisagée -->
      <div>
        <label for="cc-formule" class="block font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton font-medium mb-2">
          Formule envisagée
        </label>
        <div class="grid sm:grid-cols-3 gap-2">
          {data.formules.map((f, i) => (
            <label class="cursor-pointer">
              <input type="radio" name="formule" value={f.label} class="peer sr-only" checked={i === 1} />
              <span class="block px-4 py-3 bg-concierge-blanc border border-concierge-graphite/25 peer-checked:border-concierge-laiton peer-checked:bg-concierge-laiton/10 font-volkhov text-concierge-nuit text-sm transition-colors text-center">
                {f.label} · {f.prix} €
              </span>
            </label>
          ))}
        </div>
      </div>

      <!-- Coordonnées -->
      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="cc-nom" class="block font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton font-medium mb-2">
            Nom & prénom
          </label>
          <input
            id="cc-nom"
            name="nom"
            type="text"
            required
            autocomplete="name"
            class="w-full h-12 px-4 bg-concierge-blanc border border-concierge-graphite/25 focus:border-concierge-laiton font-volkhov text-concierge-nuit text-base outline-none transition-colors"
          />
        </div>
        <div>
          <label for="cc-tel" class="block font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton font-medium mb-2">
            Téléphone
          </label>
          <input
            id="cc-tel"
            name="telephone"
            type="tel"
            required
            autocomplete="tel"
            class="w-full h-12 px-4 bg-concierge-blanc border border-concierge-graphite/25 focus:border-concierge-laiton font-volkhov text-concierge-nuit text-base outline-none transition-colors tabular-nums"
          />
        </div>
      </div>

      <div>
        <label for="cc-message" class="block font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton font-medium mb-2">
          Précisions <span class="lowercase italic font-volkhov text-concierge-graphite/55 normal-case">(facultatif)</span>
        </label>
        <textarea
          id="cc-message"
          name="message"
          rows="3"
          placeholder="Contexte, besoins particuliers, attentes…"
          class="w-full px-4 py-3 bg-concierge-blanc border border-concierge-graphite/25 focus:border-concierge-laiton font-volkhov text-concierge-nuit text-base placeholder:text-concierge-graphite/45 outline-none transition-colors resize-none"
        ></textarea>
      </div>

      <!-- Submit -->
      <div class="text-center pt-4 border-t border-concierge-laiton/30">
        <button
          type="submit"
          class="inline-flex items-center justify-center h-13 px-9 bg-concierge-nuit text-concierge-champagne font-hubot text-sm uppercase tracking-[0.18em] font-medium hover:bg-concierge-encre transition-colors duration-500"
          style="height: 52px;"
        >
          Envoyer la demande
        </button>
        <p class="mt-4 font-volkhov italic text-concierge-graphite/65 text-sm">
          Réponse personnelle de Charlotte sous 4 heures, en heures ouvrées.
        </p>
      </div>
    </form>
  </div>
</section>

<script define:vars={{ waBase }}>
  const form = document.getElementById('concierge-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const service = fd.get('service') || '';
      const formule = fd.get('formule') || '';
      const nom = fd.get('nom') || '';
      const tel = fd.get('telephone') || '';
      const message = fd.get('message') || '';
      const text = [
        'Bonjour, je souhaite vous contacter pour une demande de service.',
        service ? `Service : ${service}` : '',
        formule ? `Formule : ${formule}` : '',
        nom ? `Nom : ${nom}` : '',
        tel ? `Tél : ${tel}` : '',
        message ? `Précisions : ${message}` : '',
      ].filter(Boolean).join('\n');
      window.open(`${waBase}?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
    });
  }
</script>
