---
import data from '../../../data/templates/concierge.json';
const year = new Date().getFullYear();
---

<footer class="bg-concierge-blanc text-concierge-graphite/75 py-12 px-6 md:px-10 border-t border-concierge-laiton/30">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-volkhov italic text-concierge-nuit text-xl leading-none">{data.info.wordmark1}</span>
          <span class="font-volkhov text-concierge-laiton text-xl leading-none tracking-wide">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-pinyon text-concierge-laiton text-2xl leading-none">
          à votre disposition
        </p>
        <p class="mt-2 font-hubot text-[11px] uppercase tracking-[0.22em] text-concierge-graphite/60">
          {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-hubot text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-concierge-nuit transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-concierge-laiton" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-concierge-nuit transition-colors break-all">{data.info.email}</a></li>
      </ul>
    </div>

    <!-- Filet doré -->
    <div class="h-px mb-6" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgba(184,151,88,0.5) 30%, rgba(184,151,88,0.5) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-hubot text-[10px] uppercase tracking-[0.28em] text-concierge-graphite/45">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-concierge-nuit hover:text-concierge-laiton transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
