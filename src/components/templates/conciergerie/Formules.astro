---
/**
 * Formules — 3 cartes de membership privé.
 */
import data from '../../../data/templates/concierge.json';
---

<section id="formules" class="bg-concierge-nuit text-concierge-champagne py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="text-center mb-16 md:mb-20 max-w-2xl mx-auto">
      <p class="font-hubot text-[10px] uppercase tracking-[0.4em] text-concierge-laiton mb-6 font-medium">
        ✦ Formules d'abonnement ✦
      </p>
      <h2 class="font-volkhov text-concierge-champagne leading-[1.05]" style="font-size: clamp(36px, 5vw, 64px);">
        Trois cartes de membre,
        <span class="block italic text-concierge-laiton">à votre rythme.</span>
      </h2>
    </header>

    <ul class="grid md:grid-cols-3 gap-5 md:gap-6">
      {data.formules.map((f) => (
        <li class:list={[
          'relative p-7 md:p-9 flex flex-col bg-concierge-encre/40 backdrop-blur-sm border transition-colors duration-500 hover:border-concierge-laiton',
          f.populaire ? 'border-concierge-laiton lg:-mt-4 lg:mb-4 ring-1 ring-concierge-laiton/40' : 'border-concierge-champagne/15',
        ]}>
          {f.populaire && (
            <span class="absolute -top-3 left-7 inline-block bg-concierge-laiton text-concierge-nuit font-hubot text-[10px] uppercase tracking-[0.28em] font-medium px-3 py-1.5">
              ✦ Le + choisi
            </span>
          )}

          <p class="font-hubot text-[10px] uppercase tracking-[0.32em] text-concierge-laiton mb-3 font-medium">
            Carte de membre
          </p>

          <h3 class="font-volkhov italic text-concierge-champagne text-3xl md:text-4xl leading-tight mb-2">
            {f.label}
          </h3>

          <!-- Filet doré -->
          <span class="block w-12 h-px bg-concierge-laiton mb-6" aria-hidden="true"></span>

          <!-- Prix -->
          <div class="flex items-baseline gap-2 mb-5">
            <span class="font-volkhov text-concierge-champagne tabular-nums leading-none" style="font-size: clamp(40px, 4vw, 56px);">
              {f.prix} €
            </span>
            <span class="font-hubot text-concierge-champagne/65 text-sm">
              {f.frequence}
            </span>
          </div>

          <p class="font-volkhov italic text-concierge-champagne/75 text-base md:text-lg leading-[1.7] mb-6">
            {f.description}
          </p>

          <ul class="space-y-2.5 mb-7 flex-1">
            {f.inclus.map((i) => (
              <li class="flex items-start gap-2.5 font-hubot text-concierge-champagne/85 text-sm leading-relaxed">
                <span class="shrink-0 mt-1.5 block w-1.5 h-1.5 rounded-full bg-concierge-laiton" aria-hidden="true"></span>
                {i}
              </li>
            ))}
          </ul>

          <a
            href="#demande"
            class="inline-flex items-center justify-center h-12 bg-concierge-laiton text-concierge-nuit font-hubot text-sm uppercase tracking-[0.18em] font-medium hover:bg-concierge-champagne transition-colors duration-500"
          >
            Choisir cette formule
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-12 text-center font-volkhov italic text-concierge-champagne/70 text-base">
      Aucun engagement de durée. Vous pouvez changer de formule ou résilier à tout moment.
    </p>
  </div>
</section>
