---
import data from '../../../data/templates/vermeille.json';
const year = new Date().getFullYear();
---

<footer class="bg-vermeille-charbon text-vermeille-ivoire/75 py-12 px-6 md:px-10 border-t border-vermeille-or/15">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-italiana text-vermeille-ivoire text-2xl tracking-wide leading-none">
            {data.info.wordmark}
          </span>
          <span class="text-vermeille-or text-xs leading-none" aria-hidden="true">✦</span>
        </p>
        <p class="mt-2 font-italiana italic text-vermeille-rose/80 text-sm">
          {data.info.soustitre} · {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 font-inter-tight text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-vermeille-rose transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-vermeille-or/40" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-vermeille-rose transition-colors">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-vermeille-or/40" aria-hidden="true"></li>
        <li class="font-italiana italic text-vermeille-ivoire/55">{data.info.instagram}</li>
      </ul>
    </div>

    <!-- Filet doré dégradé -->
    <div class="h-px mb-6" aria-hidden="true"
         style="background: linear-gradient(to right, transparent, rgba(184,149,106,0.5) 30%, rgba(184,149,106,0.5) 70%, transparent);">
    </div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-inter-tight text-[10px] uppercase tracking-[0.25em] text-vermeille-ivoire/40">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-vermeille-ivoire/70 hover:text-vermeille-rose transition-colors font-normal">9site4</a>
      </p>
    </div>
  </div>
</footer>
