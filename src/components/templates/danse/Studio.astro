---
/**
 * Studio — photo grande largeur du lieu + adresse en dessous.
 * Layout cinematic : photo full-width avec ratio paysage, légende en bas.
 */
import data from '../../../data/templates/vermeille.json';
---

<section id="studio" class="bg-vermeille-ivoire">

  <!-- Photo grande largeur, ratio paysage -->
  <figure class="relative">
    <div class="relative aspect-[16/9] md:aspect-[21/9] overflow-hidden">
      <img
        src={data.info.photoStudio}
        alt="L'intérieur du studio Vermeille"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover grayscale brightness-[0.92]"
      />
      <!-- Voile bordeaux léger -->
      <div class="absolute inset-0 bg-vermeille-bordeaux/10"></div>
      <!-- Légende en surimpression -->
      <figcaption class="absolute bottom-6 right-6 md:bottom-10 md:right-10 text-right">
        <p class="font-italiana italic text-vermeille-ivoire text-2xl md:text-4xl drop-shadow-lg">
          Le studio
        </p>
        <p class="font-inter-tight text-[10px] md:text-[11px] uppercase tracking-[0.3em] text-vermeille-rose mt-1 drop-shadow">
          {data.info.adresseLigne1}
        </p>
      </figcaption>
    </div>
  </figure>

  <!-- Bandeau infos pratiques -->
  <div class="max-w-content mx-auto px-6 md:px-10 py-12 md:py-16 grid md:grid-cols-3 gap-8 md:gap-12 items-start">

    <!-- Adresse -->
    <div>
      <p class="font-inter-tight text-[10px] uppercase tracking-[0.3em] text-vermeille-bordeaux mb-3">Adresse</p>
      <p class="font-italiana text-vermeille-velours text-2xl leading-snug">
        {data.info.adresseLigne1}
      </p>
      <p class="font-italiana italic text-vermeille-velours/70 text-lg">
        {data.info.adresseLigne2}
      </p>
    </div>

    <!-- Horaires accueil -->
    <div>
      <p class="font-inter-tight text-[10px] uppercase tracking-[0.3em] text-vermeille-bordeaux mb-3">Accueil</p>
      <ul class="space-y-1.5">
        {data.horairesAccueil.map((h) => (
          <li class="flex items-baseline justify-between gap-3 font-inter-tight text-sm border-b border-vermeille-velours/10 pb-1.5">
            <span class="text-vermeille-velours/85">{h.jour}</span>
            <span class:list={['tabular-nums text-right', h.ouvert ? 'text-vermeille-velours/65' : 'italic text-vermeille-velours/40']}>{h.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <p class="font-inter-tight text-[10px] uppercase tracking-[0.3em] text-vermeille-bordeaux mb-3">Nous joindre</p>
      <ul class="space-y-2 font-italiana text-vermeille-velours">
        <li>
          <a href={`tel:${data.info.telephoneHref}`} class="hover:text-vermeille-bordeaux transition-colors tabular-nums text-lg underline underline-offset-4 decoration-vermeille-or/40">
            {data.info.telephone}
          </a>
        </li>
        <li>
          <a href={`mailto:${data.info.email}`} class="hover:text-vermeille-bordeaux transition-colors text-base italic underline underline-offset-4 decoration-vermeille-or/40">
            {data.info.email}
          </a>
        </li>
      </ul>
    </div>
  </div>
</section>
