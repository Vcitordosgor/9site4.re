---
/**
 * Disciplines — 5 cartes verticales hautes type AFFICHE de spectacle.
 * Photo portrait haute (3:4), nom serif italienne énorme, niveau, créneaux.
 * Layout : grid responsive avec hauteurs alternées qui décalent légèrement
 * (effet poster mural). PAS de cards horizontales équiangles.
 */
import data from '../../../data/templates/vermeille.json';
---

<section id="disciplines" class="bg-vermeille-ivoire py-24 md:py-36 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <!-- Header éditorial -->
    <header class="mb-16 md:mb-24 text-center max-w-2xl mx-auto">
      <p class="font-inter-tight text-[10px] uppercase tracking-[0.4em] text-vermeille-bordeaux mb-6">
        Les disciplines
      </p>
      <h2 class="font-italiana text-vermeille-velours leading-[1.0]" style="font-size: clamp(44px, 6vw, 80px);">
        Cinq langages,
        <span class="block italic text-vermeille-bordeaux">une même scène.</span>
      </h2>
      <div class="mt-8 flex items-center justify-center gap-3" aria-hidden="true">
        <span class="block h-px w-12 bg-vermeille-or/40"></span>
        <span class="text-vermeille-or text-sm">✦</span>
        <span class="block h-px w-12 bg-vermeille-or/40"></span>
      </div>
    </header>

    <!-- Grid de cartes affiches -->
    <ul class="grid grid-cols-2 lg:grid-cols-5 gap-x-4 md:gap-x-6 gap-y-12 md:gap-y-16">
      {data.disciplines.map((d, i) => (
        <li class:list={['group relative', i % 2 === 1 ? 'lg:mt-12' : '']}>
          <a href="#inscription" class="block">

            <!-- Carte discipline (sans photo) -->
            <div class="relative aspect-[3/4] overflow-hidden bg-vermeille-velours flex items-start justify-between p-6 md:p-8">
              <span class="font-italiana italic text-vermeille-ivoire text-3xl md:text-4xl">
                {d.numero}
              </span>
              <span class="text-vermeille-or text-2xl" aria-hidden="true">✦</span>
            </div>

            <!-- Nom -->
            <h3 class="mt-5 font-italiana text-vermeille-velours leading-[1.0] group-hover:text-vermeille-bordeaux transition-colors duration-500" style="font-size: clamp(28px, 3.5vw, 44px);">
              {d.nom}
            </h3>

            <!-- Niveau -->
            <p class="mt-2 font-inter-tight text-[10px] uppercase tracking-[0.25em] text-vermeille-bordeaux">
              {d.niveaux}
            </p>

            <!-- Description -->
            <p class="mt-3 font-inter-tight text-vermeille-velours/65 text-[13px] leading-[1.65]">
              {d.description}
            </p>

            <!-- Créneaux discret -->
            <p class="mt-4 pt-3 border-t border-vermeille-velours/15 font-italiana italic text-vermeille-velours/55 text-[13px] leading-relaxed">
              {d.creneaux}
            </p>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>
