---
/**
 * Reservation — formulaire compact 4 champs.
 */
import data from '../../../data/templates/sentiers.json';
const waBase = `https://wa.me/${data.info.whatsapp}`;
---

<section id="reservation" class="bg-sentiers-foret text-sentiers-brume py-24 md:py-36 px-6 md:px-10 relative overflow-hidden">

  <!-- Photo paysage très atténuée en arrière-plan -->
  <div class="absolute inset-0 opacity-[0.15] pointer-events-none" aria-hidden="true">
    <img src={data.carrousel[0].src} alt="" class="w-full h-full object-cover" loading="lazy" />
  </div>

  <div class="relative max-w-3xl mx-auto">

    <header class="text-center mb-14">
      <p class="font-roboto-mono text-[10px] uppercase tracking-[0.32em] text-sentiers-soleil mb-4">
        ▲ Réserver
      </p>
      <h2 class="font-tinos italic text-sentiers-brume leading-[1.05]" style="font-size: clamp(36px, 5vw, 60px);">
        Une sortie vous tente ?
      </h2>
      <p class="mt-5 font-familjen text-sentiers-brume/75 text-lg leading-relaxed max-w-md mx-auto">
        Quatre champs, c'est tout. Le formulaire ouvre WhatsApp avec votre demande pré-remplie.
      </p>
    </header>

    <form id="resa-sentiers-form" class="bg-sentiers-noir/60 backdrop-blur-sm border border-sentiers-brume/15 p-7 md:p-10 space-y-5" novalidate>

      <div>
        <label for="resa-sortie" class="block font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-sentiers-soleil mb-2">
          La sortie
        </label>
        <select
          id="resa-sortie"
          name="sortie"
          required
          class="w-full h-12 px-4 bg-sentiers-foret border border-sentiers-brume/20 focus:border-sentiers-soleil font-tinos text-sentiers-brume text-lg outline-none transition-colors cursor-pointer"
        >
          <option value="">— Choisir une sortie —</option>
          {data.sorties.map((s) => <option value={s.id}>{s.nom} · {s.lieu} · {s.prix}</option>)}
        </select>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="resa-date" class="block font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-sentiers-soleil mb-2">
            Date souhaitée
          </label>
          <input
            id="resa-date"
            name="date"
            type="date"
            required
            class="w-full h-12 px-4 bg-sentiers-foret border border-sentiers-brume/20 focus:border-sentiers-soleil font-tinos text-sentiers-brume text-lg outline-none transition-colors tabular-nums"
          />
        </div>
        <div>
          <label for="resa-pers" class="block font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-sentiers-soleil mb-2">
            Nombre de pers.
          </label>
          <input
            id="resa-pers"
            name="personnes"
            type="number"
            min="1"
            max="8"
            required
            placeholder="1 à 8"
            class="w-full h-12 px-4 bg-sentiers-foret border border-sentiers-brume/20 focus:border-sentiers-soleil font-tinos text-sentiers-brume text-lg outline-none transition-colors tabular-nums"
          />
        </div>
      </div>

      <div>
        <label for="resa-tel-sentiers" class="block font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-sentiers-soleil mb-2">
          Téléphone
        </label>
        <input
          id="resa-tel-sentiers"
          name="telephone"
          type="tel"
          required
          autocomplete="tel"
          placeholder="0692 xx xx xx"
          class="w-full h-12 px-4 bg-sentiers-foret border border-sentiers-brume/20 focus:border-sentiers-soleil font-tinos text-sentiers-brume text-lg outline-none transition-colors tabular-nums"
        />
      </div>

      <button
        type="submit"
        class="w-full inline-flex items-center justify-center gap-3 h-14 bg-sentiers-soleil text-sentiers-foret font-familjen font-medium text-base hover:bg-sentiers-brume transition-colors"
      >
        Envoyer ma demande →
      </button>

      <p class="font-tinos italic text-sentiers-brume/65 text-sm text-center">
        Réponse de Théo dans la journée. Annulation gratuite jusqu'à 48h avant.
      </p>
    </form>
  </div>
</section>

<script define:vars={{ waBase }}>
  const form = document.getElementById('resa-sentiers-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const sortie = fd.get('sortie') || '';
      const date = fd.get('date') || '';
      const personnes = fd.get('personnes') || '';
      const tel = fd.get('telephone') || '';
      const text = [
        'Salut Théo, je voudrais réserver une sortie.',
        sortie ? `Sortie : ${sortie}` : '',
        date ? `Date : ${date}` : '',
        personnes ? `Personnes : ${personnes}` : '',
        tel ? `Tél : ${tel}` : '',
      ].filter(Boolean).join('\n');
      window.open(`${waBase}?text=${encodeURIComponent(text)}`, '_blank', 'noopener,noreferrer');
    });
  }
</script>
