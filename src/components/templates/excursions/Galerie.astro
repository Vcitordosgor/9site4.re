---
/**
 * Galerie — masonry-style 8 photos avec hauteurs alternées.
 */
import data from '../../../data/templates/sentiers.json';
---

<section id="galerie" class="bg-sentiers-noir text-sentiers-brume py-24 md:py-32 px-6 md:px-10 overflow-hidden">
  <div class="max-w-content mx-auto">

    <header class="mb-12 md:mb-16 max-w-2xl">
      <p class="font-roboto-mono text-[10px] uppercase tracking-[0.32em] text-sentiers-soleil mb-4">
        ▲ Galerie
      </p>
      <h2 class="font-tinos italic text-sentiers-brume leading-[1.05]" style="font-size: clamp(36px, 5.5vw, 60px);">
        Aperçu des sorties<br/>
        <span class="not-italic font-familjen font-medium text-sentiers-soleil">de cette saison.</span>
      </h2>
    </header>

    <!-- Masonry grid avec hauteurs variables -->
    <div class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3">
      {data.galerie.map((src, i) => {
        const aspects = ['aspect-[4/5]', 'aspect-[3/4]', 'aspect-[1/1]', 'aspect-[5/4]', 'aspect-[3/4]', 'aspect-[4/5]', 'aspect-[1/1]', 'aspect-[5/4]'];
        return (
          <div class:list={['break-inside-avoid overflow-hidden', aspects[i % aspects.length]]}>
            <img
              src={src}
              alt={`Paysage de Sentiers Croisés #${i + 1}`}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
            />
          </div>
        );
      })}
    </div>

    <p class="mt-10 text-center">
      <a
        href={`https://instagram.com/${data.info.instagram.replace('@', '')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-familjen font-medium text-sentiers-soleil text-sm uppercase tracking-wider hover:text-sentiers-brume transition-colors"
      >
        Plus de photos sur {data.info.instagram} →
      </a>
    </p>
  </div>
</section>
