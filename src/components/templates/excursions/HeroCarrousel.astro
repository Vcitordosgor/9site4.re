---
/**
 * HeroCarrousel — 4 photos full-screen en cycle auto-fade 6s.
 * Titre Tinos italic placé en bas-gauche, sticker "Sortie du jour" en haut-droite.
 * Animation jamais utilisée dans les autres templates.
 */
import data from '../../../data/templates/sentiers.json';
---

<section id="top" class="relative min-h-[100svh] bg-sentiers-foret text-sentiers-brume overflow-hidden">

  <!-- Slides du carrousel -->
  <div class="absolute inset-0">
    {data.carrousel.map((p, i) => (
      <div
        data-slide={i}
        class:list={[
          'absolute inset-0 transition-opacity duration-1000',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
      >
        <img
          src={p.src}
          alt={p.alt}
          class="w-full h-full object-cover"
          fetchpriority={i === 0 ? 'high' : 'low'}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
      </div>
    ))}
  </div>

  <!-- Légende lieu de la photo courante (synchronisée avec le slide actif) -->
  <div class="hidden md:flex absolute top-32 left-10 z-10 flex-col gap-2 max-w-[40%]" aria-live="polite">
    {data.carrousel.map((p, i) => (
      <div
        data-slide-caption={i}
        class:list={[
          'inline-flex items-baseline gap-2 px-3 py-1.5 bg-sentiers-foret/60 backdrop-blur-sm ring-1 ring-sentiers-brume/15 transition-opacity duration-700',
          i === 0 ? 'opacity-100' : 'opacity-0 absolute',
        ]}
      >
        <span class="text-sentiers-soleil text-[10px]" aria-hidden="true">📍</span>
        <span class="font-roboto-mono text-[10px] uppercase tracking-[0.22em] text-sentiers-brume">
          {p.lieu}
        </span>
        <span class="font-roboto-mono text-[10px] tabular-nums text-sentiers-soleil/80">
          · {p.altitude}
        </span>
      </div>
    ))}
  </div>

  <!-- Voile vert sombre dégradé -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(14,40,32,0.7) 0%, rgba(14,40,32,0.45) 50%, rgba(14,40,32,0.85) 100%);" aria-hidden="true"></div>

  <!-- Sticker "Sortie du jour" en haut droite -->
  <div class="absolute top-24 right-6 md:top-32 md:right-10 z-10 max-w-xs">
    <div class="bg-sentiers-terre text-sentiers-brume p-5 transform rotate-2" style="box-shadow: 0 8px 24px rgba(184,90,61,0.35);">
      <p class="font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-sentiers-soleil mb-2">
        ▲ {data.info.sortieDuJour.label}
      </p>
      <p class="font-tinos italic text-sentiers-brume text-2xl leading-tight mb-1">
        {data.info.sortieDuJour.titre}
      </p>
      <p class="font-familjen text-sentiers-brume/85 text-sm">
        {data.info.sortieDuJour.date}
      </p>
      <a href="#reservation" class="mt-3 inline-flex items-center gap-1.5 font-familjen font-medium text-sentiers-soleil text-xs uppercase tracking-wider hover:text-sentiers-brume transition-colors">
        Il reste 3 places →
      </a>
    </div>
  </div>

  <!-- Contenu principal -->
  <div class="relative z-10 max-w-content mx-auto px-6 md:px-10 min-h-[100svh] flex flex-col justify-end pb-20 md:pb-28 pt-32">

    <!-- Eyebrow -->
    <p class="font-roboto-mono text-[10px] uppercase tracking-[0.4em] text-sentiers-soleil mb-6">
      Guide rando indépendant · 974 · depuis {data.info.annee}
    </p>

    <!-- Titre principal Tinos italic -->
    <h1 class="font-tinos italic text-sentiers-brume leading-[0.95] max-w-4xl" style="font-size: clamp(48px, 9vw, 144px);">
      Le Maïdo<br/>
      <span class="text-sentiers-soleil">n'attend que vous.</span>
    </h1>

    <!-- Sous-titre -->
    <p class="mt-7 font-familjen text-sentiers-brume/85 text-lg md:text-2xl max-w-xl leading-relaxed">
      Six sorties guidées par mois sur les sentiers les plus spectaculaires de l'île. Petit groupe, sécurité, anecdotes. Aucune frustration de mauvaises photos.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#sorties"
        class="inline-flex items-center justify-center h-14 px-8 bg-sentiers-soleil text-sentiers-foret font-familjen font-medium text-base hover:bg-sentiers-brume transition-colors"
      >
        Voir les sorties →
      </a>
      <a
        href="#reservation"
        class="inline-flex items-center h-14 px-7 border border-sentiers-brume/40 text-sentiers-brume font-familjen text-base hover:border-sentiers-soleil hover:text-sentiers-soleil transition-colors"
      >
        Réserver une journée
      </a>
    </div>

    <!-- Bulletin 'Conditions du jour' façon guide rando pro -->
    <div class="mt-10 inline-flex flex-wrap items-center gap-x-4 gap-y-2 px-4 py-2.5 rounded-full bg-sentiers-foret/45 backdrop-blur-sm ring-1 ring-sentiers-brume/15 max-w-full">
      <span class="flex items-center gap-1.5 shrink-0 font-roboto-mono text-[10px] uppercase tracking-[0.22em] text-sentiers-soleil">
        <span class="block w-1.5 h-1.5 rounded-full bg-sentiers-soleil sentiers-pulse" aria-hidden="true"></span>
        Conditions Maïdo
      </span>
      <span class="flex items-center gap-1.5 font-roboto-mono text-[11px] text-sentiers-brume/85 tabular-nums">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sentiers-brume/65" aria-hidden="true"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
        6°C
      </span>
      <span class="flex items-center gap-1.5 font-roboto-mono text-[11px] text-sentiers-brume/85 tabular-nums">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sentiers-brume/65" aria-hidden="true"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
        NE 25 km/h
      </span>
      <span class="flex items-center gap-1.5 font-roboto-mono text-[11px] text-sentiers-brume/85">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sentiers-brume/65" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        ciel dégagé
      </span>
      <span class="flex items-center gap-1.5 font-roboto-mono text-[11px] text-sentiers-brume/85 tabular-nums">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sentiers-brume/65" aria-hidden="true"><path d="M17 18a5 5 0 0 0-10 0M12 9V2M4.22 10.22l1.42 1.42M1 18h2M21 18h2M18.36 11.64l1.42-1.42M23 22H1"/></svg>
        lever 5h47
      </span>
    </div>

    <!-- Indicateurs de slide -->
    <div class="mt-16 flex items-center gap-3">
      {data.carrousel.map((_, i) => (
        <button
          type="button"
          data-dot={i}
          class:list={[
            'slide-dot block h-1 transition-all duration-500',
            i === 0 ? 'bg-sentiers-soleil w-12' : 'bg-sentiers-brume/40 w-6',
          ]}
          aria-label={`Photo ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>

  <style>
    /* Pulse subtil de la pastille 'live' du bulletin de conditions */
    .sentiers-pulse { animation: sentiers-pulse 2.4s ease-in-out infinite; }
    @keyframes sentiers-pulse {
      0%, 100% { opacity: 0.45; transform: scale(1); }
      50%      { opacity: 1;    transform: scale(1.4); }
    }
    @media (prefers-reduced-motion: reduce) {
      .sentiers-pulse { animation: none; }
    }
  </style>

  <script>
    const slides = document.querySelectorAll<HTMLElement>('[data-slide]');
    const dots = document.querySelectorAll<HTMLElement>('[data-dot]');
    const captions = document.querySelectorAll<HTMLElement>('[data-slide-caption]');
    let current = 0;

    function go(idx: number) {
      slides.forEach((s, i) => {
        s.style.opacity = i === idx ? '1' : '0';
      });
      captions.forEach((c, i) => {
        c.style.opacity = i === idx ? '1' : '0';
        if (i === idx) c.classList.remove('absolute');
        else c.classList.add('absolute');
      });
      dots.forEach((d, i) => {
        if (i === idx) {
          d.classList.remove('bg-sentiers-brume/40', 'w-6');
          d.classList.add('bg-sentiers-soleil', 'w-12');
        } else {
          d.classList.remove('bg-sentiers-soleil', 'w-12');
          d.classList.add('bg-sentiers-brume/40', 'w-6');
        }
      });
      current = idx;
    }

    if (slides.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      setInterval(() => go((current + 1) % slides.length), 6000);
    }

    dots.forEach((d, i) => {
      d.addEventListener('click', () => go(i));
    });
  </script>
</section>
