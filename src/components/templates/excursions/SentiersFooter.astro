---
import data from '../../../data/templates/sentiers.json';
const year = new Date().getFullYear();
---

<footer class="bg-sentiers-noir text-sentiers-brume/70 py-12 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-2">
          <span class="font-familjen font-medium text-sentiers-brume text-lg leading-none">{data.info.wordmark}</span>
          <span class="text-sentiers-lichen text-xs leading-none" aria-hidden="true">▲</span>
        </p>
        <p class="mt-2 font-tinos italic text-sentiers-brume/55 text-sm">
          {data.info.soustitre} · {data.info.guide} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-familjen text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-sentiers-soleil transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-sentiers-lichen" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-sentiers-soleil transition-colors break-all">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-sentiers-lichen" aria-hidden="true"></li>
        <li class="font-tinos italic text-sentiers-soleil">{data.info.instagram}</li>
      </ul>
    </div>

    <div class="h-px mb-6 bg-gradient-to-r from-transparent via-sentiers-lichen/40 to-transparent" aria-hidden="true"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-roboto-mono text-[10px] uppercase tracking-[0.25em] text-sentiers-brume/45">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-sentiers-brume/70 hover:text-sentiers-soleil transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
