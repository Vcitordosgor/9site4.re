---
import data from '../../../data/templates/mahatma.json';
---

<header
  id="mahatma-header"
  data-scrolled="false"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 data-[scrolled=false]:bg-transparent data-[scrolled=true]:bg-mahatma-papier/95 data-[scrolled=true]:backdrop-blur-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-mahatma-encre/15"
>
  <div class="max-w-content mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <a href="#top" class="flex items-baseline gap-2 group" aria-label="Atelier Mahatma — accueil">
      <span class="font-fira-mono text-mahatma-cachet text-xs leading-none">▢</span>
      <span class="font-schibsted font-bold text-mahatma-encre text-base leading-none tracking-tight uppercase">
        {data.info.wordmark}
      </span>
      <span class="font-schibsted font-light text-mahatma-encre text-base leading-none tracking-tight uppercase">
        {data.info.wordmark2}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-7 font-atkinson text-[13px] text-mahatma-encre/75" aria-label="Navigation">
      <a href="#projets" class="hover:text-mahatma-cachet transition-colors">Projets</a>
      <a href="#atelier" class="hover:text-mahatma-cachet transition-colors">Atelier</a>
      <a href="#methode" class="hover:text-mahatma-cachet transition-colors">Méthode</a>
      <a href="#honoraires" class="hover:text-mahatma-cachet transition-colors">Honoraires</a>
    </nav>

    <a
      href="#rendez-vous"
      class="inline-flex items-center h-9 px-4 border border-mahatma-encre text-mahatma-encre font-atkinson text-[13px] font-bold hover:bg-mahatma-encre hover:text-mahatma-papier transition-colors"
    >
      Rendez-vous
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('mahatma-header');
  if (header) {
    const update = () => { header.dataset.scrolled = String(window.scrollY > 60); };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
