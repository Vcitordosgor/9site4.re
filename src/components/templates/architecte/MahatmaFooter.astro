---
import data from '../../../data/templates/mahatma.json';
const year = new Date().getFullYear();
---

<footer class="bg-mahatma-papier text-mahatma-encre/75 py-12 px-6 md:px-10 border-t border-mahatma-encre/15">
  <div class="max-w-content mx-auto">

    <div class="grid grid-cols-12 gap-4 items-end mb-10">

      <div class="col-span-12 md:col-span-6">
        <p class="flex items-baseline gap-2">
          <span class="font-fira-mono text-mahatma-cachet text-xs">▢</span>
          <span class="font-schibsted font-bold text-mahatma-encre text-base uppercase tracking-tight">{data.info.wordmark}</span>
          <span class="font-schibsted font-light text-mahatma-encre text-base uppercase tracking-tight">{data.info.wordmark2}</span>
        </p>
        <p class="mt-3 font-atkinson italic text-mahatma-beton text-sm">
          {data.info.adresseLigne1} · {data.info.adresseLigne2} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="col-span-12 md:col-span-6 flex flex-col md:flex-row md:items-center md:justify-end gap-2 md:gap-7 font-atkinson text-sm">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-mahatma-cachet transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1 h-1 rounded-full bg-mahatma-cachet" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-mahatma-cachet transition-colors break-all">{data.info.email}</a></li>
      </ul>
    </div>

    <div class="h-px mb-6 bg-mahatma-encre/15" aria-hidden="true"></div>

    <!-- Mentions Ordre des architectes -->
    <p class="mb-6 font-fira-mono text-[10px] uppercase tracking-[0.22em] text-mahatma-beton leading-relaxed">
      ▸ {data.info.ordre} · Tous nos projets sont assurés en RCP et garantie décennale.
    </p>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-fira-mono text-[10px] uppercase tracking-[0.22em] text-mahatma-beton/65">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        ▢ Site
        <a href="/" class="text-mahatma-encre hover:text-mahatma-cachet transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
