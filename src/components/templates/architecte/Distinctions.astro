---
import data from '../../../data/templates/mahatma.json';
---

<section class="bg-mahatma-papier py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-content mx-auto">

    <header class="grid grid-cols-12 gap-4 mb-14 md:mb-16">
      <div class="col-span-12 md:col-span-3">
        <p class="font-fira-mono text-[10px] uppercase tracking-[0.22em] text-mahatma-cachet mb-4">
          ▢ § VI
        </p>
        <p class="font-fira-mono text-[10px] uppercase tracking-[0.22em] text-mahatma-beton">
          Distinctions
        </p>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="font-schibsted font-bold text-mahatma-encre leading-[0.95] tracking-tight uppercase" style="font-size: clamp(36px, 5vw, 64px);">
          Quatre prix,<br/>quatre projets.
        </h2>
      </div>
    </header>

    <!-- Liste de distinctions style palmarès -->
    <ul class="border-t border-mahatma-encre/15">
      {data.distinctions.map((d) => (
        <li class="grid grid-cols-12 gap-4 md:gap-6 py-7 md:py-9 items-baseline border-b border-mahatma-encre/15 group hover:bg-mahatma-blanc transition-colors">

          <!-- Année -->
          <div class="col-span-3 md:col-span-2">
            <p class="font-schibsted font-light text-mahatma-cachet leading-none tabular-nums" style="font-size: clamp(28px, 3vw, 44px);">
              {d.annee}
            </p>
          </div>

          <!-- Prix + catégorie -->
          <div class="col-span-9 md:col-span-7">
            <h3 class="font-schibsted font-bold text-mahatma-encre text-xl md:text-2xl uppercase tracking-tight leading-tight">
              {d.prix}
            </h3>
            <p class="mt-1 font-fira-mono text-[10px] uppercase tracking-[0.22em] text-mahatma-beton">
              ◯ Catégorie {d.categorie}
            </p>
            <p class="mt-2 font-atkinson italic text-mahatma-encre/75 text-base">
              Projet : {d.projet}
            </p>
          </div>

          <!-- Statut -->
          <div class="col-span-12 md:col-span-3 md:text-right">
            <span class:list={[
              'inline-block px-3 py-1.5 font-fira-mono text-[10px] uppercase tracking-[0.22em]',
              d.statut === 'Lauréat' ? 'bg-mahatma-cachet text-mahatma-papier' : 'border border-mahatma-encre/40 text-mahatma-encre',
            ]}>
              ▸ {d.statut}
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
