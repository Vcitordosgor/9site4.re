---
import data from '../../../data/templates/lagon.json';
const year = new Date().getFullYear();
---

<footer class="bg-lagon-charbon text-lagon-coco py-12 px-5 md:px-8">
  <div class="max-w-content mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">

      <div>
        <p class="flex items-baseline gap-1">
          <span class="font-bagel text-lagon-mangue text-2xl leading-none">{data.info.wordmark}</span>
          <span class="font-bagel text-lagon-pitaya text-2xl leading-none">{data.info.wordmark2}</span>
          <span class="text-lagon-mangue text-xs ml-1" aria-hidden="true">★</span>
        </p>
        <p class="mt-3 font-architects text-lagon-coco/75 text-xl rotate-[-1deg]">
          ↳ {data.info.ville} · depuis {data.info.annee}
        </p>
      </div>

      <ul class="flex flex-col md:flex-row md:items-center gap-2 md:gap-7 font-onest text-sm font-medium">
        <li><a href={`tel:${data.info.telephoneHref}`} class="hover:text-lagon-mangue transition-colors tabular-nums">{data.info.telephone}</a></li>
        <li class="hidden md:inline-block w-1.5 h-1.5 rounded-full bg-lagon-pitaya" aria-hidden="true"></li>
        <li><a href={`mailto:${data.info.email}`} class="hover:text-lagon-mangue transition-colors">{data.info.email}</a></li>
        <li class="hidden md:inline-block w-1.5 h-1.5 rounded-full bg-lagon-pitaya" aria-hidden="true"></li>
        <li><a href={`https://instagram.com/${data.info.instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="text-lagon-mangue hover:text-lagon-blanc transition-colors">{data.info.instagram}</a></li>
      </ul>
    </div>

    <!-- Filet pop -->
    <div class="h-1 mb-6 bg-gradient-to-r from-lagon-mangue via-lagon-pitaya to-lagon-turquoise" aria-hidden="true"></div>

    <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-3 font-onest text-[11px] uppercase tracking-wider text-lagon-coco/55 font-medium">
      <p>© {year} {data.info.nom} · SIRET {data.info.siret}</p>
      <p>
        Site créé par
        <a href="/" class="text-lagon-mangue hover:text-lagon-coco transition-colors">9site4</a>
      </p>
    </div>
  </div>
</footer>
