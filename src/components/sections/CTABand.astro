---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

/**
 * CTABand — bande finale fond bleu-nuit, contraste fort (brief §7.7).
 * Halos signature en arrière-plan pour conserver la chaleur.
 */
---

<section class="relative overflow-hidden px-6 py-24 md:py-32 bg-bleu-nuit text-blanc-casse">
  <!-- Halos signature, fortement visibles sur fond bleu-nuit -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-32 -left-24 w-[44rem] h-[44rem]"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(145 166 255 / 0.55) 0%, transparent 70%);">
    </div>
    <div class="absolute -bottom-32 -right-24 w-[44rem] h-[44rem]"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(255 143 0 / 0.40) 0%, transparent 70%);">
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[28rem] h-[28rem] opacity-60"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(145 166 255 / 0.30) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <h2 class="scroll-reveal font-sora font-bold text-4xl md:text-6xl text-balance leading-tight">
      Prêt à lancer votre site ?
    </h2>
    <p class="scroll-reveal mt-6 text-lg md:text-xl text-blanc-casse/75 leading-relaxed">
      Pas besoin de cahier des charges compliqué. Parlez-nous de votre activité,
      on s'occupe du reste.
    </p>
    <div class="scroll-reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <Button variant="primary" size="lg" href="/contact">
        Demander mon site
        <Icon name="arrow-right" size={20} strokeWidth={2.25} />
      </Button>
      <a
        href="/realisations"
        class="inline-flex items-center justify-center gap-2 h-14 px-8 text-lg font-semibold rounded-full text-bleu hover:text-blanc-casse transition-colors"
      >
        Voir les réalisations
      </a>
    </div>
  </div>
</section>
