---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

/**
 * CTABand — bande finale fond bleu (#91A6FF), accents orange.
 * Halos signature en arrière-plan pour donner de la profondeur.
 */
---

<section class="relative overflow-hidden px-6 py-24 md:py-32 bg-bleu text-bleu-nuit">
  <!-- Halos pour profondeur sur fond bleu pâle -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <!-- Halo bleu-nuit gauche : effet de profondeur -->
    <div class="absolute -top-32 -left-24 w-[44rem] h-[44rem]"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(11 20 55 / 0.45) 0%, transparent 70%);">
    </div>
    <!-- Halo orange droite -->
    <div class="absolute -bottom-32 -right-24 w-[44rem] h-[44rem]"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(255 143 0 / 0.50) 0%, transparent 70%);">
    </div>
    <!-- Halo bleu-nuit central pour densité -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[28rem] h-[28rem] opacity-70"
         style="background: radial-gradient(50% 50% at 50% 50%, rgb(11 20 55 / 0.25) 0%, transparent 70%);">
    </div>
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <h2 class="scroll-reveal font-sora font-bold text-4xl md:text-6xl text-balance leading-tight">
      Prêt à lancer votre site ?
    </h2>
    <p class="scroll-reveal mt-6 text-lg md:text-xl text-bleu-nuit/85 leading-relaxed">
      Pas besoin de cahier des charges compliqué. Parlez-nous de votre activité,
      on s'occupe du reste.
    </p>
    <div class="scroll-reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <Button variant="primary" size="lg" href="/contact">
        Demander mon site
        <Icon name="arrow-right" size={20} strokeWidth={2.25} />
      </Button>
      <a
        href="/realisations"
        class="inline-flex items-center justify-center gap-2 h-14 px-8 text-lg font-semibold rounded-full text-bleu-nuit hover:text-orange transition-colors"
      >
        Voir les réalisations
      </a>
    </div>
  </div>
</section>
