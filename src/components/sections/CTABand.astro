---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

/**
 * CTABand — bande finale fond bleu-nuit, contraste fort.
 */
---

<section class="relative px-6 py-24 md:py-32 bg-bleu-nuit text-blanc-casse">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="scroll-reveal font-sora font-bold text-4xl md:text-6xl text-balance leading-tight">
      Prêt à lancer votre site ?
    </h2>
    <p class="scroll-reveal mt-6 text-lg md:text-xl text-blanc-casse/85 leading-relaxed">
      Pas besoin de cahier des charges compliqué. Parlez-nous de votre activité,
      on s'occupe du reste.
    </p>
    <div class="scroll-reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <Button variant="primary" size="lg" href="/contact">
        Demander mon site
        <Icon name="arrow-right" size={20} strokeWidth={2.25} />
      </Button>
      <a
        href="/realisations"
        class="inline-flex items-center justify-center gap-2 h-14 px-8 text-lg font-semibold rounded-full text-bleu hover:text-blanc-casse transition-colors"
      >
        Voir les réalisations
      </a>
    </div>
  </div>
</section>
