---
import Icon from '../ui/Icon.astro';
import { inclusions as items } from '../../lib/inclusions';

/**
 * Offre — grille de 8 items avec icônes (brief §7.3).
 * 1 col mobile → 2 col tablette → 4 col desktop.
 * Données partagées avec la page Tarifs via src/lib/inclusions.ts
 */
---

<section class="relative overflow-hidden px-6 py-20 md:py-28 bg-bleu/[0.06]">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute top-1/4 -left-24 w-[28rem] h-[28rem] halo-bleu opacity-50"></div>
    <div class="absolute bottom-0 -right-24 w-[24rem] h-[24rem] halo-orange opacity-40"></div>
  </div>
  <div class="relative mx-auto max-w-content">
    <div class="text-center max-w-2xl mx-auto">
      <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-orange text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
        Ce qui est inclus
      </p>
      <h2 class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
        Tout est inclus dans votre abonnement
      </h2>
      <p class="scroll-reveal mt-5 text-lg text-bleu-nuit/70 leading-relaxed">
        Pas de surprise, pas d'option cachée. Une seule offre, claire et complète.
      </p>
    </div>

    <ul class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {items.map((item, i) => {
        const isBleu = i % 2 === 0;
        return (
          <li
            class="scroll-reveal group relative bg-blanc-casse rounded-2xl ring-1 ring-bleu-nuit/10 p-6 transition-all duration-300 ease-out-soft hover:-translate-y-0.5 hover:shadow-card-hover hover:ring-bleu-nuit/15"
            style={`transition-delay: ${(i % 4) * 60}ms`}
          >
            <span class:list={[
              'flex w-12 h-12 rounded-xl items-center justify-center transition-colors duration-300',
              isBleu
                ? 'bg-bleu-nuit text-blanc-casse group-hover:bg-bleu group-hover:text-bleu-nuit'
                : 'bg-orange text-bleu-nuit group-hover:bg-bleu-nuit group-hover:text-blanc-casse',
            ]}>
              <Icon name={item.icon} size={22} strokeWidth={1.75} />
            </span>
            <h3 class="mt-5 font-sora font-semibold text-lg text-bleu-nuit leading-snug">
              {item.titre}
            </h3>
            <p class="mt-2 text-sm text-bleu-nuit/65 leading-relaxed">{item.texte}</p>
          </li>
        );
      })}
    </ul>
  </div>
</section>
