---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';

/**
 * Formulaires intégrés — section conversion (brief §13).
 * Tabs "Je suis…" + démo de formulaire adapté au métier.
 */

type FieldType =
  // Anciens types (rendu visuel) — encore utilisés en attendant 2b.3
  | 'text'
  | 'date'
  | 'time'
  | 'counter'
  | 'tel'
  | 'chips'
  | 'select'
  | 'cards'
  // Nouveaux types (vrais HTML inputs interactifs) — utilisés à partir de 2b.3
  | 'input-text'
  | 'input-tel'
  | 'input-date'
  | 'input-time'
  | 'input-number'
  | 'select-real'
  | 'textarea'
  | 'radios-cards'
  | 'radios-chips'
  | 'checkbox';

interface FieldOption {
  value: string;
  label: string;
}

interface Field {
  type: FieldType;
  label: string;
  // Anciens props (rendu visuel statique)
  value?: string;
  options?: string[] | FieldOption[];
  active?: number;
  hint?: string;
  icon?: string;
  // Nouveaux props (vrais HTML inputs)
  name?: string;
  placeholder?: string;
  defaultValue?: string;
  defaultChecked?: boolean;
  min?: string | number;
  max?: string | number;
  rows?: number;
  span?: 1 | 2;
}

interface Metier {
  id: string;
  label: string;
  shortLabel?: string;
  icon: string;
  color: 'bleu' | 'orange';
  formKicker: string;
  formTitle: string;
  fields: Field[];
  cta: string;
  example: string;
}

/**
 * 6 métiers de la démo, avec champs inspirés des formulaires réels des
 * templates clients (yoga/Reservation, resto/Reservation, paysagiste/Devis,
 * institut/Reservation, gite/Reservation, coach/Essai). Chaque métier garde
 * la logique propre à son activité — étape 2b transformera ces fields en
 * vrais HTML inputs cliquables.
 */
