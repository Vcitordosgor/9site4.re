---

<section
  id="formulaires-integres"
  class="relative overflow-hidden px-6 py-20 md:py-28"
  aria-labelledby="formulaires-titre"
>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-32 right-0 w-[32rem] h-[32rem] halo-orange opacity-30"></div>
    <div class="absolute -bottom-24 left-0 w-[28rem] h-[28rem] halo-bleu opacity-30"></div>
  </div>

  <div class="relative mx-auto max-w-content">
    <!-- Header -->
    <div class="max-w-3xl">
      <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-orange text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
        Formulaires intégrés
      </p>
      <h2 id="formulaires-titre" class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
        Recevez des demandes claires,
        <span class="text-bleu-nuit/60">directement sur WhatsApp ou par e-mail.</span>
      </h2>
      <p class="scroll-reveal mt-6 text-lg text-bleu-nuit/70 leading-relaxed">
        Votre site ne sert pas seulement à être vu. Il aide vos clients
        à vous contacter avec les bonnes informations, sans allers-retours
        inutiles.
      </p>
    </div>

    <!-- Section A : 3 étapes pédagogiques (Le client remplit → Vous recevez → Vous répondez) -->
    <ol
      class="scroll-reveal mt-12 grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 relative"
      aria-label="Les 3 étapes du parcours formulaire"
    >
      {etapes.map((e, i) => (
        <li class="relative">
          <article class="relative h-full flex flex-col rounded-2xl bg-blanc-casse ring-1 ring-bleu-nuit/10 p-6 md:p-7 transition-all duration-300 ease-out-soft hover:-translate-y-0.5 hover:shadow-card-hover hover:ring-bleu-nuit/15">
            <div class="flex items-start justify-between gap-4">
              <span class:list={[
                'flex w-12 h-12 rounded-xl items-center justify-center shrink-0',
                e.color === 'orange'
                  ? 'bg-orange/20 text-bleu-nuit'
                  : 'bg-bleu/25 text-bleu-nuit',
              ]}>
                <Icon name={e.icon} size={22} strokeWidth={1.75} />
              </span>
              <span class="font-sora font-bold text-bleu-nuit/15 leading-none tabular-nums" style="font-size: 44px;">
                {e.num}
              </span>
            </div>
            <h3 class="mt-5 font-sora font-semibold text-lg text-bleu-nuit leading-snug">
              {e.titre}
            </h3>
            <p class="mt-2 text-sm text-bleu-nuit/65 leading-relaxed">
              {e.texte}
            </p>
          </article>
          {/* Connecteur flèche entre les cartes (desktop only) */}
          {i < etapes.length - 1 && (
            <span
              class="hidden md:flex absolute top-1/2 -translate-y-1/2 -right-3.5 w-7 h-7 rounded-full bg-blanc-casse ring-1 ring-bleu-nuit/10 items-center justify-center text-bleu-nuit/40 z-10"
              aria-hidden="true"
            >
              <Icon name="arrow-right" size={14} strokeWidth={2.25} />
            </span>
          )}
        </li>
      ))}
    </ol>

    <!-- Démo interactive -->
    <div
      class="scroll-reveal mt-16 rounded-3xl bg-bleu-nuit text-blanc-casse overflow-hidden shadow-card-hover"
      data-form-demo
    >
      <!-- Header démo -->
      <div class="px-6 md:px-10 pt-8 md:pt-10 pb-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="font-roboto-mono text-[10px] uppercase tracking-[0.32em] text-orange">
              Démo interactive
            </p>
            <h3 class="mt-2 font-sora font-bold text-2xl md:text-3xl">
              Je suis…
            </h3>
          </div>
          <p class="text-sm text-blanc-casse/60 max-w-sm text-right hidden md:block">
            Cliquez sur votre métier pour voir le formulaire qui s’adapte.
          </p>
        </div>

        <!-- Tabs métiers -->
        <div role="tablist" aria-label="Choisir un métier" class="mt-6 flex flex-wrap gap-2">
          {metiers.map((m, i) => (
            <button
              type="button"
              role="tab"
              data-tab={m.id}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${m.id}`}
              id={`tab-${m.id}`}
              tabindex={i === 0 ? 0 : -1}
              class="group inline-flex items-center gap-2 h-11 px-4 rounded-full ring-1 ring-blanc-casse/20 text-sm font-medium transition-all duration-200 ease-out hover:ring-blanc-casse/40 hover:bg-blanc-casse/5 aria-selected:bg-blanc-casse aria-selected:text-bleu-nuit aria-selected:ring-blanc-casse cursor-pointer"
            >
              <Icon name={m.icon} size={16} strokeWidth={2} />
              <span class="md:hidden">{m.shortLabel ?? m.label}</span>
              <span class="hidden md:inline">{m.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Panels -->
      <div class="relative px-6 md:px-10 pb-10">
        {metiers.map((m, i) => (
          <div
            role="tabpanel"
            id={`panel-${m.id}`}
            aria-labelledby={`tab-${m.id}`}
            data-panel={m.id}
            data-active={i === 0 ? 'true' : 'false'}
            hidden={i !== 0}
          >
            <!-- Header full-width : kicker + titre + intro orientée bénéfice pro -->
            <header class="mb-6 lg:mb-8 max-w-3xl">
              <p class="font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-orange">
                {m.formKicker}
              </p>
              <h4 class="mt-3 font-sora font-bold text-xl md:text-2xl text-blanc-casse">
                {m.formTitle}
              </h4>
              <p class="mt-3 text-sm text-blanc-casse/70 leading-relaxed">
                {m.example}
              </p>
            </header>

            <!-- Grid : formulaire à gauche (3/5) + carte 'Message reçu' à droite (2/5) -->
            <div class="grid lg:grid-cols-5 gap-6 lg:gap-8 items-start">

            <!-- Colonne mini-formulaire -->
            <div class="lg:col-span-3">
              <div class="rounded-2xl bg-blanc-casse text-bleu-nuit p-6 md:p-7 shadow-card-hover ring-1 ring-blanc-casse/30">
                <!-- Faux entête : URL clientexemple.re -->
                <div class="flex items-center gap-1.5 pb-4 border-b border-bleu-nuit/10">
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                </div>

                <p class="mt-5 font-sora font-semibold text-lg leading-snug">{m.formTitle}</p>

                <p class="mt-1 text-sm text-bleu-nuit/65">
                  Aperçu interactif — cliquez dans les champs.
                </p>

                <form
                  class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-3.5"
                  data-demo-form
                  data-metier={m.id}
                  onsubmit="event.preventDefault();"
                  novalidate
                >
                  {m.fields.map((f) => {
                    const fieldId = `${m.id}-${f.name}`;
                    const wrapClass = f.span === 2 ? 'sm:col-span-2' : '';
                    const inputBase = 'w-full h-11 px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit placeholder:text-bleu-nuit/30 focus:ring-2 focus:ring-bleu-nuit/40 outline-none transition-shadow';
                    return (
                      <div class={wrapClass}>
                        {f.type !== 'checkbox' && (
                          <label for={fieldId} class="block text-[11px] font-medium text-bleu-nuit/55 uppercase tracking-wide mb-1.5">
                            {f.label}
                          </label>
                        )}

                        {f.type === 'input-text' && (
                          <input id={fieldId} type="text" name={f.name}
                            placeholder={f.placeholder} value={f.defaultValue ?? ''}
                            class={inputBase} />
                        )}

                        {f.type === 'input-tel' && (
                          <input id={fieldId} type="tel" name={f.name} inputmode="tel"
                            autocomplete="tel" placeholder={f.placeholder}
                            value={f.defaultValue ?? ''}
                            class={`${inputBase} tabular-nums`} />
                        )}

                        {f.type === 'input-email' && (
                          <input id={fieldId} type="email" name={f.name}
                            autocomplete="email" placeholder={f.placeholder}
                            value={f.defaultValue ?? ''}
                            class={inputBase} />
                        )}

                        {f.type === 'input-file' && (
                          <label for={fieldId} class="flex flex-col items-center justify-center gap-1 h-[74px] px-3 rounded-xl ring-1 ring-dashed ring-bleu-nuit/25 bg-blanc-casse cursor-pointer hover:ring-bleu-nuit/45 hover:bg-bleu-nuit/[0.02] transition-all text-center">
                            <input id={fieldId} type="file" name={f.name}
                              accept="image/*"
                              class="sr-only" />
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-bleu-nuit/45" aria-hidden="true">
                              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
                              <circle cx="12" cy="13" r="3"/>
                            </svg>
                            <span class="text-[11px] font-medium text-bleu-nuit/70 leading-tight">Cliquez pour joindre une photo</span>
                            {f.hint && (
                              <span class="text-[9px] text-bleu-nuit/45 leading-tight">{f.hint}</span>
                            )}
                          </label>
                        )}

                        {f.type === 'input-date' && (
                          <input id={fieldId} type="date" name={f.name}
                            value={f.defaultValue ?? ''}
                            class={`${inputBase} tabular-nums cursor-pointer`} />
                        )}

                        {f.type === 'input-time' && (
                          <input id={fieldId} type="time" name={f.name}
                            value={f.defaultValue ?? ''}
                            class={`${inputBase} tabular-nums cursor-pointer`} />
                        )}

                        {f.type === 'input-number' && (
                          <input id={fieldId} type="number" name={f.name}
                            min={f.min} max={f.max} value={f.defaultValue ?? ''}
                            class={`${inputBase} tabular-nums`} />
                        )}

                        {f.type === 'select-real' && (
                          <select id={fieldId} name={f.name}
                            class={`${inputBase} cursor-pointer appearance-none bg-no-repeat bg-[right_0.875rem_center] pr-9`}
                            style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%230B1437%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><path d=%22m6 9 6 6 6-6%22/></svg>'); background-size: 12px;">
                            {(f.options as FieldOption[]).map((o) => (
                              <option value={o.value} selected={o.value === f.defaultValue}>
                                {o.label}
                              </option>
                            ))}
                          </select>
                        )}

                        {f.type === 'textarea' && (
                          <textarea id={fieldId} name={f.name}
                            rows={f.rows ?? 2} placeholder={f.placeholder}
                            class="w-full px-3.5 py-2.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit placeholder:text-bleu-nuit/30 focus:ring-2 focus:ring-bleu-nuit/40 outline-none resize-none transition-shadow"
                          >{f.defaultValue ?? ''}</textarea>
                        )}

                        {f.type === 'radios-cards' && (
                          <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                            {(f.options as FieldOption[]).map((o) => (
                              <label class="cursor-pointer">
                                <input type="radio" name={fieldId} value={o.value}
                                  data-field-name={f.name} data-label={o.label}
                                  checked={o.value === f.defaultValue ? true : undefined}
                                  class="peer sr-only" />
                                <span class="block text-center px-2 py-2.5 rounded-xl text-xs font-medium leading-tight transition-all bg-bleu-nuit/[0.04] text-bleu-nuit/70 ring-1 ring-bleu-nuit/10 peer-checked:bg-bleu-nuit peer-checked:text-blanc-casse peer-checked:ring-bleu-nuit hover:bg-bleu-nuit/[0.08] peer-focus-visible:ring-2 peer-focus-visible:ring-bleu-nuit/40">
                                  {o.label}
                                </span>
                              </label>
                            ))}
                          </div>
                        )}

                        {f.type === 'radios-chips' && (
                          <div class="flex flex-wrap gap-1.5">
                            {(f.options as FieldOption[]).map((o) => (
                              <label class="cursor-pointer">
                                <input type="radio" name={fieldId} value={o.value}
                                  data-field-name={f.name} data-label={o.label}
                                  checked={o.value === f.defaultValue ? true : undefined}
                                  class="peer sr-only" />
                                <span class="inline-flex items-center h-8 px-3 rounded-full text-xs font-medium transition-all bg-bleu-nuit/[0.06] text-bleu-nuit/70 ring-1 ring-bleu-nuit/10 peer-checked:bg-bleu-nuit peer-checked:text-blanc-casse peer-checked:ring-bleu-nuit hover:bg-bleu-nuit/[0.10] peer-focus-visible:ring-2 peer-focus-visible:ring-bleu-nuit/40">
                                  {o.label}
                                </span>
                              </label>
                            ))}
                          </div>
                        )}

                        {f.type === 'checkbox' && (
                          <label for={fieldId} class="flex items-center gap-2.5 h-11 px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse cursor-pointer hover:ring-bleu-nuit/30 transition-all">
                            <input id={fieldId} type="checkbox" name={f.name}
                              checked={f.defaultChecked ? true : undefined}
                              class="peer sr-only" />
                            <span class="flex items-center justify-center w-5 h-5 rounded-md ring-1 ring-bleu-nuit/25 peer-checked:bg-bleu-nuit peer-checked:ring-bleu-nuit transition-all shrink-0">
                              <svg class="w-3 h-3 text-blanc-casse opacity-0 peer-checked:opacity-100 transition-opacity" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path d="M16.7 5.3a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3-3a1 1 0 0 1 1.4-1.4l2.3 2.3 6.3-6.3a1 1 0 0 1 1.4 0z"/>
                              </svg>
                            </span>
                            <span class="text-sm font-medium text-bleu-nuit">{f.label}</span>
                          </label>
                        )}
                      </div>
                    );
                  })}
                </form>

                <button
                  type="submit"
                  class:list={[
                    'mt-6 w-full h-12 rounded-full font-inter font-semibold text-base inline-flex items-center justify-center gap-2 cursor-pointer transition-all duration-200 ease-out hover:-translate-y-0.5 active:translate-y-0',
                    m.color === 'orange'
                      ? 'bg-orange text-bleu-nuit hover:bg-orange/90 shadow-[0_8px_24px_rgba(255,143,0,0.35)]'
                      : 'bg-bleu-nuit text-blanc-casse hover:bg-bleu-nuit/85 shadow-[0_8px_24px_rgba(11,20,55,0.35)]',
                  ]}
                >
                  {m.cta}
                  <Icon name="arrow-right" size={18} strokeWidth={2} />
                </button>
                <p class="mt-2 text-[11px] text-bleu-nuit/45 text-center">
                  Cliquez pour simuler l'envoi — la conversation à droite
                  s'animera comme à la réception.
                </p>

                <p class="mt-3 text-[11px] text-bleu-nuit/45 text-center">
                  Démo visuelle — sur votre site, les demandes arrivent directement par e-mail ou WhatsApp.
                </p>
              </div>
            </div>

            <!-- Colonne conversation WhatsApp Business : 3 bulles (client, formulaire 9site4, pro) -->
            <aside class="lg:col-span-2 lg:sticky lg:top-24" aria-label={`Aperçu conversation pour ${m.label}`}>
              <div
                class="rounded-2xl bg-[#0E1A24] ring-1 ring-blanc-casse/15 overflow-hidden shadow-card-hover"
                data-message-card
              >
                <!-- Header WhatsApp Business -->
                <header class="flex items-center gap-3 px-4 py-3 bg-[#075E54] text-blanc-casse">
                  <span class="flex w-9 h-9 rounded-full bg-blanc-casse/20 items-center justify-center font-sora font-bold text-sm shrink-0" aria-hidden="true">
                    {m.label.charAt(0)}
                  </span>
                  <div class="flex-1 min-w-0">
                    <p class="font-sora font-semibold text-sm leading-tight truncate">Vous · WhatsApp Business</p>
                    <p class="text-[11px] text-blanc-casse/75 leading-tight flex items-center gap-1.5 mt-0.5">
                      <span class="block w-1.5 h-1.5 rounded-full bg-[#25D366]"></span>
                      en ligne
                    </p>
                  </div>
                  <span class="flex items-center gap-3 text-blanc-casse/70" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="6" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="18" r="1.5"/></svg>
                  </span>
                </header>

                <!-- Convo body (fond bleu nuit léger pour évoquer WA) -->
                <div class="px-3 py-4 space-y-2.5">

                  <!-- Bulle 1 : message client (gauche) -->
                  <div class="flex justify-start">
                    <div class="max-w-[85%] rounded-2xl rounded-bl-sm bg-blanc-casse text-bleu-nuit px-3 py-2 shadow-sm">
                      <p class="text-[13px] leading-snug">{m.clientIntro}</p>
                      <p class="text-[10px] text-bleu-nuit/40 mt-1 text-right tabular-nums">10:24</p>
                    </div>
                  </div>

                  <!-- Bulle 2 : notification 9site4 (centre, ring orange) -->
                  <div class="flex justify-center">
                    <div
                      class="w-full rounded-xl bg-blanc-casse ring-1 ring-orange/40 px-3.5 py-3 shadow-sm"
                      data-notif-bubble
                    >
                      <p class="font-roboto-mono text-[9px] uppercase tracking-[0.22em] font-semibold text-orange flex items-center gap-1.5 mb-2">
                        <Icon name="mail" size={11} strokeWidth={2.5} class="shrink-0" />
                        9site4 · Nouveau formulaire
                      </p>
                      <p class="font-sora font-semibold text-bleu-nuit text-sm leading-snug">
                        Nouvelle demande — {m.label}
                      </p>
                      <dl class="mt-2.5 space-y-1.5">
                        {m.fields.map((f) => (
                          <div class="grid grid-cols-[6rem_1fr] gap-2 items-baseline">
                            <dt class="text-[9.5px] uppercase tracking-wide text-bleu-nuit/55 font-medium leading-tight">
                              {f.label}
                            </dt>
                            <dd
                              class="text-[12px] text-bleu-nuit leading-snug break-words"
                              data-message-key={f.name}
                            >
                              {fieldDisplay(f)}
                            </dd>
                          </div>
                        ))}
                      </dl>
                      <p class="text-[10px] text-bleu-nuit/40 mt-2.5 text-right tabular-nums">10:24 ✓✓</p>
                    </div>
                  </div>

                  <!-- Bulle 3 : réponse pro (droite, vert WhatsApp) -->
                  <div class="flex justify-end">
                    <div class="max-w-[85%] rounded-2xl rounded-br-sm bg-[#DCF8C6] text-bleu-nuit px-3 py-2 shadow-sm">
                      <p class="text-[13px] leading-snug">{m.proReply}</p>
                      <p class="text-[10px] text-bleu-nuit/40 mt-1 text-right tabular-nums">
                        10:25 <span class="text-[#34B7F1]">✓✓</span>
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </aside>

            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA bas de section -->
    <div class="scroll-reveal mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm text-bleu-nuit/65 max-w-md">
        Aucun de ces 6 cas n'est exactement le vôtre ? On adapte le formulaire
        à toute activité — c'est inclus.
      </p>
      <Button variant="secondary" size="md" href="/contact">
        Décrire mon besoin
        <Icon name="arrow-right" size={18} strokeWidth={2} />
      </Button>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-form-demo]').forEach((demo) => {
    const tabs = Array.from(demo.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(demo.querySelectorAll<HTMLElement>('[data-panel]'));

    const select = (id: string, focusTab = false) => {
      tabs.forEach((tab) => {
        const active = tab.dataset.tab === id;
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');
        if (active && focusTab) tab.focus();
      });
      panels.forEach((p) => {
        const active = p.dataset.panel === id;
        p.dataset.active = String(active);
        if (active) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        if (id) select(id);
      });

      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const dir = e.key === 'ArrowRight' ? 1 : -1;
        const next = tabs[(i + dir + tabs.length) % tabs.length];
        const id = next.dataset.tab;
        if (id) select(id, true);
      });
    });

    // Sync live : quand un input du form change, mettre à jour la carte 'Message reçu'
    const placeholder = '—';
    const formatDate = (iso: string): string => {
      if (!iso) return placeholder;
      const d = new Date(iso);
      if (isNaN(d.getTime())) return iso;
      return d.toLocaleDateString('fr-FR', {
        weekday: 'long', day: 'numeric', month: 'long',
      });
    };
    const formatTime = (v: string): string =>
      v ? v.replace(':', 'h') : placeholder;

    const displayValue = (panel: HTMLElement, fieldName: string): string => {
      const form = panel.querySelector<HTMLFormElement>('[data-demo-form]');
      if (!form) return placeholder;

      // 1. Radio group : retrouvé via data-field-name
      const radioChecked = form.querySelector<HTMLInputElement>(
        `input[type="radio"][data-field-name="${fieldName}"]:checked`
      );
      if (radioChecked) {
        return radioChecked.dataset.label || radioChecked.value || placeholder;
      }
      // Si pas de radio coché mais un radio existe avec ce data-field-name → '—'
      const anyRadio = form.querySelector(`input[type="radio"][data-field-name="${fieldName}"]`);
      if (anyRadio) return placeholder;

      // 2. Autres inputs : par name
      const el = form.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        `[name="${fieldName}"]`
      );
      if (!el) return placeholder;

      if (el.tagName === 'SELECT') {
        const sel = el as HTMLSelectElement;
        return sel.options[sel.selectedIndex]?.textContent?.trim() || placeholder;
      }
      if (el instanceof HTMLInputElement) {
        if (el.type === 'checkbox') return el.checked ? 'Oui' : 'Non';
        if (el.type === 'date') return formatDate(el.value);
        if (el.type === 'time') return formatTime(el.value);
        if (el.type === 'file') {
          const f = el.files?.[0];
          return f ? f.name : 'Aucune photo jointe';
        }
        return el.value || el.placeholder || placeholder;
      }
      if (el instanceof HTMLTextAreaElement) {
        return el.value || el.placeholder || placeholder;
      }
      return placeholder;
    };

    const syncMessageCard = (panel: HTMLElement) => {
      const card = panel.querySelector<HTMLElement>('[data-message-card]');
      if (!card) return;
      const dds = card.querySelectorAll<HTMLElement>('[data-message-key]');
      dds.forEach((dd) => {
        const name = dd.dataset.messageKey;
        if (!name) return;
        const newValue = displayValue(panel, name);
        if (dd.textContent === newValue) return; // pas de changement → pas de flash
        dd.textContent = newValue;
        // Flash orange bref pour signaler que la valeur a changé en live
        if (typeof dd.animate === 'function') {
          dd.animate(
            [{ color: '#FF8F00' }, { color: '#FEFEFA' }],
            { duration: 700, easing: 'ease-out' }
          );
        }
      });
    };

    // 'Simuler l'envoi' : au submit du form, on déclenche une animation sur la
    // carte conversation (pulse + flash de la bulle 9site4). Pas d'envoi réel.
    const simulateSend = (panel: HTMLElement) => {
      const card = panel.querySelector<HTMLElement>('[data-message-card]');
      if (!card) return;

      // Pulse + glow orange de toute la carte
      if (typeof card.animate === 'function') {
        card.animate(
          [
            { transform: 'scale(1)',     boxShadow: '0 0 0 0 rgba(255, 143, 0, 0)' },
            { transform: 'scale(1.015)', boxShadow: '0 0 0 8px rgba(255, 143, 0, 0.25)' },
            { transform: 'scale(1)',     boxShadow: '0 0 0 0 rgba(255, 143, 0, 0)' },
          ],
          { duration: 800, easing: 'ease-out' }
        );
      }

      // Flash subtil du fond de la bulle 9site4 (notification reçue)
      const notif = card.querySelector<HTMLElement>('[data-notif-bubble]');
      if (notif && typeof notif.animate === 'function') {
        notif.animate(
          [
            { backgroundColor: 'rgba(255, 143, 0, 0.18)' },
            { backgroundColor: 'rgba(254, 254, 250, 1)' },
          ],
          { duration: 700, easing: 'ease-out' }
        );
      }

      // Sur mobile, scroller doucement vers la conversation pour voir l'effet
      if (window.matchMedia('(max-width: 1023px)').matches) {
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    };

    panels.forEach((panel) => {
      const form = panel.querySelector<HTMLFormElement>('[data-demo-form]');
      if (!form) return;
      form.addEventListener('input', () => syncMessageCard(panel));
      form.addEventListener('change', () => syncMessageCard(panel));
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        simulateSend(panel);
      });
    });
  });
</script>
