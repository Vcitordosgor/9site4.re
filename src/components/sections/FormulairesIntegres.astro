---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';

/**
 * Formulaires intégrés — section conversion (brief §13).
 * Tabs "Je suis…" + démo de formulaire adapté au métier.
 */

type FieldType =
  // Anciens types (rendu visuel) — encore utilisés en attendant 2b.3
  | 'text'
  | 'date'
  | 'time'
  | 'counter'
  | 'tel'
  | 'chips'
  | 'select'
  | 'cards'
  // Nouveaux types (vrais HTML inputs interactifs) — utilisés à partir de 2b.3
  | 'input-text'
  | 'input-tel'
  | 'input-date'
  | 'input-time'
  | 'input-number'
  | 'select-real'
  | 'textarea'
  | 'radios-cards'
  | 'radios-chips'
  | 'checkbox';

interface FieldOption {
  value: string;
  label: string;
}

interface Field {
  type: FieldType;
  label: string;
  // Anciens props (rendu visuel statique)
  value?: string;
  options?: string[] | FieldOption[];
  active?: number;
  hint?: string;
  icon?: string;
  // Nouveaux props (vrais HTML inputs)
  name?: string;
  placeholder?: string;
  defaultValue?: string;
  defaultChecked?: boolean;
  min?: string | number;
  max?: string | number;
  rows?: number;
  span?: 1 | 2;
}

interface Metier {
  id: string;
  label: string;
  shortLabel?: string;
  icon: string;
  color: 'bleu' | 'orange';
  formKicker: string;
  formTitle: string;
  fields: Field[];
  cta: string;
  example: string;
}

/**
 * 6 métiers de la démo, avec champs inspirés des formulaires réels des
 * templates clients (yoga/Reservation, resto/Reservation, paysagiste/Devis,
 * institut/Reservation, gite/Reservation, coach/Essai). Chaque métier garde
 * la logique propre à son activité — étape 2b transformera ces fields en
 * vrais HTML inputs cliquables.
 */
const metiers: Metier[] = [
  {
    id: 'yoga',
    label: 'Prof de yoga',
    shortLabel: 'Yoga',
    icon: 'sparkle',
    color: 'orange',
    formKicker: 'Formulaire · Réservation cours',
    formTitle: 'Réservez un cours',
    fields: [
      { type: 'radios-cards', name: 'pratique', label: 'Pratique',
        options: [
          { value: 'hatha', label: 'Hatha' },
          { value: 'vinyasa', label: 'Vinyasa' },
          { value: 'yin', label: 'Yin' },
          { value: 'meditation', label: 'Méditation' },
        ],
        defaultValue: 'hatha', span: 2 },
      { type: 'radios-chips', name: 'niveau', label: 'Niveau',
        options: [
          { value: 'debutant', label: 'Débutant' },
          { value: 'intermediaire', label: 'Intermédiaire' },
          { value: 'confirme', label: 'Confirmé' },
        ],
        defaultValue: 'debutant', span: 2 },
      { type: 'input-date', name: 'date', label: 'Date du cours',
        defaultValue: '2025-11-20', span: 1 },
      { type: 'input-tel', name: 'telephone', label: 'Téléphone',
        placeholder: '0692 •• •• ••', span: 1 },
    ],
    cta: 'Réserver mon cours',
    example: 'Le client choisit pratique, niveau et créneau — vous savez immédiatement ce qu\'il vous faut prévoir.',
  },
  {
    id: 'resto',
    label: 'Restaurant',
    shortLabel: 'Resto',
    icon: 'calendar-clock',
    color: 'orange',
    formKicker: 'Formulaire · Réservation table',
    formTitle: 'Réservez votre table',
    fields: [
      { type: 'input-date', name: 'date', label: 'Date',
        defaultValue: '2025-11-14', span: 1 },
      { type: 'input-time', name: 'heure', label: 'Heure',
        defaultValue: '20:30', span: 1 },
      { type: 'input-number', name: 'personnes', label: 'Personnes',
        defaultValue: '4', min: 1, max: 12, span: 1 },
      { type: 'input-tel', name: 'telephone', label: 'Téléphone',
        placeholder: '0692 •• •• ••', span: 1 },
      { type: 'textarea', name: 'message', label: 'Demande spéciale (facultatif)',
        placeholder: 'Allergies, occasion, table en terrasse…',
        rows: 2, span: 2 },
    ],
    cta: 'Réserver ma table',
    example: 'Date, heure, couverts, contact — tout arrive structuré, fini les allers-retours téléphone.',
  },
  {
    id: 'artisan',
    label: 'Artisan / BTP',
    shortLabel: 'Artisan',
    icon: 'wrench',
    color: 'bleu',
    formKicker: 'Formulaire · Demande de devis',
    formTitle: 'Demandez votre devis',
    fields: [
      { type: 'select-real', name: 'travaux', label: 'Type de travaux',
        options: [
          { value: 'depannage', label: 'Dépannage' },
          { value: 'installation', label: 'Installation / Pose' },
          { value: 'renovation', label: 'Rénovation' },
          { value: 'sur-mesure', label: 'Sur mesure' },
        ],
        defaultValue: 'renovation', span: 1 },
      { type: 'select-real', name: 'commune', label: 'Commune',
        options: [
          { value: 'st-denis', label: 'Saint-Denis' },
          { value: 'st-paul', label: 'Saint-Paul' },
          { value: 'st-pierre', label: 'Saint-Pierre' },
          { value: 'st-andre', label: 'Saint-André' },
          { value: 'le-tampon', label: 'Le Tampon' },
          { value: 'autre', label: 'Autre commune' },
        ],
        defaultValue: 'st-denis', span: 1 },
      { type: 'radios-chips', name: 'urgence', label: 'Urgence',
        options: [
          { value: 'urgent', label: 'Urgent (sous 48 h)' },
          { value: 'mois', label: 'Dans le mois' },
          { value: 'pas-presse', label: 'Pas pressé' },
        ],
        defaultValue: 'mois', span: 2 },
      { type: 'input-tel', name: 'telephone', label: 'Téléphone',
        placeholder: '0692 •• •• ••', span: 1 },
      { type: 'textarea', name: 'message', label: 'Précisez votre besoin',
        placeholder: 'Surface, état actuel, contraintes…',
        rows: 2, span: 2 },
    ],
    cta: 'Demander mon devis',
    example: 'Le client qualifie son besoin avant l\'appel — vous gagnez 10 min par devis et vous chiffrez plus juste.',
  },
  {
    id: 'institut',
    label: 'Institut de beauté',
    shortLabel: 'Institut',
    icon: 'palette',
    color: 'orange',
    formKicker: 'Formulaire · Prise de rendez-vous',
    formTitle: 'Prenez rendez-vous',
    fields: [
      { type: 'select-real', name: 'prestation', label: 'Prestation',
        options: [
          { value: 'soin-visage', label: 'Soin visage' },
          { value: 'massage', label: 'Massage' },
          { value: 'epilation', label: 'Épilation' },
          { value: 'manucure', label: 'Manucure / beauté des mains' },
          { value: 'indecis', label: 'Conseil souhaité' },
        ],
        defaultValue: 'soin-visage', span: 2 },
      { type: 'radios-chips', name: 'plage', label: 'Plage horaire',
        options: [
          { value: 'matin', label: 'Matin' },
          { value: 'midi', label: 'Midi' },
          { value: 'apresmidi', label: 'Après-midi' },
          { value: 'soir', label: 'Soir' },
        ],
        defaultValue: 'apresmidi', span: 2 },
      { type: 'input-date', name: 'jour', label: 'Jour souhaité',
        defaultValue: '2025-11-21', span: 1 },
      { type: 'input-tel', name: 'telephone', label: 'Téléphone',
        placeholder: '0692 •• •• ••', span: 1 },
    ],
    cta: 'Prendre rendez-vous',
    example: 'Prestation, créneau, contact — votre planning se remplit sans que vous décrochiez le téléphone.',
  },
  {
    id: 'gite',
    label: 'Gîte / Location',
    shortLabel: 'Gîte',
    icon: 'globe',
    color: 'bleu',
    formKicker: 'Formulaire · Demande de séjour',
    formTitle: 'Vérifiez les disponibilités',
    fields: [
      { type: 'input-date', name: 'arrivee', label: 'Arrivée',
        defaultValue: '2025-11-22', span: 1 },
      { type: 'input-date', name: 'depart', label: 'Départ',
        defaultValue: '2025-11-29', span: 1 },
      { type: 'input-number', name: 'voyageurs', label: 'Voyageurs',
        defaultValue: '5', min: 1, max: 12, span: 1 },
      { type: 'checkbox', name: 'animaux', label: 'Animaux bienvenus',
        defaultChecked: false, span: 1 },
      { type: 'input-text', name: 'prenom', label: 'Prénom',
        placeholder: 'Emma', span: 1 },
      { type: 'input-tel', name: 'telephone', label: 'Téléphone',
        placeholder: '0692 •• •• ••', span: 1 },
    ],
    cta: 'Vérifier les dispos',
    example: 'Dates, voyageurs, contact — vous voyez la demande en un coup d\'œil et confirmez en 1 minute.',
  },
  {
    id: 'coach',
    label: 'Coach sportif',
    shortLabel: 'Coach',
    icon: 'calendar-check',
    color: 'bleu',
    formKicker: 'Formulaire · Séance d\'essai',
    formTitle: 'Réservez votre essai',
    fields: [
      { type: 'radios-cards', name: 'objectif', label: 'Objectif',
        options: [
          { value: 'poids', label: 'Perte de poids' },
          { value: 'muscle', label: 'Prise de muscle' },
          { value: 'forme', label: 'Mise en forme' },
        ],
        defaultValue: 'poids', span: 2 },
      { type: 'radios-chips', name: 'niveau', label: 'Niveau actuel',
        options: [
          { value: 'debutant', label: 'Débutant' },
          { value: 'intermediaire', label: 'Intermédiaire' },
          { value: 'confirme', label: 'Confirmé' },
        ],
        defaultValue: 'debutant', span: 2 },
      { type: 'select-real', name: 'frequence', label: 'Fréquence visée',
        options: [
          { value: '1-2', label: '1 à 2 séances / sem' },
          { value: '3-4', label: '3 à 4 séances / sem' },
          { value: '5+', label: '5 séances ou + / sem' },
        ],
        defaultValue: '3-4', span: 1 },
      { type: 'input-tel', name: 'telephone', label: 'Téléphone',
        placeholder: '0692 •• •• ••', span: 1 },
    ],
    cta: 'Réserver mon essai',
    example: 'Objectif, niveau, fréquence — vous proposez le bon programme dès le 1er échange.',
  },
];

const etapes = [
  {
    num: '01',
    icon: 'file-text',
    color: 'bleu',
    titre: 'Le client remplit le formulaire',
    texte: 'Il indique ce dont il a besoin : rendez-vous, devis, réservation, créneau, message…',
  },
  {
    num: '02',
    icon: 'mail',
    color: 'orange',
    titre: 'Vous recevez les informations',
    texte: 'Tout arrive directement par e-mail et/ou WhatsApp, déjà structuré.',
  },
  {
    num: '03',
    icon: 'calendar-check',
    color: 'bleu',
    titre: 'Vous répondez plus vite',
    texte: 'Vous avez les bonnes infos pour rappeler, confirmer, envoyer un devis ou proposer un créneau.',
  },
];
---

<section
  id="formulaires-integres"
  class="relative overflow-hidden px-6 py-20 md:py-28"
  aria-labelledby="formulaires-titre"
>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-32 right-0 w-[32rem] h-[32rem] halo-orange opacity-30"></div>
    <div class="absolute -bottom-24 left-0 w-[28rem] h-[28rem] halo-bleu opacity-30"></div>
  </div>

  <div class="relative mx-auto max-w-content">
    <!-- Header -->
    <div class="max-w-3xl">
      <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-orange text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
        Formulaires intégrés
      </p>
      <h2 id="formulaires-titre" class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
        Votre site devient
        <span class="text-bleu-nuit/60">un vrai point d'entrée commercial.</span>
      </h2>
      <p class="scroll-reveal mt-6 text-lg text-bleu-nuit/70 leading-relaxed">
        Un site joli ne suffit pas. Pour qu'il rapporte, il doit transformer
        les visiteurs en clients. Voici comment ça se passe — en 3 étapes simples.
      </p>
    </div>

    <!-- Section A : 3 étapes pédagogiques (Le client remplit → Vous recevez → Vous répondez) -->
    <ol
      class="scroll-reveal mt-12 grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 relative"
      aria-label="Les 3 étapes du parcours formulaire"
    >
      {etapes.map((e, i) => (
        <li class="relative">
          <article class="relative h-full flex flex-col rounded-2xl bg-blanc-casse ring-1 ring-bleu-nuit/10 p-6 md:p-7 transition-all duration-300 ease-out-soft hover:-translate-y-0.5 hover:shadow-card-hover hover:ring-bleu-nuit/15">
            <div class="flex items-start justify-between gap-4">
              <span class:list={[
                'flex w-12 h-12 rounded-xl items-center justify-center shrink-0',
                e.color === 'orange'
                  ? 'bg-orange/20 text-bleu-nuit'
                  : 'bg-bleu/25 text-bleu-nuit',
              ]}>
                <Icon name={e.icon} size={22} strokeWidth={1.75} />
              </span>
              <span class="font-sora font-bold text-bleu-nuit/15 leading-none tabular-nums" style="font-size: 44px;">
                {e.num}
              </span>
            </div>
            <h3 class="mt-5 font-sora font-semibold text-lg text-bleu-nuit leading-snug">
              {e.titre}
            </h3>
            <p class="mt-2 text-sm text-bleu-nuit/65 leading-relaxed">
              {e.texte}
            </p>
          </article>
          {/* Connecteur flèche entre les cartes (desktop only) */}
          {i < etapes.length - 1 && (
            <span
              class="hidden md:flex absolute top-1/2 -translate-y-1/2 -right-3.5 w-7 h-7 rounded-full bg-blanc-casse ring-1 ring-bleu-nuit/10 items-center justify-center text-bleu-nuit/40 z-10"
              aria-hidden="true"
            >
              <Icon name="arrow-right" size={14} strokeWidth={2.25} />
            </span>
          )}
        </li>
      ))}
    </ol>

    <!-- Démo interactive -->
    <div
      class="scroll-reveal mt-16 rounded-3xl bg-bleu-nuit text-blanc-casse overflow-hidden shadow-card-hover"
      data-form-demo
    >
      <!-- Header démo -->
      <div class="px-6 md:px-10 pt-8 md:pt-10 pb-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="font-roboto-mono text-[10px] uppercase tracking-[0.32em] text-orange">
              Démo interactive
            </p>
            <h3 class="mt-2 font-sora font-bold text-2xl md:text-3xl">
              Je suis…
            </h3>
          </div>
          <p class="text-sm text-blanc-casse/60 max-w-sm text-right hidden md:block">
            Cliquez sur votre métier pour voir le formulaire qui s’adapte.
          </p>
        </div>

        <!-- Tabs métiers -->
        <div role="tablist" aria-label="Choisir un métier" class="mt-6 flex flex-wrap gap-2">
          {metiers.map((m, i) => (
            <button
              type="button"
              role="tab"
              data-tab={m.id}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${m.id}`}
              id={`tab-${m.id}`}
              tabindex={i === 0 ? 0 : -1}
              class="group inline-flex items-center gap-2 h-11 px-4 rounded-full ring-1 ring-blanc-casse/20 text-sm font-medium transition-all duration-200 ease-out hover:ring-blanc-casse/40 hover:bg-blanc-casse/5 aria-selected:bg-blanc-casse aria-selected:text-bleu-nuit aria-selected:ring-blanc-casse cursor-pointer"
            >
              <Icon name={m.icon} size={16} strokeWidth={2} />
              <span class="md:hidden">{m.shortLabel ?? m.label}</span>
              <span class="hidden md:inline">{m.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Panels -->
      <div class="relative px-6 md:px-10 pb-10">
        {metiers.map((m, i) => (
          <div
            role="tabpanel"
            id={`panel-${m.id}`}
            aria-labelledby={`tab-${m.id}`}
            data-panel={m.id}
            data-active={i === 0 ? 'true' : 'false'}
            hidden={i !== 0}
            class="grid lg:grid-cols-5 gap-8 lg:gap-10 items-start"
          >
            <!-- Colonne explication -->
            <div class="lg:col-span-2">
              <p class="font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-orange">
                {m.formKicker}
              </p>
              <h4 class="mt-3 font-sora font-bold text-xl md:text-2xl text-blanc-casse">
                {m.formTitle}
              </h4>
              <p class="mt-3 text-sm text-blanc-casse/70 leading-relaxed">
                {m.example}
              </p>
              <ul class="mt-6 space-y-2.5 text-sm text-blanc-casse/85">
                <li class="flex items-start gap-2.5">
                  <Icon name="shield-check" size={16} class="text-orange shrink-0 mt-0.5" strokeWidth={2.25} />
                  <span>Champs adaptés au métier</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <Icon name="shield-check" size={16} class="text-orange shrink-0 mt-0.5" strokeWidth={2.25} />
                  <span>Notification immédiate</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <Icon name="shield-check" size={16} class="text-orange shrink-0 mt-0.5" strokeWidth={2.25} />
                  <span>Pré-rempli selon disponibilités</span>
                </li>
              </ul>
            </div>

            <!-- Colonne mini-formulaire -->
            <div class="lg:col-span-3">
              <div class="rounded-2xl bg-blanc-casse text-bleu-nuit p-6 md:p-7 shadow-card-hover ring-1 ring-blanc-casse/30">
                <!-- Faux entête : URL clientexemple.re -->
                <div class="flex items-center gap-1.5 pb-4 border-b border-bleu-nuit/10">
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                </div>

                <p class="mt-5 font-sora font-semibold text-lg leading-snug">{m.formTitle}</p>

                <div class="mt-5 space-y-4">
                  {m.fields.map((f) => (
                    <div>
                      <p class="text-[11px] font-medium text-bleu-nuit/55 uppercase tracking-wide">{f.label}</p>

                      {f.type === 'text' && (
                        <div class="mt-1.5 h-11 flex items-center px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit">
                          {f.value}
                        </div>
                      )}

                      {f.type === 'date' && (
                        <div class="mt-1.5 h-11 flex items-center justify-between px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit">
                          <span>{f.value}</span>
                          <Icon name="calendar-clock" size={16} class="text-bleu-nuit/40" strokeWidth={2} />
                        </div>
                      )}

                      {f.type === 'time' && (
                        <div class="mt-1.5 h-11 flex items-center justify-between px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit">
                          <span>{f.value}</span>
                          <Icon name="calendar-clock" size={16} class="text-bleu-nuit/40" strokeWidth={2} />
                        </div>
                      )}

                      {f.type === 'tel' && (
                        <div class="mt-1.5 h-11 flex items-center px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit tabular-nums">
                          {f.value}
                        </div>
                      )}

                      {f.type === 'counter' && (
                        <div class="mt-1.5 h-11 flex items-center justify-between px-1 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse">
                          <button type="button" disabled class="w-9 h-9 rounded-lg flex items-center justify-center text-lg font-bold text-bleu-nuit/40 cursor-not-allowed" aria-label="Diminuer">−</button>
                          <span class="text-sm font-bold text-bleu-nuit tabular-nums">{f.value}</span>
                          <button type="button" disabled class="w-9 h-9 rounded-lg flex items-center justify-center text-lg font-bold text-bleu-nuit/40 cursor-not-allowed" aria-label="Augmenter">+</button>
                        </div>
                      )}

                      {f.type === 'chips' && (
                        <div class="mt-1.5 flex flex-wrap gap-1.5">
                          {f.options?.map((opt, idx) => (
                            <span class:list={[
                              'inline-flex items-center h-8 px-3 rounded-full text-xs font-medium transition-colors',
                              idx === (f.active ?? 0)
                                ? 'bg-bleu-nuit text-blanc-casse'
                                : 'bg-bleu-nuit/[0.06] text-bleu-nuit/70 ring-1 ring-bleu-nuit/10',
                            ]}>{opt}</span>
                          ))}
                        </div>
                      )}

                      {f.type === 'cards' && (
                        <div class="mt-1.5 grid grid-cols-3 gap-1.5">
                          {f.options?.map((opt, idx) => (
                            <div class:list={[
                              'flex flex-col items-center justify-center text-center px-2 py-3 rounded-xl text-[11px] font-medium leading-tight transition-colors',
                              idx === (f.active ?? 0)
                                ? (m.color === 'orange' ? 'bg-orange text-bleu-nuit ring-2 ring-bleu-nuit/20' : 'bg-bleu text-bleu-nuit ring-2 ring-bleu-nuit/20')
                                : 'bg-bleu-nuit/[0.04] text-bleu-nuit/65 ring-1 ring-bleu-nuit/10',
                            ]}>
                              {f.icon && idx === (f.active ?? 0) && (
                                <Icon name={f.icon} size={16} strokeWidth={2} class="mb-1" />
                              )}
                              {opt}
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>

                <button
                  type="button"
                  disabled
                  aria-label="Aperçu du bouton — démo non fonctionnelle"
                  class:list={[
                    'mt-6 w-full h-12 rounded-full font-inter font-semibold text-base inline-flex items-center justify-center gap-2 cursor-not-allowed',
                    m.color === 'orange'
                      ? 'bg-orange text-bleu-nuit hover:bg-orange/90'
                      : 'bg-bleu-nuit text-blanc-casse hover:bg-bleu-nuit/90',
                  ]}
                >
                  {m.cta}
                  <Icon name="arrow-right" size={18} strokeWidth={2} />
                </button>

                <p class="mt-3 text-[11px] text-bleu-nuit/45 text-center">
                  Aperçu non fonctionnel — chaque site reçoit un formulaire sur mesure.
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA bas de section -->
    <div class="scroll-reveal mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm text-bleu-nuit/65 max-w-md">
        Aucun de ces 6 cas n'est exactement le vôtre ? On adapte le formulaire
        à toute activité — c'est inclus.
      </p>
      <Button variant="secondary" size="md" href="/contact">
        Décrire mon besoin
        <Icon name="arrow-right" size={18} strokeWidth={2} />
      </Button>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-form-demo]').forEach((demo) => {
    const tabs = Array.from(demo.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(demo.querySelectorAll<HTMLElement>('[data-panel]'));

    const select = (id: string, focusTab = false) => {
      tabs.forEach((tab) => {
        const active = tab.dataset.tab === id;
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');
        if (active && focusTab) tab.focus();
      });
      panels.forEach((p) => {
        const active = p.dataset.panel === id;
        p.dataset.active = String(active);
        if (active) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        if (id) select(id);
      });

      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const dir = e.key === 'ArrowRight' ? 1 : -1;
        const next = tabs[(i + dir + tabs.length) % tabs.length];
        const id = next.dataset.tab;
        if (id) select(id, true);
      });
    });
  });
</script>
