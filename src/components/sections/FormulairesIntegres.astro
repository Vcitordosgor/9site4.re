---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';

/**
 * Formulaires intégrés — section conversion (brief §13).
 * Tabs "Je suis…" + démo de formulaire adapté au métier.
 */

type FieldType = 'text' | 'date' | 'time' | 'counter' | 'tel' | 'chips' | 'select' | 'cards';

interface Field {
  type: FieldType;
  label: string;
  value?: string;
  hint?: string;
  options?: string[];
  active?: number;
  icon?: string;
}

interface Metier {
  id: string;
  label: string;
  shortLabel?: string;
  icon: string;
  color: 'bleu' | 'orange';
  formKicker: string;
  formTitle: string;
  fields: Field[];
  cta: string;
  example: string;
}

const metiers: Metier[] = [
  {
    id: 'resto',
    label: 'Restaurateur',
    shortLabel: 'Resto',
    icon: 'calendar-clock',
    color: 'orange',
    formKicker: 'Formulaire · Réservation',
    formTitle: 'Réservez votre table',
    fields: [
      { type: 'date', label: 'Date', value: 'Vendredi 14 nov.' },
      { type: 'time', label: 'Heure', value: '20h30' },
      { type: 'counter', label: 'Personnes', value: '4' },
      { type: 'tel', label: 'Téléphone', value: '0692 •• •• ••' },
    ],
    cta: 'Réserver ma table',
    example: 'Le client choisit son créneau, vous recevez un WhatsApp instantané.',
  },
  {
    id: 'artisan',
    label: 'Artisan / BTP',
    shortLabel: 'Artisan',
    icon: 'wrench',
    color: 'bleu',
    formKicker: 'Formulaire · Devis',
    formTitle: 'Demandez votre devis',
    fields: [
      { type: 'cards', label: 'Type d’intervention', options: ['Dépannage', 'Pose / Création', 'Rénovation'], active: 1, icon: 'wrench' },
      { type: 'text', label: 'Surface concernée', value: '45 m²' },
      { type: 'chips', label: 'Délai souhaité', options: ['Urgent', 'Sous 2 sem.', 'Pas pressé'], active: 1 },
      { type: 'tel', label: 'Téléphone', value: '0692 •• •• ••' },
    ],
    cta: 'Demander mon devis',
    example: 'Le client qualifie son besoin avant l’appel — vous gagnez 10 min par devis.',
  },
  {
    id: 'coach',
    label: 'Coach / Bien-être',
    shortLabel: 'Coach',
    icon: 'calendar-check',
    color: 'orange',
    formKicker: 'Formulaire · Rendez-vous',
    formTitle: 'Prenez rendez-vous',
    fields: [
      { type: 'chips', label: 'Objectif', options: ['Découverte', 'Suivi', 'Bilan'], active: 0 },
      { type: 'chips', label: 'Préférence créneau', options: ['Matin', 'Midi', 'Soir'], active: 2 },
      { type: 'date', label: 'Première séance', value: 'Mardi 18 nov.' },
      { type: 'tel', label: 'Téléphone', value: '0692 •• •• ••' },
    ],
    cta: 'Prendre rendez-vous',
    example: 'Le créneau est qualifié — fini les "Vous ouvrez le samedi ?" par mail.',
  },
  {
    id: 'gite',
    label: 'Gîte / Tourisme',
    shortLabel: 'Gîte',
    icon: 'globe',
    color: 'bleu',
    formKicker: 'Formulaire · Demande de séjour',
    formTitle: 'Vérifiez les disponibilités',
    fields: [
      { type: 'date', label: 'Arrivée', value: 'Sam. 22 nov.' },
      { type: 'date', label: 'Départ', value: 'Sam. 29 nov.' },
      { type: 'counter', label: 'Voyageurs', value: '5' },
      { type: 'tel', label: 'Téléphone', value: '0692 •• •• ••' },
    ],
    cta: 'Vérifier les dispos',
    example: 'Vous voyez la demande en 1 coup d’œil : dates, voyageurs, contact.',
  },
  {
    id: 'consultant',
    label: 'Consultant / B2B',
    shortLabel: 'Consultant',
    icon: 'headphones',
    color: 'orange',
    formKicker: 'Formulaire · Qualification',
    formTitle: 'Planifions un échange',
    fields: [
      { type: 'cards', label: 'Vous êtes', options: ['Indépendant', 'TPE / PME', 'Grand groupe'], active: 1, icon: 'headphones' },
      { type: 'text', label: 'Besoin principal', value: 'Stratégie commerciale' },
      { type: 'chips', label: 'Échéance', options: ['< 1 mois', '1-3 mois', '> 3 mois'], active: 0 },
      { type: 'tel', label: 'Téléphone', value: '0692 •• •• ••' },
    ],
    cta: 'Planifier un échange',
    example: 'Vous discutez seulement avec des prospects qualifiés — plus de tri à faire.',
  },
];

const benefits = [
  { icon: 'wand', titre: 'Pensé pour votre métier', texte: 'Réservation, devis, RDV ou intervention — pas un "Contactez-nous" générique.' },
  { icon: 'shield-check', titre: 'Filtre les bonnes demandes', texte: 'Champs adaptés qui qualifient le besoin et écartent le spam.' },
  { icon: 'calendar-check', titre: 'Notification immédiate', texte: 'Email + WhatsApp dès qu’une demande arrive. Pas de retard, pas de loupé.' },
];
---

<section
  id="formulaires-integres"
  class="relative overflow-hidden px-6 py-20 md:py-28"
  aria-labelledby="formulaires-titre"
>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-32 right-0 w-[32rem] h-[32rem] halo-orange opacity-30"></div>
    <div class="absolute -bottom-24 left-0 w-[28rem] h-[28rem] halo-bleu opacity-30"></div>
  </div>

  <div class="relative mx-auto max-w-content">
    <!-- Header -->
    <div class="max-w-3xl">
      <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-orange text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
        Formulaires intégrés
      </p>
      <h2 id="formulaires-titre" class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
        Votre site reçoit les bonnes demandes,
        <span class="text-bleu-nuit/60">pas du spam.</span>
      </h2>
      <p class="scroll-reveal mt-6 text-lg text-bleu-nuit/70 leading-relaxed">
        Un site joli ne suffit pas. Pour qu’il rapporte, il doit transformer
        les visiteurs en clients. Chez 9site4, votre formulaire est conçu pour
        votre métier — chaque champ a une raison d’être.
      </p>
    </div>

    <!-- 3 bénéfices -->
    <ul class="scroll-reveal mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
      {benefits.map((b) => (
        <li class="flex items-start gap-3 rounded-2xl bg-blanc-casse ring-1 ring-bleu-nuit/10 p-5">
          <span class="flex w-10 h-10 rounded-xl bg-bleu/20 text-bleu-nuit items-center justify-center shrink-0">
            <Icon name={b.icon} size={20} strokeWidth={1.75} />
          </span>
          <div>
            <p class="font-sora font-semibold text-bleu-nuit leading-snug">{b.titre}</p>
            <p class="mt-1 text-sm text-bleu-nuit/65 leading-relaxed">{b.texte}</p>
          </div>
        </li>
      ))}
    </ul>

    <!-- Démo interactive -->
    <div
      class="scroll-reveal mt-16 rounded-3xl bg-bleu-nuit text-blanc-casse overflow-hidden shadow-card-hover"
      data-form-demo
    >
      <!-- Header démo -->
      <div class="px-6 md:px-10 pt-8 md:pt-10 pb-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="font-roboto-mono text-[10px] uppercase tracking-[0.32em] text-orange">
              Démo interactive
            </p>
            <h3 class="mt-2 font-sora font-bold text-2xl md:text-3xl">
              Je suis…
            </h3>
          </div>
          <p class="text-sm text-blanc-casse/60 max-w-sm text-right hidden md:block">
            Cliquez sur votre métier pour voir le formulaire qui s’adapte.
          </p>
        </div>

        <!-- Tabs métiers -->
        <div role="tablist" aria-label="Choisir un métier" class="mt-6 flex flex-wrap gap-2">
          {metiers.map((m, i) => (
            <button
              type="button"
              role="tab"
              data-tab={m.id}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${m.id}`}
              id={`tab-${m.id}`}
              tabindex={i === 0 ? 0 : -1}
              class="group inline-flex items-center gap-2 h-11 px-4 rounded-full ring-1 ring-blanc-casse/20 text-sm font-medium transition-all duration-200 ease-out hover:ring-blanc-casse/40 hover:bg-blanc-casse/5 aria-selected:bg-blanc-casse aria-selected:text-bleu-nuit aria-selected:ring-blanc-casse cursor-pointer"
            >
              <Icon name={m.icon} size={16} strokeWidth={2} />
              <span class="md:hidden">{m.shortLabel ?? m.label}</span>
              <span class="hidden md:inline">{m.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Panels -->
      <div class="relative px-6 md:px-10 pb-10">
        {metiers.map((m, i) => (
          <div
            role="tabpanel"
            id={`panel-${m.id}`}
            aria-labelledby={`tab-${m.id}`}
            data-panel={m.id}
            data-active={i === 0 ? 'true' : 'false'}
            hidden={i !== 0}
            class="grid lg:grid-cols-5 gap-8 lg:gap-10 items-start"
          >
            <!-- Colonne explication -->
            <div class="lg:col-span-2">
              <p class="font-roboto-mono text-[10px] uppercase tracking-[0.28em] text-orange">
                {m.formKicker}
              </p>
              <h4 class="mt-3 font-sora font-bold text-xl md:text-2xl text-blanc-casse">
                {m.formTitle}
              </h4>
              <p class="mt-3 text-sm text-blanc-casse/70 leading-relaxed">
                {m.example}
              </p>
              <ul class="mt-6 space-y-2.5 text-sm text-blanc-casse/85">
                <li class="flex items-start gap-2.5">
                  <Icon name="shield-check" size={16} class="text-orange shrink-0 mt-0.5" strokeWidth={2.25} />
                  <span>Champs adaptés au métier</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <Icon name="shield-check" size={16} class="text-orange shrink-0 mt-0.5" strokeWidth={2.25} />
                  <span>Notification immédiate</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <Icon name="shield-check" size={16} class="text-orange shrink-0 mt-0.5" strokeWidth={2.25} />
                  <span>Pré-rempli selon disponibilités</span>
                </li>
              </ul>
            </div>

            <!-- Colonne mini-formulaire -->
            <div class="lg:col-span-3">
              <div class="rounded-2xl bg-blanc-casse text-bleu-nuit p-6 md:p-7 shadow-card-hover ring-1 ring-blanc-casse/30">
                <!-- Faux entête : URL clientexemple.re -->
                <div class="flex items-center gap-1.5 pb-4 border-b border-bleu-nuit/10">
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-bleu-nuit/15"></span>
                </div>

                <p class="mt-5 font-sora font-semibold text-lg leading-snug">{m.formTitle}</p>

                <div class="mt-5 space-y-4">
                  {m.fields.map((f) => (
                    <div>
                      <p class="text-[11px] font-medium text-bleu-nuit/55 uppercase tracking-wide">{f.label}</p>

                      {f.type === 'text' && (
                        <div class="mt-1.5 h-11 flex items-center px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit">
                          {f.value}
                        </div>
                      )}

                      {f.type === 'date' && (
                        <div class="mt-1.5 h-11 flex items-center justify-between px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit">
                          <span>{f.value}</span>
                          <Icon name="calendar-clock" size={16} class="text-bleu-nuit/40" strokeWidth={2} />
                        </div>
                      )}

                      {f.type === 'time' && (
                        <div class="mt-1.5 h-11 flex items-center justify-between px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit">
                          <span>{f.value}</span>
                          <Icon name="calendar-clock" size={16} class="text-bleu-nuit/40" strokeWidth={2} />
                        </div>
                      )}

                      {f.type === 'tel' && (
                        <div class="mt-1.5 h-11 flex items-center px-3.5 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse text-sm font-medium text-bleu-nuit tabular-nums">
                          {f.value}
                        </div>
                      )}

                      {f.type === 'counter' && (
                        <div class="mt-1.5 h-11 flex items-center justify-between px-1 rounded-xl ring-1 ring-bleu-nuit/15 bg-blanc-casse">
                          <button type="button" disabled class="w-9 h-9 rounded-lg flex items-center justify-center text-lg font-bold text-bleu-nuit/40 cursor-not-allowed" aria-label="Diminuer">−</button>
                          <span class="text-sm font-bold text-bleu-nuit tabular-nums">{f.value}</span>
                          <button type="button" disabled class="w-9 h-9 rounded-lg flex items-center justify-center text-lg font-bold text-bleu-nuit/40 cursor-not-allowed" aria-label="Augmenter">+</button>
                        </div>
                      )}

                      {f.type === 'chips' && (
                        <div class="mt-1.5 flex flex-wrap gap-1.5">
                          {f.options?.map((opt, idx) => (
                            <span class:list={[
                              'inline-flex items-center h-8 px-3 rounded-full text-xs font-medium transition-colors',
                              idx === (f.active ?? 0)
                                ? 'bg-bleu-nuit text-blanc-casse'
                                : 'bg-bleu-nuit/[0.06] text-bleu-nuit/70 ring-1 ring-bleu-nuit/10',
                            ]}>{opt}</span>
                          ))}
                        </div>
                      )}

                      {f.type === 'cards' && (
                        <div class="mt-1.5 grid grid-cols-3 gap-1.5">
                          {f.options?.map((opt, idx) => (
                            <div class:list={[
                              'flex flex-col items-center justify-center text-center px-2 py-3 rounded-xl text-[11px] font-medium leading-tight transition-colors',
                              idx === (f.active ?? 0)
                                ? (m.color === 'orange' ? 'bg-orange text-bleu-nuit ring-2 ring-bleu-nuit/20' : 'bg-bleu text-bleu-nuit ring-2 ring-bleu-nuit/20')
                                : 'bg-bleu-nuit/[0.04] text-bleu-nuit/65 ring-1 ring-bleu-nuit/10',
                            ]}>
                              {f.icon && idx === (f.active ?? 0) && (
                                <Icon name={f.icon} size={16} strokeWidth={2} class="mb-1" />
                              )}
                              {opt}
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>

                <button
                  type="button"
                  disabled
                  aria-label="Aperçu du bouton — démo non fonctionnelle"
                  class:list={[
                    'mt-6 w-full h-12 rounded-full font-inter font-semibold text-base inline-flex items-center justify-center gap-2 cursor-not-allowed',
                    m.color === 'orange'
                      ? 'bg-orange text-bleu-nuit hover:bg-orange/90'
                      : 'bg-bleu-nuit text-blanc-casse hover:bg-bleu-nuit/90',
                  ]}
                >
                  {m.cta}
                  <Icon name="arrow-right" size={18} strokeWidth={2} />
                </button>

                <p class="mt-3 text-[11px] text-bleu-nuit/45 text-center">
                  Aperçu non fonctionnel — chaque site reçoit un formulaire sur mesure.
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA bas de section -->
    <div class="scroll-reveal mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm text-bleu-nuit/65 max-w-md">
        Aucun de ces 5 cas n’est exactement le vôtre ? On peut adapter le
        formulaire à toute activité — c’est inclus.
      </p>
      <Button variant="secondary" size="md" href="/contact">
        Décrire mon besoin
        <Icon name="arrow-right" size={18} strokeWidth={2} />
      </Button>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-form-demo]').forEach((demo) => {
    const tabs = Array.from(demo.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(demo.querySelectorAll<HTMLElement>('[data-panel]'));

    const select = (id: string, focusTab = false) => {
      tabs.forEach((tab) => {
        const active = tab.dataset.tab === id;
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');
        if (active && focusTab) tab.focus();
      });
      panels.forEach((p) => {
        const active = p.dataset.panel === id;
        p.dataset.active = String(active);
        if (active) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        if (id) select(id);
      });

      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const dir = e.key === 'ArrowRight' ? 1 : -1;
        const next = tabs[(i + dir + tabs.length) % tabs.length];
        const id = next.dataset.tab;
        if (id) select(id, true);
      });
    });
  });
</script>
