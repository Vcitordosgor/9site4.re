---
/**
 * Mini-preview Foudre Coaching — brutalist athletic.
 * Hero asymétrique 7/5 : H1 manifeste oversized + photo recadrée + stats.
 */
---

<div class="absolute inset-0 bg-coach-noir text-coach-blanc font-barlow overflow-hidden">

  <!-- Mini header noir avec wordmark FOUDRE -->
  <div class="flex items-center justify-between px-3 pt-2 pb-2 text-coach-blanc border-b border-coach-blanc/10">
    <div class="flex items-baseline gap-1">
      <span class="font-big-shoulders font-black text-[10px] tracking-tight uppercase">FOUDRE</span>
      <span class="font-jetbrains text-coach-lime text-[6px]">/974</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-wider text-coach-blanc/70 font-medium">
      <span>Programmes</span>
      <span>Tarifs</span>
    </div>
    <span class="inline-flex items-center h-3 px-1.5 bg-coach-lime text-coach-noir font-big-shoulders font-bold text-[6px] uppercase tracking-wider">
      Essai
    </span>
  </div>

  <!-- Hero asymétrique -->
  <div class="px-3 pt-2 pb-2 grid grid-cols-12 gap-2 h-[calc(100%-1.6rem)]">

    <!-- LEFT (7) : H1 manifeste -->
    <div class="col-span-7 flex flex-col justify-between">
      <div>
        <p class="font-jetbrains text-[6px] uppercase tracking-[0.2em] text-coach-gris mb-1">EST. 2019 · ST-PIERRE</p>
        <p class="font-big-shoulders font-black uppercase leading-[0.85] text-coach-blanc" style="font-size: clamp(14px, 3vw, 26px);">
          Ton corps<br/>
          mérite mieux<br/>
          <span class="text-coach-lime">qu'excuses.</span>
        </p>
      </div>
      <div class="flex items-center gap-1 mt-1">
        <span class="inline-flex items-center h-4 px-2 bg-coach-lime text-coach-noir font-big-shoulders font-bold text-[6px] uppercase tracking-wider">
          Réserver →
        </span>
      </div>
    </div>

    <!-- RIGHT (5) : photo recadrée portrait + stats -->
    <div class="col-span-5 flex flex-col gap-1">
      <div class="relative aspect-[4/5] bg-coach-graphite overflow-hidden flex-1">
        <img
          src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=300&q=70"
          alt=""
          class="w-full h-full object-cover grayscale"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute bottom-0 inset-x-0 h-[2px] bg-coach-lime"></span>
        <span class="absolute top-1 left-1 px-1 bg-coach-noir/85 font-jetbrains text-[5px] uppercase tracking-wider text-coach-lime">
          MARIUS
        </span>
      </div>
      <!-- 3 mini stats -->
      <div class="grid grid-cols-3 gap-0.5 text-center">
        {[['184', 'clients'], ['1.2T', 'kg/an'], ['6', 'ans']].map(([v, l]) => (
          <div>
            <p class="font-big-shoulders font-black text-coach-lime leading-none text-[10px]">{v}</p>
            <p class="font-jetbrains text-[5px] uppercase text-coach-gris leading-tight">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
