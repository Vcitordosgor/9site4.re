---
/**
 * Mini-preview Meg & Dan — fidèle au hero split blanc : texte gauche
 * (eyebrow vert + wordmark Fraunces "Le geste juste, la coupe qui révèle.")
 * + photo verticale droite avec ring vert.
 */
---

<div class="absolute inset-0 bg-salon-blanc text-salon-noir overflow-hidden">

  <!-- Filet vert vertical central (style hero desktop) -->
  <span class="absolute left-1/2 top-6 bottom-6 w-px bg-salon-vert-clair/30" aria-hidden="true"></span>

  <!-- Mini header -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5 border-b border-salon-noir/10">
    <div class="flex items-baseline gap-1">
      <span class="font-fraunces font-semibold text-salon-noir text-[10px]">Meg</span>
      <span class="font-fraunces text-salon-vert text-[10px]">&amp;</span>
      <span class="font-fraunces font-semibold text-salon-noir text-[10px]">Dan</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-salon-noir/65 font-medium">
      <span>Prestations</span>
      <span>Équipe</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-salon-vert text-salon-blanc font-mulish font-semibold text-[6px] uppercase tracking-wider rounded-full">
      Prendre RDV
    </span>
  </div>

  <!-- Hero split : texte gauche / photo droite -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-2 pb-2 h-[calc(100%-1.6rem)]">

    <!-- LEFT (7) : eyebrow vert + wordmark Fraunces -->
    <div class="col-span-7 flex flex-col justify-center">
      <p class="flex items-center gap-1 font-mulish text-[5.5px] uppercase tracking-[0.3em] text-salon-vert mb-1 font-semibold">
        <span class="inline-block w-3 h-px bg-salon-vert" aria-hidden="true"></span>
        <span>Salon · Saint-Gilles</span>
      </p>
      <p class="font-fraunces font-bold text-salon-noir leading-[1.0]" style="font-size: clamp(13px, 2.7vw, 22px);">
        Le geste juste,
      </p>
      <p class="font-fraunces italic font-semibold text-salon-vert leading-[1.0] mt-0.5" style="font-size: clamp(13px, 2.7vw, 22px);">
        la coupe qui révèle.
      </p>
      <p class="mt-1.5 text-salon-noir/75 text-[6.5px] leading-snug max-w-[90%]">
        Coupe, couleur, soin, barbe — sur rendez-vous.
      </p>
      <div class="mt-1.5 flex items-center gap-1">
        <span class="inline-flex items-center h-3 px-2 bg-salon-vert text-salon-blanc font-mulish font-semibold text-[6px] uppercase tracking-wider rounded-full">
          Prendre RDV
        </span>
      </div>
    </div>

    <!-- RIGHT (5) : photo verticale ring vert -->
    <div class="col-span-5">
      <figure class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 4/5;">
        <span class="absolute -top-1 -left-1 right-2 bottom-2 ring-1 ring-salon-vert-clair/40 rounded-sm pointer-events-none" aria-hidden="true"></span>
        <img
          src="https://plus.unsplash.com/premium_photo-1669675935887-fdfb81d37cc7?q=80&w=240"
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </div>
</div>
