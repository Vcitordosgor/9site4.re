---
/**
 * Mini-preview Meg & Dan — salon coiffure noir/vert forêt minimaliste.
 */
---

<div class="absolute inset-0 bg-salon-blanc text-salon-noir overflow-hidden">

  <!-- Mini header -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5 border-b border-salon-noir/15">
    <div class="flex items-baseline gap-1">
      <span class="font-lora font-medium text-salon-noir text-[10px]">Meg</span>
      <span class="font-lora text-salon-vert text-[10px]">&</span>
      <span class="font-lora font-medium text-salon-noir text-[10px]">Dan</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-wider text-salon-noir/65 font-medium">
      <span>Prestations</span>
      <span>Équipe</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-salon-vert text-salon-blanc font-raleway font-semibold text-[6px] uppercase tracking-wider">
      Prendre RDV
    </span>
  </div>

  <!-- Hero split -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-2 pb-2 h-[calc(100%-1.6rem)]">

    <!-- LEFT : titre serif Lora -->
    <div class="col-span-7 flex flex-col justify-center">
      <p class="font-raleway text-[6px] uppercase tracking-[0.3em] text-salon-vert mb-1 font-bold">
        Saint-Gilles-les-Bains
      </p>
      <p class="font-lora font-medium text-salon-noir leading-[0.95]" style="font-size: clamp(13px, 2.6vw, 22px);">
        L'art<br/>
        de la coupe<br/>
        <span class="italic font-light text-salon-vert">précise.</span>
      </p>
      <div class="mt-2 flex items-center gap-1">
        <span class="inline-flex items-center h-3 px-1.5 bg-salon-noir text-salon-blanc font-raleway font-semibold text-[6px] uppercase tracking-wider">
          Réserver →
        </span>
      </div>
    </div>

    <!-- RIGHT : photo verticale + détail -->
    <div class="col-span-5">
      <div class="relative aspect-[3/4] bg-salon-gris overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1562322140-8baeececf3df?w=300&q=70"
          alt=""
          class="w-full h-full object-cover grayscale-[20%]"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute bottom-0 inset-x-0 h-[2px] bg-salon-vert"></span>
      </div>
    </div>
  </div>
</div>
