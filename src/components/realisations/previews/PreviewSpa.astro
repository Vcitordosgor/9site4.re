---
/**
 * Mini-preview Elio Spa — fidèle au hero full-bleed : photo plein écran
 * + overlay sombre + ornement vague terracotta + tagline Lora centrée
 * "L'art du geste, le souffle du temps."
 */
---

<div class="absolute inset-0 bg-spa-cacao text-spa-creme overflow-hidden">

  <!-- Photo full-bleed -->
  <img
    src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=600&q=75"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />

  <!-- Double overlay pour lisibilité (matche le hero) -->
  <div class="absolute inset-0 bg-spa-cacao/40" aria-hidden="true"></div>
  <div class="absolute inset-0" aria-hidden="true"
       style="background: linear-gradient(180deg, rgb(58 47 38 / 0.55) 0%, rgb(58 47 38 / 0.20) 35%, rgb(58 47 38 / 0.20) 65%, rgb(58 47 38 / 0.85) 100%);">
  </div>

  <!-- Mini header transparent -->
  <div class="relative flex items-center justify-between px-3 pt-2">
    <div class="flex items-baseline gap-0.5">
      <span class="font-bodoni italic font-light text-spa-creme text-[10px]">Elio</span>
      <span class="font-bodoni italic font-light text-spa-rose text-[10px]">spa</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-spa-creme/80 font-medium">
      <span>Rituels</span>
      <span>Soins</span>
    </div>
  </div>

  <!-- Ornement vague terracotta -->
  <svg class="relative z-10 mx-auto mt-2 w-12 h-3 text-spa-terracotta/85" viewBox="0 0 100 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
    <path d="M2 12 Q 15 4, 28 12 T 54 12 T 80 12 T 98 12" />
  </svg>

  <!-- Contenu centré -->
  <div class="relative z-10 absolute inset-x-3 bottom-2.5 text-center">
    <p class="font-raleway font-light text-[5.5px] uppercase tracking-[0.4em] text-spa-rose mb-1.5">
      Spa &amp; massages · Saint-Pierre
    </p>
    <p class="font-lora text-spa-creme leading-[1.05] font-medium" style="font-size: clamp(13px, 2.8vw, 22px);">
      L'art du geste,
    </p>
    <p class="font-lora italic font-normal text-spa-rose leading-[1.05]" style="font-size: clamp(13px, 2.8vw, 22px);">
      le souffle du temps.
    </p>
    <div class="mt-1.5 flex items-center justify-center gap-1.5">
      <span class="inline-flex items-center h-3 px-2 bg-spa-terracotta text-spa-blanc font-raleway font-semibold text-[6px] uppercase tracking-[0.18em] rounded-full">
        Réserver un soin
      </span>
    </div>
  </div>
</div>
