---
/**
 * Mini-preview Elio Spa — Nature distilled, terracotta + crème + sable.
 */
---

<div class="absolute inset-0 bg-spa-creme text-spa-cacao font-manrope overflow-hidden">

  <!-- Mini header -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5">
    <div class="flex items-baseline gap-1">
      <span class="font-bodoni italic font-light text-spa-cacao text-[11px]">Elio</span>
      <span class="font-bodoni italic font-light text-spa-terracotta text-[11px]">spa</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-spa-cacao/65 font-medium">
      <span>Rituels</span>
      <span>Soins</span>
    </div>
    <span class="font-bodoni italic text-spa-argile text-[7px] underline underline-offset-2 decoration-spa-terracotta/50">
      Réserver
    </span>
  </div>

  <!-- Hero centré -->
  <div class="flex flex-col items-center justify-center text-center px-4 pt-2 pb-3 h-[calc(100%-1.5rem)]">

    <p class="font-manrope text-[6px] uppercase tracking-[0.32em] text-spa-terracotta mb-1.5 font-semibold">
      ✦ Saint-Pierre · La Réunion
    </p>

    <p class="font-bodoni font-light text-spa-cacao leading-[0.95]" style="font-size: clamp(14px, 2.8vw, 26px);">
      Le rituel,
      <span class="block italic text-spa-terracotta">avant tout.</span>
    </p>

    <p class="mt-2 max-w-[80%] font-bodoni italic text-spa-cacao/65 text-[7px] leading-snug">
      Soins du visage, massages signature, hammam.
    </p>

    <!-- Filet ornement -->
    <div class="mt-2 flex items-center gap-1.5">
      <span class="block h-px w-6 bg-spa-terracotta/50"></span>
      <span class="text-spa-terracotta text-[5px]">✦</span>
      <span class="block h-px w-6 bg-spa-terracotta/50"></span>
    </div>

    <span class="mt-2 inline-flex items-center h-3 px-2 bg-spa-argile text-spa-creme font-manrope font-semibold text-[6px] uppercase tracking-[0.18em]">
      Réserver un rituel
    </span>
  </div>
</div>
