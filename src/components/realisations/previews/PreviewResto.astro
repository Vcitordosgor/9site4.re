---
/**
 * Mini-preview Le jardin perdu — fidèle au hero magazine éditorial sur
 * fond bleu encre profond + filets or laiton + wordmark Bodoni géant
 * blanc/or + encart photo à droite.
 */
---

<div class="absolute inset-0 bg-resto-bleu-encre text-resto-blanc-casse overflow-hidden">

  <!-- Filets or laiton décoratifs (coins) -->
  <span class="absolute top-2 left-2 w-3 h-px bg-resto-or/60" aria-hidden="true"></span>
  <span class="absolute top-2 left-2 w-px h-3 bg-resto-or/60" aria-hidden="true"></span>
  <span class="absolute bottom-2 right-2 w-3 h-px bg-resto-or/60" aria-hidden="true"></span>
  <span class="absolute bottom-2 right-2 w-px h-3 bg-resto-or/60" aria-hidden="true"></span>

  <!-- Mini header magazine sur fond encre -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5 border-b border-resto-or/15">
    <span class="font-bodoni italic font-medium text-resto-blanc-casse text-[10px] tracking-wide">Le jardin perdu</span>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-resto-blanc-casse/65 font-medium">
      <span>La carte</span>
      <span>Cave</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-resto-bleu-roi text-resto-blanc-casse font-manrope font-semibold text-[6px] uppercase tracking-wider">
      Réserver
    </span>
  </div>

  <!-- Hero magazine éditorial : grand wordmark gauche, encart photo droite -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-2 pb-2 h-[calc(100%-1.6rem)]">

    <!-- LEFT (8) : eyebrow or + wordmark Bodoni géant + tagline italique -->
    <div class="col-span-8 flex flex-col justify-center">
      <p class="font-manrope font-medium text-[5.5px] uppercase tracking-[0.32em] text-resto-or mb-1">
        · Restaurant gastronomique · St-Denis ·
      </p>
      <p class="font-bodoni text-resto-blanc-casse leading-[0.92] font-medium" style="font-size: clamp(16px, 3.4vw, 30px);">
        Le jardin
      </p>
      <p class="font-bodoni italic text-resto-or leading-[0.92] font-normal pl-2" style="font-size: clamp(16px, 3.4vw, 30px);">
        perdu.
      </p>
      <p class="mt-1.5 font-bodoni italic text-resto-blanc-casse/85 text-[7px] leading-snug max-w-[80%]">
        Cuisine du marché, tables sous les filaos.
      </p>
    </div>

    <!-- RIGHT (4) : encart photo verticale + filet or -->
    <div class="col-span-4 flex items-center">
      <figure class="relative w-full overflow-hidden" style="aspect-ratio: 4/5;">
        <img
          src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=240&q=70"
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute inset-0 ring-1 ring-resto-or/40 pointer-events-none" aria-hidden="true"></span>
      </figure>
    </div>
  </div>
</div>
