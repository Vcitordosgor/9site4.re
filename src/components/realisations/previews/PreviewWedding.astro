---
/**
 * Mini-preview Sève & Sel — fidèle au hero éditorial wedding magazine :
 * fond ivoire, monogramme géant S&S Italianno, ornement floral, tagline
 * Cormorant italique, bandeau de chiffres entre filets dorés.
 */
---

<div class="absolute inset-0 bg-seve-ivoire text-seve-marine font-outfit overflow-hidden">

  <!-- Filet doré haut -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-seve-or to-transparent" aria-hidden="true"></div>

  <!-- Eyebrow centré -->
  <div class="relative pt-2 flex items-center justify-center gap-1">
    <span class="block w-3 h-px bg-seve-or" aria-hidden="true"></span>
    <span class="font-outfit text-[5px] uppercase tracking-[0.3em] text-seve-marine/70">Wedding planner · St-Gilles</span>
    <span class="block w-3 h-px bg-seve-or" aria-hidden="true"></span>
  </div>

  <!-- Monogramme géant centré + ornements -->
  <div class="relative mt-1 px-2 grid grid-cols-[1fr_auto_1fr] items-center gap-1">
    <!-- Fleur tropicale -->
    <svg viewBox="0 0 60 80" class="justify-self-end w-7 text-seve-or" aria-hidden="true">
      <g fill="none" stroke="currentColor" stroke-width="0.5">
        <path d="M45 80 Q40 60 35 45 Q30 30 20 18" />
        <ellipse cx="20" cy="18" rx="3" ry="6" fill="currentColor" fill-opacity="0.3" />
        <ellipse cx="25" cy="22" rx="3" ry="6" fill="currentColor" fill-opacity="0.3" transform="rotate(72 25 22)" />
        <ellipse cx="22" cy="28" rx="3" ry="6" fill="currentColor" fill-opacity="0.3" transform="rotate(144 22 28)" />
        <circle cx="22" cy="22" r="1.5" fill="currentColor" />
      </g>
    </svg>

    <h1 class="font-italianno text-seve-marine leading-[0.85] text-center" style="font-size: clamp(38px, 8vw, 64px);">
      <span>S</span><span class="text-seve-or align-middle" style="font-size:0.7em">&amp;</span><span>S</span>
    </h1>

    <!-- Palme -->
    <svg viewBox="0 0 60 80" class="justify-self-start w-7 text-seve-or" aria-hidden="true">
      <g fill="none" stroke="currentColor" stroke-width="0.5">
        <path d="M15 80 Q20 60 25 45 Q30 30 40 18" />
        <g stroke-width="0.4" transform="translate(40 18)">
          <path d="M0 0 Q-6 -4 -14 -3" />
          <path d="M0 0 Q-2 -10 -4 -16" />
          <path d="M0 0 Q3 -8 7 -14" />
          <path d="M0 0 Q7 -6 14 -7" />
          <path d="M0 0 Q6 3 12 8" />
        </g>
      </g>
    </svg>
  </div>

  <!-- Tagline italique -->
  <p class="relative mt-1 text-center font-cormorant italic text-seve-marine leading-tight px-2" style="font-size: clamp(7px, 1.6vw, 12px);">
    L'océan vous marie.
  </p>

  <!-- Bandeau chiffres entre filets dorés -->
  <div class="absolute inset-x-2 bottom-2 border-y border-seve-or/40 py-1 grid grid-cols-3 gap-1 text-center">
    <div>
      <div class="font-cormorant text-seve-marine leading-none" style="font-size:10px;">47</div>
      <div class="font-outfit uppercase tracking-wider text-seve-marine/65" style="font-size:4px;letter-spacing:0.18em;">cérémonies 2025</div>
    </div>
    <div>
      <div class="font-cormorant text-seve-or leading-none" style="font-size:10px;">Avr→Oct</div>
      <div class="font-outfit uppercase tracking-wider text-seve-marine/65" style="font-size:4px;letter-spacing:0.18em;">saison sèche</div>
    </div>
    <div>
      <div class="font-cormorant text-seve-marine leading-none" style="font-size:10px;">2017</div>
      <div class="font-outfit uppercase tracking-wider text-seve-marine/65" style="font-size:4px;letter-spacing:0.18em;">depuis · Réunion</div>
    </div>
  </div>
</div>
