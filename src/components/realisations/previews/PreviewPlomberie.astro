---
/**
 * Mini-preview Bernard Plomberie — poster industriel utilitaire.
 * Anthracite + jaune signalisation + ciment + URGENCE rouge.
 */
---

<div class="absolute inset-0 bg-bp-ciment text-bp-anthracite overflow-hidden">

  <!-- Mini header utilitaire -->
  <div class="flex items-center justify-between px-3 pt-1.5 pb-1.5 bg-bp-anthracite text-bp-jaune">
    <div class="flex items-center gap-1">
      <span class="inline-flex items-center justify-center w-3 h-3 bg-bp-jaune text-bp-anthracite font-bebas text-[8px] leading-none">B</span>
      <span class="font-bebas text-[10px] tracking-wide text-bp-blanc leading-none">BERNARD</span>
      <span class="font-bebas text-[10px] tracking-wide text-bp-jaune leading-none">PLOMBERIE</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-bp-rouge text-bp-blanc font-bebas text-[6px] tracking-widest uppercase">
      ☎ URGENCE 24/7
    </span>
  </div>

  <!-- Hero -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-2 pb-2 h-[calc(100%-1.6rem)]">

    <!-- LEFT (8) : titre poster -->
    <div class="col-span-8 flex flex-col justify-center">
      <p class="font-archivo text-[6px] uppercase tracking-[0.22em] text-bp-rouge mb-1 font-bold">
        ▲ Le Tampon · 974
      </p>
      <p class="font-bebas font-bold text-bp-anthracite leading-[0.85] tracking-tight" style="font-size: clamp(15px, 3.2vw, 28px);">
        DÉPANNAGE<br/>
        <span class="text-bp-jaune-fonce">RAPIDE.</span>
      </p>
      <p class="mt-1 font-archivo text-bp-anthracite/85 text-[6.5px] font-medium leading-snug">
        18 ans · Sud de l'île · Devis gratuit en 1h.
      </p>
      <div class="mt-1.5 flex items-center gap-1">
        <span class="inline-flex items-center h-3 px-1.5 bg-bp-jaune text-bp-anthracite font-bebas tracking-widest text-[7px]">
          DEMANDER UN DEVIS
        </span>
      </div>
    </div>

    <!-- RIGHT (4) : grand numéro tél -->
    <div class="col-span-4 flex flex-col items-center justify-center">
      <div class="bg-bp-anthracite text-bp-jaune p-1.5 w-full text-center" style="border: 1.5px solid #FFC72C;">
        <p class="font-archivo text-[5px] uppercase tracking-wider opacity-80">Téléphone</p>
        <p class="font-bebas tracking-tight text-[10px] tabular-nums leading-tight">0692 00 00 00</p>
      </div>
      <p class="mt-1 font-archivo text-bp-anthracite text-[5px] uppercase tracking-wider font-bold">
        ★ Service rapide
      </p>
    </div>
  </div>
</div>
