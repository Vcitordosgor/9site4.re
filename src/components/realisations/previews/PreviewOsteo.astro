---
/**
 * Mini-preview Cabinet Verveine — médical épuré quasi-monochrome.
 */
---

<div class="absolute inset-0 bg-verveine-creme text-verveine-encre font-public-sans overflow-hidden">

  <!-- Mini header -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5 border-b border-verveine-encre/10">
    <div class="flex items-baseline gap-1">
      <span class="font-cardo text-verveine-encre text-[10px]">Verveine</span>
      <span class="font-karla text-[6px] uppercase tracking-[0.22em] text-verveine-beton">D.O.</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] text-verveine-encre/65">
      <span>Approche</span>
      <span>Motifs</span>
      <span>Tarifs</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 border border-verveine-encre text-verveine-encre font-public-sans font-medium text-[6px]">
      Prendre RDV
    </span>
  </div>

  <!-- Hero fiche praticienne -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-2 pb-2 h-[calc(100%-1.5rem)]">

    <!-- LEFT (5) : photo praticienne carrée -->
    <div class="col-span-5">
      <div class="relative aspect-square bg-verveine-papier overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=300&q=70"
          alt=""
          class="w-full h-full object-cover grayscale"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-1 border border-verveine-creme/40"></div>
        <span class="absolute bottom-0 inset-x-0 h-[2px] bg-verveine-sauge"></span>
      </div>
    </div>

    <!-- RIGHT (7) : carte d'identité pro -->
    <div class="col-span-7 flex flex-col justify-center">
      <p class="font-karla text-[6px] uppercase tracking-[0.28em] text-verveine-beton mb-1 font-medium">
        Cabinet · Saint-Pierre
      </p>
      <p class="font-cardo text-verveine-encre leading-[1.05]" style="font-size: clamp(11px, 2.4vw, 18px);">
        Dr Hélène<br/>
        Saint-Pierre
      </p>
      <p class="mt-0.5 font-cardo italic text-verveine-beton text-[7px]">
        Ostéopathe D.O.
      </p>

      <!-- Filet sauge -->
      <span class="mt-1 block h-px w-6 bg-verveine-sauge"></span>

      <!-- Bullets diplômes -->
      <ul class="mt-1 space-y-[2px]">
        {['CEESO Paris 2009', 'DU Pédiatrique 2014'].map((d) => (
          <li class="flex items-baseline gap-1 font-cardo text-verveine-encre/75 text-[6px]">
            <span class="block w-1 h-px bg-verveine-encre/40"></span>
            {d}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
