---
/**
 * Mini-preview Le Cap Anglais — topo-guide d'altitude.
 * Vert mousse + brun terre + crème papier + rouge balisage.
 */
---

<div class="absolute inset-0 bg-cap-papier text-cap-charbon font-bricolage overflow-hidden">

  <!-- Lignes topo en arrière-plan -->
  <svg class="absolute -right-12 -bottom-12 w-32 h-32 opacity-[0.1] pointer-events-none" viewBox="0 0 600 600" fill="none" stroke="#3D5840" stroke-width="0.6" aria-hidden="true">
    <ellipse cx="300" cy="300" rx="280" ry="200" transform="rotate(-15 300 300)"/>
    <ellipse cx="300" cy="300" rx="200" ry="140" transform="rotate(-10 300 300)"/>
    <ellipse cx="300" cy="300" rx="120" ry="90"/>
    <circle cx="320" cy="300" r="6" fill="#C03A2C"/>
  </svg>

  <!-- Mini header avec épingle topo -->
  <div class="relative flex items-center justify-between px-3 pt-2 pb-1.5">
    <div class="flex items-center gap-1">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="text-cap-rouge"><path d="M12 2L4 8l8 14 8-14-8-6z"/><circle cx="12" cy="9" r="2.5" fill="currentColor"/></svg>
      <span class="font-bricolage font-semibold text-cap-charbon text-[9px]">Le Cap Anglais</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] text-cap-charbon/75">
      <span>Le gîte</span>
      <span>Chambres</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-cap-mousse text-cap-papier font-bricolage font-semibold text-[6px]">
      Réserver
    </span>
  </div>

  <!-- Hero topo-guide -->
  <div class="relative px-3 pt-1 pb-2 grid grid-cols-12 gap-2 h-[calc(100%-1.5rem)]">

    <!-- LEFT (7) : photo + GPS -->
    <div class="col-span-7">
      <div class="relative aspect-[4/3] bg-cap-charbon overflow-hidden">
        <img
          src="/images/gite/hero-cilaos.webp"
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute top-1 left-1 bg-cap-papier/90 px-1 font-jetbrains text-[5px] uppercase tracking-wider text-cap-terre">
          Alt. 1 220 m
        </span>
        <!-- Étiquette GPS bas -->
        <span class="absolute bottom-0 inset-x-0 bg-cap-charbon/85 px-1 py-0.5 font-jetbrains text-[5px] text-cap-papier tabular-nums">
          −21.1373, 55.4711
        </span>
      </div>
    </div>

    <!-- RIGHT (5) : fiche topo -->
    <div class="col-span-5 flex flex-col">
      <p class="font-jetbrains text-[5.5px] uppercase tracking-[0.22em] text-cap-mousse mb-1 font-medium">
        Fiche n° 47
      </p>
      <p class="font-bricolage font-semibold text-cap-charbon leading-[0.95] mb-1" style="font-size: clamp(10px, 2vw, 16px);">
        Le Cap<br/>Anglais
      </p>
      <p class="font-crimson-pro italic text-cap-terre text-[6px]">
        Gîte de cirque · Cilaos
      </p>

      <!-- Classification ananas -->
      <div class="mt-1 flex items-center gap-0.5">
        {[1, 2, 3, 4].map((i) => <span class="text-cap-mousse text-[7px]">✦</span>)}
        <span class="text-cap-pierre/30 text-[7px]">✦</span>
      </div>

      <!-- Filet rouge -->
      <span class="mt-1 h-[1.5px] w-4 bg-cap-rouge"></span>
    </div>
  </div>
</div>
