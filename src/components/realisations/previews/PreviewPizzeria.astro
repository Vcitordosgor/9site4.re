---
/**
 * Mini-preview Pizza Lé O — trattoria éditoriale.
 * Crème + rouge tomate + dorée vintage, typo Fraunces serif italien.
 */
---

<div class="absolute inset-0 bg-pizza-creme text-pizza-charbon overflow-hidden">

  <!-- Mini header -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5 border-b border-pizza-charbon/15">
    <div class="flex items-baseline gap-1">
      <span class="font-fraunces font-bold text-pizza-rouge text-[10px] italic">Pizza</span>
      <span class="font-fraunces font-light text-pizza-charbon text-[10px] italic">Lé O</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-wider text-pizza-charbon/65 font-medium">
      <span>Carte</span>
      <span>Menus</span>
      <span>Réserver</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-pizza-rouge text-pizza-creme font-dm-sans font-bold text-[6px] uppercase tracking-wider">
      Commander
    </span>
  </div>

  <!-- Hero -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-1 pb-2 h-[calc(100%-1.6rem)]">

    <!-- LEFT : titre éditorial -->
    <div class="col-span-7 flex flex-col justify-center">
      <p class="font-dm-sans text-[6px] uppercase tracking-[0.22em] text-pizza-rouge mb-1 font-semibold">
        ✦ Saint-Paul · 974
      </p>
      <p class="font-fraunces font-bold italic text-pizza-charbon leading-[0.95]" style="font-size: clamp(13px, 2.6vw, 22px);">
        La trattoria<br/>
        <span class="text-pizza-rouge">comme à Naples.</span>
      </p>
      <p class="mt-1.5 font-dm-sans italic text-pizza-charbon/65 text-[6.5px] leading-snug">
        Pizzas au feu de bois, carte courte, ardoise du jour.
      </p>
      <div class="mt-2 flex items-center gap-1">
        <span class="inline-flex items-center h-3 px-1.5 bg-pizza-charbon text-pizza-creme font-dm-sans font-bold text-[6px] uppercase tracking-wider">
          Voir la carte
        </span>
        <span class="font-fraunces italic text-pizza-rouge text-[7px] underline underline-offset-2 decoration-pizza-dore/50">
          Réserver
        </span>
      </div>
    </div>

    <!-- RIGHT : photo pizza recadrée -->
    <div class="col-span-5">
      <div class="relative aspect-square bg-pizza-charbon overflow-hidden rounded-sm" style="transform: rotate(2deg);">
        <img
          src="https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?w=300&q=70"
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute top-1 left-1 px-1 bg-pizza-creme/95 font-fraunces italic text-pizza-rouge text-[6px]">
          Margherita
        </span>
      </div>
    </div>
  </div>
</div>
