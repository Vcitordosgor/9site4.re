---
/**
 * Mini-preview Camille Aubry — page de livre, registre littéraire.
 * Gris perle + bleu nuit + prune + terre rose. Aucune photo.
 */
---

<div class="absolute inset-0 bg-aubry-perle text-aubry-encre font-albert overflow-hidden">

  <!-- Esperluette ornement géant en arrière-plan -->
  <p class="absolute top-1/2 -right-3 -translate-y-1/2 font-caslon italic text-aubry-rose/15 leading-none select-none pointer-events-none" style="font-size: 110px;" aria-hidden="true">
    &amp;
  </p>

  <!-- Mini header -->
  <div class="relative flex items-center justify-between px-3 pt-2 pb-1.5">
    <span class="font-caslon text-aubry-encre text-[10px]">Camille Aubry<span class="text-aubry-rose">.</span></span>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-aubry-encre/65 font-light">
      <span>Approche</span>
      <span>Cadre</span>
      <span>Modalités</span>
    </div>
    <span class="font-caslon italic text-aubry-encre text-[7px] underline underline-offset-2 decoration-aubry-rose">
      Prendre RDV
    </span>
  </div>

  <!-- Hero composition typographique livre -->
  <div class="relative px-3 pt-1.5 pb-2 h-[calc(100%-1.5rem)] flex flex-col">

    <div class="flex items-baseline justify-between font-plex-mono text-[5.5px] uppercase tracking-[0.28em] text-aubry-prune mb-1.5">
      <span>Cabinet Aubry — Saint-Denis</span>
      <span>p. 01</span>
    </div>

    <!-- Chiffre romain géant -->
    <p class="font-caslon italic text-aubry-prune leading-none mb-1 select-none" style="font-size: 32px;">
      I.
    </p>

    <!-- Titre incipit -->
    <p class="font-caslon text-aubry-encre leading-[1.05] max-w-[80%]" style="font-size: clamp(11px, 2.3vw, 18px);">
      Une consultation, ça commence par un appel.
    </p>

    <!-- Filet rose -->
    <span class="mt-1.5 block w-6 h-px bg-aubry-rose"></span>

    <!-- Mini paragraphe filé -->
    <p class="mt-1 font-caslon text-aubry-encre/80 leading-[1.6] text-[6.5px] max-w-[85%] line-clamp-2">
      Vous tapez un numéro, vous laissez sonner, et quelque chose change déjà.
    </p>

    <!-- ADELI footer -->
    <div class="mt-auto pt-1.5 border-t border-aubry-encre/15 flex items-baseline justify-between font-plex-mono text-[5.5px] uppercase tracking-[0.22em] text-aubry-prune">
      <span>ADELI 974 31 5896</span>
      <span>↓ Continuer</span>
    </div>
  </div>
</div>
