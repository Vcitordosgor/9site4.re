---
/**
 * Mini-preview Les agapanthes — carnet du paysagiste botanique.
 * Lin + violet agapanthe + sauge + rose poudre, Cormorant + Outfit.
 */
---

<div class="absolute inset-0 bg-agap-lin text-agap-feuille overflow-hidden">

  <!-- Mini header -->
  <div class="flex items-center justify-between px-3 pt-2 pb-1.5">
    <div class="flex items-baseline gap-0.5">
      <span class="font-cormorant italic text-agap-feuille text-[10px]">Les</span>
      <span class="font-cormorant italic font-semibold text-agap-violet text-[10px]">agapanthes</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-agap-feuille/65 font-medium">
      <span>Services</span>
      <span>Réalisations</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-agap-violet text-agap-lin font-outfit font-semibold text-[6px] uppercase tracking-[0.18em] rounded-full">
      Devis gratuit
    </span>
  </div>

  <!-- Hero -->
  <div class="grid grid-cols-12 gap-2 px-3 pt-2 pb-2 h-[calc(100%-1.5rem)] relative">

    <!-- Petit ornement feuille SVG -->
    <svg class="absolute top-1 right-1 w-4 h-4 text-agap-sauge/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
    </svg>

    <!-- LEFT (7) : eyebrow violet + wordmark Cormorant aligné sur le hero -->
    <div class="col-span-7 flex flex-col justify-center">
      <p class="flex items-center gap-1 font-outfit text-[5.5px] uppercase tracking-[0.32em] text-agap-violet mb-1 font-medium">
        <span class="block w-3 h-px bg-agap-violet" aria-hidden="true"></span>
        <span>Atelier paysagiste · Saint-Leu</span>
      </p>
      <p class="font-cormorant font-medium text-agap-feuille leading-[0.98]" style="font-size: clamp(14px, 2.8vw, 24px);">
        L'art du jardin
      </p>
      <p class="font-cormorant italic font-medium text-agap-violet leading-[0.98]" style="font-size: clamp(14px, 2.8vw, 24px);">
        à la créole.
      </p>
      <p class="mt-1.5 font-outfit text-agap-feuille/75 text-[6.5px] leading-snug">
        Création · entretien · plantes locales.
      </p>
    </div>

    <!-- RIGHT (5) : grand carré violet ornemental -->
    <div class="col-span-5">
      <div class="relative aspect-square bg-agap-violet/15 overflow-hidden">
        <img
          src="/images/paysagiste/hero.webp"
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute bottom-1 left-1 right-1 font-cormorant italic text-agap-lin text-[6px] text-center">
          jardin créé en 2024
        </span>
      </div>
    </div>
  </div>
</div>
