---
/**
 * Mini-preview Maison Marléne — boutique-hôtel parisien raffiné.
 * Nacre + champagne doré + bordeaux satiné, Marcellus + EB Garamond.
 */
---

<div class="absolute inset-0 bg-marlene-nacre text-marlene-noir font-mulish overflow-hidden">

  <!-- Filets dorés latéraux -->
  <div class="absolute top-1 bottom-1 left-1.5 w-px bg-gradient-to-b from-transparent via-marlene-champagne/40 to-transparent"></div>
  <div class="absolute top-1 bottom-1 right-1.5 w-px bg-gradient-to-b from-transparent via-marlene-champagne/40 to-transparent"></div>

  <!-- Mini header avec wordmark espacé -->
  <div class="relative flex items-center justify-between px-3 pt-2 pb-1.5">
    <div class="flex items-baseline gap-1">
      <span class="font-marcellus text-marlene-noir text-[8px] uppercase tracking-[0.32em] leading-none">MAISON</span>
      <span class="font-marcellus text-marlene-bordeaux text-[8px] uppercase tracking-[0.32em] leading-none">MARLÉNE</span>
    </div>
    <div class="flex items-center gap-1.5 text-[6px] uppercase tracking-[0.18em] text-marlene-noir/70 font-light">
      <span>Rituel</span>
      <span>Soins</span>
    </div>
    <span class="inline-flex items-center h-3 px-2 bg-marlene-bordeaux text-marlene-nacre font-marcellus text-[6px] tracking-wide">
      Réserver
    </span>
  </div>

  <!-- Hero éditorial centré -->
  <div class="relative flex flex-col items-center justify-center text-center px-4 pt-2 pb-2 h-[calc(100%-1.5rem)]">

    <p class="font-mulish text-[5px] uppercase tracking-[0.4em] text-marlene-champagne mb-1.5">
      — Institut · depuis 2012 —
    </p>

    <p class="font-marcellus text-marlene-noir leading-[0.95] tracking-[0.15em] uppercase">
      <span class="block" style="font-size: clamp(10px, 2vw, 16px);">MAISON</span>
      <span class="block italic font-eb-garamond text-marlene-bordeaux mt-0.5" style="font-size: clamp(15px, 3vw, 26px); letter-spacing: 0.05em;">
        Marléne
      </span>
    </p>
    <p class="mt-1.5 font-eb-garamond italic text-marlene-moka text-[7px]">
      Institut de beauté & soins
    </p>

    <!-- Filet doré ornement -->
    <div class="mt-2 flex items-center gap-1.5">
      <span class="block h-px w-6 bg-gradient-to-r from-transparent to-marlene-champagne"></span>
      <span class="font-eb-garamond italic text-marlene-champagne text-[8px]">&amp;</span>
      <span class="block h-px w-6 bg-gradient-to-l from-transparent to-marlene-champagne"></span>
    </div>

    <span class="mt-2 inline-flex items-center h-3 px-2 bg-marlene-bordeaux text-marlene-nacre font-marcellus text-[5.5px] uppercase tracking-wider">
      Réserver mon soin
    </span>
  </div>
</div>
