---
import Badge from '../ui/Badge.astro';
import Icon from '../ui/Icon.astro';
import categories from '../../data/categories.json';

// Imports des 24 mini-previews custom (un par template)
import PreviewResto from './previews/PreviewResto.astro';
import PreviewPizzeria from './previews/PreviewPizzeria.astro';
import PreviewBarJus from './previews/PreviewBarJus.astro';
import PreviewSalon from './previews/PreviewSalon.astro';
import PreviewInstitut from './previews/PreviewInstitut.astro';
import PreviewSpa from './previews/PreviewSpa.astro';
import PreviewPlomberie from './previews/PreviewPlomberie.astro';
import PreviewElectricien from './previews/PreviewElectricien.astro';
import PreviewPaysagiste from './previews/PreviewPaysagiste.astro';
import PreviewOsteo from './previews/PreviewOsteo.astro';
import PreviewDieteticienne from './previews/PreviewDieteticienne.astro';
import PreviewPsy from './previews/PreviewPsy.astro';
import PreviewCoach from './previews/PreviewCoach.astro';
import PreviewYoga from './previews/PreviewYoga.astro';
import PreviewDanse from './previews/PreviewDanse.astro';
import PreviewGite from './previews/PreviewGite.astro';
import PreviewExcursions from './previews/PreviewExcursions.astro';
import PreviewLocation from './previews/PreviewLocation.astro';
import PreviewConsultant from './previews/PreviewConsultant.astro';
import PreviewComptable from './previews/PreviewComptable.astro';
import PreviewArchitecte from './previews/PreviewArchitecte.astro';
import PreviewAutoEcole from './previews/PreviewAutoEcole.astro';
import PreviewConciergerie from './previews/PreviewConciergerie.astro';
import PreviewAideDomicile from './previews/PreviewAideDomicile.astro';

/**
 * RealisationCard — chaque carte affiche un VRAI mini-preview du template
 * (composant Astro custom reproduisant fidèlement le hero du template),
 * encadré dans une frame navigateur ultra-minimaliste (3 ronds, pas d'URL).
 */
interface Realisation {
  id: number;
  nom: string;
  categorie: string;
  sousTitre: string;
  moduleInclus: string;
  slug: string;
  previewUrl?: string;
  thumbnail?: string;
}

interface Props {
  realisation: Realisation;
  ctaHref?: string;
}

const { realisation, ctaHref = '/contact' } = Astro.props;

const categoryName =
  categories.find((c) => c.id === realisation.categorie)?.nom ??
  realisation.categorie;

// Mapping slug → composant Preview correspondant
const previewMap: Record<string, any> = {
  'restaurant-gastronomique':         PreviewResto,
  'snack-pizzeria':                   PreviewPizzeria,
  'bar-a-jus-tropical':               PreviewBarJus,
  'salon-de-coiffure':                PreviewSalon,
  'institut-de-beaute':               PreviewInstitut,
  'spa-massage':                      PreviewSpa,
  'plomberie':                        PreviewPlomberie,
  'electricite-generale':             PreviewElectricien,
  'paysagiste':                       PreviewPaysagiste,
  'cabinet-osteopathie':              PreviewOsteo,
  'dieteticienne':                    PreviewDieteticienne,
  'psychologue':                      PreviewPsy,
  'coach-sportif':                    PreviewCoach,
  'studio-yoga':                      PreviewYoga,
  'ecole-de-danse':                   PreviewDanse,
  'gite-de-montagne':                 PreviewGite,
  'excursions-randonnee':             PreviewExcursions,
  'location-saisonniere-bord-de-mer': PreviewLocation,
  'consultant':                       PreviewConsultant,
  'cabinet-comptable':                PreviewComptable,
  'architecte':                       PreviewArchitecte,
  'auto-ecole':                       PreviewAutoEcole,
  'conciergerie':                     PreviewConciergerie,
  'aide-a-domicile':                  PreviewAideDomicile,
};

const Preview = previewMap[realisation.slug] ?? null;

// Fallback visuel pour entrées sans preview
const visuals: Record<string, { icon: string }> = {
  restaurants: { icon: 'sparkle' },
  beaute: { icon: 'palette' },
  artisans: { icon: 'wrench' },
  sante: { icon: 'shield-check' },
  sport: { icon: 'sparkle' },
  tourisme: { icon: 'globe' },
  pro: { icon: 'file-text' },
  particuliers: { icon: 'headphones' },
};

const moduleIcons: Record<string, string> = {
  'Réservation': 'calendar-clock',
  'Rendez-vous': 'calendar-check',
  'Devis': 'file-text',
  'Intervention': 'wrench',
};
const moduleColors: Record<string, 'bleu' | 'orange'> = {
  'Rendez-vous': 'bleu',
  'Intervention': 'bleu',
  'Réservation': 'orange',
  'Devis': 'orange',
};

const visual = visuals[realisation.categorie] ?? visuals.pro;
const moduleIcon = moduleIcons[realisation.moduleInclus] ?? 'sparkle';
const moduleColor = moduleColors[realisation.moduleInclus] ?? 'orange';
---

<article class="tilt-card group relative bg-blanc-casse rounded-2xl ring-1 ring-bleu-nuit/10 shadow-card overflow-hidden flex flex-col hover:shadow-card-hover hover:ring-bleu-nuit/15">

  {realisation.previewUrl && Preview ? (
    <!-- 🖥️ MINI-PREVIEW NAVIGATEUR : vrai composant template miniaturisé -->
    <a
      href={realisation.previewUrl}
      target="_blank"
      rel="noopener"
      class="block group/preview overflow-hidden border-b border-bleu-nuit/10 bg-bleu-nuit"
      aria-label={`Voir le template ${realisation.nom}`}
    >
      <!-- Browser chrome minimaliste : 3 ronds seuls, pas d'URL fake -->
      <div class="flex items-center gap-1.5 px-3 py-2 bg-bleu-nuit/95" aria-hidden="true">
        <span class="block w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></span>
        <span class="block w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></span>
        <span class="block w-2.5 h-2.5 rounded-full bg-[#28C840]"></span>
      </div>

      <!-- Viewport : vrai mini-preview du template -->
      <div class="relative aspect-[5/3] overflow-hidden bg-blanc-casse transition-transform duration-700 ease-out-soft group-hover/preview:scale-[1.015]">
        <Preview />
      </div>
    </a>
  ) : (
    <!-- Fallback : gradient placeholder -->
    <div class="relative aspect-[5/3] overflow-hidden bg-gradient-to-br from-bleu-nuit/30 via-bleu/30 to-orange/15">
      <div class="absolute inset-0 flex items-center justify-center text-bleu-nuit/30">
        <Icon name={visual.icon} size={48} strokeWidth={1.5} />
      </div>
    </div>
  )}

  <!-- Corps de carte : métadonnées catalogue -->
  <div class="flex-1 flex flex-col p-6">

    <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
      <Badge variant="secondary" size="sm">{categoryName}</Badge>
      {realisation.previewUrl && (
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-orange text-bleu-nuit text-[10px] font-bold uppercase tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-bleu-nuit animate-pulse" aria-hidden="true"></span>
          Démo en ligne
        </span>
      )}
    </div>

    <h3 class="text-xl font-sora font-semibold text-bleu-nuit">{realisation.nom}</h3>
    <p class="mt-2 text-sm text-bleu-nuit/70 leading-relaxed">{realisation.sousTitre}</p>

    <div class:list={[
      'pill-bounce mt-4 inline-flex items-center gap-2 self-start px-3 py-1.5 rounded-full text-sm text-bleu-nuit',
      moduleColor === 'bleu' ? 'bg-bleu' : 'bg-orange',
    ]}>
      <Icon
        name={moduleIcon}
        size={16}
        class="text-bleu-nuit shrink-0"
        strokeWidth={2}
      />
      <span><strong class="font-semibold">{realisation.moduleInclus}</strong></span>
    </div>

    {realisation.previewUrl && (
      <a
        href={realisation.previewUrl}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center justify-center gap-2 h-10 px-4 text-sm font-semibold rounded-full bg-bleu-nuit text-blanc-casse hover:bg-orange hover:text-bleu-nuit transition-all"
      >
        Voir le template
        <Icon name="arrow-right" size={14} strokeWidth={2.5} />
      </a>
    )}

    <a
      href={ctaHref}
      class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-bleu-nuit group-hover:text-orange transition-colors"
    >
      Je veux un site comme celui-ci
      <Icon name="arrow-right" size={16} class="transition-transform duration-300 ease-out-soft group-hover:translate-x-1" strokeWidth={2} />
    </a>
  </div>
</article>
