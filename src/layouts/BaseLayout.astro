---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import siteConfig from '../data/siteConfig.json';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyCTA from '../components/layout/MobileStickyCTA.astro';
import { absoluteUrl, type PageSeo } from '../lib/seo';

interface Props {
  seo: PageSeo;
  bare?: boolean;
}

const { seo, bare = false } = Astro.props;
const canonicalUrl = absoluteUrl(seo.canonical);
const ogImageUrl = absoluteUrl(seo.ogImage);

// Schema.org enrichi : Organization + ProfessionalService + Service
// Pour SEO local La Réunion (974) : aire desservie multi-villes + service explicite + prix
const schemaOrg = {
  '@context': 'https://schema.org',
  '@graph': [
    // Organization : entité 9site4
    {
      '@type': 'Organization',
      '@id': `${siteConfig.siteUrl}/#organization`,
      name: siteConfig.siteName,
      url: siteConfig.siteUrl,
      email: siteConfig.contact.email,
      logo: {
        '@type': 'ImageObject',
        url: absoluteUrl('/og-image.png'),
        width: 1200,
        height: 630,
      },
      slogan: siteConfig.baseline,
      knowsLanguage: 'fr',
    },
    // WebSite : permet la box de recherche Google
    {
      '@type': 'WebSite',
      '@id': `${siteConfig.siteUrl}/#website`,
      url: siteConfig.siteUrl,
      name: siteConfig.siteName,
      description: siteConfig.baseline,
      inLanguage: 'fr-RE',
      publisher: { '@id': `${siteConfig.siteUrl}/#organization` },
    },
    // ProfessionalService : agence web locale
    {
      '@type': 'ProfessionalService',
      '@id': `${siteConfig.siteUrl}/#localbusiness`,
      name: siteConfig.siteName,
      description: siteConfig.baseline,
      url: siteConfig.siteUrl,
      email: siteConfig.contact.email,
      telephone: `+${siteConfig.contact.whatsapp}`,
      image: absoluteUrl(seo.ogImage),
      priceRange: '€€',
      knowsLanguage: 'fr',
      // Aire géographique desservie : Île de La Réunion + 7 grandes villes
      areaServed: [
        { '@type': 'AdministrativeArea', name: 'La Réunion' },
        { '@type': 'City', name: 'Saint-Denis', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
        { '@type': 'City', name: 'Saint-Pierre', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
        { '@type': 'City', name: 'Saint-Paul', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
        { '@type': 'City', name: 'Saint-Gilles-les-Bains', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
        { '@type': 'City', name: 'Le Tampon', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
        { '@type': 'City', name: 'Saint-Leu', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
        { '@type': 'City', name: 'Saint-André', containedInPlace: { '@type': 'AdministrativeArea', name: 'La Réunion' } },
      ],
      // Géolocalisation centrale Réunion (pour Google Maps / Local Pack)
      geo: {
        '@type': 'GeoCoordinates',
        latitude: -21.1151,
        longitude: 55.5364,
      },
      address: {
        '@type': 'PostalAddress',
        addressRegion: 'La Réunion',
        addressCountry: 'FR',
        postalCode: '974',
      },
      // Service principal avec prix
      makesOffer: {
        '@type': 'Offer',
        url: `${siteConfig.siteUrl}/tarifs`,
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: 97.4,
          priceCurrency: 'EUR',
          unitText: 'MON',
          description: '97,4 €/mois — Tout inclus (site, domaine, hébergement, maintenance)',
        },
        itemOffered: {
          '@type': 'Service',
          name: 'Création de site vitrine clé en main',
          description: 'Site web professionnel sur-mesure pour TPE et PME réunionnaises. Domaine, hébergement, maintenance et modifications inclus.',
          provider: { '@id': `${siteConfig.siteUrl}/#organization` },
          areaServed: { '@type': 'AdministrativeArea', name: 'La Réunion' },
          serviceType: 'Web design · Création de site internet',
        },
      },
      // Lien vers l'organisation parente
      parentOrganization: { '@id': `${siteConfig.siteUrl}/#organization` },
    },
    // WebPage : page courante
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: seo.title,
      description: seo.description,
      isPartOf: { '@id': `${siteConfig.siteUrl}/#website` },
      inLanguage: 'fr-RE',
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: ogImageUrl,
      },
    },
  ],
};
---

<!doctype html>
<html lang="fr-RE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FEFEFA" />

    <!-- Primary -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr-RE" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <meta name="geo.region" content="RE" />
    <meta name="geo.placename" content="La Réunion" />
    <meta name="geo.position" content="-21.1151;55.5364" />
    <meta name="ICBM" content="-21.1151, 55.5364" />
    {seo.noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={seo.ogImageAlt} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={seo.ogImageAlt} />

    <!-- View Transitions API (fade entre pages) -->
    <ClientRouter />

    <!-- Schema.org LocalBusiness -->
    {!seo.noindex && (
      <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
    )}

    <!-- Slot pour préchargements / hints page-spécifiques (preconnect, preload, etc.) -->
    <slot name="head" />

    <!-- Build marker (debug) — permet d'identifier la version déployée -->
    <meta name="build-id" content={`9site4-${new Date().toISOString().slice(0, 19)}-24templates-thumbnails`} />
  </head>
  <body class="flex flex-col min-h-dvh">
    {!bare && <Header />}
    <main class="flex-1">
      <slot />
    </main>
    {!bare && <Footer />}
    {!bare && <MobileStickyCTA />}

    <script>
      // Bootstrap des animations interactives (rejoué à chaque navigation View Transitions)
      const bootstrap = () => {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // 1. Reveal au scroll
        const reveal = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                reveal.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        document
          .querySelectorAll('.scroll-reveal:not(.is-visible)')
          .forEach((el) => reveal.observe(el));

        if (reduced) return;

        // 2. Count-up sur les chiffres marqués data-count
        const countObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              const target = parseFloat(el.dataset.count || '0');
              const decimals = parseInt(el.dataset.countDecimals || '0', 10);
              const suffix = el.dataset.countSuffix || '';
              const duration = 1100;
              const start = performance.now();

              const formatValue = (v: number) => {
                const fixed = v.toFixed(decimals);
                return decimals > 0 ? fixed.replace('.', ',') : fixed;
              };

              const tick = (now: number) => {
                const t = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - t, 3);
                el.textContent = formatValue(target * eased) + suffix;
                if (t < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
              countObserver.unobserve(el);
            }
          },
          { threshold: 0.5 }
        );
        document
          .querySelectorAll<HTMLElement>('[data-count]:not([data-counted])')
          .forEach((el) => {
            el.dataset.counted = 'true';
            countObserver.observe(el);
          });

        // 3. Tilt 3D sur les cards Réalisations
        const tiltCards = document.querySelectorAll<HTMLElement>('.tilt-card');
        const onMove = (e: MouseEvent, card: HTMLElement) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width;
          const y = (e.clientY - rect.top) / rect.height;
          const rotY = (x - 0.5) * 8;
          const rotX = (0.5 - y) * 8;
          card.style.setProperty('--tilt-x', `${rotX}deg`);
          card.style.setProperty('--tilt-y', `${rotY}deg`);
          card.style.setProperty('--tilt-ty', '-4px');
        };
        const onLeave = (card: HTMLElement) => {
          card.style.setProperty('--tilt-x', '0deg');
          card.style.setProperty('--tilt-y', '0deg');
          card.style.setProperty('--tilt-ty', '0px');
        };
        tiltCards.forEach((card) => {
          if ((card as any)._tiltBound) return;
          (card as any)._tiltBound = true;
          card.addEventListener('mousemove', (e) => onMove(e as MouseEvent, card));
          card.addEventListener('mouseleave', () => onLeave(card));
        });
      };

      // Boot au chargement initial
      bootstrap();
      // Re-boot après chaque navigation View Transitions
      document.addEventListener('astro:page-load', bootstrap);
    </script>

    <!-- Curseur custom emoji 🇷🇪 (drapeau de La Réunion) — desktop souris uniquement.
         Le caractère emoji n'étant pas supporté par cursor: url(), on superpose
         un span DOM qui suit la souris et rend l'emoji via la font emoji du système.
         Bootstrap appelé au load initial ET à chaque astro:page-load (sinon le
         span est perdu après navigation View Transitions). -->
    <script is:inline>
      (function () {
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

        var cursor = null;
        var x = 0, y = 0, raf = 0;
        var listenersAttached = false;

        var textSelector = 'input[type="text"], input[type="email"], input[type="tel"], input[type="number"], input[type="date"], input[type="time"], input[type="search"], input[type="url"], input[type="password"], textarea, [contenteditable="true"]';

        function setOpacity(v) { if (cursor) cursor.style.opacity = v; }

        function update() {
          // -4/-22 pour caler le coin haut-gauche de l'emoji 32px sur le pixel cliqué
          if (cursor) cursor.style.transform = 'translate(' + (x - 4) + 'px, ' + (y - 22) + 'px)';
          raf = 0;
        }

        function bootstrap() {
          // Recrée le span s'il a été perdu par une View Transition
          cursor = document.getElementById('emoji-cursor');
          if (!cursor) {
            cursor = document.createElement('span');
            cursor.id = 'emoji-cursor';
            cursor.textContent = '🇷🇪';
            cursor.setAttribute('aria-hidden', 'true');
            document.body.appendChild(cursor);
          }
          // Réapplique la classe sur body (peut avoir été perdue avec le swap body)
          document.body.classList.add('js-emoji-cursor');

          // Listeners attachés une seule fois (sur document, pas remplacé par les transitions)
          if (listenersAttached) return;
          listenersAttached = true;

          document.addEventListener('mousemove', function (e) {
            x = e.clientX;
            y = e.clientY;
            if (!raf) raf = requestAnimationFrame(update);
          }, { passive: true });

          document.addEventListener('mouseleave', function () { setOpacity('0'); });
          document.addEventListener('mouseenter', function () { setOpacity('1'); });

          document.addEventListener('mouseover', function (e) {
            var t = e.target;
            if (!(t instanceof Element)) return;
            setOpacity(t.closest(textSelector) ? '0' : '1');
          });
        }

        bootstrap();
        document.addEventListener('astro:page-load', bootstrap);
      })();
    </script>
  </body>
</html>
