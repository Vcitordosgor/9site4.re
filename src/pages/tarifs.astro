---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import Icon from '../components/ui/Icon.astro';
import Faq from '../components/sections/Faq.tsx';
import CTABand from '../components/sections/CTABand.astro';
import siteConfig from '../data/siteConfig.json';
import faq from '../data/faq.json';
import { inclusions } from '../lib/inclusions';
import { getSeo } from '../lib/seo';

// Liste résumée pour les cartes de prix (titres seulement, pas de paragraphe)
const cardItems = inclusions.map((i) => i.titre);
---

<BaseLayout seo={getSeo('tarifs')}>
  <!-- En-tête -->
  <section class="relative overflow-hidden px-6 pt-24 pb-12 md:pt-32 md:pb-16">
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[40rem] h-[40rem] halo-mix opacity-50"></div>
    </div>
    <div class="mx-auto max-w-3xl text-center">
      <p class="inline-flex items-center px-3 py-1.5 rounded-full bg-orange text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
        Tarifs
      </p>
      <h1 class="mt-4 text-4xl md:text-6xl font-sora font-bold text-bleu-nuit text-balance leading-tight">
        Une offre claire, tout est inclus.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-bleu-nuit/70 leading-relaxed">
        Pas d'option cachée, pas d'engagement de durée. Choisissez la formule qui vous convient.
      </p>
    </div>
  </section>

  <!-- 2 cartes de prix -->
  <section class="relative px-6 pb-20" aria-label="Formules tarifaires">
    <div class="mx-auto max-w-4xl">
      <div class="grid sm:grid-cols-2 gap-5">
        <!-- Mensuel -->
        <article class="scroll-reveal flex flex-col bg-blanc-casse rounded-2xl ring-2 ring-bleu shadow-card p-7 md:p-8 transition-all duration-300 ease-out-soft hover:-translate-y-0.5 hover:shadow-card-hover">
          <p class="text-sm font-semibold text-bleu-nuit/60 uppercase tracking-wide">Mensuel</p>
          <p class="mt-3 flex items-baseline gap-1">
            <span class="font-sora font-bold text-5xl text-bleu-nuit" data-count="97.4" data-count-decimals="1" data-count-suffix="€">{siteConfig.pricing.monthly}</span>
            <span class="text-base text-bleu-nuit/60">/mois</span>
          </p>
          <p class="mt-3 text-sm text-bleu-nuit/65">Sans engagement de durée.</p>
          <ul class="mt-7 space-y-3 flex-1">
            {cardItems.map((label) => (
              <li class="flex items-start gap-3 text-sm text-bleu-nuit/85">
                <Icon name="shield-check" size={18} class="text-bleu-nuit shrink-0 mt-0.5" strokeWidth={2} />
                <span>{label}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <Button variant="primary" size="md" href="/contact" fullWidth>
              Demander mon site
              <Icon name="arrow-right" size={18} strokeWidth={2} />
            </Button>
          </div>
        </article>

        <!-- Annuel -->
        <article class="scroll-reveal relative flex flex-col bg-bleu-nuit text-blanc-casse rounded-2xl shadow-card-hover p-7 md:p-8 transition-all duration-300 ease-out-soft hover:-translate-y-0.5">
          <div class="flex items-center justify-between">
            <p class="text-sm font-semibold text-blanc-casse/70 uppercase tracking-wide">Annuel</p>
            <Badge variant="primary" size="sm">≈ 2 mois offerts</Badge>
          </div>
          <p class="mt-3 flex items-baseline gap-1">
            <span class="font-sora font-bold text-5xl" data-count="974" data-count-suffix="€">{siteConfig.pricing.yearly}</span>
            <span class="text-base text-blanc-casse/60">/an</span>
          </p>
          <p class="mt-3 text-sm text-blanc-casse/70">Plus économique sur l'année.</p>
          <ul class="mt-7 space-y-3 flex-1">
            {cardItems.map((label) => (
              <li class="flex items-start gap-3 text-sm text-blanc-casse/85">
                <Icon name="shield-check" size={18} class="text-orange shrink-0 mt-0.5" strokeWidth={2} />
                <span>{label}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <Button variant="primary" size="md" href="/contact" fullWidth>
              Demander mon site
              <Icon name="arrow-right" size={18} strokeWidth={2} />
            </Button>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Section "Ce qui est inclus" : reprise détaillée des 8 items -->
  <section class="relative overflow-hidden px-6 py-20 md:py-28 bg-bleu/[0.06]" aria-labelledby="inclus-titre">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute top-1/4 -left-24 w-[28rem] h-[28rem] halo-bleu opacity-50"></div>
      <div class="absolute bottom-0 -right-24 w-[24rem] h-[24rem] halo-orange opacity-40"></div>
    </div>
    <div class="relative mx-auto max-w-content">
      <div class="text-center max-w-2xl mx-auto">
        <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-bleu text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
          Ce qui est inclus
        </p>
        <h2 id="inclus-titre" class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
          Tout ce dont vous avez besoin
        </h2>
      </div>
      <ul class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {inclusions.map((item, i) => {
          const isBleu = i % 2 === 0;
          return (
            <li
              class="scroll-reveal group bg-blanc-casse rounded-2xl ring-1 ring-bleu-nuit/10 p-6 transition-all duration-300 ease-out-soft hover:-translate-y-0.5 hover:shadow-card-hover hover:ring-bleu-nuit/15"
              style={`transition-delay: ${(i % 4) * 60}ms`}
            >
              <span class:list={[
                'flex w-12 h-12 rounded-xl items-center justify-center transition-colors duration-300',
                isBleu
                  ? 'bg-bleu/25 text-bleu-nuit group-hover:bg-bleu-nuit group-hover:text-blanc-casse'
                  : 'bg-orange/15 text-orange group-hover:bg-orange group-hover:text-bleu-nuit',
              ]}>
                <Icon name={item.icon} size={22} strokeWidth={1.75} />
              </span>
              <h3 class="mt-5 font-sora font-semibold text-lg text-bleu-nuit leading-snug">
                {item.titre}
              </h3>
              <p class="mt-2 text-sm text-bleu-nuit/65 leading-relaxed">{item.texte}</p>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Ce qui nous différencie -->
  <section class="relative px-6 py-20 md:py-28" aria-labelledby="differencie-titre">
    <div class="mx-auto max-w-3xl text-center">
      <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-orange text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
        Ce qui nous différencie
      </p>
      <h2 id="differencie-titre" class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
        Une seule équipe pour tout votre site
      </h2>
      <p class="scroll-reveal mt-6 text-lg text-bleu-nuit/70 leading-relaxed">
        Votre site, votre nom de domaine, votre hébergement, votre maintenance et
        vos modifications simples sont inclus. Vous avez un seul interlocuteur,
        un site adapté à votre métier, et un module de contact pensé pour
        recevoir les bonnes demandes : réservation, devis, rendez-vous ou
        intervention.
      </p>
    </div>
  </section>

  <!-- FAQ accordéon -->
  <section class="relative overflow-hidden px-6 py-20 md:py-28 bg-bleu/[0.06]" aria-labelledby="faq-titre">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-24 right-0 w-[28rem] h-[28rem] halo-bleu opacity-40"></div>
    </div>
    <div class="relative mx-auto max-w-3xl">
      <div class="text-center mb-12">
        <p class="scroll-reveal inline-flex items-center px-3 py-1.5 rounded-full bg-bleu text-bleu-nuit text-xs font-semibold uppercase tracking-wide">
          FAQ
        </p>
        <h2 id="faq-titre" class="scroll-reveal mt-4 font-sora font-bold text-3xl md:text-5xl text-bleu-nuit text-balance leading-tight">
          Questions fréquentes
        </h2>
      </div>
      <Faq client:load items={faq} />
    </div>
  </section>

  <CTABand />
</BaseLayout>
