---
import '@fontsource/newsreader/300.css';
import '@fontsource/newsreader/400.css';
import '@fontsource/newsreader/500.css';
import '@fontsource/newsreader/300-italic.css';
import '@fontsource/newsreader/400-italic.css';
import '@fontsource/plus-jakarta-sans/400.css';
import '@fontsource/plus-jakarta-sans/500.css';
import '@fontsource/plus-jakarta-sans/600.css';
import '@fontsource/plus-jakarta-sans/700.css';
import '@fontsource/reenie-beanie/400.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';
import monaData from '../../data/templates/mona.json';

import MonaHeader from '../../components/templates/dieteticienne/MonaHeader.astro';
import HeroTable from '../../components/templates/dieteticienne/HeroTable.astro';
import Presentation from '../../components/templates/dieteticienne/Presentation.astro';
import Piliers from '../../components/templates/dieteticienne/Piliers.astro';
import Publics from '../../components/templates/dieteticienne/Publics.astro';
import Etapes from '../../components/templates/dieteticienne/Etapes.astro';
import Programmes from '../../components/templates/dieteticienne/Programmes.astro';
import Recettes from '../../components/templates/dieteticienne/Recettes.astro';
import Avis from '../../components/templates/dieteticienne/Avis.astro';
import RendezVous from '../../components/templates/dieteticienne/RendezVous.astro';
import Trouver from '../../components/templates/dieteticienne/Trouver.astro';
import CTAFinal from '../../components/templates/dieteticienne/CTAFinal.astro';
import MonaFooter from '../../components/templates/dieteticienne/MonaFooter.astro';
---

<BaseLayout seo={getSeo('templateDieteticienne')} bare={true}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link
      rel="preload"
      as="image"
      href={monaData.info.photoHero}
      fetchpriority="high"
    />
  </Fragment>

  <MonaHeader />

  <main id="top" class="bg-mona-creme text-mona-cacao font-jakarta">
    <HeroTable />
    <Presentation />
    <Piliers />
    <Publics />
    <Etapes />
    <Programmes />
    <Recettes />
    <Avis />
    <RendezVous />
    <Trouver />
    <CTAFinal />
  </main>

  <MonaFooter />

  <!-- Sticky CTA mobile : pill terracotta arrondi (vs rectangle encre osteo, bordeaux danse) -->
  <a
    id="mona-sticky-cta"
    href="#rendez-vous"
    data-visible="false"
    class="md:hidden fixed bottom-5 inset-x-5 z-40 inline-flex items-center justify-center h-13 bg-mona-terracotta text-mona-creme font-jakarta text-sm font-semibold rounded-full transition-all duration-300 data-[visible=false]:opacity-0 data-[visible=false]:translate-y-4 data-[visible=false]:pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:translate-y-0"
    style="height: 52px; box-shadow: 0 12px 28px rgba(210,125,84,0.40);"
  >
    Prendre rendez-vous →
  </a>

  <script>
    const sticky = document.getElementById('mona-sticky-cta');
    const rdv = document.getElementById('rendez-vous');
    if (sticky && rdv) {
      const update = () => {
        const rect = rdv.getBoundingClientRect();
        const inRdv = rect.top < window.innerHeight && rect.bottom > 80;
        const scrolledPastHero = window.scrollY > 600;
        sticky.dataset.visible = String(scrolledPastHero && !inRdv);
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
    }
  </script>
</BaseLayout>
