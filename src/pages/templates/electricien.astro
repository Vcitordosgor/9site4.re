---
import '@fontsource/syne/latin-400.css';
import '@fontsource/syne/latin-500.css';
import '@fontsource/syne/latin-600.css';
import '@fontsource/syne/latin-700.css';
import '@fontsource/syne/latin-800.css';
import '@fontsource/space-grotesk/latin-300.css';
import '@fontsource/space-grotesk/latin-400.css';
import '@fontsource/space-grotesk/latin-500.css';
import '@fontsource/space-grotesk/latin-600.css';
import '@fontsource/space-grotesk/latin-700.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';
import voltaData from '../../data/templates/volta.json';

import VoltaHeader from '../../components/templates/electricien/VoltaHeader.astro';
import HeroVolta from '../../components/templates/electricien/HeroVolta.astro';
import Services from '../../components/templates/electricien/Services.astro';
import Urgence from '../../components/templates/electricien/Urgence.astro';
import Process from '../../components/templates/electricien/Process.astro';
import Galerie from '../../components/templates/electricien/Galerie.astro';
import Avis from '../../components/templates/electricien/Avis.astro';
import Devis from '../../components/templates/electricien/Devis.astro';
import Trouver from '../../components/templates/electricien/Trouver.astro';
import CTAFinal from '../../components/templates/electricien/CTAFinal.astro';
import VoltaFooter from '../../components/templates/electricien/VoltaFooter.astro';
---

<BaseLayout seo={getSeo('templateElectricien')} bare={true}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link
      rel="preload"
      as="image"
      href={voltaData.info.photoHero}
      fetchpriority="high"
    />
  </Fragment>

  <VoltaHeader />

  <main id="top" class="bg-volta-noir text-volta-fumee font-space-grotesk">
    <HeroVolta />
    <Services />
    <Urgence />
    <Process />
    <Galerie />
    <Avis />
    <Devis />
    <Trouver />
    <CTAFinal />
  </main>

  <VoltaFooter />

  <!-- Sticky bottom CTA mobile : "Devis gratuit" cyan -->
  <a
    id="volta-sticky-cta"
    href="#devis"
    data-visible="false"
    class="md:hidden fixed bottom-4 inset-x-4 z-40 inline-flex items-center justify-center h-14 px-6 text-sm font-space-grotesk font-semibold uppercase tracking-[0.18em] rounded-sm bg-volta-cyan text-volta-noir transition-all duration-300 ease-out data-[visible=false]:opacity-0 data-[visible=false]:translate-y-4 data-[visible=false]:pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:translate-y-0"
    style="box-shadow: 0 12px 32px rgb(6 212 245 / 0.35);"
  >
    Demander un devis
  </a>

  <script>
    const sticky = document.getElementById('volta-sticky-cta');
    const devis = document.getElementById('devis');
    if (sticky && devis) {
      const updateSticky = () => {
        const rect = devis.getBoundingClientRect();
        const inDevis = rect.top < window.innerHeight && rect.bottom > 80;
        const scrolledPastHero = window.scrollY > 480;
        sticky.dataset.visible = String(scrolledPastHero && !inDevis);
      };
      updateSticky();
      window.addEventListener('scroll', updateSticky, { passive: true });
      window.addEventListener('resize', updateSticky, { passive: true });
    }
  </script>

  <style>
    .scroll-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .scroll-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.scroll-reveal').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
