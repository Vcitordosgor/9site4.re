---
import '@fontsource/yeseva-one/latin-400.css';
import '@fontsource/italianno/latin-400.css';
import '@fontsource/karla/latin-400.css';
import '@fontsource/karla/latin-500.css';
import '@fontsource/karla/latin-600.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';
import vanilleData from '../../data/templates/vanille.json';

import VanilleHeader from '../../components/templates/patisserie/VanilleHeader.astro';
import HeroVanille from '../../components/templates/patisserie/HeroVanille.astro';
import Specialites from '../../components/templates/patisserie/Specialites.astro';
import Saisons from '../../components/templates/patisserie/Saisons.astro';
import Patissiere from '../../components/templates/patisserie/Patissiere.astro';
import Commandes from '../../components/templates/patisserie/Commandes.astro';
import Avis from '../../components/templates/patisserie/Avis.astro';
import Contact from '../../components/templates/patisserie/Contact.astro';
import VanilleFooter from '../../components/templates/patisserie/VanilleFooter.astro';
---

<BaseLayout seo={getSeo('templatePatisserie')} bare={true}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="preload" as="image" href={vanilleData.info.photoHero} fetchpriority="high" />
  </Fragment>

  <VanilleHeader />

  <main class="bg-vanille-creme text-vanille-gousse font-karla">
    <HeroVanille />
    <Specialites />
    <Saisons />
    <Patissiere />
    <Commandes />
    <Avis />
    <Contact />
  </main>

  <VanilleFooter />
</BaseLayout>
