---
import '@fontsource/bebas-neue/400.css';
import '@fontsource/archivo/400.css';
import '@fontsource/archivo/500.css';
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/archivo/800.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';
import bernardData from '../../data/templates/bernard.json';

import UrgenceBar from '../../components/templates/plomberie/UrgenceBar.astro';
import PlomberieHeader from '../../components/templates/plomberie/PlomberieHeader.astro';
import HeroPoster from '../../components/templates/plomberie/HeroPoster.astro';
import Services from '../../components/templates/plomberie/Services.astro';
import Tarifs from '../../components/templates/plomberie/Tarifs.astro';
import Intervention from '../../components/templates/plomberie/Intervention.astro';
import Garanties from '../../components/templates/plomberie/Garanties.astro';
import Zone from '../../components/templates/plomberie/Zone.astro';
import Realisations from '../../components/templates/plomberie/Realisations.astro';
import APropos from '../../components/templates/plomberie/APropos.astro';
import Avis from '../../components/templates/plomberie/Avis.astro';
import CTAFinal from '../../components/templates/plomberie/CTAFinal.astro';
import PlomberieFooter from '../../components/templates/plomberie/PlomberieFooter.astro';

const phoneHref = bernardData.info.telephoneHref;
---

<BaseLayout seo={getSeo('templatePlomberie')} bare={true}>

  <!-- UrgenceBar : bandeau noir collé tout en haut, AVANT le header -->
  <UrgenceBar />

  <!-- Header sticky (commence sous la UrgenceBar grâce à top-0 sticky) -->
  <PlomberieHeader />

  <main id="top" class="bg-bp-ciment text-bp-anthracite font-archivo">
    <HeroPoster />
    <Services />
    <Tarifs />
    <Intervention />
    <Garanties />
    <Zone />
    <Realisations />
    <APropos />
    <Avis />
    <CTAFinal />
  </main>

  <PlomberieFooter />

  <!-- Sticky bottom mobile : bouton appel direct (action #1 pour artisan) -->
  <a
    id="bp-sticky-call"
    href={`tel:${phoneHref}`}
    data-visible="false"
    aria-label="Appeler Bernard maintenant"
    class="md:hidden fixed bottom-4 inset-x-4 z-40 inline-flex items-center justify-center gap-2 h-14 px-6 text-sm font-archivo font-bold uppercase tracking-[0.22em] bg-bp-jaune text-bp-anthracite border-2 border-bp-anthracite transition-all duration-300 ease-out data-[visible=false]:opacity-0 data-[visible=false]:translate-y-4 data-[visible=false]:pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:translate-y-0"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    <span>Appeler Bernard</span>
  </a>

  <script>
    /* Sticky CTA mobile : visible après scroll du hero */
    const sticky = document.getElementById('bp-sticky-call');
    if (sticky) {
      const updateSticky = () => {
        const scrolledPastHero = window.scrollY > 480;
        sticky.dataset.visible = String(scrolledPastHero);
      };
      updateSticky();
      window.addEventListener('scroll', updateSticky, { passive: true });
    }
  </script>
</BaseLayout>
