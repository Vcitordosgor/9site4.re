---
import '@fontsource/hanken-grotesk/latin-300.css';
import '@fontsource/hanken-grotesk/latin-400.css';
import '@fontsource/hanken-grotesk/latin-500.css';
import '@fontsource/hanken-grotesk/latin-600.css';
import '@fontsource/hanken-grotesk/latin-700.css';
import '@fontsource/instrument-serif/latin-400.css';
import '@fontsource/instrument-serif/latin-400-italic.css';
import '@fontsource/space-mono/latin-400.css';
import '@fontsource/space-mono/latin-700.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';
import lucasData from '../../data/templates/lucas.json';

import LucasHeader from '../../components/templates/consultant/LucasHeader.astro';
import HeroPortfolio from '../../components/templates/consultant/HeroPortfolio.astro';
import Pitch from '../../components/templates/consultant/Pitch.astro';
import Missions from '../../components/templates/consultant/Missions.astro';
import Competences from '../../components/templates/consultant/Competences.astro';
import Tarifs from '../../components/templates/consultant/Tarifs.astro';
import Principes from '../../components/templates/consultant/Principes.astro';
import RendezVous from '../../components/templates/consultant/RendezVous.astro';
import CV from '../../components/templates/consultant/CV.astro';
import CTAFinal from '../../components/templates/consultant/CTAFinal.astro';
import LucasFooter from '../../components/templates/consultant/LucasFooter.astro';
---

<BaseLayout seo={getSeo('templateConsultant')} bare={true}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
  </Fragment>

  <LucasHeader />

  <main id="top" class="bg-lucas-noir text-lucas-blanc font-hanken">
    <HeroPortfolio />
    <Pitch />
    <Missions />
    <Competences />
    <Tarifs />
    <Principes />
    <RendezVous />
    <CV />
    <CTAFinal />
  </main>

  <LucasFooter />

  <!-- Sticky CTA mobile : rectangle plein vert électrique terminal -->
  <a
    id="lucas-sticky-cta"
    href="#rendez-vous"
    data-visible="false"
    class="md:hidden fixed bottom-5 inset-x-5 z-40 inline-flex items-center justify-center gap-2 h-12 bg-lucas-vert text-lucas-noir font-hanken font-semibold text-sm transition-all duration-300 data-[visible=false]:opacity-0 data-[visible=false]:translate-y-4 data-[visible=false]:pointer-events-none data-[visible=true]:opacity-100 data-[visible=true]:translate-y-0"
    style="box-shadow: 0 12px 28px rgba(0,210,106,0.30);"
  >
    <span class="font-space-mono">▶</span> Prendre rendez-vous
  </a>

  <script>
    const sticky = document.getElementById('lucas-sticky-cta');
    const rdv = document.getElementById('rendez-vous');
    if (sticky && rdv) {
      const update = () => {
        const rect = rdv.getBoundingClientRect();
        const inSection = rect.top < window.innerHeight && rect.bottom > 80;
        const scrolledPastHero = window.scrollY > 600;
        sticky.dataset.visible = String(scrolledPastHero && !inSection);
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
    }
  </script>
</BaseLayout>
