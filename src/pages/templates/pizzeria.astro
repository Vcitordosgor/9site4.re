---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';
import data from '../../data/templates/pizzeria.json';

import PizzeriaHeader from '../../components/templates/pizzeria/PizzeriaHeader.astro';
import PizzeriaFooter from '../../components/templates/pizzeria/PizzeriaFooter.astro';
import PizzaAnimation from '../../components/templates/pizzeria/PizzaAnimation.astro';
import PizzeriaShop from '../../components/templates/pizzeria/PizzeriaShop.tsx';

const waUrl = `https://wa.me/${data.info.whatsapp}?text=${encodeURIComponent('Bonjour, je voudrais commander une pizza chez ' + data.info.nom + '.')}`;
---

<BaseLayout seo={getSeo('templatePizzeria')} bare={true}>
  <PizzeriaHeader />

  <main id="top" class="bg-pizza-creme text-pizza-charbon font-inter">

    <!-- ============== HERO ============== -->
    <section class="relative overflow-hidden bg-pizza-charbon text-white px-6 pt-12 pb-20 md:pt-20 md:pb-32">
      <!-- Halo rouge gauche derrière le texte -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-32 -left-32 w-[44rem] h-[44rem] rounded-full"
             style="background: radial-gradient(50% 50% at 50% 50%, rgb(200 16 46 / 0.20) 0%, transparent 70%);">
        </div>
        <div class="absolute -bottom-32 -right-32 w-[44rem] h-[44rem] rounded-full"
             style="background: radial-gradient(50% 50% at 50% 50%, rgb(184 134 11 / 0.15) 0%, transparent 70%);">
        </div>
      </div>

      <div class="relative mx-auto max-w-content grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
        <!-- Pizza : en haut sur mobile, à droite sur desktop -->
        <div class="hero-pizza order-1 lg:order-2 lg:col-span-5 w-[300px] md:w-[400px] lg:w-full mx-auto">
          <PizzaAnimation />
        </div>

        <!-- Texte -->
        <div class="hero-text order-2 lg:order-1 lg:col-span-7 text-center lg:text-left">
          <p class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-pizza-tomate text-white text-xs font-semibold uppercase tracking-wide">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
            Saint-Paul · La Réunion
          </p>
          <h1 class="mt-6 font-playfair font-bold leading-[1.05]" style="font-size: clamp(48px, 7vw, 88px);">
            <span class="block text-white">{data.info.nom}</span>
            <span class="block text-pizza-tomate italic font-semibold mt-1" style="font-size: clamp(28px, 4.5vw, 56px);">
              {data.info.tagline}
            </span>
          </h1>
          <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0">
            Pâte fermentée 48h, produits frais, four à bois.
            Commande en ligne, prête en 25 min.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4 lg:justify-start justify-center">
            <a href="#menu" class="inline-flex items-center justify-center h-14 px-8 text-lg font-semibold rounded-full bg-pizza-tomate text-white shadow-card hover:bg-[#A50D26] hover:shadow-card-hover transition-all">
              Voir le menu
            </a>
            <a href="#commander" class="inline-flex items-center justify-center h-14 px-8 text-lg font-semibold rounded-full bg-white text-pizza-charbon shadow-card hover:bg-pizza-creme hover:shadow-card-hover transition-all">
              Commander
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============== À PROPOS ============== -->
    <section class="relative overflow-hidden px-6 py-20 md:py-28 bg-pizza-creme">
      <!-- Texture de lin très subtile (lignes diagonales fines) -->
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true"
           style="background-image: repeating-linear-gradient(45deg, #1A1A1A 0, #1A1A1A 1px, transparent 1px, transparent 8px), repeating-linear-gradient(-45deg, #1A1A1A 0, #1A1A1A 1px, transparent 1px, transparent 12px);">
      </div>

      <div class="relative mx-auto max-w-content">
        <div class="text-center max-w-2xl mx-auto">
          <p class="inline-flex items-center px-3 py-1.5 rounded-full bg-pizza-basilic text-white text-xs font-semibold uppercase tracking-wide">
            Notre histoire
          </p>
          <h2 class="scroll-reveal mt-4 font-playfair font-bold text-4xl md:text-6xl text-pizza-charbon leading-tight">
            Une pizzeria familiale, depuis {data.info.annee}
          </h2>
          <p class="scroll-reveal mt-6 text-lg text-pizza-charbon/80 leading-relaxed max-w-2xl mx-auto">
            Lé O, c'est l'histoire d'une famille passée par Naples, tombée amoureuse de l'île.
            On y fait la pizza comme on l'a apprise là-bas — pâte fermentée 48 heures, four à
            bois d'eucalyptus, et une touche péi qui change tout.
          </p>
        </div>

        <ul class="mt-14 grid sm:grid-cols-3 gap-5 max-w-5xl mx-auto">
          {data.engagements.map((e, i) => {
            const icons = [
              // Timer (Pâte 48h)
              '<circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 2.5"/><path d="M9 2h6"/><path d="M12 5v2"/>',
              // Flame (Four à bois)
              '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 17a7 7 0 0 0 4-4c1-2 1.5-3 1.5-4.5A4.5 4.5 0 0 0 12 4a4 4 0 0 0-4 4c0 .67.27 1.51.5 2 .5 1 1 2 1 3a2 2 0 0 1-2 2c-.6 0-1.5-.5-1-1.5z"/>',
              // Leaf (Produits locaux)
              '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
            ];
            return (
              <li class="scroll-reveal relative bg-white rounded-2xl shadow-card p-7 pl-9 border-l-4 border-pizza-tomate transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover" style={`transition-delay: ${i * 80}ms`}>
                <span class="flex w-12 h-12 rounded-xl bg-pizza-tomate/10 text-pizza-tomate items-center justify-center">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[i]} />
                </span>
                <h3 class="mt-5 font-playfair font-bold text-xl text-pizza-tomate">{e.titre}</h3>
                <p class="mt-2 text-sm text-pizza-charbon/85 leading-relaxed">{e.texte}</p>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- ============== MENU + COMMANDER (1 island Preact) ============== -->
    <PizzeriaShop
      client:load
      info={{ nom: data.info.nom, whatsapp: data.info.whatsapp }}
      menu={data.menu}
      items={data.items}
      zones={data.zones}
      horairesCommande={data.horairesCommande}
    />

    <!-- ============== INFOS PRATIQUES ============== -->
    <section id="contact" class="relative px-6 py-20 md:py-28 bg-pizza-creme">
      <div class="mx-auto max-w-content">
        <div class="text-center max-w-2xl mx-auto">
          <p class="inline-flex items-center px-3 py-1.5 rounded-full bg-pizza-bois text-pizza-charbon text-xs font-semibold uppercase tracking-wide">
            Nous trouver
          </p>
          <h2 class="mt-4 font-playfair font-bold text-4xl md:text-6xl text-pizza-charbon leading-tight">
            Infos pratiques
          </h2>
        </div>

        <div class="mt-12 grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-2xl ring-1 ring-pizza-charbon/10 p-7 md:p-8">
            <h3 class="font-playfair font-bold text-2xl text-pizza-tomate">Adresse & contact</h3>
            <ul class="mt-5 space-y-3 text-pizza-charbon">
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-pizza-tomate shrink-0"></span>
                <span>{data.info.adresse}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-pizza-tomate shrink-0"></span>
                <a href={`tel:${data.info.telephoneHref}`} class="hover:text-pizza-tomate transition-colors">{data.info.telephone}</a>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-pizza-tomate shrink-0"></span>
                <a href={`mailto:${data.info.email}`} class="hover:text-pizza-tomate transition-colors break-all">{data.info.email}</a>
              </li>
            </ul>

            <h3 class="mt-8 font-playfair font-bold text-2xl text-pizza-tomate">Horaires</h3>
            <ul class="mt-5 space-y-2 text-pizza-charbon">
              {data.info.horaires.map((h) => (
                <li class="flex items-baseline gap-3">
                  <span class="font-semibold min-w-[10rem]">{h.jour}</span>
                  <span class={h.ouvert ? '' : 'text-pizza-charbon/70 italic'}>{h.label}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-white rounded-2xl ring-1 ring-pizza-charbon/10 overflow-hidden flex flex-col items-center justify-center min-h-[20rem] p-8 text-center"
               style="background-image: linear-gradient(135deg, rgb(45 106 79 / 0.10) 0%, rgb(184 134 11 / 0.08) 100%);">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-pizza-charbon/40" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <p class="mt-4 font-playfair font-semibold text-lg text-pizza-charbon">
              Carte — Saint-Paul, La Réunion
            </p>
            <p class="mt-2 text-sm text-pizza-charbon/65">
              {data.info.adresse}
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <PizzeriaFooter />
</BaseLayout>

<style is:global>
  /* Animation feedback "+1 ajouté" */
  @keyframes feedback {
    0% { opacity: 0; transform: translateX(-50%) translateY(10px) scale(0.9); }
    15%, 85% { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
    100% { opacity: 0; transform: translateX(-50%) translateY(-10px) scale(0.95); }
  }
  .animate-feedback {
    animation: feedback 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* Pulse du compteur panier au clic "+" */
  @keyframes cart-pulse {
    0%, 100% { transform: scale(1); }
    30% { transform: scale(1.3); }
    60% { transform: scale(0.95); }
  }
  .animate-cart-pulse {
    animation: cart-pulse 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Animations d'entrée hero — texte de gauche, pizza de droite, décalées */
  @keyframes hero-text-in {
    from { opacity: 0; transform: translateX(-32px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes hero-pizza-in {
    from { opacity: 0; transform: translateX(32px) scale(0.92); }
    to { opacity: 1; transform: translateX(0) scale(1); }
  }
  .hero-text {
    animation: hero-text-in 800ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: 100ms;
  }
  .hero-pizza {
    animation: hero-pizza-in 800ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: 300ms;
  }

  /* Onglets menu : fade in au switch */
  @keyframes tab-fade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .menu-tab-content {
    animation: tab-fade 250ms ease-out;
  }

  /* Masquer la scrollbar des onglets */
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }

  @media (prefers-reduced-motion: reduce) {
    .animate-feedback, .animate-cart-pulse, .hero-text, .hero-pizza, .menu-tab-content {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
