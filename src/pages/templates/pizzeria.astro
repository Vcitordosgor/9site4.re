---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/600-italic.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';

import PizzeriaHeader from '../../components/templates/pizzeria/PizzeriaHeader.astro';
import PizzeriaFooter from '../../components/templates/pizzeria/PizzeriaFooter.astro';
import HeroImmersive from '../../components/templates/pizzeria/HeroImmersive.astro';
import StatBanner from '../../components/templates/pizzeria/StatBanner.astro';
---

<BaseLayout seo={getSeo('templatePizzeria')} bare={true}>
  <PizzeriaHeader />

  <main id="top" class="bg-pizza-creme text-pizza-charbon font-inter">
    <HeroImmersive />
    <StatBanner />

    <!-- Sections suivantes : à venir dans les commits 3-5 -->
    <section id="manifeste" class="py-32 px-6 text-center text-pizza-charbon/50">
      <p class="italic">— Section Manifeste à venir —</p>
    </section>
    <section id="carte" class="py-32 px-6 text-center text-pizza-charbon/50 bg-pizza-charbon/[0.03]">
      <p class="italic">— Section Carte à venir —</p>
    </section>
    <section id="commander" class="py-32 px-6 text-center text-pizza-charbon/50">
      <p class="italic">— Section Commander à venir —</p>
    </section>
    <section id="atelier" class="py-32 px-6 text-center text-pizza-charbon/50 bg-pizza-charbon/[0.03]">
      <p class="italic">— Section Atelier à venir —</p>
    </section>
    <section id="avis" class="py-32 px-6 text-center text-pizza-charbon/50">
      <p class="italic">— Section Avis à venir —</p>
    </section>
    <section id="contact" class="py-32 px-6 text-center text-pizza-charbon/50 bg-pizza-charbon/[0.03]">
      <p class="italic">— Section Trouver le restaurant à venir —</p>
    </section>
  </main>

  <PizzeriaFooter />
</BaseLayout>
