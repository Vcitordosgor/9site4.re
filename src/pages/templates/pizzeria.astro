---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/600-italic.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';

import PizzeriaHeader from '../../components/templates/pizzeria/PizzeriaHeader.astro';
import PizzeriaFooter from '../../components/templates/pizzeria/PizzeriaFooter.astro';
import PizzeriaHeader from '../../components/templates/pizzeria/PizzeriaHeader.astro';
import PizzeriaFooter from '../../components/templates/pizzeria/PizzeriaFooter.astro';
import HeroImmersive from '../../components/templates/pizzeria/HeroImmersive.astro';
import StatBanner from '../../components/templates/pizzeria/StatBanner.astro';
import Manifesto from '../../components/templates/pizzeria/Manifesto.astro';
import Gallery from '../../components/templates/pizzeria/Gallery.astro';
import Testimonials from '../../components/templates/pizzeria/Testimonials.astro';
import PizzeriaShop from '../../components/templates/pizzeria/PizzeriaShop.tsx';
import data from '../../data/templates/pizzeria.json';
---

<BaseLayout seo={getSeo('templatePizzeria')} bare={true}>
  <PizzeriaHeader />

  <main id="top" class="bg-pizza-creme text-pizza-charbon font-inter">
    <HeroImmersive />
    <StatBanner />
    <Manifesto />

    <!-- Carte + Commander (1 island Preact qui partage le panier) -->
    <PizzeriaShop
      client:load
      info={{ nom: data.info.nom, whatsapp: data.info.whatsapp }}
      menu={data.menu}
      items={data.items}
      zones={data.zones}
      horairesCommande={data.horairesCommande}
    />

    <Gallery />
    <Testimonials />

    <!-- Trouver le restaurant : commit 5 -->
    <section id="contact" class="py-32 px-6 text-center text-pizza-charbon/50 bg-pizza-charbon/[0.03]">
      <p class="italic">— Section Trouver à venir (commit 5) —</p>
    </section>
  </main>

  <PizzeriaFooter />
</BaseLayout>
