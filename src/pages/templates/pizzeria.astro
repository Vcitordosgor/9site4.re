---
import '@fontsource/playfair-display/latin-400.css';
import '@fontsource/playfair-display/latin-600.css';
import '@fontsource/playfair-display/latin-700.css';
import '@fontsource/playfair-display/latin-400-italic.css';
import '@fontsource/playfair-display/latin-600-italic.css';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeo } from '../../lib/seo';

import PizzeriaHeader from '../../components/templates/pizzeria/PizzeriaHeader.astro';
import PizzeriaFooter from '../../components/templates/pizzeria/PizzeriaFooter.astro';
import PizzeriaHeader from '../../components/templates/pizzeria/PizzeriaHeader.astro';
import PizzeriaFooter from '../../components/templates/pizzeria/PizzeriaFooter.astro';
import HeroImmersive from '../../components/templates/pizzeria/HeroImmersive.astro';
import StatBanner from '../../components/templates/pizzeria/StatBanner.astro';
import Manifesto from '../../components/templates/pizzeria/Manifesto.astro';
import Testimonials from '../../components/templates/pizzeria/Testimonials.astro';
import FindUs from '../../components/templates/pizzeria/FindUs.astro';
import PizzeriaShop from '../../components/templates/pizzeria/PizzeriaShop.tsx';
import data from '../../data/templates/pizzeria.json';
---

<BaseLayout seo={getSeo('templatePizzeria')} bare={true}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link
      rel="preload"
      as="image"
      href="https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?w=1280&q=80&fm=webp"
      imagesrcset="https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?w=640&q=75&fm=webp 640w, https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?w=1024&q=78&fm=webp 1024w, https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?w=1600&q=80&fm=webp 1600w"
      imagesizes="100vw"
      fetchpriority="high"
    />
  </Fragment>

  <PizzeriaHeader />

  <main id="top" class="bg-pizza-creme text-pizza-charbon font-inter">
    <HeroImmersive />
    <StatBanner />
    <Manifesto />

    <!-- Carte + Commander (1 island Preact qui partage le panier) -->
    <PizzeriaShop
      client:load
      info={{ nom: data.info.nom, whatsapp: data.info.whatsapp }}
      menu={data.menu}
      items={data.items}
      zones={data.zones}
      horairesCommande={data.horairesCommande}
    />

    <Testimonials />
    <FindUs />
  </main>

  <PizzeriaFooter />
</BaseLayout>
