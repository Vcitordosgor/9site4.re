---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/ui/Icon.astro';
import siteConfig from '../data/siteConfig.json';
import { getSeo } from '../lib/seo';

/**
 * Mentions légales — page provisoire (brief §10bis).
 * - bandeau d'avertissement visible
 * - 7 sections avec [À compléter] explicite
 * - noindex tant que la page reste provisoire (BaseLayout prop)
 * - exclue du sitemap et de robots.txt
 */

const sections = [
  {
    titre: 'Éditeur du site',
    contenu: `${siteConfig.legal.editor}`,
    aide: 'Raison sociale, forme juridique, capital, RCS, n° SIRET, adresse, téléphone, email.',
  },
  {
    titre: 'Hébergeur',
    contenu: siteConfig.legal.host,
    aide: 'Nom, raison sociale, adresse complète et numéro de téléphone de l\'hébergeur.',
  },
  {
    titre: 'Directeur de la publication',
    contenu: `${siteConfig.legal.publisher}`,
    aide: 'Nom de la personne responsable du contenu publié sur le site.',
  },
  {
    titre: 'Propriété intellectuelle',
    contenu: '[À compléter]',
    aide: 'Mention sur la propriété des contenus (textes, images, logo) et conditions de réutilisation.',
  },
  {
    titre: 'Données personnelles & RGPD',
    contenu: '[À compléter]',
    aide: 'Finalités de traitement, base légale, durée de conservation, droits (accès, rectification, opposition, suppression), DPO, contact CNIL.',
  },
  {
    titre: 'Cookies',
    contenu: '[À compléter]',
    aide: 'Inventaire des cookies utilisés (fonctionnels, mesure d\'audience, tiers), durée de vie et moyens de gestion du consentement.',
  },
  {
    titre: 'Contact',
    contenu: siteConfig.contact.email,
    aide: 'Adresse email de contact pour toute question relative aux mentions légales ou aux données personnelles.',
  },
];
---

<BaseLayout seo={getSeo('legal')}>
  <article class="px-6 pt-24 pb-20 md:pt-32 md:pb-28">
    <div class="mx-auto max-w-3xl">
      <!-- En-tête -->
      <header>
        <p class="text-sm font-semibold text-bleu-nuit/70 uppercase tracking-wide">
          Informations
        </p>
        <h1 class="mt-3 text-4xl md:text-5xl font-sora font-bold text-bleu-nuit text-balance leading-tight">
          Mentions légales
        </h1>
      </header>

      <!-- Bandeau d'avertissement -->
      <aside
        role="note"
        aria-label="Statut de la page"
        class="mt-8 flex items-start gap-4 rounded-2xl bg-orange/10 ring-1 ring-orange/30 p-5 md:p-6"
      >
        <span class="flex w-10 h-10 shrink-0 rounded-full bg-orange/20 text-orange items-center justify-center mt-0.5">
          <Icon name="alert-triangle" size={20} strokeWidth={2} />
        </span>
        <div>
          <p class="font-sora font-semibold text-base text-bleu-nuit">
            Page provisoire
          </p>
          <p class="mt-1 text-sm text-bleu-nuit/80 leading-relaxed">
            À compléter avant la mise en ligne définitive du site. Cette page est
            actuellement en <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bleu-nuit/5 ring-1 ring-bleu-nuit/10">noindex</code>
            et exclue du sitemap.
          </p>
        </div>
      </aside>

      <!-- Sections -->
      <div class="mt-12 space-y-10">
        {sections.map((section) => {
          const placeholder = section.contenu.includes('[À compléter]');
          return (
            <section>
              <h2 class="font-sora font-semibold text-2xl text-bleu-nuit">
                {section.titre}
              </h2>
              <p class:list={[
                'mt-3 text-base leading-relaxed',
                placeholder ? 'text-bleu-nuit/70 italic' : 'text-bleu-nuit/85',
              ]}>
                {section.contenu}
              </p>
              <p class="mt-2 text-xs text-bleu-nuit/65 leading-relaxed">
                <span class="font-semibold uppercase tracking-wide">À renseigner :</span>
                {' '}{section.aide}
              </p>
            </section>
          );
        })}
      </div>

      <!-- Pied : retour accueil -->
      <footer class="mt-16 pt-8 border-t border-bleu-nuit/10">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm font-semibold text-bleu-nuit hover:text-orange transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Retour à l'accueil
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>
