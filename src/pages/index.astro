---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/siteConfig.json';
---

<BaseLayout title={siteConfig.siteName} description={siteConfig.baseline}>
  <main class="relative min-h-dvh flex items-center justify-center px-6">
    <div class="absolute inset-0 -z-10 halo-mix opacity-60" aria-hidden="true"></div>
    <div class="text-center max-w-2xl">
      <p class="text-sm font-medium text-bleu-nuit/60 tracking-wide uppercase">{siteConfig.location.areaCode} · {siteConfig.location.region}</p>
      <h1 class="mt-4 text-hero font-sora font-bold text-bleu-nuit">{siteConfig.siteName}</h1>
      <p class="mt-6 text-lg md:text-xl text-bleu-nuit/70">{siteConfig.baseline}</p>
      <p class="mt-10 text-sm text-bleu-nuit/50">Setup terminé — étape 1/15. En attente de validation pour la suite.</p>
    </div>
  </main>
</BaseLayout>
