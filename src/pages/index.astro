---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Promesse from '../components/sections/Promesse.astro';
import Offre from '../components/sections/Offre.astro';
import ModuleMetier from '../components/sections/ModuleMetier.astro';
import ApercuRealisations from '../components/sections/ApercuRealisations.astro';
import TarifsBref from '../components/sections/TarifsBref.astro';
import CTABand from '../components/sections/CTABand.astro';
import siteConfig from '../data/siteConfig.json';
---

<BaseLayout
  title={`${siteConfig.siteName} — Création de site vitrine à La Réunion (974)`}
  description="Sites vitrines clé en main pour TPE/PME réunionnaises. Tout inclus : domaine, hébergement, maintenance. À partir de 97,4€/mois."
>
  <Hero />
  <Promesse />
  <Offre />
  <ModuleMetier />
  <ApercuRealisations />
  <TarifsBref />
  <CTABand />
</BaseLayout>
